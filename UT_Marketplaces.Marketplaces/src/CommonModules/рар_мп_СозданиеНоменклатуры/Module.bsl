
#Область Ozon

Функция ПолучитьСписокТоваровСХарактеристиками_Ozon(Аккаунт, ВидНоменклатуры) Экспорт
	
	ИдентификаторСтраницы = "";
	
	ТабЗначТоваров = Новый ТаблицаЗначений;
	ТабЗначТоваров.Колонки.Добавить("IDТовара");
	ТабЗначТоваров.Колонки.Добавить("Артикул");
	ТабЗначТоваров.Колонки.Добавить("НаименованиеТовара");
	ТабЗначТоваров.Колонки.Добавить("СтавкаНДС");
	ТабЗначТоваров.Колонки.Добавить("Штрихкод");
	ТабЗначТоваров.Колонки.Добавить("Вес");
	ТабЗначТоваров.Колонки.Добавить("ЕдИзмеренияВеса");
	ТабЗначТоваров.Колонки.Добавить("КартинкаТовара");
	ТабЗначТоваров.Колонки.Добавить("SKUТовара");
	ТабЗначТоваров.Колонки.Добавить("Номенклатура");
	ТабЗначТоваров.Колонки.Добавить("Упаковка");
	ТабЗначТоваров.Колонки.Добавить("НомерСтроки");
		
	HTTPОтвет = рар_мп_Ozon_Методы.Метод_СписокТоваров(Аккаунт, ИдентификаторСтраницы); 
	
	Если HTTPОтвет.Свойство("ОтветAPI") Тогда
		
		Если HTTPОтвет.КодСостояния <> 200 Тогда
			
			ТабЗначТоваров.Очистить();
			
			Сообщение = Новый СообщениеПользователю;
			Сообщение.Текст = "Ошибка при получении товаров из маркетплейса. Подробное описание ошибки можно посмотреть в журнале регистрации";
			Сообщение.Сообщить();
			
			Комментарий = СтрШаблон("Аккаунт: %3. Код запроса:%1. Описание ошибки:%2", HTTPОтвет.КодСостояния, HTTPОтвет.ОтветAPI.message, Аккаунт);
				
			ЗаписьЖурналаРегистрации("Ошибка при получении ", УровеньЖурналаРегистрации.Ошибка,,,Комментарий,);

			Возврат	ТабЗначТоваров; 
				
		КонецЕсли;
		
		ИдентификаторСтраницы 	= HTTPОтвет.ОтветAPI.result.last_id; 
		КоличествоСтраниц 		= Цел(HTTPОтвет.ОтветAPI.result.total/1000);
		МассивТоваровИзЗапроса 	= HTTPОтвет.ОтветAPI.result.items;
		
		КоличествоЗапросов = 0;
		
		Пока КоличествоСтраниц > 0 Цикл
			
			Если КоличествоЗапросов = 50 Тогда
				
				КоличествоЗапросов = 0;
				
				ВремяОжидания = 5;
				
				ВремяСледующегоЗапроса = ТекущаяДата() + ВремяОжидания;
				
				Пока ТекущаяДата() < ВремяСледующегоЗапроса Цикл
					// Ожидаем время для следующего запроса	
				КонецЦикла;
				
			КонецЕсли;
			
			HTTPОтвет = рар_мп_Ozon_Методы.Метод_СписокТоваров(Аккаунт, ИдентификаторСтраницы);
			
			КоличествоЗапросов = КоличествоЗапросов + 1;
			
			Если HTTPОтвет.Свойство("ОтветAPI") Тогда
				
				Если HTTPОтвет.КодСостояния <> 200 Тогда
					
					ТабЗначТоваров.Очистить();
				
					Сообщение = Новый СообщениеПользователю;
					Сообщение.Текст = "Ошибка при получении товаров из маркетплейса. Подробное описание ошибки можно посмотреть в журнале регистрации";
					Сообщение.Сообщить();
					
					Комментарий = СтрШаблон("Аккаунт: %3. Код запроса:%1. Описание ошибки:%2", HTTPОтвет.КодСостояния, HTTPОтвет.ОтветAPI.message, Аккаунт);
						
					ЗаписьЖурналаРегистрации("Ошибка при получении ", УровеньЖурналаРегистрации.Ошибка,,,Комментарий,);

					Возврат ТабЗначТоваров;
						
				КонецЕсли;
				
				ИдентификаторСтраницы = HTTPОтвет.ОтветAPI.result.last_id;
				ОбщегоНазначенияКлиентСервер.ДополнитьМассив(МассивТоваровИзЗапроса, HTTPОтвет.ОтветAPI.result.items, Истина);		
				КоличествоСтраниц = КоличествоСтраниц - 1; 
				
			Иначе
				
				Сообщение = Новый СообщениеПользователю;
				Сообщение.Текст = "Ошибка при получении данных о товарах. Подробное описание ошибки можно посмотреть в журнале регистрации";
				Сообщение.Сообщить();
				
				Комментарий = "Ошибка при получении JSON. Некорректные значения JSON";
				
				ЗаписьЖурналаРегистрации("Ошибка при получении данных о товарах", УровеньЖурналаРегистрации.Ошибка,,,СтрШаблон("Аккаунт: %3. Код запроса:%1. Описание ошибки:%2", HTTPОтвет.КодСостояния, Комментарий, Аккаунт),);
			
			КонецЕсли;
			
		КонецЦикла;
		
		ПакетыТоваров = РазделениеМассиваНаПакеты(МассивТоваровИзЗапроса, 1000);
		
		Для Каждого Пакет Из ПакетыТоваров Цикл
			
			Если КоличествоЗапросов = 50 Тогда
				
				КоличествоЗапросов = 0;
				
				ВремяОжидания = 5;
				
				ВремяСледующегоЗапроса = ТекущаяДата() + ВремяОжидания;
				
				Пока ТекущаяДата() < ВремяСледующегоЗапроса Цикл
					// Ожидаем время для следующего запроса	
				КонецЦикла;
				
			КонецЕсли;
		
			HTTPОтветОписанияХарактеристикТовара = рар_мп_Ozon_Методы.Метод_ПолучитьОписаниеХарактеристикТовара(Аккаунт, Пакет.Значение);
			
			КоличествоЗапросов = КоличествоЗапросов + 1;
			
			Если HTTPОтветОписанияХарактеристикТовара.Свойство("ОтветAPI") Тогда
				
				Если HTTPОтветОписанияХарактеристикТовара.КодСостояния <> 200 Тогда
					
					Сообщение = Новый СообщениеПользователю;
					Сообщение.Текст = СтрШаблон("Ошибка при получении информации о товарах. 
												|Подробное описание ошибки можно посмотреть в журнале регистрации");
					Сообщение.Сообщить();
					
					Комментарий = СтрШаблон("Аккаунт: %3. Код запроса:%1. Описание ошибки:%2", 
												HTTPОтветОписанияХарактеристикТовара.КодСостояния, HTTPОтветОписанияХарактеристикТовара.ОтветAPI.message, Аккаунт);
					
					ЗаписьЖурналаРегистрации("Ошибка при получении информации о товарах", УровеньЖурналаРегистрации.Ошибка,,,Комментарий,);
					
				Иначе
					
					Если КоличествоЗапросов = 50 Тогда
						
						КоличествоЗапросов = 0;
						
						ВремяОжидания = 5;
						
						ВремяСледующегоЗапроса = ТекущаяДата() + ВремяОжидания;
						
						Пока ТекущаяДата() < ВремяСледующегоЗапроса Цикл
							// Ожидаем время для следующего запроса	
						КонецЦикла;
						
					КонецЕсли;
					
					HTTPОтветОписанияХарактеристикТовараДляНоменклатуры = рар_мп_Ozon_Методы.Метод_ПолучитьОписаниеХарактеристикТовараДляНоменклатуры(Аккаунт, Пакет.Значение);
					
					КоличествоЗапросов = КоличествоЗапросов + 1;
					
					ТаблицаХарактеристик = Новый ТаблицаЗначений;
					
					Если HTTPОтветОписанияХарактеристикТовараДляНоменклатуры.Свойство("ОтветAPI") Тогда
						
						Если HTTPОтветОписанияХарактеристикТовараДляНоменклатуры.КодСостояния <> 200 Тогда
							
							Сообщение = Новый СообщениеПользователю;
							Сообщение.Текст = СтрШаблон("Ошибка при получении характеристик товаров. 
														|Подробное описание ошибки можно посмотреть в журнале регистрации");
														Сообщение.Сообщить();
							
							Комментарий = СтрШаблон("Аккаунт: %3. Код запроса:%1. Описание ошибки:%2", 
														HTTPОтветОписанияХарактеристикТовараДляНоменклатуры.КодСостояния, 
														HTTPОтветОписанияХарактеристикТовараДляНоменклатуры.ОтветAPI.message, Аккаунт);
							
							ЗаписьЖурналаРегистрации("Ошибка при получении характеристик товаров", УровеньЖурналаРегистрации.Ошибка,,,Комментарий,);
							
						Иначе	
							
							ТаблицаХарактеристик = ПреобразоватьМассивВТаблицуЗначений(HTTPОтветОписанияХарактеристикТовараДляНоменклатуры.ОтветAPI.result);
							
						КонецЕсли;
						
					Иначе
						
						ТабЗначТоваров.Очистить();
						
						Сообщение = Новый СообщениеПользователю;
						Сообщение.Текст = "Ошибка при получении характеристик товаров. Подробное описание ошибки можно посмотреть в журнале регистрации";
						Сообщение.Сообщить();
						
						Комментарий = "Ошибка при получении JSON. Некорректные значения JSON";
						
						ЗаписьЖурналаРегистрации("Ошибка при получении характеристик товаров", 
													УровеньЖурналаРегистрации.Ошибка,,,СтрШаблон("Аккаунт: %3. Код запроса:%1. Описание ошибки:%2", 
													HTTPОтвет.КодСостояния, Комментарий, Аккаунт),);
						
						Возврат ТабЗначТоваров;
						
					КонецЕсли;
					
					Для Каждого Товар Из HTTPОтветОписанияХарактеристикТовара.ОтветAPI.items Цикл
						
						Попытка
														
							IDТовара		   	= Формат(Товар.id,"ЧГ=");
							Артикул  		   	= Формат(Товар.offer_id,"ЧГ=");
							НаименованиеТовара 	= Товар.name;
							СтавкаНДС			= Товар.vat;
							SKU					= "";
							
							Если Товар.sources.Количество() <> 0 Тогда
								
								SKU = Товар.sources[0].sku;
								
							КонецЕсли;
							
							НайтиНоменклатуру	= Справочники.Номенклатура.НайтиПоРеквизиту("Артикул", Артикул);
							
							Запись				= РегистрыСведений.рар_мп_Ozon_СопоставленныеТовары.СоздатьМенеджерЗаписи();
							Запись.Аккаунт		= Аккаунт;
							Запись.IDТовара		= IDТовара;
							Запись.Артикул		= Артикул;
							Запись.SKUТовара    = SKU; 
							
							Запись.Прочитать();
							
							Если НЕ Запись.Выбран() Тогда
								
								НоваяСтрока = ТабЗначТоваров.Добавить();
								
								НоваяСтрока.IDТовара  	  		= IDТовара;
								НоваяСтрока.Артикул		 	  	= Артикул;   
								НоваяСтрока.НаименованиеТовара	= НаименованиеТовара;
								НоваяСтрока.SKUТовара			= SKU;
								НоваяСтрока.СтавкаНДС 			= СопостовлениеНДС_Ozon(СтавкаНДС);
								
								Если НайтиНоменклатуру <> Справочники.Номенклатура.ПустаяСсылка() И НЕ ПустаяСтрока(Артикул) И НЕ НайтиНоменклатуру.ПометкаУдаления Тогда 
									
									НоваяСтрока.Номенклатура 	= НайтиНоменклатуру;
									НоваяСтрока.Упаковка		= НайтиНоменклатуру.ЕдиницаИзмерения;
									
								КонецЕсли;	
								
								Если Товар.barcodes.Количество() > 0 Тогда
									
									НоваяСтрока.Штрихкод = Товар.barcodes[0];	
									
								КонецЕсли;	

								Если HTTPОтветОписанияХарактеристикТовараДляНоменклатуры.КодСостояния = 200 Тогда
									
									НайденныеСтроки = ТаблицаХарактеристик.НайтиСтроки(Новый Структура("id", Товар.id));
									
									Если НайденныеСтроки.Количество() <> 0 Тогда
										
										СтрокаХарактеристик = НайденныеСтроки.Получить(0);
										
										НоваяСтрока.Вес				= СтрокаХарактеристик.weight;
										НоваяСтрока.ЕдИзмеренияВеса = СопостовлениеВеса(СтрокаХарактеристик.weight_unit);
										НоваяСтрока.КартинкаТовара	= СтрокаХарактеристик.primary_image;
										
									КонецЕсли;
									
								КонецЕсли;
								
							КонецЕсли;
							
						Исключение
							
							Сообщение = Новый СообщениеПользователю;
							Сообщение.Текст = СтрШаблон("Ошибка при получении информации о товаре с id: %1. 
														|Подробное описание ошибки можно посмотреть в журнале регистрации",
														Товар.id);
							Сообщение.Сообщить();
							
							Комментарий = СтрШаблон("Аккаунт: %3. Код запроса:%1. Описание ошибки:%2", HTTPОтвет.КодСостояния, ОписаниеОшибки(), Аккаунт);
							
							ЗаписьЖурналаРегистрации(СтрШаблон("Ошибка при получении информации о товаре с id: %1", Товар.id), 
														УровеньЖурналаРегистрации.Ошибка,,,Комментарий,);
							
						КонецПопытки;
						
					КонецЦикла;
					
				КонецЕсли;		
				
			Иначе
				
				ТабЗначТоваров.Очистить();
				
				Сообщение = Новый СообщениеПользователю;
				Сообщение.Текст = "Ошибка при получении данных о товарах. Подробное описание ошибки можно посмотреть в журнале регистрации";
				Сообщение.Сообщить();
				
				Комментарий = "Ошибка при получении JSON. Некорректные значения JSON";
				
				ЗаписьЖурналаРегистрации("Ошибка при получении данных о товарах", УровеньЖурналаРегистрации.Ошибка,,,
											СтрШаблон("Аккаунт: %3. Код запроса:%1. Описание ошибки:%2", HTTPОтвет.КодСостояния, Комментарий, Аккаунт),);
				
				Возврат ТабЗначТоваров;
				
			КонецЕсли;
			
		КонецЦикла;
		
	Иначе
		
		Сообщение = Новый СообщениеПользователю;
		Сообщение.Текст = "Ошибка при получении данных о товарах. Подробное описание ошибки можно посмотреть в журнале регистрации";
		Сообщение.Сообщить();
		
		Комментарий = "Ошибка при получении JSON. Некорректные значения JSON";
		
		ЗаписьЖурналаРегистрации("Ошибка при получении данных о товарах", УровеньЖурналаРегистрации.Ошибка,,,СтрШаблон("Аккаунт: %3. Код запроса:%1. Описание ошибки:%2", HTTPОтвет.КодСостояния, Комментарий, Аккаунт),);
		
		Возврат ТабЗначТоваров;
		
	КонецЕсли;
	
	Массив = Новый Массив;
	
	Для Сч = 1 По ТабЗначТоваров.Количество() Цикл
		
		Массив.Добавить(Сч);
		
	КонецЦикла;
	
	ТабЗначТоваров.ЗагрузитьКолонку(Массив,"НомерСтроки");
	
	Возврат ТабЗначТоваров;

КонецФункции

Функция РазделениеМассиваНаПакеты(ИсходныйМассив, РазмерПакета)
	
	// Создаем структуру для хранения пакетов
	Пакеты = Новый Структура;
	
	// Параметры для разделения
	КоличествоПакетов = Цел(ИсходныйМассив.Количество() / РазмерПакета);
	Если ИсходныйМассив.Количество() % РазмерПакета > 0 Тогда
		КоличествоПакетов = КоличествоПакетов + 1;
	КонецЕсли;
	
	// Разделяем массив на пакеты
	Для НомерПакета = 1 По КоличествоПакетов Цикл
		НовыйПакет = Новый Массив;
		НачальныйИндекс = (НомерПакета - 1) * РазмерПакета;
		КонечныйИндекс = Мин(НачальныйИндекс + РазмерПакета - 1, ИсходныйМассив.Количество() - 1);
		
		Для Индекс = НачальныйИндекс По КонечныйИндекс Цикл
			НовыйПакет.Добавить(ИсходныйМассив[Индекс]);
		КонецЦикла;
		
		// Добавляем пакет в структуру с ключом "ПакетN"
		Пакеты.Вставить("Пакет" + Формат(НомерПакета, "ЧГ=0"), НовыйПакет);
	КонецЦикла;
	
	Возврат Пакеты;
	
КонецФункции

Функция ПреобразоватьМассивВТаблицуЗначений(МассивСтруктур)
    
    Данные = Новый ТаблицаЗначений;
	
	Для Каждого ЭлементМассива Из МассивСтруктур Цикл
		
		Если Данные.Колонки.Количество() = 0 Тогда
			
			Для Каждого ЗначениеСтруктуры Из ЭлементМассива Цикл
				
				МассивДопустимыеТипы = Новый Массив;
				
				ТипКолонки = ТипЗнч(ЗначениеСтруктуры.Значение); 
				
    			МассивДопустимыеТипы.Добавить(ТипКолонки);  
				
    			Описание_Типов = Новый ОписаниеТипов(МассивДопустимыеТипы);
				
				Данные.Колонки.Добавить(ЗначениеСтруктуры.Ключ, Описание_Типов);
				
			КонецЦикла;
			
		КонецЕсли;
		
        НоваяСтрока = Данные.Добавить();
		
        Для Каждого ЗначениеСтруктуры Из ЭлементМассива Цикл
            НоваяСтрока[ЗначениеСтруктуры.Ключ] = ЗначениеСтруктуры.Значение;
		КонецЦикла;
		
    КонецЦикла;
    
    Возврат Данные;
    
КонецФункции

#КонецОбласти 

#Область Wildberries

Функция ПолучитьСписокТоваровСХарактеристиками_Wildberries(Аккаунт, ВидНоменклатуры) Экспорт

	ТабЗначТоваров = Новый ТаблицаЗначений;
	ТабЗначТоваров.Колонки.Добавить("IDТовара");
	ТабЗначТоваров.Колонки.Добавить("Артикул");
	ТабЗначТоваров.Колонки.Добавить("НаименованиеТовара");
	ТабЗначТоваров.Колонки.Добавить("Штрихкод");
	ТабЗначТоваров.Колонки.Добавить("Размер");
	ТабЗначТоваров.Колонки.Добавить("Вес");
	ТабЗначТоваров.Колонки.Добавить("ЕдИзмеренияВеса");
	ТабЗначТоваров.Колонки.Добавить("КартинкаТовара");
	ТабЗначТоваров.Колонки.Добавить("Номенклатура");
	ТабЗначТоваров.Колонки.Добавить("Упаковка");
	ТабЗначТоваров.Колонки.Добавить("НомерСтроки");
	ТабЗначТоваров.Колонки.Добавить("Характеристика");
	ТабЗначТоваров.Колонки.Добавить("IDРазмера");
	ТабЗначТоваров.Колонки.Добавить("ВозможностьСменыЦенДляРазмеров");
		
	КоличествоНоменклатуры = 100;
