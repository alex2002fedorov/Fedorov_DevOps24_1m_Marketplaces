#Область СопоставитьНоменклатуру

Функция СопоставитьНоменклатуру(ТоварыКСопоставлению, АккаунтМаркетплейса) Экспорт

	ВыбранныеСтроки = ТоварыКСопоставлению.НайтиСтроки(Новый Структура("ИзменитьПозицию", Истина));
	Маркетплейс		= ОбщегоНазначения.ЗначениеРеквизитаОбъекта(АккаунтМаркетплейса, "Маркетплейс");
	
	Если ВыбранныеСтроки.Количество() = 0 Тогда
	
		Сообщение = Новый СообщениеПользователю;
		Сообщение.Текст = "Не выбрано ни одной строки для сопоставления номенклатуры";
		Сообщение.Сообщить();
         	
	Иначе
			
		Для каждого Стр Из ВыбранныеСтроки Цикл
			
			Если Стр.ИзменитьПозицию = Ложь Тогда
					
					Продолжить;	
					
				КонецЕсли;
		
			Если ЗначениеЗаполнено(Стр.Номенклатура) Тогда			
			   		
				Если Маркетплейс = Перечисления.рар_мп_Маркетплейсы.Wildberries Тогда
				
					МенеджерЗаписи 					  = РегистрыСведений.рар_мп_Wildberries_СопоставленныеТовары.СоздатьМенеджерЗаписи();
					МенеджерЗаписи.Аккаунт			  = АккаунтМаркетплейса; 
					МенеджерЗаписи.IDТовара			  = Стр.IDТовара;
					МенеджерЗаписи.Артикул			  = Стр.Артикул;
					МенеджерЗаписи.Баракод			  = Стр.Штрихкод;
