Функция ПолучитьХарактеристику(Размер, ВидНоменклатуры, Номенклатура, СоздаватьХарактеристику)
	
	ХарактеристикаИндивидуальнаяДляНоменклатуры = Перечисления.ВариантыИспользованияХарактеристикНоменклатуры.ИндивидуальныеДляНоменклатуры;
	
	Если ВидНоменклатуры.ИспользоватьХарактеристики = Истина Тогда
	
		Если ВидНоменклатуры.ИспользованиеХарактеристик <> ХарактеристикаИндивидуальнаяДляНоменклатуры Тогда
			
			ПоискХарактеристики 			= Справочники.ХарактеристикиНоменклатуры.НайтиПоНаименованию(Размер, Истина, , ВидНоменклатуры);		
			ПоискХарактеристикиСРазмером	= Справочники.ХарактеристикиНоменклатуры.НайтиПоНаименованию("Размер " + Размер, Истина, , ВидНоменклатуры);
			
			Если ПоискХарактеристики = Справочники.ХарактеристикиНоменклатуры.ПустаяСсылка() 
					И ПоискХарактеристикиСРазмером = Справочники.ХарактеристикиНоменклатуры.ПустаяСсылка()  
						И СоздаватьХарактеристику Тогда
				// Создаем новую характеристику
				НоваяХарактеристика = Справочники.ХарактеристикиНоменклатуры.СоздатьЭлемент();
				НоваяХарактеристика.Наименование	= "Размер " + Размер;
				НоваяХарактеристика.Владелец		= ВидНоменклатуры;
				НоваяХарактеристика.Записать();
				
				Возврат НоваяХарактеристика.Ссылка;
				
			ИначеЕсли ЗначениеЗаполнено(ПоискХарактеристикиСРазмером) И ПоискХарактеристики = Справочники.ХарактеристикиНоменклатуры.ПустаяСсылка() Тогда
				
				Возврат ПоискХарактеристикиСРазмером;
				
			Иначе
				
				Возврат ПоискХарактеристики;
				
			КонецЕсли;
			
		Иначе
			
			ПоискХарактеристики 			= Справочники.ХарактеристикиНоменклатуры.НайтиПоНаименованию(Размер, Истина, , Номенклатура);		
			ПоискХарактеристикиСРазмером	= Справочники.ХарактеристикиНоменклатуры.НайтиПоНаименованию("Размер " + Размер, Истина, , Номенклатура);
			
			Если ПоискХарактеристики = Справочники.ХарактеристикиНоменклатуры.ПустаяСсылка()
					И ПоискХарактеристикиСРазмером = Справочники.ХарактеристикиНоменклатуры.ПустаяСсылка() 
						И СоздаватьХарактеристику Тогда
				// Создаем новую характеристику
				НоваяХарактеристика = Справочники.ХарактеристикиНоменклатуры.СоздатьЭлемент();
				НоваяХарактеристика.Наименование	= "Размер " + Размер;
				НоваяХарактеристика.Владелец		= Номенклатура;
				НоваяХарактеристика.Записать();
				
				Возврат НоваяХарактеристика.Ссылка;
				
			ИначеЕсли ЗначениеЗаполнено(ПоискХарактеристикиСРазмером) И ПоискХарактеристики = Справочники.ХарактеристикиНоменклатуры.ПустаяСсылка() Тогда
				
				Возврат ПоискХарактеристикиСРазмером;
				
			Иначе
				
				Возврат ПоискХарактеристики;
				
			КонецЕсли; 
			
		КонецЕсли;
		
	Иначе
		
		Возврат Неопределено;
		
	КонецЕсли;	
	
КонецФункции

Процедура ДобавитьШтрихкод(Номенклатура, Штрихкод, Характеристика, Упаковка, НомерСтроки, Артикул)
	
	МенеджерЗаписиШтрихкод 					= РегистрыСведений.ШтрихкодыНоменклатуры.СоздатьМенеджерЗаписи();
	МенеджерЗаписиШтрихкод.Штрихкод 		= Штрихкод;
	МенеджерЗаписиШтрихкод.Номенклатура 	= Номенклатура;
	МенеджерЗаписиШтрихкод.Характеристика	= Характеристика;
	МенеджерЗаписиШтрихкод.Упаковка			= Упаковка;
	
	Попытка
		
		МенеджерЗаписиШтрихкод.Записать();
		
	Исключение
		
		Сообщение = Новый СообщениеПользователю;
		Сообщение.Текст = СтрШаблон("Ошибка при добавлении штрихкода номенклатуры - %1. 
		|Подробное описание ошибки можно посмотреть в журнале регистрации.", Номенклатура);
		Сообщение.Сообщить();
		
		ЗаписьЖурналаРегистрации(СтрШаблон("Ошибка добавления штрихкода для номенклатуры (артикул: %1, наименование: %2, строка %3) в регистр сведений 'ШтрихкодыНоменклатуры'",
		Артикул, Номенклатура, НомерСтроки), 
		УровеньЖурналаРегистрации.Ошибка,,,ОписаниеОшибки(),);
		
	КонецПопытки;
	
КонецПроцедуры

