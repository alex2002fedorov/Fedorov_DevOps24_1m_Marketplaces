							Запись.Размер	 = Размер.techSize;
							Запись.IDРазмера = Размер.chrtID;
							
							Запись.Прочитать();

							Если НЕ Запись.Выбран() Тогда 
								
								Артикул						= Строка.vendorCode;
								НайтиНоменклатуру			= Справочники.Номенклатура.НайтиПоРеквизиту("Артикул", Артикул);
							
								СтрокаТЗ					= ТабЗначТоваров.Добавить(); 
								СтрокаТЗ.IDТовара			= Формат(Строка.nmID, "ЧГ=");
								СтрокаТЗ.Артикул			= Артикул;
								
								Если НайтиНоменклатуру <> Справочники.Номенклатура.ПустаяСсылка() И НЕ ПустаяСтрока(Артикул) И НЕ НайтиНоменклатуру.ПометкаУдаления Тогда 
				
									СтрокаТЗ.Номенклатура 	= НайтиНоменклатуру;
									СтрокаТЗ.Упаковка		= НайтиНоменклатуру.ЕдиницаИзмерения;
									СтрокаТЗ.Характеристика	= ПолучитьХарактеристику(Размер.techSize, ВидНоменклатуры, НайтиНоменклатуру, Ложь);
									
								КонецЕсли;
								
								СтрокаТЗ.Штрихкод			= Размер.skus.Получить(0);
								СтрокаТЗ.НаименованиеТовара	= Строка.title;
								СтрокаТЗ.Размер				= Размер.techSize;
								СтрокаТЗ.IDРазмера			= Размер.chrtID;
								СтрокаТЗ.КартинкаТовара		= Строка.photos.Получить(0).c246x328;
								СтрокаТЗ.Вес				= Строка.dimensions.weightBrutto;
								СтрокаТЗ.ЕдИзмеренияВеса	= Справочники.УпаковкиЕдиницыИзмерения.НайтиПоНаименованию("кг");
																	
							КонецЕсли;	
						
						КонецЦикла;		
					
					КонецЦикла;
				
				Исключение
					
					ТабЗначТоваров.Очистить();
					
					Сообщение = Новый СообщениеПользователю;
					Сообщение.Текст = "Ошибка при получении данных о товарах.  
									   |Подробное описание ошибки можно посмотреть в журнале регистрации";
					Сообщение.Сообщить();
					
					Комментарий = СтрШаблон("Аккаунт: %3. Код запроса:%1. Описание ошибки:%2", HTTPОтвет.КодСостояния, ОписаниеОшибки(), Аккаунт);
					
					ЗаписьЖурналаРегистрации("Ошибка при получении товаров к сопоставлению", 
											 УровеньЖурналаРегистрации.Ошибка,,,Комментарий,);
					
					Возврат ТабЗначТоваров;
				
				КонецПопытки;	
				
			КонецЕсли;
			
		Иначе
			
			ТабЗначТоваров.Очистить();
			
			Сообщение = Новый СообщениеПользователю;
			Сообщение.Текст = "Ошибка при получении данных о товарах. Подробное описание ошибки можно посмотреть в журнале регистрации";
			Сообщение.Сообщить();
			
			Комментарий = "Ошибка при получении JSON. Некорректные значения JSON";
			
			ЗаписьЖурналаРегистрации("Ошибка при получении данных о товарах", УровеньЖурналаРегистрации.Ошибка,,,СтрШаблон("Аккаунт: %3. Код запроса:%1. Описание ошибки:%2", HTTPОтвет.КодСостояния, Комментарий, Аккаунт),);
			
			Возврат ТабЗначТоваров;
			
		КонецЕсли;
	
	КонецЦикла;
	
	ПроверитьНаИзменениеЦен(Аккаунт, ТабЗначТоваров);
	
	Массив = Новый Массив;
	
	Для Сч = 1 По ТабЗначТоваров.Количество() Цикл
		
		Массив.Добавить(Сч);
		
	КонецЦикла;
	
	ТабЗначТоваров.ЗагрузитьКолонку(Массив,"НомерСтроки");
	
	Возврат ТабЗначТоваров;	
	
КонецФункции

Процедура ПроверитьНаИзменениеЦен(Аккаунт, ТабЗначТоваров)
	
	Смещение = 0;
	
	HTTPОтвет = рар_мп_Wildberries_Методы.Метод_ПолучитьТоварыСЦенами(Аккаунт, Смещение);
	
	КоличествоЗапросов = 1;
	
	Если HTTPОтвет.Свойство("ОтветAPI") Тогда
		
		Если HTTPОтвет.КодСостояния <> 200 Тогда
			
			ТабЗначТоваров.Очистить();
			
			Сообщение = Новый СообщениеПользователю;
			Сообщение.Текст = "Ошибка при получении товаров к сопоставлению. 
								|Подробное описание ошибки можно посмотреть в журнале регистрации";
			Сообщение.Сообщить();
			
			Если HTTPОтвет.ОтветAPI.Свойство("errorText") Тогда
				
				ОписаниеОшибки = HTTPОтвет.ОтветAPI.errorText;	
				
			Иначе
				
				ОписаниеОшибки = HTTPОтвет.ОтветAPI.detail;	
				
			КонецЕсли; 
			
			Комментарий = СтрШаблон("Аккаунт: %3. Код запроса:%1. Описание ошибки:%2", HTTPОтвет.КодСостояния, ОписаниеОшибки, Аккаунт);
			
			ЗаписьЖурналаРегистрации("Ошибка при получении товаров к сопоставлению", 
										УровеньЖурналаРегистрации.Ошибка,,,Комментарий,);
			
			Возврат; 	
			
		Иначе
			
			Пока HTTPОтвет.ОтветAPI.data.listGoods.Количество() <> 0 Цикл
				
				Попытка
					
					Для Каждого Строка Из HTTPОтвет.ОтветAPI.data.listGoods Цикл
						
						НайденныеСтрокиНоменклатуры = ТабЗначТоваров.НайтиСтроки(Новый Структура("Артикул", Строка.vendorCode));
						
						Если НайденныеСтрокиНоменклатуры.Количество() > 0 Тогда
							
							Для Каждого НайденнаяСтрока Из НайденныеСтрокиНоменклатуры Цикл
								
								НайденнаяСтрока.ВозможностьСменыЦенДляРазмеров = Строка.editableSizePrice;
								
							КонецЦикла;
						
						КонецЕсли;
						
					КонецЦикла;
					
				Исключение
					
					ТабЗначТоваров.Очистить();
					
					Сообщение = Новый СообщениеПользователю;
					Сообщение.Текст = "Ошибка при получении товаров к сопоставлению. 
									   |Подробное описание ошибки можно посмотреть в журнале регистрации";
					Сообщение.Сообщить();
					
					Комментарий = СтрШаблон("Аккаунт: %3. Код запроса:%1. Описание ошибки:%2", HTTPОтвет.КодСостояния, ОписаниеОшибки(), Аккаунт);
					
					ЗаписьЖурналаРегистрации("Ошибка при получении товаров к сопоставлению", 
											 УровеньЖурналаРегистрации.Ошибка,,,Комментарий,);
					
					Возврат;
					
				КонецПопытки;
				
				Смещение = Смещение + 1000;
				
				Если КоличествоЗапросов = 10 Тогда
					
					ВремяОжидания = 6;
					
					ВремяСледующегоЗапроса = ТекущаяДата() + ВремяОжидания;
					
					Пока ТекущаяДата() < ВремяСледующегоЗапроса Цикл
						// Ожидаем время для следующего запроса	
					КонецЦикла;
					
					КоличествоЗапросов = 0;
					
				КонецЕсли;
				
				HTTPОтвет = рар_мп_Wildberries_Методы.Метод_ПолучитьТоварыСЦенами(Аккаунт, Строка(Смещение));
				
				КоличествоЗапросов = КоличествоЗапросов + 1;
				
				Если HTTPОтвет.Свойство("ОтветAPI") Тогда
					
					Если HTTPОтвет.КодСостояния <> 200 Тогда
						
						ТабЗначТоваров.Очистить();
						
						Сообщение = Новый СообщениеПользователю;
						Сообщение.Текст = "Ошибка при получении товаров к сопоставлению. 
											|Подробное описание ошибки можно посмотреть в журнале регистрации";
						Сообщение.Сообщить();
						
						Если HTTPОтвет.ОтветAPI.Свойство("errorText") Тогда
							
							ОписаниеОшибки = HTTPОтвет.ОтветAPI.errorText;	
							
						Иначе
							
							ОписаниеОшибки = HTTPОтвет.ОтветAPI.detail;	
							
						КонецЕсли; 
						
						Комментарий = СтрШаблон("Аккаунт: %3. Код запроса:%1. Описание ошибки:%2", HTTPОтвет.КодСостояния, ОписаниеОшибки, Аккаунт);
						
						ЗаписьЖурналаРегистрации("Ошибка при получении товаров к сопоставлению", 
													УровеньЖурналаРегистрации.Ошибка,,,Комментарий,);
						
						Возврат;
						
					КонецЕсли;
					
				Иначе
					
					ТабЗначТоваров.Очистить();
					
					Сообщение = Новый СообщениеПользователю;
					Сообщение.Текст = "Ошибка при получении данных о товарах. Подробное описание ошибки можно посмотреть в журнале регистрации";
					Сообщение.Сообщить();
					
					Комментарий = "Ошибка при получении JSON. Некорректные значения JSON";
					
					ЗаписьЖурналаРегистрации("Ошибка при получении данных о товарах", УровеньЖурналаРегистрации.Ошибка,,,СтрШаблон("Аккаунт: %3. Код запроса:%1. Описание ошибки:%2", HTTPОтвет.КодСостояния, Комментарий, Аккаунт),);
					
					Возврат;
					
				КонецЕсли;
				
			КонецЦикла;
			
		КонецЕсли;
		
	Иначе
		
		ТабЗначТоваров.Очистить();
		
		Сообщение = Новый СообщениеПользователю;
		Сообщение.Текст = "Ошибка при получении данных о товарах. Подробное описание ошибки можно посмотреть в журнале регистрации";
		Сообщение.Сообщить();
		
		Комментарий = "Ошибка при получении JSON. Некорректные значения JSON";
		
		ЗаписьЖурналаРегистрации("Ошибка при получении данных о товарах", УровеньЖурналаРегистрации.Ошибка,,,СтрШаблон("Аккаунт: %3. Код запроса:%1. Описание ошибки:%2", HTTPОтвет.КодСостояния, Комментарий, Аккаунт),);
		
		Возврат;
		
	КонецЕсли;
	
КонецПроцедуры

