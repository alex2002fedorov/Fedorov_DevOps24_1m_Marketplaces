Функция СопостовлениеНДС_Ozon(СтавкаНДС)
	
	Соответствие = Новый Соответствие;
	Соответствие.Вставить("20.00",	Справочники.СтавкиНДС.НайтиПоНаименованию("20%"));
	Соответствие.Вставить("6.00", 	Справочники.СтавкиНДС.НайтиПоНаименованию("6%"));
	Соответствие.Вставить("0.00", 	Справочники.СтавкиНДС.НайтиПоНаименованию("Без НДС"));	
	Соответствие.Вставить("10.00", 	Справочники.СтавкиНДС.НайтиПоНаименованию("10%"));
	Соответствие.Вставить("16.67", 	Справочники.СтавкиНДС.НайтиПоНаименованию("16,67%"));
	Соответствие.Вставить("5.00", 	Справочники.СтавкиНДС.НайтиПоНаименованию("5%"));
	Соответствие.Вставить("7.00", 	Справочники.СтавкиНДС.НайтиПоНаименованию("7%"));
	Соответствие.Вставить("9.09", 	Справочники.СтавкиНДС.НайтиПоНаименованию("9,09%"));
	
	СтавкаНДС = Соответствие[СтавкаНДС];
	
	Возврат СтавкаНДС;	
	
КонецФункции

Функция СопостовлениеВеса(ЕдИзмеренияВеса)
	
	Соответствие = Новый Соответствие;      
	Соответствие.Вставить("g",		Справочники.УпаковкиЕдиницыИзмерения.НайтиПоНаименованию("г"));
	Соответствие.Вставить("kg", 	Справочники.УпаковкиЕдиницыИзмерения.НайтиПоНаименованию("кг"));
	Соответствие.Вставить("t", 		Справочники.УпаковкиЕдиницыИзмерения.НайтиПоНаименованию("т"));	
	Соответствие.Вставить("mg", 	Справочники.УпаковкиЕдиницыИзмерения.НайтиПоНаименованию("мг"));
	
	СтавкаНДС = Соответствие[ЕдИзмеренияВеса];
	
	Возврат СтавкаНДС;	
	
КонецФункции 

Процедура ЗагрузитьИзображение(Номенклатура, АдресКартинки, Артикул)
	
	Адрес 				= ПолучениеФайловИзИнтернета.СкачатьФайлНаСервере(АдресКартинки);
	ПутьКФайлу 			= Адрес.Путь;
	ПоискТочки			= СтрНайти(АдресКартинки, ".", НаправлениеПоиска.СКонца);
	РасширениеБезТочки	= Прав(АдресКартинки, СтрДлина(АдресКартинки) - ПоискТочки);	
	Файл 				= Новый Файл(ПутьКФайлу);	
		
	Попытка
		
		ПараметрыФайла 								= РаботаСФайлами.ПараметрыДобавленияФайла();
		ПараметрыФайла.ВладелецФайлов 				= Номенклатура;
		ПараметрыФайла.ВремяИзмененияУниверсальное 	= Файл.ПолучитьУниверсальноеВремяИзменения();
		ПараметрыФайла.ИмяБезРасширения 			= "КартинкаТовара";
		ПараметрыФайла.РасширениеБезТочки 			= РасширениеБезТочки;
		
		ДвоичныеДанные 					= Новый ДвоичныеДанные(ПутьКФайлу);
		АдресФайлаВоВременномХранилище 	= ПоместитьВоВременноеХранилище(ДвоичныеДанные);
		
		ПрисоединенныйФайл = РаботаСФайлами.ДобавитьФайл(ПараметрыФайла, АдресФайлаВоВременномХранилище, "");
		
		НоменклатураОбъект 				= Номенклатура.ПолучитьОбъект(); 		
		НоменклатураОбъект.ФайлКартинки = ПрисоединенныйФайл;
		НоменклатураОбъект.Записать();			
		
		УдалитьФайлы(АдресФайлаВоВременномХранилище);
		
	Исключение
		
		Сообщение = Новый СообщениеПользователю;
		Сообщение.Текст = СтрШаблон("При добавлении изображения товара - %1  произошла ощибка. 
									|Подробное описание ошибки можно посмотреть в журнале регистрации.",	Номенклатура);
		Сообщение.Сообщить();
		
		ЗаписьЖурналаРегистрации(СтрШаблон("Ошибка при добавлении изображения товара с артикулом: %1 и названием: %2", 
											Артикул, Номенклатура), УровеньЖурналаРегистрации.Ошибка,,,ОписаниеОшибки(),);
		
	КонецПопытки;
	
КонецПроцедуры

