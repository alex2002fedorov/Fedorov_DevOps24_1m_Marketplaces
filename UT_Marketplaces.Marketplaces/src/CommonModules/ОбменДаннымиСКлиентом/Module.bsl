Функция ПолучитьУпаковкиПоГУИДНоменклатуры(Параметры)
	
	Результат = Новый Структура("Данные, Успешно, Сообщение", Неопределено, Ложь, "Ошибка получения данных товара");
	
	Номенклатура = Справочники.Номенклатура.ПолучитьСсылку(Новый УникальныйИдентификатор(Параметры.Номенклатура));
	
	МассивНоменклатуры=Новый Массив;
	МассивНоменклатуры.Добавить(Номенклатура);	
	ФоновыеЗаданияСервер.ВыполнитьДобавлениеМассиваНоменклатурыВРегистрОбменаС_ТСД_В_ФоновомЗадании(МассивНоменклатуры);
	
	Данные=РаботаСоСправочниками.ПолучитьДанныеУпаковокПоНоменклатуре(Номенклатура);
	Результат.Данные=Данные; 
