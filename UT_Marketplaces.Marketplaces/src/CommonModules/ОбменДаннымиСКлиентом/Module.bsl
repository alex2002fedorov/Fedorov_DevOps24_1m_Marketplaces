Процедура ОпределитьТипДокументаИОбработать(Параметры, Документ, Результат)
	
	Если Параметры.ВидДокумента = "ЗаказПоставщику" ИЛИ Параметры.ВидДокумента = "ПриобретениеТоваровУслуг" Тогда 
		ОбработкаДокументаОснованияПриемки(Документ.Ссылка, Результат);
	ИначеЕсли Параметры.ВидДокумента = "ЗаказКлиента" ИЛИ Параметры.ВидДокумента = "РеализацияТоваровУслуг" Тогда 
		ОбработкаДокументаОснованияОтгрузки(Документ.Ссылка, Результат);
	ИначеЕсли Параметры.ВидДокумента = "ПересчетТоваров" Тогда
		ОбработкаДокументаПересчетаТоваров(Документ.Ссылка, Результат);
	ИначеЕсли Параметры.ВидДокумента = "ЗаказНаПеремещение" Тогда
		ОбработкаДокументаЗаказНаПеремещение(Параметры.ГУИДПользователя, Документ.Ссылка, Результат);
	ИначеЕсли Параметры.ВидДокумента = "ПеремещениеТоваров" Тогда
		ОбработкаДокументаПеремещениеТоваров(Документ.Ссылка, Результат);
	КонецЕсли;	
	
КонецПроцедуры

Процедура ОбработкаДанныхТовара(ДанныеШтрихкода, Результат)
	
	Скидки = РаботаСоСправочниками.ПолучитьСкидки(ДанныеШтрихкода.Номенклатура, ДанныеШтрихкода.Характеристика);
	
