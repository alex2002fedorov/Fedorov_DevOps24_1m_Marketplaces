Функция СоздатьНоменклатуруИПривязатьШК(Параметры)
	Упаковка = Справочники.УпаковкиЕдиницыИзмерения.ПолучитьСсылку(Новый УникальныйИдентификатор(Параметры.ГУИДУпаковки));
	ВидНоменклатуры = Справочники.ВидыНоменклатуры.ПолучитьСсылку(Новый УникальныйИдентификатор(Параметры.ГУИДВидаНоменклатуры));
	Номенклатура = Справочники.Номенклатура.Создатьноменклатуру(Параметры.НаименованиеНоменклатуры, Упаковка, ВидНоменклатуры);
	РегистрыСведений.ШтрихкодыНоменклатуры.СоздатьШК(Параметры.Штрихкод, Номенклатура, , Упаковка);	
