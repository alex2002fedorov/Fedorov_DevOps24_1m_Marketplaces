Функция ПолучитьТовар(Параметры)
	
	Результат = Новый Структура("Данные, Успешно, Сообщение", Неопределено, Ложь, "Ошибка поиска товара по штрихкоду или товар с данным штрихкодом отсутсвует.");
	Товар = РаботаСШтрихкодами.ПолучитьНоменклатуруПоШК(Параметры.Штрихкод);
	Если НЕ Товар = Неопределено Тогда		
		Результат.Данные = Товар;
		Результат.Успешно = Истина;
		Результат.Сообщение = "";
	КонецЕсли;
	                                  
	Возврат Результат;
	
КонецФункции

Функция ПолучитьДанныеТовара(Параметры)
	
	Результат = Новый Структура("Данные, Успешно, Сообщение", Неопределено, Ложь, "Ошибка поиска товара по штрихкоду или товар с данным штрихкодом отсутсвует.");
	
	ДанныеШтрихкода = РаботаСШтрихкодами.ПолучитьДанныеТовараПоШК(Параметры.Штрихкод);
	Если НЕ ДанныеШтрихкода = Неопределено Тогда  
		ОбработкаДанныхТовара(ДанныеШтрихкода, Результат);	
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция ПолучитьДанныеТовараПоГУИД(Параметры)
	
	Результат = Новый Структура("Данные, Успешно, Сообщение", Неопределено, Ложь, "Ошибка получения данных товара");
	
	ДанныеТовара = Параметры.ДанныеТовара;
	ДанныеТовара.Номенклатура = Справочники.Номенклатура.ПолучитьСсылку(Новый УникальныйИдентификатор(ДанныеТовара.Номенклатура));
	ДанныеТовара.Характеристика = Справочники.ХарактеристикиНоменклатуры.ПолучитьСсылку(Новый УникальныйИдентификатор(ДанныеТовара.Характеристика));
	ДанныеТовара.Вставить("НоменклатураНаименование", ДанныеТовара.Номенклатура.Наименование);
	ДанныеТовара.Вставить("ХарактеристикаНаименование", "");
	Если ЗначениеЗаполнено(ДанныеТовара.Характеристика) Тогда 
		ДанныеТовара.ХарактеристикаНаименование = ДанныеТовара.Характеристика.Наименование;
	КонецЕсли;

	ОбработкаДанныхТовара(ДанныеТовара, Результат);
	
	Возврат Результат;
	
КонецФункции

Функция ПолучитьЯчейкуПоШК(Параметры)
	Результат = Новый Структура("Ячейка, ГУИДЯчейки, Успешно, Сообщение", Неопределено, Неопределено, Ложь, "Ошибка поиска ячейки по штрихкоду или ячейка с данным штрихкодом отсутсвует.");
	Ячейка = РаботаСШтрихкодами.ПолучитьСсылкуЯчейкиПоШК(Параметры.Штрихкод);
	Если НЕ Ячейка = Неопределено Тогда		
		Результат.Ячейка = Ячейка.Наименование;
		Результат.ГУИДЯчейки = Ячейка.УникальныйИдентификатор();
		Результат.Успешно = Истина;
		Результат.Сообщение = "";
	КонецЕсли;
	
	Возврат Результат;
КонецФункции

Функция ПолучитьДанныеЯчейки(Параметры)
	
	Результат = Новый Структура("Данные, Успешно, Сообщение", Неопределено, Ложь, "Ошибка поиска ячейки по штрихкоду.");
	
	ЯчейкаСсылка = РаботаСШтрихкодами.ПолучитьСсылкуЯчейкиПоШК(Параметры.Штрихкод);

	Если НЕ ЯчейкаСсылка = Неопределено Тогда 
		
		Остатки = ОстаткиСервер.ПолучитьОстаткиВЯчейке(ЯчейкаСсылка);
		
		Если Остатки.Количество() = 0 Тогда 
			Результат.Сообщение = "В ячейке нет товаров";
		Иначе 
			Остатки.Колонки.Добавить("НоменклатураГУИД");
			Остатки.Колонки.Добавить("ХарактеристикаГУИД");
			Для Каждого Стр Из Остатки Цикл 
				Стр.НоменклатураГУИД = Стр.Номенклатура.УникальныйИдентификатор();
				//Если ЗначениеЗаполнено(Стр.Характеристика) Тогда 
					Стр.ХарактеристикаГУИД = Стр.Характеристика.УникальныйИдентификатор();
				//КонецЕсли;
			КонецЦикла;
			Остатки.Колонки.Удалить("Номенклатура");
			Остатки.Колонки.Удалить("Характеристика");	
			
			Данные = Новый Структура;
			Данные.Вставить("Ячейка", ЯчейкаСсылка.Наименование);
			Данные.Вставить("Остатки", ОбщегоНазначения.ТаблицаЗначенийВМассив(Остатки));
			
			Результат.Данные = Данные;
			Результат.Успешно = Истина;
			Результат.Сообщение = "";
		КонецЕсли;	
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

