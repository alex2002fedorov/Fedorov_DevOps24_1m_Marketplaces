Процедура ОбработкаДокументаОснованияПриемки(ДокСсылка, Результат)
	
	МассивВозможныхДокументовПриемки = РаботаСДокументами.ПолучитьМассивВозможныхДокументовПриемки(ДокСсылка);
	Если НЕ МассивВозможныхДокументовПриемки = Неопределено Тогда 
		Если МассивВозможныхДокументовПриемки.Количество() = 0 Тогда 
			Результат.Сообщение = "Нельзя оформить приемку на основании данного документа";	
		Иначе   
			ДанныеДокумента = РаботаСДокументами.ПолучитьДанныеДокументаОснованияПриемкиОтгрузки(ДокСсылка);					
			Результат.Успешно = Истина;
			Результат.Сообщение = "";
			Результат.Данные = Новый Структура("ДанныеДокумента,МассивВозможныхДокументовПриемки", ДанныеДокумента, МассивВозможныхДокументовПриемки);				
		КонецЕсли;								
	КонецЕсли;	
	
КонецПроцедуры // ОбработкаДокументаОснованияПриемки()

Функция ПослеРучногоВыбораДокумента(Параметры)
	
	Результат = Новый Структура("Данные, Успешно, Сообщение", Неопределено, Ложь, "Ошибка поиска документов в центральной базе или документы не найдены");
		
	Если Параметры.ВидДокумента = "ЗаказПоставщику" Тогда 
		Ссылка = Документы.ЗаказПоставщику.ПолучитьСсылку(Новый УникальныйИдентификатор(Параметры.ГУИД));
		ОбработкаДокументаОснованияПриемки(Ссылка, Результат);
	ИначеЕсли Параметры.ВидДокумента = "ПриобретениеТоваровУслуг" Тогда 
		Ссылка = Документы.ПриобретениеТоваровУслуг.ПолучитьСсылку(Новый УникальныйИдентификатор(Параметры.ГУИД));
		ОбработкаДокументаОснованияПриемки(Ссылка, Результат);
	ИначеЕсли Параметры.ВидДокумента = "ЗаказКлиента" Тогда 
		Ссылка = Документы.ЗаказКлиента.ПолучитьСсылку(Новый УникальныйИдентификатор(Параметры.ГУИД));
		ОбработкаДокументаОснованияОтгрузки(Ссылка, Результат);
	ИначеЕсли Параметры.ВидДокумента = "РеализацияТоваровУслуг" Тогда 
		Ссылка = Документы.РеализацияТоваровУслуг.ПолучитьСсылку(Новый УникальныйИдентификатор(Параметры.ГУИД));
		ОбработкаДокументаОснованияОтгрузки(Ссылка, Результат);
	КонецЕсли;
	
	Возврат Результат;			
	
КонецФункции

