	//Данные = Новый Структура;
	//Данные.Вставить("Наименование", ДанныеШтрихкода.НоменклатураНаименование);
	//Данные.Вставить("Характеристика", ДанныеШтрихкода.ХарактеристикаНаименование);
	//Данные.Вставить("ТоварГУИД", ДанныеШтрихкода.Номенклатура.УникальныйИдентификатор());
	//Данные.Вставить("ХарактеристикаГУИД", ДанныеШтрихкода.Характеристика.УникальныйИдентификатор());
	//Если ДанныеШтрихкода.Свойство("УпаковкаНаименование") Тогда	
	//	Данные.Вставить("Упаковка", ДанныеШтрихкода.УпаковкаНаименование);
	//	Данные.Вставить("ВидНоменклатурыГУИД", ДанныеШтрихкода.НоменклатураВидНоменклатуры.УникальныйИдентификатор());
	//	Данные.Вставить("УпаковкаГУИД", ДанныеШтрихкода.Упаковка.УникальныйИдентификатор());
	//	Данные.Вставить("ЕдиницаИзмеренияГУИД", ДанныеШтрихкода.НоменклатураЕдиницаИзмерения.УникальныйИдентификатор());
	//КонецЕсли;
	ДанныеШтрихкода.Вставить("Фото", РаботаСоСправочниками.ПолучитьФотоНоменклатуры(ДанныеШтрихкода.Номенклатура));
