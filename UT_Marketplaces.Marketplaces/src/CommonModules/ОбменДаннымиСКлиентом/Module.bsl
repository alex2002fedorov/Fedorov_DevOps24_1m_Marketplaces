Функция ВыполнитьМетодОбмена(ИмяФункции, Параметры = Неопределено) Экспорт
	Параметры = СериализаторXDTO.ПрочитатьXDTO(Параметры);
	Попытка
		Результат = Вычислить(СтрШаблон("%1(Параметры)", ИмяФункции));
		Если Результат = Неопределено Тогда
			Возврат СериализаторXDTO.ЗаписатьXDTO(Новый Структура("Успешно", Истина));
		ИначеЕсли ОбщегоНазначенияТСД.ЭтоЗначениеПримитивногоТипа(Результат) Тогда
			Возврат СериализаторXDTO.ЗаписатьXDTO(Новый Структура("Результат", Результат));
		Иначе//должна быть структура
			Возврат СериализаторXDTO.ЗаписатьXDTO(Результат);
		КонецЕсли;
	Исключение
		ПодробнаяОшибка = ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
		ОпсаниеОшибки = ОписаниеОшибки();
		ЗаписьЖурналаРегистрации("Мобильное приложение", УровеньЖурналаРегистрации.Ошибка,,,ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
		Возврат СериализаторXDTO.ЗаписатьXDTO(Новый Структура("Успешно, Сообщение", Ложь, ОпсаниеОшибки));
	КонецПопытки;
КонецФункции

Функция СерверДоступен(Параметры)
	МассивПользователейИБ = ПользователиИнформационнойБазы.ПолучитьПользователей();
	
	ИтоговыйМассивПользователейИБ = Новый Массив;
	Для Каждого Элемент ИЗ МассивПользователейИБ Цикл
		Если Элемент.ПоказыватьВСпискеВыбора Тогда
			СтруктураПользователя = Новый Структура("Имя, УникальныйИдентификатор", Элемент.Имя, Строка(Элемент.УникальныйИдентификатор)); 
			ИтоговыйМассивПользователейИБ.Добавить(СтруктураПользователя);
		КонецЕсли;
	КонецЦикла;	
	
	Ответ = Новый Структура ("Успешно, МассивПользователейИБ", Истина, ИтоговыйМассивПользователейИБ);
	Возврат Ответ; 
КонецФункции

Функция АвторизоватьПользователя(Параметры)
	ОтветАвторизаци = Новый Структура("Успешно, Сообщение, ИмяКонфигурации", Истина, "", Метаданные.Имя);
	ПользовательИБ = ПользователиИнформационнойБазы.НайтиПоИмени(Параметры.Логин);
	Если ПользовательИБ = Неопределено Тогда
		ОтветАвторизаци.Успешно = Ложь;
		ОтветАвторизаци.Сообщение = "Такого пользователя нет в базе!";
	Иначе
		Если ЕстьДоступКСервисам(ПользовательИБ) Тогда
			Если ПарольСовпадаетСПаролемИБ(ПользовательИБ, Параметры.Пароль) Тогда
				ОтветАвторизаци.Успешно = Истина;
				Пользователь = Справочники.Пользователи.НайтиПоРеквизиту("ИдентификаторПользователяИБ", ПользовательИБ.УникальныйИдентификатор);
				ПланыОбмена.ОбменДаннымиМобильноеПриложение.СоздатьУзелОбмена(ОтветАвторизаци, Пользователь);
				ОтветАвторизаци.Вставить("ГУИДПользователя", Пользователь.УникальныйИдентификатор());
				ОтветАвторизаци.Вставить("НаименованиеПользователя", Пользователь.Наименование);
				ОбщегоНазначенияТСД.ВставитьВСтруктуруВерсиюОбмена(ОтветАвторизаци);
			Иначе
				ОтветАвторизаци.Успешно = Ложь;
				ОтветАвторизаци.Сообщение = "Неверно введен пароль!";
			КонецЕсли;	
		Иначе
			ОтветАвторизаци.Успешно = Ложь;
			ОтветАвторизаци.Сообщение = "У пользователя нет прав для работы на мобильном устройстве. Обратитесь к администратору";
		КонецЕсли;
	КонецЕсли;
	Возврат ОтветАвторизаци;
КонецФункции

Функция ПроверитьПользователяНаСервере(Параметры)
	ОтветПроверки = Новый Структура("Успешно, Сообщение", Истина, "");
	ПользовательИБ = ПользователиИнформационнойБазы.НайтиПоИмени(Параметры.Логин); 
	
	Если ПарольПользователяПоменялся(ПользовательИБ, Параметры.Пароль) Тогда
		ОтветПроверки.Успешно = Ложь;
		ОтветПроверки.Сообщение = "У пользователя сменился пароль. Необходима повторная авторизация";
	Иначе 
		Если Не ЕстьДоступКСервисам(ПользовательИБ) Тогда
			ОтветПроверки.Успешно = Ложь;
			ОтветПроверки.Сообщение = "У пользователя нет прав для работы на мобильном устройстве. Обратитесь к администратору";
		КонецЕсли;
	КонецЕсли;
	
	ОбщегоНазначенияТСД.ВставитьВСтруктуруВерсиюОбмена(ОтветПроверки);
	Возврат ОтветПроверки;
КонецФункции

Функция ПарольПользователяПоменялся(ПользовательИБ, Пароль)
	Если ПарольСовпадаетСПаролемИБ(ПользовательИБ, Пароль) Тогда
		Возврат Ложь;
	Иначе
		Возврат Истина;
	КонецЕсли;
КонецФункции

Функция ЕстьДоступКСервисам(ПользовательИБ)
	Если Пользователи.РолиДоступны("РаботаСВебСервисами", ПользовательИБ) Тогда
		Возврат Истина;
	Иначе
		Возврат Ложь;  
	КонецЕсли;
КонецФункции

Функция ПолучитьДокумент(Параметры)
	Документ = РаботаСШтрихкодами.ПолучитьДокументПоШК(Параметры.Штрихкод);
	Результат = Новый Структура("Успешно, Сообщение, ТипНайденногоДокумента", Истина, "", "");
	Если Документ <> Неопределено Тогда 
		Результат.ТипНайденногоДокумента = Строка(ТипЗнч(Документ));
		Если ТипЗнч(Документ) = Тип("ДокументСсылка.ПересчетТоваров") Тогда
			Если Документ.Статус <> Перечисления.СтатусыПересчетовТоваров.ВРаботе Тогда
				Результат.Успешно = Ложь;
				Результат.Сообщение = "Неверный статус документа. Работа с документом возможна только со статусом ""В работе""!";
			Иначе
				РаботаСДокументами.ПолучитьДанныеДокументаПересчетТоваров(Документ, Результат);
			КонецЕсли;	
		ИначеЕсли ТипЗнч(Документ) = Тип("ДокументСсылка.ЗаказНаПеремещение") Тогда
			РаботаСДокументами.СоздатьПеремещениеТоваровНаОсновеЗаказаНаПеремещения(Параметры.ГУИДПользователя, Документ, Результат);
		ИначеЕсли ТипЗнч(Документ) = Тип("ДокументСсылка.ПеремещениеТоваров") Тогда
			РаботаСДокументами.ПолучитьДанныеДокументаПеремещениеТоваров(Документ, Результат);
		ИначеЕсли ТипЗнч(Документ) = Тип("ДокументСсылка.ЗаказПоставщику") ИЛИ
			ТипЗнч(Документ) = Тип("ДокументСсылка.ПриобретениеТоваровУслуг") Тогда
			Результат.Вставить("Данные");
			Результат.Успешно = Ложь;
			Результат.Сообщение = "Ошибка поиска документа в центральной базе или документ не найден";
			ОбработкаДокументаОснованияПриемки(Документ, Результат);
		ИначеЕсли ТипЗнч(Документ) = Тип("ДокументСсылка.ЗаказКлиента") ИЛИ
			ТипЗнч(Документ) = Тип("ДокументСсылка.РеализацияТоваровУслуг") Тогда
			Результат.Вставить("Данные");
			Результат.Успешно = Ложь;
			Результат.Сообщение = "Ошибка поиска документа в центральной базе или документ не найден";
			ОбработкаДокументаОснованияОтгрузки(Документ, Результат);
		КонецЕсли;
	Иначе
		Результат.Успешно = Ложь;
		Результат.Сообщение = "Нет документа с таким штрихкодом!";
	КонецЕсли;
	Возврат Результат;
КонецФункции 

Функция ПолучитьКоличествоОбъектовКОбмену(Параметры)
	Результат = Новый Структура("Успешно, Сообщение, КоличествоОбъектов", Истина, "", 0);
	Если НЕ ЗначениеЗаполнено(ПараметрыСеанса.ТекущийУзелТСД) Тогда    
		Результат.Успешно=Ложь;
    	Результат.Сообщение="Узел не найден";
        Возврат Результат
	КонецЕсли;
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	СкладскиеЯчейкиИзменения.Ссылка КАК Ссылка
		|ПОМЕСТИТЬ ВТ_Изменения
		|ИЗ
		|	Справочник.СкладскиеЯчейки.Изменения КАК СкладскиеЯчейкиИзменения
		|ГДЕ
		|	СкладскиеЯчейкиИзменения.Узел = &Узел
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	НоменклатураИзменения.Ссылка
		|ИЗ
		|	Справочник.Номенклатура.Изменения КАК НоменклатураИзменения
		|ГДЕ
		|	НоменклатураИзменения.Узел = &Узел
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	ХарактеристикиНоменклатурыИзменения.Ссылка
		|ИЗ
		|	Справочник.ХарактеристикиНоменклатуры.Изменения КАК ХарактеристикиНоменклатурыИзменения
		|ГДЕ
		|	ХарактеристикиНоменклатурыИзменения.Узел = &Узел
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	УпаковкиЕдиницыИзмеренияИзменения.Ссылка
		|ИЗ
		|	Справочник.УпаковкиЕдиницыИзмерения.Изменения КАК УпаковкиЕдиницыИзмеренияИзменения
		|ГДЕ
		|	УпаковкиЕдиницыИзмеренияИзменения.Узел = &Узел
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	СкладыИзменения.Ссылка
		|ИЗ
		|	Справочник.Склады.Изменения КАК СкладыИзменения
		|ГДЕ
		|	СкладыИзменения.Узел = &Узел
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	ВидыНоменклатурыИзменения.Ссылка
		|ИЗ
		|	Справочник.ВидыНоменклатуры.Изменения КАК ВидыНоменклатурыИзменения
		|ГДЕ
		|	ВидыНоменклатурыИзменения.Узел = &Узел
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	ОрганизацииИзменения.Ссылка
		|ИЗ
		|	Справочник.Организации.Изменения КАК ОрганизацииИзменения
		|ГДЕ
		|	ОрганизацииИзменения.Узел = &Узел
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	СкладскиеПомещенияИзменения.Ссылка
		|ИЗ
		|	Справочник.СкладскиеПомещения.Изменения КАК СкладскиеПомещенияИзменения
		|ГДЕ
		|	СкладскиеПомещенияИзменения.Узел = &Узел
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ ВТ_Изменения.Ссылка) КАК КоличествоОбъектов
		|ИЗ
		|	ВТ_Изменения КАК ВТ_Изменения";
	
	Запрос.УстановитьПараметр("Узел", ПараметрыСеанса.ТекущийУзелТСД);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	ВыборкаДетальныеЗаписи.Следующий();
	Результат.Успешно=Истина;
    Результат.КоличествоОбъектов=ВыборкаДетальныеЗаписи.КоличествоОбъектов;
	
	Возврат Результат;
КонецФункции

