#Область СохранениеСопоставления

Функция СохранениеСопоставления(ТоварыКСопоставлению, АккаунтМаркетплейса) Экспорт

	ВыбранныеСтроки = ТоварыКСопоставлению.НайтиСтроки(Новый Структура("ИзменитьПозицию", Истина));
	
	Если ВыбранныеСтроки.Количество() = 0 Тогда
	
		Сообщение = Новый СообщениеПользователю;
		Сообщение.Текст = "Не выбрано ни одной строки для сохранения сопоставления складов";
		Сообщение.Сообщить();
		
	Иначе
			
		Для каждого Стр Из ВыбранныеСтроки Цикл
		
			Если ЗначениеЗаполнено(Стр.Номенклатура) Тогда
				
				Маркетплейс = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(АккаунтМаркетплейса, "Маркетплейс");
			
				Если Маркетплейс = Перечисления.рар_мп_Маркетплейсы.Wildberries Тогда
				
					МенеджерЗаписи 					  = РегистрыСведений.рар_мп_Wildberries_СопоставленныеТовары.СоздатьМенеджерЗаписи();
					МенеджерЗаписи.Аккаунт			  = АккаунтМаркетплейса; 
					МенеджерЗаписи.IDТовара			  = Стр.IDТовара;
					МенеджерЗаписи.Артикул			  = Стр.Артикул;
					МенеджерЗаписи.Баракод			  = Стр.Баракод;
					МенеджерЗаписи.Размер 			  = Стр.Размер;
					МенеджерЗаписи.Номенклатура		  = Стр.Номенклатура;
					МенеджерЗаписи.Характеристика 	  = Стр.Характеристика;
					
					Если ЗначениеЗаполнено(Стр.Упаковка) Тогда
					
						МенеджерЗаписи.Упаковка = Стр.Упаковка;	
					
					Иначе
					
						ЕдиницаИзмерения = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Стр.Номенклатура, "ЕдиницаИзмерения");
						
						МенеджерЗаписи.Упаковка = ЕдиницаИзмерения;
					
					КонецЕсли;
					
					МенеджерЗаписи.НаименованиеТовара = Стр.НаименованиеТовара;
					
				ИначеЕсли Маркетплейс = Перечисления.рар_мп_Маркетплейсы.ЯндексМаркет  Тогда
					
					МенеджерЗаписи 					  = РегистрыСведений.рар_мп_ЯндексМаркет_СопоставленныеТовары.СоздатьМенеджерЗаписи();
					МенеджерЗаписи.Аккаунт 			  = АккаунтМаркетплейса; 
					МенеджерЗаписи.SKUТовара 		  = Стр.SKUТовара;
					МенеджерЗаписи.SKUЯндексМаркета   = Стр.SKUЯндексМаркета;
					МенеджерЗаписи.Артикул 			  = Стр.Артикул;
					МенеджерЗаписи.Номенклатура		  = Стр.Номенклатура;
					МенеджерЗаписи.Характеристика 	  = Стр.Характеристика;
					
					Если ЗначениеЗаполнено(Стр.Упаковка) Тогда
					
						МенеджерЗаписи.Упаковка = Стр.Упаковка;	
					
					Иначе
					
						ЕдиницаИзмерения = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Стр.Номенклатура, "ЕдиницаИзмерения");
						
						МенеджерЗаписи.Упаковка = ЕдиницаИзмерения;
					
					КонецЕсли;
					
					МенеджерЗаписи.НаименованиеТовара = Стр.НаименованиеТовара;
					
				ИначеЕсли Маркетплейс = Перечисления.рар_мп_Маркетплейсы.OZON  Тогда
				
					МенеджерЗаписи 					  = РегистрыСведений.рар_мп_Ozon_СопоставленныеТовары.СоздатьМенеджерЗаписи();	
				    МенеджерЗаписи.Аккаунт			  = АккаунтМаркетплейса; 
					МенеджерЗаписи.IDТовара			  = Стр.IDТовара; 
					МенеджерЗаписи.SKUТовара 		  = Стр.SKUТовара;
					МенеджерЗаписи.Артикул			  = Стр.Артикул;
					МенеджерЗаписи.Номенклатура		  = Стр.Номенклатура;
					МенеджерЗаписи.Характеристика 	  = Стр.Характеристика;
					
					Если ЗначениеЗаполнено(Стр.Упаковка) Тогда
					
						МенеджерЗаписи.Упаковка = Стр.Упаковка;	
					
					Иначе
					
						ЕдиницаИзмерения = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Стр.Номенклатура, "ЕдиницаИзмерения");
						
						МенеджерЗаписи.Упаковка = ЕдиницаИзмерения;
					
					КонецЕсли;
					
					МенеджерЗаписи.НаименованиеТовара = Стр.НаименованиеТовара;					
				КонецЕсли;
				
				Попытка
				
					МенеджерЗаписи.Записать();
					
					ТоварыКСопоставлению.Удалить(ТоварыКСопоставлению.Индекс(Стр));
				
				Исключение
					
					Сообщение = Новый СообщениеПользователю;
					Сообщение.Текст = СтрШаблон("Ошибка при сопоставлении товара с уникальным идентификатором: %1 и названием: %2. 
												|Продробную ошибку можно посмотреть в журнале регистрации", 
												Стр.IDТовара, Стр.НаименованиеТовара);
					Сообщение.Сообщить();
					
					ЗаписьЖурналаРегистрации(СтрШаблон("Ошибка при сопоставлении товара с уникальным идентификатором: %1 и названием: %2", 
														Стр.IDТовара, Стр.НаименованиеТовара), УровеньЖурналаРегистрации.Ошибка,,,ОписаниеОшибки(),);
				
				КонецПопытки;
				    			
			
			Иначе
			
				Сообщение = Новый СообщениеПользователю;
				Сообщение.Текст = СтрШаблон("Не удалось сохранить сопоставление так как не указано значение в поле 'Номенклатура' для товара 
											|с уникальным идентификатором: %1 и названием: %2", Стр.IDТовара, Стр.НаименованиеТовара);
				Сообщение.Сообщить();	
			
			КонецЕсли;
		
		КонецЦикла;
		
		Сообщение = Новый СообщениеПользователю;
		Сообщение.Текст = "Сохранение сопоставления товаров завершено";
		Сообщение.Сообщить();
		
	КонецЕсли;
	
	Возврат ТоварыКСопоставлению;

КонецФункции

