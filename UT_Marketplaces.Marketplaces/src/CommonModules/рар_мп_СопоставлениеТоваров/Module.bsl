			ИначеЕсли ОбщегоНазначения.ЗначениеРеквизитаОбъекта(АккаунтМаркетплейса, "Маркетплейс") = Перечисления.рар_мп_Маркетплейсы.OZON  Тогда
			
				МенеджерЗаписи 			 = РегистрыСведений.рар_мп_Ozon_СопоставленныеТовары.СоздатьМенеджерЗаписи();	
			    МенеджерЗаписи.Аккаунт   = АккаунтМаркетплейса; 
				МенеджерЗаписи.IDТовара  = Стр.IDТовара;
				МенеджерЗаписи.SKUТовара = Стр.SKUТовара;
				МенеджерЗаписи.Артикул   = Стр.Артикул;
				
			КонецЕсли; 
			
			Попытка
			
				МенеджерЗаписи.Удалить();
				
				СопоставленныеТовары.Удалить(СопоставленныеТовары.Индекс(Стр));
			
			Исключение
				
				Сообщение = Новый СообщениеПользователю;
				Сообщение.Текст = СтрШаблон("Ошибка при удалении сопоставления товара с уникальным идентификатором: %1 и названием: %2. 
											|Продробную ошибку можно посмотреть в журнале регистрации", 
											Стр.IDТовара, Стр.НаименованиеТовара);
				Сообщение.Сообщить();
				
				ЗаписьЖурналаРегистрации(СтрШаблон("Ошибка при удалении сопоставления товара с уникальным идентификатором: %1 и названием: %2", 
													Стр.IDТовара, Стр.НаименованиеТовара), УровеньЖурналаРегистрации.Ошибка,,,ОписаниеОшибки(),);
			
			КонецПопытки;
		
		КонецЦикла;
		
		Сообщение = Новый СообщениеПользователю;
		Сообщение.Текст = "Удаление сопоставления товаров завершено";
		Сообщение.Сообщить();
		
	КонецЕсли;	
	
	Возврат СопоставленныеТовары;

КонецФункции

#КонецОбласти

#Область СопоставлениеПоАртикулу

Функция СопоставлениеПоАртикулу(ТоварыКСопоставлению, АккаунтМаркетплейса) Экспорт

	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	Номенклатура.Ссылка КАК Номенклатура,
		|	Номенклатура.ЕдиницаИзмерения КАК Упаковка,
		|	Номенклатура.Артикул КАК Артикул
		|ИЗ
		|	Справочник.Номенклатура КАК Номенклатура
		|ГДЕ
		|	Номенклатура.Артикул В (&Артикулы)";
	
	МассивАртикулов = ОбщегоНазначенияУТ.УдалитьПовторяющиесяЭлементыМассива(ТоварыКСопоставлению.ВыгрузитьКолонку("Артикул"));

	Запрос.УстановитьПараметр("Артикулы", МассивАртикулов);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выгрузить();
	
	Для каждого Строка Из ТоварыКСопоставлению Цикл
		
		Если Строка.Артикул <> "" Тогда
			
			НайденныеСтроки = ВыборкаДетальныеЗаписи.НайтиСтроки(Новый Структура("Артикул", Строка.Артикул));
		
			Если НайденныеСтроки.Количество() = 0 Тогда
			
				Сообщение = Новый СообщениеПользователю;
				Сообщение.Текст = СтрШаблон("Не удалось найти номенклатуру с артикулом: %1 в 1С. 
											|Необходимо выбрать номенклатуру, характеристику и упаковку вручную", Строка.Артикул);
				Сообщение.Сообщить();	
			
			ИначеЕсли НайденныеСтроки.Количество() > 1 Тогда
				
				Сообщение = Новый СообщениеПользователю;
				Сообщение.Текст = СтрШаблон("Для номенклатуры с артикулом: %1 заведено несколько номенклатур в 1С.  
											|Необходимо выбрать номенклатуру, характеристику и упаковку вручную", Строка.Артикул);
				Сообщение.Сообщить();
				
			Иначе
			
				Строка.Номенклатура = НайденныеСтроки.Получить(0).Номенклатура;
			
			КонецЕсли;
			
		Иначе
			
			Маркетплейс = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(АккаунтМаркетплейса, "Маркетплейс");
			
			Сообщение = Новый СообщениеПользователю;
			Сообщение.Текст = СтрШаблон("Для номенклатуры с уникальным идентификатором: %1 не указан артикул.  
										|Необходимо выбрать номенклатуру, характеристику и упаковку вручную", 
										?(Маркетплейс = Перечисления.рар_мп_Маркетплейсы.ЯндексМаркет, Строка.SKUТовара, Строка.IDТовара));
			Сообщение.Сообщить();	
		
		КонецЕсли;

	КонецЦикла;
	
	Возврат ТоварыКСопоставлению;

КонецФункции

#КонецОбласти

#Область СопоставлениеПоШтрихкоду

