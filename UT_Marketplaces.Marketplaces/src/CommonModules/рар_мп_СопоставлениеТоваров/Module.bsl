#Область Ozon

Функция ПолучитьСписокТоваровКСопоставлению_Ozon(Аккаунт) Экспорт

	ИдентификаторСтраницы = "";
	
	ТабЗначТоваров = Новый ТаблицаЗначений;
	ТабЗначТоваров.Колонки.Добавить("IDТовара");
	ТабЗначТоваров.Колонки.Добавить("Артикул");
	ТабЗначТоваров.Колонки.Добавить("Баракод");
	ТабЗначТоваров.Колонки.Добавить("НаименованиеТовара");
	ТабЗначТоваров.Колонки.Добавить("SKUТовара");
	
	HTTPОтвет = рар_мп_Ozon_Методы.Метод_СписокТоваров(Аккаунт, ИдентификаторСтраницы); 
	
	Если HTTPОтвет.Свойство("ОтветAPI") Тогда
		
		Если HTTPОтвет.КодСостояния <> 200 Тогда
			
			ТабЗначТоваров.Очистить();
			
			Сообщение = Новый СообщениеПользователю;
			Сообщение.Текст = "Ошибка при получении товаров из маркетплейса. Подробное описание ошибки можно посмотреть в журнале регистрации";
			Сообщение.Сообщить();
			
			Комментарий = СтрШаблон("Аккаунт: %3. Код запроса:%1. Описание ошибки:%2", HTTPОтвет.КодСостояния, HTTPОтвет.ОтветAPI.message, Аккаунт);
				
			ЗаписьЖурналаРегистрации("Ошибка при получении ", УровеньЖурналаРегистрации.Ошибка,,,Комментарий,);

			Возврат	ТабЗначТоваров; 
				
		КонецЕсли;
		
		ИдентификаторСтраницы = HTTPОтвет.ОтветAPI.result.last_id; 
		КоличествоСтраниц = Цел(HTTPОтвет.ОтветAPI.result.total/1000);
		МассивТоваровИзЗапроса = HTTPОтвет.ОтветAPI.result.items;
		
		КоличествоЗапросов = 0;
		
		Пока КоличествоСтраниц > 0 Цикл
			
			Если КоличествоЗапросов = 50 Тогда
				
				КоличествоЗапросов = 0;
				
				ВремяОжидания = 5;
				
				ВремяСледующегоЗапроса = ТекущаяДата() + ВремяОжидания;
				
				Пока ТекущаяДата() < ВремяСледующегоЗапроса Цикл
					// Ожидаем время для следующего запроса	
				КонецЦикла;
				
			КонецЕсли;
			
			HTTPОтвет = рар_мп_Ozon_Методы.Метод_СписокТоваров(Аккаунт, ИдентификаторСтраницы);
			
			КоличествоЗапросов = КоличествоЗапросов + 1;
			
			Если HTTPОтвет.Свойство("ОтветAPI") Тогда
				
				Если HTTPОтвет.КодСостояния <> 200 Тогда
					
					ТабЗначТоваров.Очистить();
				
					Сообщение = Новый СообщениеПользователю;
					Сообщение.Текст = "Ошибка при получении товаров из маркетплейса. Подробное описание ошибки можно посмотреть в журнале регистрации";
					Сообщение.Сообщить();
					
					Комментарий = СтрШаблон("Аккаунт: %3. Код запроса:%1. Описание ошибки:%2", HTTPОтвет.КодСостояния, HTTPОтвет.ОтветAPI.message, Аккаунт);
						
					ЗаписьЖурналаРегистрации("Ошибка при получении ", УровеньЖурналаРегистрации.Ошибка,,,Комментарий,);

					Возврат ТабЗначТоваров;
						
				КонецЕсли;
				
				ИдентификаторСтраницы = HTTPОтвет.ОтветAPI.result.last_id;
				ОбщегоНазначенияКлиентСервер.ДополнитьМассив(МассивТоваровИзЗапроса, HTTPОтвет.ОтветAPI.result.items, Истина);		
				КоличествоСтраниц = КоличествоСтраниц - 1; 
				
			Иначе
				
				Сообщение = Новый СообщениеПользователю;
				Сообщение.Текст = "Ошибка при получении данных о товарах. Подробное описание ошибки можно посмотреть в журнале регистрации";
				Сообщение.Сообщить();
				
				Комментарий = "Ошибка при получении JSON. Некорректные значения JSON";
				
				ЗаписьЖурналаРегистрации("Ошибка при получении данных о товарах", УровеньЖурналаРегистрации.Ошибка,,,СтрШаблон("Аккаунт: %3. Код запроса:%1. Описание ошибки:%2", HTTPОтвет.КодСостояния, Комментарий, Аккаунт),);
			
			КонецЕсли;
			
		КонецЦикла;
		
		ПакетыТоваров = РазделениеМассиваНаПакеты(МассивТоваровИзЗапроса, 1000);
		
		Для Каждого Пакет Из ПакетыТоваров Цикл
			
			Если КоличествоЗапросов = 50 Тогда
				
				КоличествоЗапросов = 0;
				
				ВремяОжидания = 5;
				
				ВремяСледующегоЗапроса = ТекущаяДата() + ВремяОжидания;
				
				Пока ТекущаяДата() < ВремяСледующегоЗапроса Цикл
					// Ожидаем время для следующего запроса	
				КонецЦикла;
				
			КонецЕсли;
		
			HTTPОтвет = рар_мп_Ozon_Методы.Метод_ПолучитьОписаниеХарактеристикТовара(Аккаунт, Пакет.Значение);
			
			КоличествоЗапросов = КоличествоЗапросов + 1;
			
			Если HTTPОтвет.Свойство("ОтветAPI") Тогда
				
				Если HTTPОтвет.КодСостояния <> 200 Тогда
					
					Сообщение = Новый СообщениеПользователю;
					Сообщение.Текст = СтрШаблон("Ошибка при получении информации о товарах. 
												|Подробное описание ошибки можно посмотреть в журнале регистрации");
					Сообщение.Сообщить();
					
					Комментарий = СтрШаблон("Аккаунт: %3. Код запроса:%1. Описание ошибки:%2", HTTPОтвет.КодСостояния, HTTPОтвет.ОтветAPI.message, Аккаунт);
					
					ЗаписьЖурналаРегистрации("Ошибка при получении информации о товарах", УровеньЖурналаРегистрации.Ошибка,,,Комментарий,);
					
				Иначе
					
					Для Каждого Товар Из HTTPОтвет.ОтветAPI.items Цикл
						
						Попытка
							
							IDТовара		   = Формат(Товар.id,"ЧГ=");
							Артикул  		   = Формат(Товар.offer_id,"ЧГ=");
							НаименованиеТовара = Товар.name;
							SKU				   = "";
							Если Товар.sources.Количество() <> 0 Тогда
								SKU = Товар.sources[0].sku;
							КонецЕсли;
							Баракод = "";
							Если Товар.Свойство("barcodes") Тогда
								Если Товар.barcodes.Количество() <> 0 Тогда
									Баракод = Товар.barcodes.Получить(0);
								КонецЕсли;
							КонецЕсли;
							
							Запись 				= РегистрыСведений.рар_мп_Ozon_СопоставленныеТовары.СоздатьМенеджерЗаписи();
							Запись.Аккаунт  	= Аккаунт;
							Запись.IDТовара 	= IDТовара;
							Запись.Артикул  	= Артикул;
							Запись.SKUТовара 	= SKU;
							
							Запись.Прочитать();
							
							Если Не Запись.Выбран() Тогда
								
								НоваяСтрока = ТабЗначТоваров.Добавить();
								
								НоваяСтрока.IDТовара  	  		= IDТовара;
								НоваяСтрока.Артикул		 	  	= Артикул;
								НоваяСтрока.Баракод				= Баракод;
								НоваяСтрока.НаименованиеТовара	= НаименованиеТовара;
								НоваяСтрока.SKUТовара			= SKU;
								
							КонецЕсли;
							
						Исключение
							
							Сообщение = Новый СообщениеПользователю;
							Сообщение.Текст = СтрШаблон("Ошибка при получении информации о товаре с id: %1. 
														|Подробное описание ошибки можно посмотреть в журнале регистрации",
														Товар.id);
							Сообщение.Сообщить();
							
							Комментарий = СтрШаблон("Аккаунт: %3. Код запроса:%1. Описание ошибки:%2", HTTPОтвет.КодСостояния, ОписаниеОшибки(), Аккаунт);
							
							ЗаписьЖурналаРегистрации(СтрШаблон("Ошибка при получении информации о товаре с id: %1", Товар.id), 
														УровеньЖурналаРегистрации.Ошибка,,,Комментарий,);
							
						КонецПопытки;
						
					КонецЦикла;
					
				КонецЕсли;		
				
			Иначе
				
				ТабЗначТоваров.Очистить();
				
				Сообщение = Новый СообщениеПользователю;
				Сообщение.Текст = "Ошибка при получении данных о товарах. Подробное описание ошибки можно посмотреть в журнале регистрации";
				Сообщение.Сообщить();
				
				Комментарий = "Ошибка при получении JSON. Некорректные значения JSON";
				
				ЗаписьЖурналаРегистрации("Ошибка при получении данных о товарах", УровеньЖурналаРегистрации.Ошибка,,,
											СтрШаблон("Аккаунт: %3. Код запроса:%1. Описание ошибки:%2", HTTPОтвет.КодСостояния, Комментарий, Аккаунт),);
				
				Возврат ТабЗначТоваров;
				
			КонецЕсли;
			
		КонецЦикла;
		
	Иначе
		
		Сообщение = Новый СообщениеПользователю;
		Сообщение.Текст = "Ошибка при получении данных о товарах. Подробное описание ошибки можно посмотреть в журнале регистрации";
		Сообщение.Сообщить();
		
		Комментарий = "Ошибка при получении JSON. Некорректные значения JSON";
		
		ЗаписьЖурналаРегистрации("Ошибка при получении данных о товарах", УровеньЖурналаРегистрации.Ошибка,,,СтрШаблон("Аккаунт: %3. Код запроса:%1. Описание ошибки:%2", HTTPОтвет.КодСостояния, Комментарий, Аккаунт),);
		
		Возврат ТабЗначТоваров;
		
	КонецЕсли;
	
	Возврат ТабЗначТоваров;

КонецФункции

Функция РазделениеМассиваНаПакеты(ИсходныйМассив, РазмерПакета)
	
	// Создаем структуру для хранения пакетов
	Пакеты = Новый Структура;
	
	// Параметры для разделения
	КоличествоПакетов = Цел(ИсходныйМассив.Количество() / РазмерПакета);
	Если ИсходныйМассив.Количество() % РазмерПакета > 0 Тогда
		КоличествоПакетов = КоличествоПакетов + 1;
	КонецЕсли;
	
	// Разделяем массив на пакеты
	Для НомерПакета = 1 По КоличествоПакетов Цикл
		НовыйПакет = Новый Массив;
		НачальныйИндекс = (НомерПакета - 1) * РазмерПакета;
		КонечныйИндекс = Мин(НачальныйИндекс + РазмерПакета - 1, ИсходныйМассив.Количество() - 1);
		
		Для Индекс = НачальныйИндекс По КонечныйИндекс Цикл
			НовыйПакет.Добавить(ИсходныйМассив[Индекс]);
		КонецЦикла;
		
		// Добавляем пакет в структуру с ключом "ПакетN"
		Пакеты.Вставить("Пакет" + Формат(НомерПакета, "ЧГ=0"), НовыйПакет);
	КонецЦикла;
	
	Возврат Пакеты;
	
КонецФункции

#КонецОбласти

#Область ЯндексМаркет

Функция ПолучитьСписокТоваровКСопоставлению_ЯндексМаркет(Аккаунт) Экспорт
	
	ПослядняяСтраница = Ложь;
	СледующаяСтраница = "";
	Архив = Ложь;
	
	ТабЗначТоваров = Новый ТаблицаЗначений;
	ТабЗначТоваров.Колонки.Добавить("SKUТовара");
	ТабЗначТоваров.Колонки.Добавить("SKUЯндексМаркета");
	ТабЗначТоваров.Колонки.Добавить("НаименованиеТовара");
	ТабЗначТоваров.Колонки.Добавить("Артикул");
	ТабЗначТоваров.Колонки.Добавить("Баракод");
		
	Пока НЕ ПослядняяСтраница Цикл
	
		HTTPОтвет = рар_мп_ЯндексМаркет_Методы.Метод_ИнформацияОТоварахВКаталогах(Аккаунт, СледующаяСтраница, Архив);
		
		Если HTTPОтвет.Свойство("ОтветAPI") Тогда
			
			Если HTTPОтвет.КодСостояния <> 200 Тогда
				
				ТабЗначТоваров.Очистить();
				
				Сообщение = Новый СообщениеПользователю;
				Сообщение.Текст = "Ошибка при получении товаров к сопоставлению. 
								   |Подробное описание ошибки можно посмотреть в журнале регистрации";
				Сообщение.Сообщить();
				
				Комментарий = СтрШаблон("Аккаунт: %3. Код запроса:%1. Описание ошибки:%2", HTTPОтвет.КодСостояния, HTTPОтвет.ОтветAPI.errors.Получить(0).message, Аккаунт);
				
				ЗаписьЖурналаРегистрации("Ошибка при получении товаров к сопоставлению", 
										 УровеньЖурналаРегистрации.Ошибка,,,Комментарий,);
				
				Возврат ТабЗначТоваров; 	
				
			Иначе
				
				Попытка
			
					Для каждого Строка Из HTTPОтвет.ОтветAPI.result.offerMappings Цикл
						
						Запись 			 = РегистрыСведений.рар_мп_ЯндексМаркет_СопоставленныеТовары.СоздатьМенеджерЗаписи();
						Запись.Аккаунт   = Аккаунт;
						Запись.SKUТовара = Строка.offer.offerId;
						Запись.Артикул   = ?(Строка.offer.Свойство("vendorCode"), Строка.offer.vendorCode, "");
						
						Запись.Прочитать();

						Если НЕ Запись.Выбран() Тогда
			
							СтрокаТЗ		     	  	= ТабЗначТоваров.Добавить(); 
							СтрокаТЗ.SKUТовара 	 		= Строка.offer.offerId;
							СтрокаТЗ.Артикул 	 	  	= ?(Строка.offer.Свойство("vendorCode"), Строка.offer.vendorCode, "");
							СтрокаТЗ.НаименованиеТовара	= Строка.offer.name;
							
							Если Строка.Свойство("mapping") Тогда
								Если Строка.mapping.Свойство("marketSku") Тогда
									СтрокаТЗ.SKUЯндексМаркета = СтрЗаменить(Строка(Строка.mapping.marketSku), Символы.НПП, "");
								КонецЕсли;
							КонецЕсли;
							
							Если Строка.offer.Свойство("barcodes") Тогда
								Если Строка.offer.barcodes.Количество() > 0 Тогда
									СтрокаТЗ.Баракод = Строка.offer.barcodes.Получить(0);
								КонецЕсли;
							КонецЕсли;
							
						КонецЕсли;	
						
					КонецЦикла;
					
					Если HTTPОтвет.ОтветAPI.result.paging.Свойство("nextPageToken") Тогда
						СледующаяСтраница = HTTPОтвет.ОтветAPI.result.paging.nextPageToken;			
					Иначе
						
						Если Архив = Ложь Тогда
							
							Архив = Истина;
							СледующаяСтраница = "";
							
						Иначе
							
							ПослядняяСтраница = Истина;
							
						КонецЕсли;
						
					КонецЕсли;	
				
				Исключение
					
					ТабЗначТоваров.Очистить();
					
					Сообщение = Новый СообщениеПользователю;
					Сообщение.Текст = "Ошибка при получении товаров к сопоставлению. Подробное описание ошибки можно посмотреть в журнале регистрации";
					Сообщение.Сообщить();
					
					Комментарий = СтрШаблон("Аккаунт: %3. Код запроса:%1. Описание ошибки:%2", HTTPОтвет.КодСостояния, ОписаниеОшибки(), Аккаунт);
					
					ЗаписьЖурналаРегистрации("Ошибка при получении товаров к сопоставлению", 
											 УровеньЖурналаРегистрации.Ошибка,,,Комментарий,);
					
					Возврат ТабЗначТоваров;
				
				КонецПопытки;	
				
			КонецЕсли;
			
		Иначе
			
			ТабЗначТоваров.Очистить();
			
			Сообщение = Новый СообщениеПользователю;
			Сообщение.Текст = "Ошибка при получении данных о товарах. Подробное описание ошибки можно посмотреть в журнале регистрации";
			Сообщение.Сообщить();
			
			Комментарий = "Ошибка при получении JSON. Некорректные значения JSON";
			
			ЗаписьЖурналаРегистрации("Ошибка при получении данных о товарах", УровеньЖурналаРегистрации.Ошибка,,,СтрШаблон("Аккаунт: %3. Код запроса:%1. Описание ошибки:%2", HTTPОтвет.КодСостояния, Комментарий, Аккаунт),);
			
			Возврат ТабЗначТоваров;
			
		КонецЕсли;
		
	КонецЦикла; 
	
	Возврат ТабЗначТоваров;
	
КонецФункции

