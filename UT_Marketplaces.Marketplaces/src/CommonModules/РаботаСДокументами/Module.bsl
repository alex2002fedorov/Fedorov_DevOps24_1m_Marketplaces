Процедура ЗарегистрироватьКОбменуПриОчисткеСтатуса(ДокументОбъект) Экспорт
	Если ДокументОбъект.рар_мп_СтатусДокументаВТСД = Перечисления.рар_мп_СтатусыДокументовВТСД.ПустаяСсылка() Тогда
		Если СтатусДокументаВТСДБылДругим(ДокументОбъект.Ссылка, ДокументОбъект.рар_мп_СтатусДокументаВТСД) Тогда
			ДокументОбъект.ДополнительныеСвойства.Вставить("ЗарегистрироватьДокументКОбменуНаТСД", Истина);
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры 

Функция СтатусДокументаВТСДБылДругим(ДокументСсылка, СтатусДокументаВТСД)
	
	НаименованиеДокумента = ДокументСсылка.Метаданные().Имя;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ЗаказКлиента.Ссылка КАК Ссылка
		|ИЗ
		|	Документ.ЗаказКлиента КАК ЗаказКлиента
		|ГДЕ
		|	ЗаказКлиента.Ссылка = &Ссылка
		|	И ЗаказКлиента.рар_мп_СтатусДокументаВТСД <> &рар_мп_СтатусДокументаВТСД
		|	И ЗаказКлиента.рар_мп_СтатусДокументаВТСД <> &СтатусЗавершен";
	
	Запрос.УстановитьПараметр("рар_мп_СтатусДокументаВТСД", СтатусДокументаВТСД);
	Запрос.УстановитьПараметр("СтатусЗавершен", Перечисления.рар_мп_СтатусыДокументовВТСД.Завершен);
	Запрос.УстановитьПараметр("Ссылка", ДокументСсылка);
	
	Запрос.Текст = СтрЗаменить(Запрос.Текст, "Документ.ЗаказКлиента", "Документ." + НаименованиеДокумента);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Если РезультатЗапроса.Пустой() Тогда
		Возврат Ложь;
	Иначе 
		Возврат Истина;
	КонецЕсли;

КонецФункции

