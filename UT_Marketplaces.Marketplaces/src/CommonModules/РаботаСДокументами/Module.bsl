Функция ПолучитьМассивВозможныхДокументовОтгрузки(ДокументОснование) Экспорт
	
	МассивТиповДокументов = Новый Массив;		
	Если ТипЗнч(ДокументОснование) = Тип("ДокументСсылка.ЗаказКлиента") Тогда 
		Если НЕ ДокументОснование.Статус = Перечисления.СтатусыЗаказовКлиентов.КОтгрузке И 
			НЕ ДокументОснование.Статус = Перечисления.СтатусыЗаказовКлиентов.КОбеспечению Тогда 
			Возврат МассивТиповДокументов;
		КонецЕсли;
		Отгрузить = Перечисления.ВариантыОбеспечения.Отгрузить;
		ПодходящиеДокументы = ДокументОснование.Товары.Найти(Отгрузить, "ВариантОбеспечения");
		Если ПодходящиеДокументы = Неопределено Тогда 
			Возврат МассивТиповДокументов;
		КонецЕсли;
		
		Если ДокументОснование.Склад.ИспользоватьОрдернуюСхемуПриПоступлении Тогда			 
				МассивТиповДокументов.Добавить("РеализацияТоваровУслуг");
				МассивТиповДокументов.Добавить("РасходныйОрдерНаТовары");			
		Иначе 
			МассивТиповДокументов.Добавить("РеализацияТоваровУслуг");	
		КонецЕсли;
	ИначеЕсли ТипЗнч(ДокументОснование) = Тип("ДокументСсылка.РеализацияТоваровУслуг") Тогда
		Если ДокументОснование.Склад.ИспользоватьОрдернуюСхемуПриПоступлении Тогда 
			Если НЕ ЗначениеЗаполнено(ДокументОснование.ЗаказКлиента) Тогда 
				МассивТиповДокументов.Добавить("РасходныйОрдерНаТовары");
			КонецЕсли;
		КонецЕсли;	
	КонецЕсли;	
	Возврат МассивТиповДокументов;	
	
КонецФункции

Функция ВзятьВРаботуЗаказКлиента(Параметры) Экспорт 
	Результат = Новый Структура("Успешно, Сообщение", Истина, "");
	Документ = Документы.ЗаказКлиента.ПолучитьСсылку(Параметры.ГУИДЗаказаКлиента); 
	ПользовательТСД = Справочники.Пользователи.ПолучитьСсылку(Параметры.ГУИДПользователя);
	Если Документ.рар_мп_СтатусДокументаВТСД = Перечисления.рар_мп_СтатусыДокументовВТСД.Новый Тогда
		ДокументОбъект = Документ.ПолучитьОбъект();
		ДокументОбъект.рар_мп_СтатусДокументаВТСД = Перечисления.рар_мп_СтатусыДокументовВТСД.ВРаботе;
		ДокументОбъект.рар_мп_ПользовательТСД = ПользовательТСД;
		ДокументОбъект.ДополнительныеСвойства.Вставить("ВзятиеДокументаВРаботуИзТСД", Истина);
		ДокументОбъект.Записать();
	Иначе
		Результат.Успешно = Ложь;
		Результат.Сообщение = "Документ уже в работе!";
	КонецЕсли;
	
	Возврат Результат;
КонецФункции 

