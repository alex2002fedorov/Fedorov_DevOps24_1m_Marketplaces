Функция ЗаписатьРазмещениеТоваровСозданноговМП(ДокументИзМП, Пользователь) Экспорт
	НовыйДокумент = Документы.ОтборРазмещениеТоваров.СоздатьДокумент();
	НовыйДокумент.Дата = ТекущаяДатаСеанса();
	НовыйДокумент.ВидОперации = Перечисления.ВидыОперацийОтбораРазмещенияТоваров.Размещение;
	НовыйДокумент.УстановитьНовыйНомер();
	НовыйДокумент.Склад = Справочники.Склады.ПолучитьСсылку(ДокументИзМП.Склад);
	НовыйДокумент.Помещение = Справочники.СкладскиеПомещения.ПолучитьСсылку(ДокументИзМП.Помещение);
	НовыйДокумент.ЗонаПриемки = Справочники.СкладскиеЯчейки.ПолучитьСсылку(ДокументИзМП.ЗонаПриемки);
	НовыйДокумент.Ответственный = Пользователь;
	НовыйДокумент.Статус = Перечисления.СтатусыОтборовРазмещенийТоваров.ВРаботе;
	
	ТЧДокумента = ДокументИзМП.Товары;
	Для Каждого Строка Из ДокументИзМП.Товары Цикл
		НоваяСтрока = НовыйДокумент.ТоварыРазмещение.Добавить();
		НоваяСтрока.Ячейка = Справочники.СкладскиеЯчейки.ПолучитьСсылку(Строка.Ячейка);
		НоваяСтрока.Номенклатура = Справочники.Номенклатура.ПолучитьСсылку(Строка.Номенклатура);
		Если ЗначениеЗаполнено(Строка.Характеристика) Тогда
			НоваяСтрока.Характеристика = Справочники.ХарактеристикиНоменклатуры.ПолучитьСсылку(Строка.Характеристика);
		КонецЕсли;
		Если ЗначениеЗаполнено(Строка.Упаковка) Тогда	
			НоваяСтрока.Упаковка = Справочники.УпаковкиЕдиницыИзмерения.ПолучитьСсылку(Строка.Упаковка);
		КонецЕсли;
		//НоваяСтрока.Серия = Справочники.Организации.ПолучитьСсылку(ДокументИзМП.Серия);
		НоваяСтрока.Количество = Строка.КоличествоФакт;
		НоваяСтрока.КоличествоУпаковок = Строка.КоличествоФакт;
	КонецЦикла;
	
	//НовыйДокумент.Записать(РежимЗаписиДокумента.Проведение);
	НовыйДокумент.Записать(РежимЗаписиДокумента.Запись);
КонецФункции

Функция НайтиДокументыПоНомеру(Номер, ВидДокумента) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ЗаказКлиента.Ссылка КАК Ссылка,
	|	ЗаказКлиента.Номер КАК Номер,
	|	ЗаказКлиента.Дата КАК Дата,
	|	Представление(ЗаказКлиента.Склад) КАК Склад
	|ИЗ
	|	Документ.ЗаказКлиента КАК ЗаказКлиента
	|ГДЕ
	|	ЗаказКлиента.Номер = &Номер
	|%Условие";
	
	Запрос.УстановитьПараметр("Номер", Номер);

	Если ВидДокумента = "ПересчетТоваров" Тогда
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "%Условие", "И ЗаказКлиента.Статус = Значение(Перечисление.СтатусыПересчетовТоваров.ВРаботе)");
	ИначеЕсли ВидДокумента = "ПеремещениеТоваров" ИЛИ ВидДокумента = "ЗаказНаПеремещение" Тогда
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "Представление(ЗаказКлиента.Склад) КАК Склад", "Представление(ЗаказКлиента.СкладОтправитель) КАК СкладОтправитель, Представление(ЗаказКлиента.СкладПолучатель) КАК СкладПолучатель");
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "%Условие", "");
	Иначе
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "%Условие", "");
	КонецЕсли;
	
	Запрос.Текст = СтрЗаменить(Запрос.Текст, "ЗаказКлиента", ВидДокумента);
	
	
	РезультатЗапроса = Запрос.Выполнить().Выгрузить();
	РезультатЗапроса.Колонки.Добавить("ГУИД");
	Для Каждого Стр Из РезультатЗапроса Цикл 
		Стр.ГУИД = Строка(Стр.Ссылка.УникальныйИдентификатор());	
	КонецЦикла;
	
	Если РезультатЗапроса.Количество() > 0 Тогда 
		Возврат РезультатЗапроса;
	КонецЕсли;	
	
КонецФункции 

Функция ПолучитьДанныеДокументаОснованияПриемкиОтгрузки(Ссылка) Экспорт
		
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ЗаказКлиентаТовары.Номенклатура КАК Номенклатура,
	|	ЗаказКлиентаТовары.Номенклатура.ЕдиницаИзмерения КАК УпаковкаНоменклатуры,
	|	ЗаказКлиентаТовары.Упаковка КАК ЕдиницаИзмерения,
	|	ЗаказКлиентаТовары.Характеристика КАК Характеристика,
	|	ЗаказКлиентаТовары.КоличествоУпаковок КАК Количество
	|ИЗ
	|	Документ.ЗаказКлиента.Товары КАК ЗаказКлиентаТовары
	|ГДЕ
	|	ЗаказКлиентаТовары.Ссылка = &Ссылка";
	
	Запрос.Текст = СтрЗаменить(Запрос.Текст, "ЗаказКлиента", Ссылка.Метаданные().Имя);
	Запрос.УстановитьПараметр("Ссылка", Ссылка);
	
	ТЧТовары = Запрос.Выполнить().Выгрузить();
	
	ТЧТовары.Колонки.Добавить("НоменклатураСДанными");

	Для Каждого Стр Из ТЧТовары Цикл 
		Стр.НоменклатураСДанными = РаботаСоСправочниками.ПолучитьВсеСопутсвующиеДанныеПоНоменклатуре(Стр.Номенклатура);
		Если Не ЗначениеЗаполнено(Стр.ЕдиницаИзмерения) Тогда
			Стр.ЕдиницаИзмерения = Стр.УпаковкаНоменклатуры;
		КонецЕсли;
	КонецЦикла;  
		
	ДанныеДокумента = Новый Структура;
	ДанныеДокумента.Вставить("Номер", Ссылка.Номер);
	ДанныеДокумента.Вставить("Дата", Ссылка.Дата);
	ДанныеДокумента.Вставить("ГУИД", Ссылка.УникальныйИдентификатор());
	ДанныеДокумента.Вставить("Организация", Ссылка.Организация.УникальныйИдентификатор());
	ДанныеДокумента.Вставить("Склад", Ссылка.Склад.УникальныйИдентификатор());
	ДанныеДокумента.Вставить("Партнер", Строка(Ссылка.Партнер));
	ДанныеДокумента.Вставить("Контрагент", Строка(Ссылка.Контрагент));
	ДанныеДокумента.Вставить("Товары", ОбщегоНазначения.ТаблицаЗначенийВМассив(ТЧТовары));	
	
	Возврат ДанныеДокумента;
	
КонецФункции

Функция ПолучитьМассивВозможныхДокументовПриемки(ДокументОснование) Экспорт
		
	МассивТиповДокументов = Новый Массив;
	
	Если ТипЗнч(ДокументОснование) = Тип("ДокументСсылка.ЗаказПоставщику") Тогда 
		Если Константы.ИспользоватьСтатусыЗаказовПоставщикам.Получить() 
			И НЕ ДокументОснование.Статус = Перечисления.СтатусыЗаказовПоставщикам.Подтвержден Тогда 
			Возврат МассивТиповДокументов;
		КонецЕсли;			
		Если ДокументОснование.Склад.ИспользоватьОрдернуюСхемуПриПоступлении Тогда 
			ВариантПриемкиТоваров = Константы.ВариантПриемкиТоваров.Получить();
			
			Если ВариантПриемкиТоваров = Перечисления.ВариантыПриемкиТоваров.РазделенаПоЗаказамИНакладным
				ИЛИ ВариантПриемкиТоваров = Перечисления.ВариантыПриемкиТоваров.ПоДоговорамПослеЗаказовИлиНакладных Тогда 
				МассивТиповДокументов.Добавить("ПриобретениеТоваровУслуг");
				МассивТиповДокументов.Добавить("ПриходныйОрдерНаТовары");
			Иначе 
				МассивТиповДокументов.Добавить("ПриобретениеТоваровУслуг");
			КонецЕсли;
		Иначе 
			МассивТиповДокументов.Добавить("ПриобретениеТоваровУслуг");	
		КонецЕсли;
	ИначеЕсли ТипЗнч(ДокументОснование) = Тип("ДокументСсылка.ПриобретениеТоваровУслуг") Тогда
		Если ДокументОснование.Склад.ИспользоватьОрдернуюСхемуПриПоступлении Тогда 
			Если НЕ ЗначениеЗаполнено(ДокументОснование.ЗаказПоставщику) Тогда 
				МассивТиповДокументов.Добавить("ПриходныйОрдерНаТовары");
			КонецЕсли;
		КонецЕсли;	
	КонецЕсли;	
	
	Возврат МассивТиповДокументов;
	
КонецФункции // ПолучитьМассивВозможныхДокументовПриемки()

Функция ПолучитьСсылкуДокумента(ГУИД)
	
	Ссылка = Документы.ЗаказПоставщику.ПолучитьСсылку(ГУИД);		
	Объект = Ссылка.ПолучитьОбъект();
	Если Объект = Неопределено Тогда 		
		Ссылка = Документы.ПриобретениеТоваровУслуг.ПолучитьСсылку(ГУИД);
	Иначе 
		Возврат Ссылка;
	КонецЕсли;
	Объект = Ссылка.ПолучитьОбъект();
	Если Объект = Неопределено Тогда 		
		Ссылка = Документы.ЗаказКлиента.ПолучитьСсылку(ГУИД);
	Иначе 
		Возврат Ссылка;
	КонецЕсли;
	Объект = Ссылка.ПолучитьОбъект();
	Если Объект = Неопределено Тогда 		
		Ссылка = Документы.РеализацияТоваровУслуг.ПолучитьСсылку(ГУИД);
	Иначе 
		Возврат Ссылка;
	КонецЕсли;	
	
	Возврат Ссылка;
	
КонецФункции // ПолучитьСсылкуДокумента()

