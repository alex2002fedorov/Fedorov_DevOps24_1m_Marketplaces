
Функция HTTPЗапрос(ТекстЗапроса, Аккаунт) Экспорт
	
	Маркетплейс = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Аккаунт, "Маркетплейс");
	
	Если Маркетплейс = Перечисления.рар_мп_Маркетплейсы.OZON Тогда
		
		APIKEY 	 = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Аккаунт, "Ozon_ApiKey");
		ClientID = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Аккаунт, "Ozon_ClientID");
		
		ЗаголовокHTTP = Новый Соответствие();
		ЗаголовокHTTP.Вставить("Content-Type", "application/json");
		ЗаголовокHTTP.Вставить("Api-Key", APIKEY);
		ЗаголовокHTTP.Вставить("Client-Id",	ClientID);	
		
		Запрос = Новый HTTPЗапрос(ТекстЗапроса, ЗаголовокHTTP);
		
		Возврат Запрос;		
		
	ИначеЕсли Маркетплейс = Перечисления.рар_мп_Маркетплейсы.Wildberries Тогда
		
		APIKEY = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Аккаунт, "WB_ApiKey");
		
		ЗаголовокHTTP = Новый Соответствие();
		ЗаголовокHTTP.Вставить("Content-Type", 	"application/json");
		ЗаголовокHTTP.Вставить("Authorization",	APIKEY);	
		
		Запрос = Новый HTTPЗапрос(ТекстЗапроса, ЗаголовокHTTP);  
		
		Возврат Запрос;	
		
	ИначеЕсли Маркетплейс = Перечисления.рар_мп_Маркетплейсы.ЯндексМаркет Тогда
		
		APIKEY = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Аккаунт, "ЯМ_ApiKey");
		
		ЗаголовокHTTP = Новый Соответствие();
		ЗаголовокHTTP.Вставить("Content-Type", "application/json");
		ЗаголовокHTTP.Вставить("Api-Key", APIKEY);	
		
		Запрос = Новый HTTPЗапрос(ТекстЗапроса, ЗаголовокHTTP);  
		
		Возврат Запрос;	
		
	КонецЕсли;
	
КонецФункции

Функция НовоеHTTPСоединение(Адрес, Защищенное = Истина) Экспорт
	
	Прокси = ПолучениеФайловИзИнтернета.ПолучитьПрокси("http://" + Адрес);
	
	ТаймаутСоединения = 10;
	
	Если Защищенное Тогда	
		ЗащищенноеСоединение = НовоеЗащищенноеСоединение(, Новый СертификатыУдостоверяющихЦентровОС);
		Соединение = Новый HTTPСоединение(Адрес, , , , Прокси, ТаймаутСоединения, ЗащищенноеСоединение);	
	Иначе
		Соединение = Новый HTTPСоединение(Адрес, , , , Прокси, ТаймаутСоединения);
	КонецЕсли;
	
	Возврат Соединение;
	
КонецФункции

Функция НовоеЗащищенноеСоединение(СертификатКлиента = Неопределено, СертификатыУдостоверяющихЦентров = Неопределено) Экспорт
	
	Возврат Новый ЗащищенноеСоединениеOpenSSL(СертификатКлиента, СертификатыУдостоверяющихЦентров);
	
КонецФункции

Функция ВыполнитьGETЗапрос(Адрес, Аккаунт, Категория = "") Экспорт
	
	Маркетплейс = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Аккаунт, "Маркетплейс");
	
	Если Маркетплейс = Перечисления.рар_мп_Маркетплейсы.OZON Тогда
		
		АдресЗапроса = "api-seller.ozon.ru";		
		
	ИначеЕсли Маркетплейс = Перечисления.рар_мп_Маркетплейсы.Wildberries Тогда
		
		Если Категория = "Контент" Тогда
			
			АдресЗапроса = "content-api.wildberries.ru";
			
		ИначеЕсли Категория = "Аналитика" Тогда
			
			АдресЗапроса = "seller-analytics-api.wildberries.ru";
			
		ИначеЕсли Категория = "Цены и скидки" Тогда
			
			АдресЗапроса = "discounts-prices-api.wildberries.ru";
			
		ИначеЕсли Категория = "Маркетплейс" Тогда
			
			АдресЗапроса = "marketplace-api.wildberries.ru";
			
		ИначеЕсли Категория = "Статистика" Тогда
			
			АдресЗапроса = "statistics-api.wildberries.ru";
			
		ИначеЕсли Категория = "Продвижение" Тогда
			
			АдресЗапроса = "advert-api.wildberries.ru";
			
		Иначе
			
			АдресЗапроса = "";	
			
		КонецЕсли;	
		
	ИначеЕсли Маркетплейс = Перечисления.рар_мп_Маркетплейсы.ЯндексМаркет Тогда
		
		АдресЗапроса = "api.partner.market.yandex.ru";	
		
	КонецЕсли;
	
	HTTPСоединение 	= 	НовоеHTTPСоединение(АдресЗапроса);
	HTTPЗапрос		= 	HTTPЗапрос(Строка(Адрес), Аккаунт);
	
	Ответ = HTTPСоединение.Получить(HTTPЗапрос);
	ОтветВВидеСтроки = Ответ.ПолучитьТелоКакСтроку();
	
	Попытка
		
		ОтветJSON = Новый ЧтениеJSON;
		ОтветJSON.УстановитьСтроку(ОтветВВидеСтроки); 
		
		ОбъектИзJSON = ПрочитатьJSON(ОтветJSON);
		ОтветJSON.Закрыть();
		
		ОтветныеДанные = Новый Структура;
		ОтветныеДанные.Вставить("ОтветAPI", ОбъектИзJSON);
		ОтветныеДанные.Вставить("КодСостояния", Ответ.КодСостояния); 
		ОтветныеДанные.Вставить("Заголовки", Ответ.Заголовки);
		ОтветныеДанные.Вставить("ОтветКакСтрока", ОтветВВидеСтроки);	
		
	Исключение
		
		ОтветныеДанные = Новый Структура;
		ОтветныеДанные.Вставить("КодСостояния", Ответ.КодСостояния); 
		ОтветныеДанные.Вставить("Заголовки", Ответ.Заголовки);
		
	КонецПопытки;
	
	
	Возврат ОтветныеДанные;
КонецФункции 

