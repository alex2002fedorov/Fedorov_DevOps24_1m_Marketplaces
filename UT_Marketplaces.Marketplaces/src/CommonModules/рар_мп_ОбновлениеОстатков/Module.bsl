			Возврат;
			
	КонецЕсли;
		
	КоличествоЗапросов = 0;	
	
	Пока Выборка.Следующий() Цикл
		
		КоличествоСтрок               = 0;
		ОбщееКоличествоТоваров        = 0;  
		МассивСтрокНоменклатуры       = Новый Массив;
		
		ВыборкаДетальныеЗаписи = Выборка.Выбрать(ОбходРезультатаЗапроса.Прямой); 
		
		Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
			
			Если ОбщееКоличествоТоваров >= 8000 Тогда 
				
				ВремяОжидания = 60;
							
				КонДата = ТекущаяДата() + ВремяОжидания;
				
				Пока ТекущаяДата() < КонДата Цикл
					
				КонецЦикла;
				ОбщееКоличествоТоваров = 0;
				
			КонецЕсли;
			
			Если КоличествоСтрок >= 100 Тогда     
				
				Если КоличествоЗапросов = 50 Тогда
					
					КоличествоЗапросов = 0;
					
					ВремяОжидания = 5;
					
					ВремяСледующегоЗапроса = ТекущаяДата() + ВремяОжидания;
					
					Пока ТекущаяДата() < ВремяСледующегоЗапроса Цикл
						// Ожидаем время для следующего запроса	
					КонецЦикла;
				
				КонецЕсли;
				
				ОтветHTTP = рар_мп_Ozon_Методы.Метод_ОбновитьКоличествоТоваровНаСкладах(Выборка.Аккаунт, МассивСтрокНоменклатуры);
				КоличествоЗапросов = КоличествоЗапросов + 1;
				КоличествоСтрок = 0;
				МассивСтрокНоменклатуры.Очистить(); 
					
				Если ОтветHTTP.КодСостояния <> 200 Тогда
					
					Если ОтветHTTP.Свойство("ОтветAPI") Тогда
						
						Комментарий = СтрШаблон("Аккаунт: %2. Код ошибки: %3. Описание ошибки: %1", ОтветHTTP.ОтветAPI.message, Выборка.Аккаунт, ОтветHTTP.КодСостояния);
						
						ЗаписьЖурналаРегистрации("Ошибка при передаче остатков Ozon", УровеньЖурналаРегистрации.Ошибка,,, Комментарий,);

						Возврат;
						
					Иначе    
					
						Ошибка = "Ошибка при получении JSON. Некорректные значения JSON";
						Комментарий = СтрШаблон("Аккаунт: %2. Код ошибки: %3. Описание ошибки: %1", Ошибка, Выборка.Аккаунт, ОтветHTTP.КодСостояния);
						ЗаписьЖурналаРегистрации("Ошибка при передаче остатков Ozon", УровеньЖурналаРегистрации.Ошибка,,, Комментарий,);  

						Возврат;	
						
					КонецЕсли;
		
				КонецЕсли; 
				
			КонецЕсли;
			
			СтруктураПолученныхЗначение = Новый Структура("Артикул, КоличествоОстаток, ВНаличии, IDТовара, УникальныйИдентификаторСклада", ВыборкаДетальныеЗаписи.Артикул, 
															ВыборкаДетальныеЗаписи.КоличествоОстаток, ВыборкаДетальныеЗаписи.ВНаличии, ВыборкаДетальныеЗаписи.IDТовара, 
																												ВыборкаДетальныеЗаписи.УникальныйИдентификаторСклада);

			
			КоличествоСтрок        = КоличествоСтрок + 1;
			ОбщееКоличествоТоваров = ОбщееКоличествоТоваров + 1;
			МассивСтрокНоменклатуры.Добавить(СтруктураПолученныхЗначение);
			
		КонецЦикла; 
		
		Если МассивСтрокНоменклатуры.Количество() > 0 Тогда
			
			Если КоличествоЗапросов = 50 Тогда
				
				КоличествоЗапросов = 0;
				
				ВремяОжидания = 5;
				
				ВремяСледующегоЗапроса = ТекущаяДата() + ВремяОжидания;
				
