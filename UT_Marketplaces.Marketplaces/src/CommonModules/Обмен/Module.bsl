#Область РегистрацияДанныхКОбмену

Процедура ЗарегистрироватьИзмененияДанных(УзелОбмена, ЗагружатьВсюНоменклатуруВТСД = Ложь) Экспорт	
	СоставПланаОбмена = УзелОбмена.Метаданные().Состав;	
	Для Каждого ЭлементСоставаПланаОбмена Из СоставПланаОбмена Цикл
		Если ЭлементСоставаПланаОбмена.АвтоРегистрация=АвтоРегистрацияИзменений.Разрешить Тогда
			ПланыОбмена.ЗарегистрироватьИзменения(УзелОбмена,ЭлементСоставаПланаОбмена.Метаданные);
		КонецЕсли;
	КонецЦикла;
	Если Константы.ЗагружатьВсюНоменклатуруВТСД.Получить() или ЗагружатьВсюНоменклатуруВТСД Тогда  
		ПланыОбмена.ЗарегистрироватьИзменения(УзелОбмена,Метаданные.Справочники.Номенклатура);
		ПланыОбмена.ЗарегистрироватьИзменения(УзелОбмена,Метаданные.Справочники.ХарактеристикиНоменклатуры);
		ПланыОбмена.ЗарегистрироватьИзменения(УзелОбмена,Метаданные.Справочники.УпаковкиЕдиницыИзмерения);
		ПланыОбмена.ЗарегистрироватьИзменения(УзелОбмена,Метаданные.РегистрыСведений.ШтрихкодыНоменклатуры);
		ПланыОбмена.ЗарегистрироватьИзменения(УзелОбмена,Метаданные.Справочники.ШтрихкодыУпаковокТоваров);
	Иначе 
		МассивСсылок=СформироватьМассивСсылокБазовыхЕдиницИзмерения();
		Если МассивСсылок.Количество() Тогда
			ПланыОбмена.ЗарегистрироватьИзменения(УзелОбмена,МассивСсылок);
		КонецЕсли;
	КонецЕсли;
	
	ЗарегистрироватьДокументыКОбмену(УзелОбмена);
КонецПроцедуры

Процедура ЗарегистрироватьДокументыКОбмену(УзелОбмена)

	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	рар_мп_РеестрЗаказов.Ссылка КАК Ссылка
		|ИЗ
		|	Документ.рар_мп_РеестрЗаказов КАК рар_мп_РеестрЗаказов
		|ГДЕ
		|	(рар_мп_РеестрЗаказов.рар_мп_СтатусДокументаВТСД = &СтатусНовый
		|	ИЛИ рар_мп_РеестрЗаказов.рар_мп_СтатусДокументаВТСД = &СтатусВРаботе)
		|	И рар_мп_РеестрЗаказов.ПометкаУдаления = ЛОЖЬ
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	ЗаказКлиента.Ссылка
		|ИЗ
		|	Документ.ЗаказКлиента КАК ЗаказКлиента
		|ГДЕ
		|	(ЗаказКлиента.рар_мп_СтатусДокументаВТСД = &СтатусНовый
		|	ИЛИ ЗаказКлиента.рар_мп_СтатусДокументаВТСД = &СтатусВРаботе)
		|	И ЗаказКлиента.ПометкаУдаления = ЛОЖЬ";
	
	Запрос.УстановитьПараметр("СтатусНовый", Перечисления.рар_мп_СтатусыДокументовВТСД.Новый);
	Запрос.УстановитьПараметр("СтатусВРаботе", Перечисления.рар_мп_СтатусыДокументовВТСД.ВРаботе);
	
	ТЗРезультатЗапроса = Запрос.Выполнить().Выгрузить();
	
	МассивСсылок = ТЗРезультатЗапроса.ВыгрузитьКолонку("Ссылка");
	
	Если МассивСсылок.Количество() > 0 Тогда
		ПланыОбмена.ЗарегистрироватьИзменения(УзелОбмена, МассивСсылок); 
	КонецЕсли;
	
КонецПроцедуры

Процедура ЗарегистрироватьВсеОбъектыКОбменуДляВсехУзлов() Экспорт	
	
	Набор=РегистрыСведений.НоменклатураЗагруженнаяНаТСД.СоздатьНаборЗаписей();
	Набор.Записать(Истина);
	
	
	МассивУзлов=СформироватьМассивУзловДляРегистрации();
	Для каждого Узел из МассивУзлов Цикл
		ПланыОбмена.ЗарегистрироватьИзменения(Узел);
	КонецЦикла;
	
КонецПроцедуры

Процедура ОтменитьРегистрациюВсехОбъектовКОбменуДляВсехУзлов() Экспорт	
		
	МассивУзлов=СформироватьМассивУзловДляРегистрации();
	Для каждого Узел из МассивУзлов Цикл
		ПланыОбмена.УдалитьРегистрациюИзменений(Узел);
	КонецЦикла;
		
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	Номенклатура.Ссылка КАК Ссылка
		|ИЗ
		|	Справочник.Номенклатура КАК Номенклатура";
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		ПланыОбмена.ЗарегистрироватьИзменения(МассивУзлов,Новый УдалениеОбъекта(ВыборкаДетальныеЗаписи.Ссылка));
	КонецЦикла;
	
КонецПроцедуры

Процедура РегистрацияКОбменуСТСДПередЗаписью(Источник, Отказ) Экспорт
	Если Источник.ЭтоНовый() Тогда   
		НовыйГУИД  = Новый УникальныйИдентификатор();
		НоваяСсылка = Справочники[Источник.Метаданные().Имя].ПолучитьСсылку(НовыйГУИД);
		Источник.УстановитьСсылкуНового(НоваяСсылка); 
	ИНаче
		НоваяСсылка=Источник.Ссылка;
	КонецЕсли;
	
	Если ТипЗнч(Источник)=Тип("СправочникОбъект.УпаковкиЕдиницыИзмерения") 
			и Источник.Владелец=Справочники.НаборыУпаковок.БазовыеЕдиницыИзмерения  Тогда 			
		МассивУзлов=СформироватьМассивУзловДляРегистрации();
		Если МассивУзлов.Количество() Тогда
			ПланыОбмена.ЗарегистрироватьИзменения(МассивУзлов,НоваяСсылка);
		КонецЕсли;
	ИначеЕсли Константы.ЗагружатьВсюНоменклатуруВТСД.Получить() 
			и (ТипЗнч(Источник)=Тип("СправочникОбъект.Номенклатура") 
				или ТипЗнч(Источник)=Тип("СправочникОбъект.УпаковкиЕдиницыИзмерения") 
				или ТипЗнч(Источник)=Тип("СправочникОбъект.ХарактеристикиНоменклатуры")
				или ТипЗнч(Источник)=Тип("СправочникОбъект.ШтрихкодыУпаковокТоваров")) Тогда
		МассивУзлов=СформироватьМассивУзловДляРегистрации();		
		Если МассивУзлов.Количество() Тогда
			ПланыОбмена.ЗарегистрироватьИзменения(МассивУзлов,НоваяСсылка);
		КонецЕсли;
	ИначеЕсли ТипЗнч(Источник)=Тип("СправочникОбъект.УпаковкиЕдиницыИзмерения") 
			и НЕ Источник.Владелец=Справочники.НаборыУпаковок.БазовыеЕдиницыИзмерения 
			и НЕ Константы.ЗагружатьВсюНоменклатуруВТСД.Получить()Тогда
		МассивУзлов=РегистрыСведений.НоменклатураЗагруженнаяНаТСД.ПолучитьУзлыДляНоменклатуры(Источник.Владелец);
		ПланыОбмена.ЗарегистрироватьИзменения(МассивУзлов,НоваяСсылка);
	ИначеЕсли ТипЗнч(Источник)=Тип("СправочникОбъект.ХарактеристикиНоменклатуры") 
			и НЕ ТипЗнч(Источник.Владелец)=Тип("СправочникСсылка.ВидыНоменклатуры") 
			и НЕ Константы.ЗагружатьВсюНоменклатуруВТСД.Получить()Тогда     	
		МассивУзлов=РегистрыСведений.НоменклатураЗагруженнаяНаТСД.ПолучитьУзлыДляНоменклатуры(Источник.Владелец);
		Если МассивУзлов.Количество() Тогда
			ПланыОбмена.ЗарегистрироватьИзменения(МассивУзлов,НоваяСсылка);
		КонецЕсли;
	ИначеЕсли (ТипЗнч(Источник)=Тип("СправочникОбъект.Номенклатура")
			или ТипЗнч(Источник)=Тип("СправочникОбъект.ШтрихкодыУпаковокТоваров"))
			и НЕ Константы.ЗагружатьВсюНоменклатуруВТСД.Получить()Тогда
		МассивУзлов=РегистрыСведений.НоменклатураЗагруженнаяНаТСД.ПолучитьУзлыДляНоменклатуры(Источник.Ссылка);
		Если МассивУзлов.Количество() Тогда
			ПланыОбмена.ЗарегистрироватьИзменения(МассивУзлов,НоваяСсылка);
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

Процедура РегистрацияШтрихкодовКОбменуПриЗаписи(Источник, Отказ, Замещение) Экспорт
	Если Константы.ЗагружатьВсюНоменклатуруВТСД.Получить() Тогда 
		МассивУзлов=СформироватьМассивУзловДляРегистрации();
		Если МассивУзлов.Количество() Тогда
			ПланыОбмена.ЗарегистрироватьИзменения(МассивУзлов,Источник);  
		КонецЕсли;
	Иначе
		Для каждого Запись из Источник Цикл
			МассивУзлов=РегистрыСведений.НоменклатураЗагруженнаяНаТСД.ПолучитьУзлыДляНоменклатуры(Запись.Номенклатура);  
			Если МассивУзлов.Количество() Тогда
				ПланыОбмена.ЗарегистрироватьИзменения(МассивУзлов,Источник); 
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
КонецПроцедуры

Процедура ЗарегистрироватьНоменклатуруИСвязанныеОбъекты(Узел,Номенклатура) Экспорт
	ПланыОбмена.ЗарегистрироватьИзменения(Узел,Номенклатура);
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	УпаковкиЕдиницыИзмеренияИзменения.Ссылка КАК Ссылка
		|ИЗ
		|	Справочник.УпаковкиЕдиницыИзмерения КАК УпаковкиЕдиницыИзмеренияИзменения
		|ГДЕ
		|	УпаковкиЕдиницыИзмеренияИзменения.Владелец = &Владелец
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	ХарактеристикиНоменклатурыИзменения.Ссылка
		|ИЗ
		|	Справочник.ХарактеристикиНоменклатуры КАК ХарактеристикиНоменклатурыИзменения
		|ГДЕ
		|	ХарактеристикиНоменклатурыИзменения.Владелец = &Владелец
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	ШтрихкодыУпаковокТоваровИзменения.Ссылка
		|ИЗ
		|	Справочник.ШтрихкодыУпаковокТоваров КАК ШтрихкодыУпаковокТоваровИзменения
		|ГДЕ
		|	ШтрихкодыУпаковокТоваровИзменения.Номенклатура = &Владелец";
	
	Запрос.УстановитьПараметр("Владелец", Номенклатура);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ТЗ = РезультатЗапроса.Выгрузить();
	МассивСсылок=ТЗ.ВыгрузитьКолонку("Ссылка");	
	Если МассивСсылок.Количество() Тогда
		ПланыОбмена.ЗарегистрироватьИзменения(Узел,МассивСсылок); 
	КонецЕсли;	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ШтрихкодыНоменклатуры.Штрихкод КАК Штрихкод
		|ИЗ
		|	РегистрСведений.ШтрихкодыНоменклатуры КАК ШтрихкодыНоменклатуры
		|ГДЕ
		|	ШтрихкодыНоменклатуры.Номенклатура = &Номенклатура";
	
	Запрос.УстановитьПараметр("Номенклатура", Номенклатура);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		Набор=РегистрыСведений.ШтрихкодыНоменклатуры.СоздатьНаборЗаписей(); 
		Набор.Отбор.Штрихкод.Установить(ВыборкаДетальныеЗаписи.Штрихкод);
		Набор.Прочитать();
		ПланыОбмена.ЗарегистрироватьИзменения(Узел,Набор);
	КонецЦикла;
	
КонецПроцедуры

Функция СформироватьМассивУзловДляРегистрации()
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ОбменДаннымиМобильноеПриложение.Ссылка КАК Узел
		|ИЗ
		|	ПланОбмена.ОбменДаннымиМобильноеПриложение КАК ОбменДаннымиМобильноеПриложение
		|ГДЕ
		|	НЕ ОбменДаннымиМобильноеПриложение.ЭтотУзел";
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ТЗ = РезультатЗапроса.Выгрузить();
	МассивУзлов=ТЗ.ВыгрузитьКолонку("Узел");
	Возврат МассивУзлов;
КонецФункции

Функция СформироватьМассивСсылокБазовыхЕдиницИзмерения()
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	УпаковкиЕдиницыИзмерения.Ссылка КАК ЕдиницаИзмерения
		|ИЗ
		|	Справочник.УпаковкиЕдиницыИзмерения КАК УпаковкиЕдиницыИзмерения
		|ГДЕ
		|	УпаковкиЕдиницыИзмерения.Владелец = &Владелец";
	
	Запрос.УстановитьПараметр("Владелец", Справочники.НаборыУпаковок.БазовыеЕдиницыИзмерения);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ТЗ = РезультатЗапроса.Выгрузить();
	Возврат ТЗ.ВыгрузитьКолонку("ЕдиницаИзмерения");
КонецФункции

Функция ПолучитьУзелПользователяВМассиве(Пользователь)
	МассивУзлов = Новый Массив;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ОбменДаннымиМобильноеПриложение.Ссылка КАК Узел
		|ИЗ
		|	ПланОбмена.ОбменДаннымиМобильноеПриложение КАК ОбменДаннымиМобильноеПриложение
		|ГДЕ
		|	НЕ ОбменДаннымиМобильноеПриложение.ЭтотУзел
		|	И ОбменДаннымиМобильноеПриложение.Пользователь = &Пользователь";

	Запрос.УстановитьПараметр("Пользователь", Пользователь);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Если Выборка.Следующий() Тогда
		МассивУзлов.Добавить(Выборка.Узел);
	КонецЕсли;
	
	Возврат МассивУзлов;
КонецФункции

Функция СформироватьМассивУзловДляРегистрацииЗаИсключениемПользователя(Пользователь)
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ОбменДаннымиМобильноеПриложение.Ссылка КАК Узел
		|ИЗ
		|	ПланОбмена.ОбменДаннымиМобильноеПриложение КАК ОбменДаннымиМобильноеПриложение
		|ГДЕ
		|	НЕ ОбменДаннымиМобильноеПриложение.ЭтотУзел
		|	И ОбменДаннымиМобильноеПриложение.Пользователь <> &Пользователь"; 
	
	Запрос.УстановитьПараметр("Пользователь", Пользователь);

	РезультатЗапроса = Запрос.Выполнить();
	
	ТЗ = РезультатЗапроса.Выгрузить();
	МассивУзлов=ТЗ.ВыгрузитьКолонку("Узел");
	Возврат МассивУзлов;
КонецФункции

#КонецОбласти

Функция СформироватьМассивСсылокКОбмену(УзелОбмена,РазмерПакета)

		
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ОрганизацииИзменения.Ссылка КАК Ссылка
		|ПОМЕСТИТЬ ВТ_Выгру
		|ИЗ
		|	Справочник.Организации.Изменения КАК ОрганизацииИзменения
		|ГДЕ
		|	ОрганизацииИзменения.Узел = &Узел
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	ВидыНоменклатурыИзменения.Ссылка
		|ИЗ
		|	Справочник.ВидыНоменклатуры.Изменения КАК ВидыНоменклатурыИзменения
		|ГДЕ
		|	ВидыНоменклатурыИзменения.Узел = &Узел
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	СкладскиеПомещенияИзменения.Ссылка
		|ИЗ
		|	Справочник.СкладскиеПомещения.Изменения КАК СкладскиеПомещенияИзменения
		|ГДЕ
		|	СкладскиеПомещенияИзменения.Узел = &Узел
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	СкладыИзменения.Ссылка
		|ИЗ
		|	Справочник.Склады.Изменения КАК СкладыИзменения
		|ГДЕ
		|	СкладыИзменения.Узел = &Узел
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	НоменклатураИзменения.Ссылка
		|ИЗ
		|	Справочник.Номенклатура.Изменения КАК НоменклатураИзменения
		|ГДЕ
		|	НоменклатураИзменения.Узел = &Узел
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	УпаковкиЕдиницыИзмеренияИзменения.Ссылка
		|ИЗ
		|	Справочник.УпаковкиЕдиницыИзмерения.Изменения КАК УпаковкиЕдиницыИзмеренияИзменения
		|ГДЕ
		|	УпаковкиЕдиницыИзмеренияИзменения.Узел = &Узел
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	СкладскиеЯчейкиИзменения.Ссылка
		|ИЗ
		|	Справочник.СкладскиеЯчейки.Изменения КАК СкладскиеЯчейкиИзменения
		|ГДЕ
		|	СкладскиеЯчейкиИзменения.Узел = &Узел
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	СерииНоменклатуры.Ссылка
		|ИЗ
		|	Справочник.СерииНоменклатуры.Изменения КАК СерииНоменклатуры
		|ГДЕ
		|	СерииНоменклатуры.Узел = &Узел
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	ХарактеристикиНоменклатурыИзменения.Ссылка
		|ИЗ
		|	Справочник.ХарактеристикиНоменклатуры.Изменения КАК ХарактеристикиНоменклатурыИзменения
		|ГДЕ
		|	ХарактеристикиНоменклатурыИзменения.Узел = &Узел 
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	ШтрихкодыУпаковокТоваровИзменения.Ссылка
		|ИЗ
		|	Справочник.ШтрихкодыУпаковокТоваров.Изменения КАК ШтрихкодыУпаковокТоваровИзменения
		|ГДЕ
		|	ШтрихкодыУпаковокТоваровИзменения.Узел = &Узел
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ ПЕРВЫЕ %РазмерПакета%
		|	ВТ_Выгру.Ссылка КАК Ссылка
		|ИЗ
		|	ВТ_Выгру КАК ВТ_Выгру";
	
	Запрос.Текст=СтрЗаменить(Запрос.Текст,"%РазмерПакета%",Формат(РазмерПакета,"ЧГ=0"));
	Запрос.УстановитьПараметр("Узел", УзелОбмена);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Тз = РезультатЗапроса.Выгрузить();
	
	
	Возврат Тз.ВыгрузитьКолонку("Ссылка");


КонецФункции

Функция СформироватьНаборЗаписейКОбмену(УзелОбмена,РазмерПакета)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ШтрихкодыНоменклатурыИзменения.Штрихкод КАК Штрихкод
		|ПОМЕСТИТЬ ВТ_Выгру
		|ИЗ
		|	РегистрСведений.ШтрихкодыНоменклатуры.Изменения КАК ШтрихкодыНоменклатурыИзменения
		|ГДЕ
		|	ШтрихкодыНоменклатурыИзменения.Узел = &Узел
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ ПЕРВЫЕ %РазмерПакета%
		|	ВТ_Выгру.Штрихкод КАК Штрихкод
		|ИЗ
		|	ВТ_Выгру КАК ВТ_Выгру";
	
	Запрос.Текст=СтрЗаменить(Запрос.Текст,"%РазмерПакета%",Формат(РазмерПакета,"ЧГ=0"));
	Запрос.УстановитьПараметр("Узел", УзелОбмена);
	
	Выборка = Запрос.Выполнить().Выбрать();
	МассивНабораЗаписей = Новый Массив;
	Пока Выборка.Следующий() Цикл
		НаборЗаписей = РегистрыСведений.ШтрихкодыНоменклатуры.СоздатьНаборЗаписей();
		
		НаборЗаписей.Отбор.Штрихкод.Установить(Выборка.Штрихкод); 
		
		МассивНабораЗаписей.Добавить(НаборЗаписей);
	КонецЦикла;
	
	
	Возврат МассивНабораЗаписей;

КонецФункции

Функция СформироватьПакетОбмена(УзелОбмена,РазмерПакета) Экспорт
	
	ЗаписьXML = Новый ЗаписьXML;
	ЗаписьXML.УстановитьСтроку("UTF-8");	
	ЗаписьXML.ЗаписатьОбъявлениеXML();
	
	ЗаписьСообщения = ПланыОбмена.СоздатьЗаписьСообщения();	
	ЗаписьСообщения.НачатьЗапись(ЗаписьXML, УзелОбмена);
	ЗаписьXML.ЗаписатьСоответствиеПространстваИмен("xsi", "http://www.w3.org/2001/XMLSchema-instance");	
	ЗаписьXML.ЗаписатьСоответствиеПространстваИмен("v8", "http://v8.1c.ru/data");
	ФильтрВыборки=СформироватьМассивСсылокКОбмену(УзелОбмена,РазмерПакета);
	
	Если ФильтрВыборки.Количество() = 0 Тогда
		ФильтрВыборки = СформироватьНаборЗаписейКОбмену(УзелОбмена,РазмерПакета);
	КонецЕсли;
	ВыборкаИзменений = ПланыОбмена.ВыбратьИзменения(УзелОбмена, ЗаписьСообщения.НомерСообщения,ФильтрВыборки);
	
	Пока ВыборкаИзменений.Следующий() Цикл		
		Данные = ВыборкаИзменений.Получить();
		// Если перенос данных не нужен, то, возможно, необходимо записать удаление данных.	
		Если Не НуженПереносДанных(Данные, УзелОбмена) Тогда
			// Получаем значение с возможным удалением данных.			
			УдалениеДанных(Данные);
		КонецЕсли;		
		// Записываем данные в сообщение	
		ЗаписатьДанные(ЗаписьXML, Данные, УзелОбмена);   
	КонецЦикла;
	ЗаписьСообщения.ЗакончитьЗапись();
	ЗакрытаяЗапись = ЗаписьXML.Закрыть();    	
	Возврат Новый ХранилищеЗначения(ЗакрытаяЗапись, Новый СжатиеДанных(9));	
КонецФункции

Функция НуженПереносДанных(Данные, УзелОбмена) Экспорт	
	Перенос = Истина;
	
	Если ТипЗнч(Данные) = Тип("СправочникОбъект.Пользователи") Тогда		
		Если Не УзелОбмена.Пользователь.Пустая() И Данные.Ссылка <> УзелОбмена.Пользователь Тогда			
			Перенос = Ложь;		
		КонецЕсли;		
	ИначеЕсли ТипЗнч(Данные) = Тип("СправочникОбъект.СкладскиеЯчейки") Тогда
		Если Данные.ТипСкладскойЯчейки <> Перечисления.ТипыСкладскихЯчеек.Приемка 
			и Данные.ТипСкладскойЯчейки <> Перечисления.ТипыСкладскихЯчеек.Хранение  Тогда 
			Перенос = Ложь;	
		КонецЕсли; 
	ИначеЕсли ТипЗнч(Данные) = Тип("СправочникОбъект.Номенклатура") и НЕ Константы.ЗагружатьВсюНоменклатуруВТСД.Получить() Тогда
		УдалитьНоменклатуруНаУзле=НЕ РегистрыСведений.НоменклатураЗагруженнаяНаТСД.НоменклатураЗагружаетсяНаУзел(Данные.Ссылка,УзелОбмена); 
		Если УдалитьНоменклатуруНаУзле Тогда
			Данные=Новый УдалениеОбъекта(Данные.Ссылка);
		КонецЕсли;
		Перенос = Истина;
	ИначеЕсли ТипЗнч(Данные) = Тип("ДокументОбъект.ЗаказКлиента") 
		  ИЛИ ТипЗнч(Данные) = Тип("ДокументОбъект.рар_мп_РеестрЗаказов") Тогда 
		   
		Если Данные.рар_мп_СтатусДокументаВТСД = Перечисления.рар_мп_СтатусыДокументовВТСД.ВРаботе
			И Данные.рар_мп_ПользовательТСД <> УзелОбмена.Пользователь Тогда
			Возврат Ложь;   
		ИначеЕсли Данные.рар_мп_СтатусДокументаВТСД = Перечисления.рар_мп_СтатусыДокументовВТСД.Завершен Тогда 
			Возврат Ложь;
		КонецЕсли;
	КонецЕсли;
	
	Возврат Перенос;	
КонецФункции

Процедура УдалениеДанных(Данные) Экспорт
	// Получаем объект описания метаданного, соответствующий данным.
	ОбъектМетаданных = ?(ТипЗнч(Данные) = Тип("УдалениеОбъекта"), Данные.Ссылка.Метаданные(), Данные.Метаданные());
	Если Метаданные.Справочники.Содержит(ОбъектМетаданных) ИЛИ Метаданные.Документы.Содержит(ОбъектМетаданных) Тогда
		// Перенос удаления объекта для объектных.
		Данные = Новый УдалениеОбъекта(Данные.Ссылка);
	ИначеЕсли Метаданные.РегистрыСведений.Содержит(ОбъектМетаданных) Тогда		
		// Очищаем данные.
		Данные.Очистить();
	КонецЕсли;
КонецПроцедуры

Процедура ЗаписатьДанные(ЗаписьXML, Данные, УзелОбмена) Экспорт

	Если ТипЗнч(Данные) = Тип("СправочникОбъект.Пользователи") Тогда
		ЗаписатьXMLПользователь(ЗаписьXML, Данные);
	ИначеЕсли ТипЗнч(Данные) = Тип("СправочникОбъект.УпаковкиЕдиницыИзмерения")  Тогда
		ЗаписатьXMLЕдИзм(ЗаписьXML, Данные);
	ИначеЕсли ТипЗнч(Данные) = Тип("СправочникОбъект.Склады") Тогда
		ЗаписатьXMLСклады(ЗаписьXML, Данные);
	ИначеЕсли ТипЗнч(Данные) = Тип("СправочникОбъект.Организации") Тогда
		ЗаписатьXMLОрганизации(ЗаписьXML, Данные);
	ИначеЕсли ТипЗнч(Данные) = Тип("СправочникОбъект.ВидыНоменклатуры") Тогда
		ЗаписатьXMLВидыНоменклатуры(ЗаписьXML, Данные);
	ИначеЕсли ТипЗнч(Данные) = Тип("СправочникОбъект.СкладскиеЯчейки") Тогда
		ЗаписатьXMLСкладскиеЯчейки(ЗаписьXML, Данные);
	ИначеЕсли ТипЗнч(Данные) = Тип("СправочникОбъект.СкладскиеПомещения") Тогда
		ЗаписатьXMLСкладскиеПомещения(ЗаписьXML, Данные); 
	ИначеЕсли ТипЗнч(Данные) = Тип("СправочникОбъект.Номенклатура") Тогда
		ЗаписатьXMLНоменклатура(ЗаписьXML, Данные);
	ИначеЕсли ТипЗнч(Данные) = Тип("СправочникОбъект.ХарактеристикиНоменклатуры") Тогда
		ЗаписатьXMLХарактеристикаНоменклатуры(ЗаписьXML, Данные);
	ИначеЕсли ТипЗнч(Данные) = Тип("СправочникОбъект.СерииНоменклатуры") Тогда
		ЗаписатьXMLСерию(ЗаписьXML, Данные);
	ИначеЕсли ТипЗнч(Данные) = Тип("УдалениеОбъекта") 
		и ТипЗнч(Данные.Ссылка) = Тип("СправочникСсылка.Номенклатура") Тогда
		ЗаписатьXMLНоменклатураУдаление(ЗаписьXML, Данные.Ссылка);
	ИначеЕсли ТипЗнч(Данные) = Тип("ДокументОбъект.ЗаказКлиента") Тогда
		ЗаписатьXMLЗаказКлиента(ЗаписьXML, Данные, УзелОбмена.Пользователь); 
	ИначеЕсли ТипЗнч(Данные) = Тип("ДокументОбъект.рар_мп_РеестрЗаказов") Тогда
		ЗаписатьXMLРеестрЗаказов(ЗаписьXML, Данные, УзелОбмена.Пользователь); 
	ИначеЕсли ТипЗнч(Данные) = Тип("СправочникОбъект.ШтрихкодыУпаковокТоваров") Тогда
		ЗаписатьXMLШтрихкодыУпаковокТоваров(ЗаписьXML, Данные);  
	Иначе                       
		//Записываем данные с помощью стандартного метода.
		ЗаписатьXML(ЗаписьXML, Данные);
	КонецЕсли
КонецПроцедуры

#Область ЗаписьДанных
Процедура ЗаписатьXMLПользователь(ЗаписьXML, Пользователь)Экспорт
	ЗаписьXML.ЗаписатьНачалоЭлемента("CatalogObject.Пользователь.Вручную");
	
	ЗаписатьXML(ЗаписьXML, Пользователь.Ссылка, "Ref", НазначениеТипаXML.Явное);
	ЗаписатьXML(ЗаписьXML, Пользователь.Код, "Code", НазначениеТипаXML.Явное);
	ЗаписатьXML(ЗаписьXML, Пользователь.Наименование, "Description", НазначениеТипаXML.Явное);
	
	ЗаписьXML.ЗаписатьКонецЭлемента();
КонецПроцедуры

Процедура ЗаписатьXMLСклады(ЗаписьXML, Склады)Экспорт
	ЗаписьXML.ЗаписатьНачалоЭлемента("CatalogObject.Склады.Вручную");
	
	ЗаписатьXML(ЗаписьXML, Склады.Ссылка, "Ref", НазначениеТипаXML.Явное);
	ЗаписатьXML(ЗаписьXML, Склады.ЭтоГруппа, "IsGroup", НазначениеТипаXML.Явное);	
	ЗаписатьXML(ЗаписьXML, Склады.Наименование, "Description", НазначениеТипаXML.Явное);
	ЗаписатьXML(ЗаписьXML, Склады.Родитель, "Parent", НазначениеТипаXML.Явное);
	
	Если НЕ Склады.ЭтоГруппа Тогда		
		ЗаписатьXML(ЗаписьXML, Склады.ИспользоватьОрдернуюСхемуПриОтгрузке, "ИспользоватьОрдернуюСхемуПриОтгрузке", НазначениеТипаXML.Явное);
		ЗаписатьXML(ЗаписьXML, Склады.ИспользоватьОрдернуюСхемуПриОтраженииИзлишковНедостач, "ИспользоватьОрдернуюСхемуПриОтраженииИзлишковНедостач", НазначениеТипаXML.Явное); 
		ЗаписатьXML(ЗаписьXML, Склады.ИспользоватьОрдернуюСхемуПриПоступлении, "ИспользоватьОрдернуюСхемуПриПоступлении", НазначениеТипаXML.Явное);
		ЗаписатьXML(ЗаписьXML, Склады.ИспользоватьСкладскиеПомещения, "ИспользоватьСкладскиеПомещения", НазначениеТипаXML.Явное);
	КонецЕсли;	
		
	ЗаписьXML.ЗаписатьКонецЭлемента();
КонецПроцедуры

Процедура ЗаписатьXMLВидыНоменклатуры(ЗаписьXML, ВидыНоменклатуры) Экспорт
	ЗаписьXML.ЗаписатьНачалоЭлемента("CatalogObject.ВидыНоменклатуры.Вручную");
	
	ЗаписатьXML(ЗаписьXML, ВидыНоменклатуры.Ссылка, "Ref", НазначениеТипаXML.Явное);
	ЗаписатьXML(ЗаписьXML, ВидыНоменклатуры.ЭтоГруппа, "IsGroup", НазначениеТипаXML.Явное);	
	ЗаписатьXML(ЗаписьXML, ВидыНоменклатуры.Наименование, "Description", НазначениеТипаXML.Явное);
	ЗаписатьXML(ЗаписьXML, ВидыНоменклатуры.Родитель, "Parent", НазначениеТипаXML.Явное);
	Если НЕ ВидыНоменклатуры.ЭтоГруппа Тогда
		ЗаписатьXML(ЗаписьXML, ВидыНоменклатуры.ИспользоватьСерии, "ИспользоватьСерии", НазначениеТипаXML.Явное);
		ЗаписатьXML(ЗаписьXML, ВидыНоменклатуры.ИспользоватьХарактеристики, "ИспользоватьХарактеристики", НазначениеТипаXML.Явное);
		ЗаписатьXML(ЗаписьXML, ВидыНоменклатуры.ИспользованиеХарактеристик, "ИспользованиеХарактеристик", НазначениеТипаXML.Явное);
		ЗаписатьXML(ЗаписьXML, ВидыНоменклатуры.ВладелецХарактеристик, "ВладелецХарактеристик", НазначениеТипаXML.Явное);
	КонецЕсли;
	ЗаписьXML.ЗаписатьКонецЭлемента();
КонецПроцедуры

Процедура ЗаписатьXMLЕдИзм(ЗаписьXML, УпаковкиЕдиницыИзмерения) Экспорт
	ЗаписьXML.ЗаписатьНачалоЭлемента("CatalogObject.УпаковкиЕдиницыИзмерения.Вручную");
	
	СтруктураРеквизитов=РаботаСоСправочниками.ПолучитьСтруктуруУпаковки(УпаковкиЕдиницыИзмерения.Ссылка);
	
	РаботаСоСправочниками.СтруктуруВЗаписьXML(ЗаписьXML,СтруктураРеквизитов);
	
	ЗаписьXML.ЗаписатьКонецЭлемента();
КонецПроцедуры

Процедура ЗаписатьXMLОрганизации(ЗаписьXML, Организации)Экспорт
	ЗаписьXML.ЗаписатьНачалоЭлемента("CatalogObject.Организации.Вручную");
	
	ЗаписатьXML(ЗаписьXML, Организации.Ссылка, "Ref", НазначениеТипаXML.Явное);
	ЗаписатьXML(ЗаписьXML, Организации.Наименование, "Description", НазначениеТипаXML.Явное);
	
	ЗаписьXML.ЗаписатьКонецЭлемента();
КонецПроцедуры

Процедура ЗаписатьXMLСкладскиеЯчейки(ЗаписьXML, СкладскиеЯчейки) Экспорт
	ЗаписьXML.ЗаписатьНачалоЭлемента("CatalogObject.СкладскиеЯчейки.Вручную");
	
	ЗаписатьXML(ЗаписьXML, СкладскиеЯчейки.Ссылка, "Ref", НазначениеТипаXML.Явное);
	ЗаписатьXML(ЗаписьXML, СкладскиеЯчейки.ЭтоГруппа, "IsGroup", НазначениеТипаXML.Явное);
	ЗаписатьXML(ЗаписьXML, СкладскиеЯчейки.Владелец, "Owner", НазначениеТипаXML.Явное);
	ЗаписатьXML(ЗаписьXML, СкладскиеЯчейки.Код, "Code", НазначениеТипаXML.Явное);
	ЗаписатьXML(ЗаписьXML, СкладскиеЯчейки.Наименование, "Description", НазначениеТипаXML.Явное);
	ЗаписатьXML(ЗаписьXML, СкладскиеЯчейки.Родитель, "Parent", НазначениеТипаXML.Явное);	
	ЗаписатьXML(ЗаписьXML, СкладскиеЯчейки.Помещение, "Premise", НазначениеТипаXML.Явное);
	ЗаписатьXML(ЗаписьXML, РаботаСШтрихкодами.ПолучитьШК(СкладскиеЯчейки.Ссылка), "Штрихкод", НазначениеТипаXML.Явное);

	ЗаписьXML.ЗаписатьКонецЭлемента();
КонецПроцедуры

Процедура ЗаписатьXMLСкладскиеПомещения(ЗаписьXML, СкладскиеПомещения) Экспорт
	ЗаписьXML.ЗаписатьНачалоЭлемента("CatalogObject.СкладскиеПомещения.Вручную");
	
