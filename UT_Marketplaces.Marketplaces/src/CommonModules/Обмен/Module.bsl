Функция ПринятьИзменения(Отправитель, Данные) Экспорт
	Прием = Истина;
	Возврат Прием;
КонецФункции

Процедура РегистрацияДокументовКОбменуПередЗаписью(Источник, Отказ, РежимЗаписи, РежимПроведения) Экспорт
	Если Источник.ЭтоНовый() Тогда   
		НовыйГУИД  = Новый УникальныйИдентификатор();
		НоваяСсылка = Документы[Источник.Метаданные().Имя].ПолучитьСсылку(НовыйГУИД);
		Источник.УстановитьСсылкуНового(НоваяСсылка); 
	ИНаче
		НоваяСсылка = Источник.Ссылка;
	КонецЕсли;
	
	Если ТипЗнч(Источник) = Тип("ДокументОбъект.ЗаказКлиента") ИЛИ ТипЗнч(Источник) = Тип("ДокументОбъект.рар_мп_РеестрЗаказов") Тогда
		Если Источник.рар_мп_СтатусДокументаВТСД = Перечисления.рар_мп_СтатусыДокументовВТСД.Новый 
			ИЛИ Источник.ДополнительныеСвойства.Свойство("ЗарегистрироватьДокументКОбменуНаТСД") Тогда
			МассивУзлов = СформироватьМассивУзловДляРегистрации();
			ПланыОбмена.ЗарегистрироватьИзменения(МассивУзлов, НоваяСсылка);
		ИначеЕсли Источник.рар_мп_СтатусДокументаВТСД = Перечисления.рар_мп_СтатусыДокументовВТСД.ВРаботе Тогда
			Если Источник.ДополнительныеСвойства.Свойство("ВзятиеДокументаВРаботуИзТСД") Тогда 
				МассивУзлов = СформироватьМассивУзловДляРегистрацииЗаИсключениемПользователя(Источник.рар_мп_ПользовательТСД);
				ПланыОбмена.ЗарегистрироватьИзменения(МассивУзлов, НоваяСсылка); 
			Иначе
				МассивУзлов = СформироватьМассивУзловДляРегистрации();
				ПланыОбмена.ЗарегистрироватьИзменения(МассивУзлов, НоваяСсылка);
			КонецЕсли;
		ИначеЕсли Источник.рар_мп_СтатусДокументаВТСД = Перечисления.рар_мп_СтатусыДокументовВТСД.Завершен Тогда 
			Если Источник.ДополнительныеСвойства.Свойство("ЗвершениеДокументаИзТСД") Тогда
				МассивУзлов = СформироватьМассивУзловДляРегистрацииЗаИсключениемПользователя(Источник.рар_мп_ПользовательТСД);
				ПланыОбмена.ЗарегистрироватьИзменения(МассивУзлов, НоваяСсылка);
			Иначе
				МассивУзлов = СформироватьМассивУзловДляРегистрации();
				ПланыОбмена.ЗарегистрироватьИзменения(МассивУзлов, НоваяСсылка);
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры
#КонецОбласти