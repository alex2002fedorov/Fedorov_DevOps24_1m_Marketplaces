КонецПроцедуры

Функция ХешироватьПароль(Пароль) Экспорт
	Хеш = Новый ХешированиеДанных(ХешФункция.SHA1);
    Хеш.Добавить(Пароль);
    Возврат Base64Строка(Хеш.ХешСумма);	
КонецФункции

Функция ЭтоЗначениеПримитивногоТипа(Значение) Экспорт 
	Возврат ЭтоПримитивныйТип(ТипЗнч(Значение));
КонецФункции

Функция ЭтоПримитивныйТип(ПроверяемыйТип)
	Если ПроверяемыйТип = Тип("Неопределено")
		Или ПроверяемыйТип = Тип("Булево")
		Или ПроверяемыйТип = Тип("Строка")
		Или ПроверяемыйТип = Тип("Число")
		Или ПроверяемыйТип = Тип("Дата") Тогда
		Возврат Истина;
	Иначе
		Возврат Ложь;
	КонецЕсли;
КонецФункции

//Если не надет, то создает нового пользователя
Функция ПолучитьМобильногоПользователя(Логин, Наименование) Экспорт 
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	МобильныеПользователи.Ссылка КАК Ссылка
		|ИЗ
		|	Справочник.МобильныеПользователи КАК МобильныеПользователи
		|ГДЕ
		|	МобильныеПользователи.Код = &Код";
	
	Запрос.УстановитьПараметр("Код", Логин);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Выборка = РезультатЗапроса.Выбрать();
	
	Если Выборка.Следующий() Тогда
		Возврат Выборка.Ссылка;
	Иначе
		НовыйПользователь = Справочники.МобильныеПользователи.СоздатьЭлемент();
		НовыйПользователь.Код = Логин;
		НовыйПользователь.Наименование = Наименование;
		НовыйПользователь.ДатаРегистрации = ТекущаяДата();
		НовыйПользователь.Логин = Логин;
		НовыйПользователь.Записать();
		Возврат НовыйПользователь.Ссылка;
	КонецЕсли;
КонецФункции

