
#Область ЯндексМаркет

Процедура ЯндексМаркет_ЗагрузкаЗаказов() Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ЗаказКлиента.Ссылка КАК Ссылка,
		|	ЗаказКлиента.НомерПоДаннымКлиента КАК НомерПоДаннымКлиента,
		|	ЗаказКлиента.рар_мп_АккаунтМаркетплейса КАК АккаунтМаркетплейса
		|ИЗ
		|	Документ.ЗаказКлиента КАК ЗаказКлиента
		|ГДЕ
		|	ЗаказКлиента.рар_мп_АккаунтМаркетплейса.Маркетплейс = ЗНАЧЕНИЕ(Перечисление.рар_мп_Маркетплейсы.ЯндексМаркет)";
	
	РезультатЗапроса = Запрос.Выполнить();
	
	СозданныеЗаказыКлиентов = РезультатЗапроса.Выгрузить();
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	рар_мп_ВидыНоменклатурыДляУчетаЧестногоЗнака.Аккаунт КАК Аккаунт,
		|	рар_мп_ВидыНоменклатурыДляУчетаЧестногоЗнака.ВидНоменклатуры КАК ВидНоменклатуры
		|ИЗ
		|	РегистрСведений.рар_мп_ВидыНоменклатурыДляУчетаЧестногоЗнака КАК рар_мп_ВидыНоменклатурыДляУчетаЧестногоЗнака
		|ГДЕ
		|	рар_мп_ВидыНоменклатурыДляУчетаЧестногоЗнака.Аккаунт.ПометкаУдаления = ЛОЖЬ
		|	И рар_мп_ВидыНоменклатурыДляУчетаЧестногоЗнака.Аккаунт.Маркетплейс = ЗНАЧЕНИЕ(Перечисление.рар_мп_Маркетплейсы.ЯндексМаркет)
		|	И рар_мп_ВидыНоменклатурыДляУчетаЧестногоЗнака.Аккаунт.АктивныйАккаунт = ИСТИНА
		|	И рар_мп_ВидыНоменклатурыДляУчетаЧестногоЗнака.Аккаунт.СхемаРаботы = ЗНАЧЕНИЕ(Перечисление.рар_мп_СхемыРаботы.FBS)";
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВидыНоменклатурыДляЧестногоЗнака = РезультатЗапроса.Выгрузить();
		
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	рар_мп_СопоставленныеСклады.АккаунтМаркетплейса КАК АккаунтМаркетплейса,
		|	рар_мп_СопоставленныеСклады.УникальныйИдентификаторСклада КАК УникальныйИдентификаторСклада,
		|	рар_мп_СопоставленныеСклады.Склад КАК Склад,
		|	рар_мп_СопоставленныеСклады.АккаунтМаркетплейса.Наименование КАК АккаунтМаркетплейсаНаименование,
		|	рар_мп_СопоставленныеСклады.рар_мп_ЯМ_campaignId КАК рар_мп_ЯМ_campaignId
		|ИЗ
		|	РегистрСведений.рар_мп_СопоставленныеСклады КАК рар_мп_СопоставленныеСклады
		|ГДЕ
		|	рар_мп_СопоставленныеСклады.АккаунтМаркетплейса.АктивныйАккаунт = ИСТИНА
		|	И рар_мп_СопоставленныеСклады.АккаунтМаркетплейса.Маркетплейс = ЗНАЧЕНИЕ(Перечисление.рар_мп_Маркетплейсы.ЯндексМаркет)
		|	И рар_мп_СопоставленныеСклады.АккаунтМаркетплейса.ПометкаУдаления = ЛОЖЬ
		|	И рар_мп_СопоставленныеСклады.Склад.ПометкаУдаления = ЛОЖЬ
		|	И рар_мп_СопоставленныеСклады.АккаунтМаркетплейса.СхемаРаботы = ЗНАЧЕНИЕ(Перечисление.рар_мп_СхемыРаботы.FBS)
		|
		|УПОРЯДОЧИТЬ ПО
		|	АккаунтМаркетплейса,
		|	УникальныйИдентификаторСклада";
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл 
		
		СледующаяСтраница = "";
		
		HTTPОтвет = рар_мп_ЯндексМаркет_Методы.Метод_ИнформацияОНесколькихЗаказах(ВыборкаДетальныеЗаписи.АккаунтМаркетплейса, 
					ВыборкаДетальныеЗаписи.рар_мп_ЯМ_campaignId, СледующаяСтраница);
					
		Если HTTPОтвет.Свойство("ОтветAPI") Тогда 
						
			Если HTTPОтвет.КодСостояния <> 200 Тогда
							
				НазваниеОшибки = "Ошибка при получении заказов из Яндекс Маркета";
				
				ОписаниеОшибки = HTTPОтвет.ОтветAPI.errors.Получить(0).message;
				
				Комментарий = СтрШаблон("Маркетплейс: Яндекс Маркет%1Аккаунт: %2%1Код состояния: %3%1Описание ошибки: %4", 
										Символы.ПС, ВыборкаДетальныеЗаписи.АккаунтМаркетплейсаНаименование, HTTPОтвет.КодСостояния, ОписаниеОшибки);
				
				ЗаписьЖурналаРегистрации(НазваниеОшибки,УровеньЖурналаРегистрации.Ошибка,,,Комментарий,);
			
			Иначе
				
				Если HTTPОтвет.ОтветAPI.Свойство("paging") Тогда
							
					Если HTTPОтвет.ОтветAPI.paging.Свойство("nextPageToken") Тогда
					
						СледующаяСтраница = HTTPОтвет.ОтветAPI.paging.nextPageToken;	
					
					Иначе
					
						СледующаяСтраница = "";	
					
					КонецЕсли;
				
				Иначе
					
					СледующаяСтраница = "";	
					
				КонецЕсли;
				
				Заказы = HTTPОтвет.ОтветAPI.orders;
				
				ЯндексМаркет_СозданиеЗаказов(Заказы, ВыборкаДетальныеЗаписи.АккаунтМаркетплейса, ВыборкаДетальныеЗаписи.Склад, 
											 ВыборкаДетальныеЗаписи.рар_мп_ЯМ_campaignId, СозданныеЗаказыКлиентов, ВидыНоменклатурыДляЧестногоЗнака);
											 
				Пока СледующаяСтраница <> "" Цикл
												 
					HTTPОтвет = рар_мп_ЯндексМаркет_Методы.Метод_ИнформацияОНесколькихЗаказах(ВыборкаДетальныеЗаписи.АккаунтМаркетплейса, 
						ВыборкаДетальныеЗаписи.рар_мп_ЯМ_campaignId, СледующаяСтраница);
						
					Если HTTPОтвет.Свойство("ОтветAPI") Тогда
							
						Если HTTPОтвет.КодСостояния <> 200 Тогда
								
							НазваниеОшибки = "Ошибка при получении заказов из Яндекс Маркета";
							
							ОписаниеОшибки = HTTPОтвет.ОтветAPI.errors.Получить(0).message;
							
							Комментарий = СтрШаблон("Маркетплейс: Яндекс Маркет%1Аккаунт: %2%1Код состояния: %3%1Описание ошибки: %4", 
													Символы.ПС, ВыборкаДетальныеЗаписи.АккаунтМаркетплейсаНаименование, HTTPОтвет.КодСостояния, ОписаниеОшибки);
							
							ЗаписьЖурналаРегистрации(НазваниеОшибки,УровеньЖурналаРегистрации.Ошибка,,,Комментарий,);
							
							Прервать;
							
						Иначе
							
							Если HTTPОтвет.ОтветAPI.Свойство("paging") Тогда
								
								Если HTTPОтвет.ОтветAPI.paging.Свойство("nextPageToken") Тогда
								
									СледующаяСтраница = HTTPОтвет.ОтветAPI.paging.nextPageToken;	
								
								Иначе
								
									СледующаяСтраница = "";	
								
								КонецЕсли;
							
							Иначе
								
								СледующаяСтраница = "";	
								
							КонецЕсли;
							
							Заказы = HTTPОтвет.ОтветAPI.orders;
					
							ЯндексМаркет_СозданиеЗаказов(Заказы, ВыборкаДетальныеЗаписи.АккаунтМаркетплейса, ВыборкаДетальныеЗаписи.Склад, 
														ВыборкаДетальныеЗаписи.рар_мп_ЯМ_campaignId, СозданныеЗаказыКлиентов, ВидыНоменклатурыДляЧестногоЗнака);
														 
						КонецЕсли;
						
					Иначе
						
						Комментарий = "Ошибка при получении JSON. Некорректные значения JSON";
			
						ЗаписьЖурналаРегистрации("Ошибка при получении загрузке заказов", УровеньЖурналаРегистрации.Ошибка,,,
												 СтрШаблон("Аккаунт: %3. Код запроса:%1. Описание ошибки:%2", HTTPОтвет.КодСостояния, Комментарий, ВыборкаДетальныеЗаписи.АккаунтМаркетплейса),);
						
					КонецЕсли;
				КонецЦикла;							 
				
			КонецЕсли;
			
		Иначе
			
			Комментарий = "Ошибка при получении JSON. Некорректные значения JSON";
			
			ЗаписьЖурналаРегистрации("Ошибка при получении загрузке заказов", УровеньЖурналаРегистрации.Ошибка,,,
									 СтрШаблон("Аккаунт: %3. Код запроса:%1. Описание ошибки:%2", HTTPОтвет.КодСостояния, Комментарий, ВыборкаДетальныеЗаписи.АккаунтМаркетплейса),);
	
		КонецЕсли;
				
	КонецЦикла;
	

КонецПроцедуры

Процедура ЯндексМаркет_СозданиеЗаказов(Заказы, Аккаунт, Склад, УникальныйИдентификаторСклада, СозданныеЗаказыКлиентов, ВидыНоменклатурыДляЧестногоЗнака)

	Для каждого Заказ Из Заказы Цикл
		
		Номер = Строка(Формат(Заказ.id,"ЧГ=0"));
		
		НайденныеСтроки = СозданныеЗаказыКлиентов.НайтиСтроки(Новый Структура("НомерПоДаннымКлиента, АккаунтМаркетплейса", Номер, Аккаунт));
		
		Если НайденныеСтроки.Количество() = 0 Тогда
		
			Если Заказ.status = "PROCESSING" И Заказ.substatus = "STARTED" Тогда
				
				Попытка
				
					Документ = Документы.ЗаказКлиента.СоздатьДокумент(); 
					
					//Заполнение данными из 1с
					Документ.Статус 			   				  = Аккаунт.СтатусЗаказа;
					Документ.Приоритет 			   				  = Аккаунт.Приоритет;
					Документ.ХозяйственнаяОперация 				  = Аккаунт.Операция;
					Документ.Организация		   				  = Аккаунт.Организация;
					Документ.Договор 			  				  = Аккаунт.Договор;
					Документ.Склад    			   				  = Склад;
					Документ.Контрагент 		   				  = Аккаунт.Контрагент;
					Документ.Партнер       		   				  = Аккаунт.Партнер;
					Документ.Соглашение 		   				  = Аккаунт.Соглашение;
					Документ.Валюта 			   				  = Аккаунт.Валюта;
					Документ.НеОтгружатьЧастями    				  = Истина;
					Документ.рар_мп_АккаунтМаркетплейса 		  = Аккаунт;
					Документ.рар_мп_УникальныйИдентификаторСклада = УникальныйИдентификаторСклада;
					Документ.Дата								  = ПреобразоватьСтрокуВДату(Заказ.creationDate);
					Документ.рар_мп_СтатусДокументаВТСД			  = Перечисления.рар_мп_СтатусыДокументовВТСД.Новый;
					
					Если Документ.Соглашение <> Справочники.СоглашенияСКлиентами.ПустаяСсылка() Тогда
					
						Документ.КонтактноеЛицо = Аккаунт.Соглашение.КонтактноеЛицо;
						Документ.Менеджер       = Аккаунт.Соглашение.Менеджер;
						
					ИначеЕсли Документ.Договор <> Справочники.ДоговорыКонтрагентов.ПустаяСсылка() Тогда
						
						Документ.КонтактноеЛицо = Аккаунт.Договор.КонтактноеЛицо;
						Документ.Менеджер 		= Аккаунт.Договор.Менеджер;
						
					КонецЕсли; 
					
					Документ.Подразделение 		= Аккаунт.Подразделение;
					Документ.СпособДоставки 	= Перечисления.СпособыДоставки.Самовывоз;
					Документ.НалогообложениеНДС = Аккаунт.НалогообложениеНДС;
					Документ.ЦенаВключаетНДС    = Аккаунт.ЦенаВключаетНДС;
					Документ.Автор 				= ПользователиКлиентСервер.ТекущийПользователь();
					
					//Заполнение данными из маркетплейса
					Документ.рар_мп_ЯндексМаркет_СтатусЗаказа 	 = Перечисления.рар_мп_ЯндексМаркет_СтатусыЗаказов[Заказ.status];
					Документ.рар_мп_ЯндексМаркет_ПодстатусЗаказа = Перечисления.рар_мп_ЯндексМаркет_ПодстатусыЗаказов[Заказ.substatus];
					Документ.НомерПоДаннымКлиента				 = Номер;
					Документ.ДатаПоДаннымКлиента				 = Документ.Дата;
					
					ДатаОтгрузки = Заказ.delivery.shipments.Получить(0).shipmentDate;
					Документ.ДатаОтгрузки = Дата(Прав(ДатаОтгрузки, 4), Сред(ДатаОтгрузки, 4, 2), Лев(ДатаОтгрузки, 2));
					
					Товары = Заказ.items;
					
					ОтказЗаписи = Ложь;
					
					Если Заказ.Свойство("notes") Тогда
					
						Документ.Комментарий = Заказ.notes;
						
					КонецЕсли;
					
					Для каждого Товар Из Товары Цикл
						
						СтрокаДокумента = Документ.Товары.Добавить();
						
						НаборЗаписей = РегистрыСведений.рар_мп_ЯндексМаркет_СопоставленныеТовары.СоздатьНаборЗаписей();
						НаборЗаписей.Отбор.Аккаунт.Установить(Аккаунт);
						НаборЗаписей.Отбор.SKUТовара.Установить(Товар.offerId);
							
						НаборЗаписей.Прочитать();
						
						Если НаборЗаписей.Количество() > 0 Тогда 
							
							Запись = НаборЗаписей.Получить(0);
							
							СтрокаДокумента.Номенклатура   	   = Запись.Номенклатура;
							СтрокаДокумента.Характеристика 	   = Запись.Характеристика;
							СтрокаДокумента.ВариантОбеспечения = Аккаунт.ВариантОбеспечения;
							СтрокаДокумента.ДатаОтгрузки   	   = Документ.ДатаОтгрузки;
							СтрокаДокумента.Упаковка	   	   = Запись.Упаковка;
							СтрокаДокумента.КоличествоУпаковок = Число(Товар.count);
							СтрокаДокумента.Количество		   = СтрокаДокумента.КоличествоУпаковок * Справочники.УпаковкиЕдиницыИзмерения.КоэффициентУпаковки(СтрокаДокумента.Упаковка, СтрокаДокумента.Номенклатура);
							СтрокаДокумента.Склад			   = Склад;
							
							СуммаСубстатусов = 0;
							Если Товар.Свойство("subsidies") Тогда
							
								Для каждого Субстатус Из Товар.subsidies Цикл
								
									СуммаСубстатусов = СуммаСубстатусов + Субстатус.amount;		
								
								КонецЦикла;	
							
							КонецЕсли;
							
							Если СуммаСубстатусов <> 0 Тогда
								
								СтрокаДокумента.Цена = Товар.price + (СуммаСубстатусов  / СтрокаДокумента.КоличествоУпаковок);
								
								СтрокаДокумента.Сумма = СтрокаДокумента.КоличествоУпаковок * Товар.price + СуммаСубстатусов;
								
							Иначе
								
								СтрокаДокумента.Цена = Товар.price;
								
								СтрокаДокумента.Сумма = СтрокаДокумента.КоличествоУпаковок * Товар.price;
								
							КонецЕсли;
							
							СтавкаНДС = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Запись.Номенклатура, "СтавкаНДС");
							
							СтрокаДокумента.СтавкаНДС = СтавкаНДС;
							
							СтруктураПересчетаСуммы = Новый Структура;
							СтруктураПересчетаСуммы.Вставить("ЦенаВключаетНДС", Документ.ЦенаВключаетНДС);
							СтруктураПересчетаСуммы.Вставить("НалогообложениеНДС", Документ.НалогообложениеНДС);
							
							СтруктураДействий = Новый Структура;
							СтруктураДействий.Вставить("ПересчитатьСуммуНДС", СтруктураПересчетаСуммы);
							СтруктураДействий.Вставить("ПересчитатьСуммуСНДС", СтруктураПересчетаСуммы);
								
							КэшированныеЗначения = Неопределено;
									
							ПакетнаяОбработкаТабличнойЧастиКлиентСервер.ОбработатьСтрокуТЧ(СтрокаДокумента, СтруктураДействий, КэшированныеЗначения);
							
							//Заполнение ТЧ с маркировками
							Для Счетчик = 1 По СтрокаДокумента.Количество Цикл 
						
								СтрокаТоварыКРаспределению = Документ.рар_мп_ТоварыДляМаркировки.Добавить();
								
								СтрокаТоварыКРаспределению.рар_мп_СтрокаИзТЧТовары = Документ.Товары.Индекс(СтрокаДокумента) + 1;
								
								СтрокаТоварыКРаспределению.рар_мп_Номенклатура = СтрокаДокумента.Номенклатура;
								
								СтрокаТоварыКРаспределению.рар_мп_IDТовара = Формат(Товар.id, "ЧГ=0");
								
								СтрокаТоварыКРаспределению.рар_мп_Характеристика = СтрокаДокумента.Характеристика;
								
								ВидНоменклатуры = ВидыНоменклатурыДляЧестногоЗнака.НайтиСтроки(Новый Структура("Аккаунт, ВидНоменклатуры", 
																										Аккаунт,СтрокаДокумента.Номенклатура.ВидНоменклатуры));
																										
								Если Товар.Свойство("requiredInstanceTypes") Тогда
																											
									ГТДНужен = Товар.requiredInstanceTypes.Найти("GTD");
																											
									Если ГТДНужен <> Неопределено Тогда
										
										СтрокаТоварыКРаспределению.рар_мп_ЗаполнениеГТД = Истина;
										
									КонецЕсли;	
																											
								КонецЕсли;
							
								Если ВидНоменклатуры.Количество() > 0 Тогда
								
									СтрокаТоварыКРаспределению.рар_мп_ЗаполнениеМаркировки = Истина;	
								
								КонецЕсли;	
								
							КонецЦикла;
								
						Иначе
							
							ОтказЗаписи = Истина;
							
							Комментарий = СтрШаблон("Аккаунт: %1. Номер заказа: %2. Описание ошибки: Не удалось найти сопоставленный товар с артикулом: %3",
													Аккаунт, Номер, Товар.id);
						
							ЗаписьЖурналаРегистрации("Ошибка при загрузке 'Заказа клиента' из Яндекс Маркет", УровеньЖурналаРегистрации.Ошибка,,, Комментарий,);
							
							Продолжить;
							
						КонецЕсли;
							
					КонецЦикла; 
					
					Если Не ОтказЗаписи Тогда
						
						Попытка
						
							Документ.Записать(РежимЗаписиДокумента.Проведение);
						
						Исключение 
							  
							Документ.Записать(РежимЗаписиДокумента.Запись);
							
							Комментарий = СтрШаблон("Аккаунт: %1. Номер заказа: %2. Описание ошибки: %3", Аккаунт, Номер, ОписаниеОшибки());
							
							ЗаписьЖурналаРегистрации("Ошибка при проведении 'Заказа клиента' из Яндекс Маркета", 
													 УровеньЖурналаРегистрации.Ошибка,,,Комментарий,);
						
						КонецПопытки;
					
					КонецЕсли;
					
				Исключение
					
					Комментарий = СтрШаблон("Аккаунт: %1. Номер заказа: %2. Описание ошибки: %3", Аккаунт, Номер, ОписаниеОшибки());
					
					ЗаписьЖурналаРегистрации("Ошибка при загрузке 'Заказа клиента' из Яндекс Маркета", 
											 УровеньЖурналаРегистрации.Ошибка,,,Комментарий,);
				
				КонецПопытки;	
				
			КонецЕсли;
			
		Иначе
			
			Попытка
			
				Документ = НайденныеСтроки.Получить(0).Ссылка.ПолучитьОбъект();
				
				Если Документ.рар_мп_ЯндексМаркет_СтатусЗаказа <> Перечисления.рар_мп_ЯндексМаркет_СтатусыЗаказов[Заказ.status] 
					 ИЛИ Документ.рар_мп_ЯндексМаркет_ПодстатусЗаказа <> Перечисления.рар_мп_ЯндексМаркет_ПодстатусыЗаказов[Заказ.substatus] Тогда
					 
					Попытка
					
						Документ.рар_мп_ЯндексМаркет_СтатусЗаказа    = Перечисления.рар_мп_ЯндексМаркет_СтатусыЗаказов[Заказ.status];
						Документ.рар_мп_ЯндексМаркет_ПодстатусЗаказа = Перечисления.рар_мп_ЯндексМаркет_ПодстатусыЗаказов[Заказ.substatus];
						
						Если Перечисления.рар_мп_ЯндексМаркет_СтатусыЗаказов[Заказ.status] = Перечисления.рар_мп_ЯндексМаркет_СтатусыЗаказов.CANCELLED Тогда
						
							ПричинаОтменыЗаказа = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Аккаунт, "ПричинаОтменыЗаказа");
							
							Если ЗначениеЗаполнено(ПричинаОтменыЗаказа) Тогда
							
								Для каждого СтрокаТчТовары Из Документ.Товары Цикл
								
									СтрокаТчТовары.Отменено = Истина;
									
									СтрокаТчТовары.ПричинаОтмены = ПричинаОтменыЗаказа;
								
								КонецЦикла;
								
								Документ.Статус = Перечисления.СтатусыЗаказовКлиентов.Закрыт;
							
							Иначе
								
								ОписаниеОшибки = "В личном кабинете не указана причина отмены заказа";
								
								Комментарий = СтрШаблон("Аккаунт: %1. Номер заказа: %2. Описание ошибки: %3", Аккаунт, Номер, ОписаниеОшибки);
							
								ЗаписьЖурналаРегистрации("Ошибка при закрытии документа 'Заказ клиента' после отмены заказа в Яндекс Маркет", 
												 УровеньЖурналаРегистрации.Ошибка,,,Комментарий,);	
							
							КонецЕсли;
						
						КонецЕсли;
						
						Документ.Записать(РежимЗаписиДокумента.Проведение);
					
					Исключение
						
						Документ.Записать(РежимЗаписиДокумента.Запись);
						
						Комментарий = СтрШаблон("Аккаунт: %1. Номер заказа: %2. Описание ошибки: %3", Аккаунт, Номер, ОписаниеОшибки());
						
						ЗаписьЖурналаРегистрации("Ошибка при изменении статуса 'Заказа клиента' из Яндекс Маркет", 
												 УровеньЖурналаРегистрации.Ошибка,,,Комментарий,); 
					
					КонецПопытки;
					 
					
				КонецЕсли;	
			
			Исключение
				
				Комментарий = СтрШаблон("Аккаунт: %1. Номер заказа: %2. Описание ошибки: %3", Аккаунт, Номер, ОписаниеОшибки());
						
				ЗаписьЖурналаРегистрации("Ошибка при изменении статуса 'Заказа клиента' из Яндекс Маркет", 
										 УровеньЖурналаРегистрации.Ошибка,,,Комментарий,);
			
			КонецПопытки;
			
		
		КонецЕсли;
		
	КонецЦикла;

КонецПроцедуры

Функция ПреобразоватьСтрокуВДату(СтрокаДата)

	СтрокаДата	= СтрЗаменить(СтрокаДата,":","");
	СтрокаДата	= СтрЗаменить(СтрокаДата,"-","");
	СтрокаДата  = СтрЗаменить(СтрокаДата,"T","");
	СтрокаДата  = СтрЗаменить(СтрокаДата,"Z","");
	СтрокаДата  = СтрЗаменить(СтрокаДата," ","");

	Год     = Сред(СтрокаДата,5,4);
	Месяц   = Сред(СтрокаДата,3,2);
	День    = Лев(СтрокаДата,2);
	Час     = Сред(СтрокаДата,9,2);
	Минуты  = Сред(СтрокаДата,11,2);
	Секунды = Прав(СтрокаДата,2);

	Возврат Дата(Год, Месяц, День, Час, Минуты, Секунды);	

КонецФункции

#КонецОбласти  

#Область Ozon

Процедура Ozon_ЗагрузкаЗаказов() Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ЗаказКлиента.Ссылка КАК Ссылка,
		|	ЗаказКлиента.НомерПоДаннымКлиента КАК НомерПоДаннымКлиента,
		|	ЗаказКлиента.рар_мп_АккаунтМаркетплейса КАК АккаунтМаркетплейса
		|ИЗ
		|	Документ.ЗаказКлиента КАК ЗаказКлиента
		|ГДЕ
		|	ЗаказКлиента.рар_мп_АккаунтМаркетплейса.Маркетплейс = ЗНАЧЕНИЕ(Перечисление.рар_мп_Маркетплейсы.Ozon)";
	
	РезультатЗапроса = Запрос.Выполнить();
	
	СозданныеЗаказыКлиентов = РезультатЗапроса.Выгрузить();
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	рар_мп_СопоставленныеСклады.АккаунтМаркетплейса КАК АккаунтМаркетплейса,
		|	рар_мп_СопоставленныеСклады.УникальныйИдентификаторСклада КАК УникальныйИдентификаторСклада,
		|	рар_мп_СопоставленныеСклады.Склад КАК Склад,
		|	рар_мп_СопоставленныеСклады.АккаунтМаркетплейса.Наименование КАК АккаунтМаркетплейсаНаименование
		|ИЗ
		|	РегистрСведений.рар_мп_СопоставленныеСклады КАК рар_мп_СопоставленныеСклады
		|ГДЕ
		|	рар_мп_СопоставленныеСклады.АккаунтМаркетплейса.АктивныйАккаунт = ИСТИНА
		|	И рар_мп_СопоставленныеСклады.АккаунтМаркетплейса.Маркетплейс = ЗНАЧЕНИЕ(Перечисление.рар_мп_Маркетплейсы.Ozon)
		|	И рар_мп_СопоставленныеСклады.АккаунтМаркетплейса.ПометкаУдаления = ЛОЖЬ
		|	И рар_мп_СопоставленныеСклады.Склад.ПометкаУдаления = ЛОЖЬ
		|	И рар_мп_СопоставленныеСклады.АккаунтМаркетплейса.СхемаРаботы = ЗНАЧЕНИЕ(Перечисление.рар_мп_СхемыРаботы.FBS)
		|
		|УПОРЯДОЧИТЬ ПО
		|	АккаунтМаркетплейса,
		|	УникальныйИдентификаторСклада";
	
	РезультатЗапроса = Запрос.Выполнить();
	
	СозданныеАккаунтыИСопоставленныеСклады = РезультатЗапроса.Выгрузить();
	
	АккаунтыOzon = СозданныеАккаунтыИСопоставленныеСклады.ВыгрузитьКолонку("АккаунтМаркетплейса");
	
	ОбщегоНазначенияУТ.УдалитьПовторяющиесяЭлементыМассива(АккаунтыOzon);
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	рар_мп_ВидыНоменклатурыДляУчетаЧестногоЗнака.Аккаунт КАК Аккаунт,
		|	рар_мп_ВидыНоменклатурыДляУчетаЧестногоЗнака.ВидНоменклатуры КАК ВидНоменклатуры
		|ИЗ
		|	РегистрСведений.рар_мп_ВидыНоменклатурыДляУчетаЧестногоЗнака КАК рар_мп_ВидыНоменклатурыДляУчетаЧестногоЗнака
		|ГДЕ
		|	рар_мп_ВидыНоменклатурыДляУчетаЧестногоЗнака.Аккаунт В(&Аккаунт)";
	
	Запрос.УстановитьПараметр("Аккаунт", АккаунтыOzon);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВидыНоменклатурыДляЧестногоЗнака = РезультатЗапроса.Выгрузить();
	
	КоличествоЗапросов = 0;
	
	Для каждого Аккаунт Из АккаунтыOzon Цикл
	
		НеобходимоСделатьЕщеОдинЗапрос = Истина;
		
		КоличествоПропущенных = 0;
		
		Лимит = 1000;
		
		Пока НеобходимоСделатьЕщеОдинЗапрос Цикл
			
			Если КоличествоЗапросов = 50 Тогда
				
				КоличествоЗапросов = 0;
				
				ВремяОжидания = 5;
				
				ВремяСледующегоЗапроса = ТекущаяДата() + ВремяОжидания;
				
				Пока ТекущаяДата() < ВремяСледующегоЗапроса Цикл
					// Ожидаем время для следующего запроса	
				КонецЦикла;
				
			КонецЕсли;
		
			HTTPОтвет = рар_мп_Ozon_Методы.Метод_СписокОтправлений(Аккаунт, КоличествоПропущенных);
			
			КоличествоЗапросов = КоличествоЗапросов + 1;
			
			Если HTTPОтвет.Свойство("ОтветAPI") Тогда
					
				Если HTTPОтвет.КодСостояния <> 200 Тогда
								
					НазваниеОшибки = "Ошибка при получении заказов из Ozon";
					
					ОписаниеОшибки = HTTPОтвет.ОтветAPI.message;	
					
					Комментарий = СтрШаблон("Маркетплейс: Ozon%1Аккаунт: %2%1Код состояния: %3%1Описание ошибки: %4", 
											Символы.ПС, Аккаунт, HTTPОтвет.КодСостояния, ОписаниеОшибки);
					
					ЗаписьЖурналаРегистрации(НазваниеОшибки,УровеньЖурналаРегистрации.Ошибка,,,Комментарий,);
					
					НеобходимоСделатьЕщеОдинЗапрос = Ложь;
				
				Иначе
					
					НеобходимоСделатьЕщеОдинЗапрос = HTTPОтвет.ОтветAPI.result.has_next;
					
					КоличествоПропущенных = КоличествоПропущенных + Лимит;
					
					Заказы = HTTPОтвет.ОтветAPI.result.postings;
					
					Ozon_СозданиеЗаказов(Заказы, Аккаунт, СозданныеЗаказыКлиентов, СозданныеАккаунтыИСопоставленныеСклады, ВидыНоменклатурыДляЧестногоЗнака); 
					
				КонецЕсли;
				
			Иначе
				
				Комментарий = "Ошибка при получении JSON. Некорректные значения JSON";
			
				ЗаписьЖурналаРегистрации("Ошибка при получении загрузке заказов", УровеньЖурналаРегистрации.Ошибка,,,
										 СтрШаблон("Аккаунт: %3. Код запроса:%1. Описание ошибки:%2", HTTPОтвет.КодСостояния, Комментарий, Аккаунт),);
				
			КонецЕсли;
			
		
		КонецЦикла;
		
	КонецЦикла;
	
КонецПроцедуры

Процедура Ozon_СозданиеЗаказов(Заказы, Аккаунт, СозданныеЗаказыКлиентов, СозданныеАккаунтыИСопоставленныеСклады, ВидыНоменклатурыДляЧестногоЗнака)
	
	КоличествоЗапросов = 0;
	
	Для каждого Заказ Из Заказы Цикл
		
		Номер = Заказ.posting_number;
		
		ОтказЗаписи = Ложь;
		
		НайденныеСтроки = СозданныеЗаказыКлиентов.НайтиСтроки(Новый Структура("НомерПоДаннымКлиента, АккаунтМаркетплейса", Номер, Аккаунт));
		
		Если НайденныеСтроки.Количество() = 0 Тогда
			
			Если Заказ.status = "awaiting_packaging" Тогда
				
				Попытка
				
					Документ = Документы.ЗаказКлиента.СоздатьДокумент(); 
					
					//Заполнение данными из 1с
					Документ.Статус 			   		= Аккаунт.СтатусЗаказа;
					Документ.Приоритет 			   		= Аккаунт.Приоритет;
					Документ.ХозяйственнаяОперация 		= Аккаунт.Операция;
					Документ.Организация		   		= Аккаунт.Организация;
					Документ.Договор 			  		= Аккаунт.Договор;
					Документ.рар_мп_СтатусДокументаВТСД	= Перечисления.рар_мп_СтатусыДокументовВТСД.Новый;
					
					НайденныеСтрокиСкладов = СозданныеАккаунтыИСопоставленныеСклады.НайтиСтроки(Новый Структура("АккаунтМаркетплейса,УникальныйИдентификаторСклада", 
																												Аккаунт, Формат(Заказ.delivery_method.warehouse_id,"ЧГ=0")));
					Если НайденныеСтрокиСкладов.Количество() = 0 Тогда
					
						ОтказЗаписи = Истина;
						
						Комментарий = СтрШаблон("Аккаунт: %1. Номер заказа: %2. Описание ошибки: Не удалось найти сопоставленный склад с id: %3", 
												Аккаунт, Номер, Формат(Заказ.warehouseId,"ЧГ=0"));
						
						ЗаписьЖурналаРегистрации("Ошибка при загрузке 'Заказа клиента' из Ozon", УровеньЖурналаРегистрации.Ошибка,,, Комментарий,);
						
						Продолжить;
						
					Иначе
						
						Склад 		   								  = НайденныеСтрокиСкладов.Получить(0).Склад;
						Документ.Склад 								  = Склад;
						Документ.рар_мп_УникальныйИдентификаторСклада = НайденныеСтрокиСкладов.Получить(0).УникальныйИдентификаторСклада;
					
					КонецЕсли;
					
					Если НЕ ОтказЗаписи Тогда
					
						Документ.Контрагент 		   		= Аккаунт.Контрагент;
						Документ.Партнер       		   		= Аккаунт.Партнер;
						Документ.Соглашение 		   		= Аккаунт.Соглашение;
						Документ.Валюта 			   		= Аккаунт.Валюта;
						Документ.НеОтгружатьЧастями    		= Истина;
						Документ.рар_мп_АккаунтМаркетплейса = Аккаунт;
						
						ДатаСоздания  = Заказ.in_process_at;
						ДатаСоздания  = СтрЗаменить(ДатаСоздания,"T","");
						ДатаСоздания  = СтрЗаменить(ДатаСоздания,"Z","");
						ДатаСоздания  = СтрЗаменить(ДатаСоздания,":","");
						ДатаСоздания  = СтрЗаменить(ДатаСоздания,"-","");
						Документ.Дата = Дата(ДатаСоздания);
						
						Если Документ.Соглашение <> Справочники.СоглашенияСКлиентами.ПустаяСсылка() Тогда
						
							Документ.КонтактноеЛицо = Аккаунт.Соглашение.КонтактноеЛицо;
							Документ.Менеджер       = Аккаунт.Соглашение.Менеджер;
							
						ИначеЕсли Документ.Договор <> Справочники.ДоговорыКонтрагентов.ПустаяСсылка() Тогда
							
							Документ.КонтактноеЛицо = Аккаунт.Договор.КонтактноеЛицо;
							Документ.Менеджер 		= Аккаунт.Договор.Менеджер;
							
						КонецЕсли; 
						
						Документ.Подразделение 		= Аккаунт.Подразделение;
						Документ.СпособДоставки 	= Перечисления.СпособыДоставки.Самовывоз;
						Документ.НалогообложениеНДС = Аккаунт.НалогообложениеНДС;
						Документ.ЦенаВключаетНДС    = Аккаунт.ЦенаВключаетНДС;
						Документ.Автор 				= ПользователиКлиентСервер.ТекущийПользователь();
						
						//Заполнение данными из маркетплейса
						Документ.рар_мп_Ozon_СтатусЗаказа 	 = Перечисления.рар_мп_Ozon_СтатусыЗаказов[Заказ.status];
						Документ.рар_мп_Ozon_ПодстатусЗаказа = Перечисления.рар_мп_Ozon_ПодстатусыЗаказов[Заказ.substatus];
						Документ.НомерПоДаннымКлиента		 = Номер;
						Документ.ДатаПоДаннымКлиента		 = Документ.Дата;
						
						Товары = Заказ.products;
												
						ДатаОтгрузки  = Заказ.shipment_date;
						ДатаОтгрузки  = СтрЗаменить(ДатаОтгрузки,"T","");
						ДатаОтгрузки  = СтрЗаменить(ДатаОтгрузки,"Z","");
						ДатаОтгрузки  = СтрЗаменить(ДатаОтгрузки,":","");
						ДатаОтгрузки  = СтрЗаменить(ДатаОтгрузки,"-","");
