#КонецОбласти

#Область Wildberries

Процедура Wildberries_ЗагрузкаЗаказов() Экспорт

	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ЗаказКлиента.Ссылка КАК Ссылка,
		|	ЗаказКлиента.НомерПоДаннымКлиента КАК НомерПоДаннымКлиента,
		|	ЗаказКлиента.рар_мп_АккаунтМаркетплейса КАК АккаунтМаркетплейса
		|ИЗ
		|	Документ.ЗаказКлиента КАК ЗаказКлиента
		|ГДЕ
		|	ЗаказКлиента.рар_мп_АккаунтМаркетплейса.Маркетплейс = ЗНАЧЕНИЕ(Перечисление.рар_мп_Маркетплейсы.Wildberries)";
	
	РезультатЗапроса = Запрос.Выполнить();
	
	СозданныеЗаказыКлиентов = РезультатЗапроса.Выгрузить();
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	рар_мп_СопоставленныеСклады.АккаунтМаркетплейса КАК АккаунтМаркетплейса,
		|	рар_мп_СопоставленныеСклады.УникальныйИдентификаторСклада КАК УникальныйИдентификаторСклада,
		|	рар_мп_СопоставленныеСклады.Склад КАК Склад,
		|	рар_мп_СопоставленныеСклады.АккаунтМаркетплейса.Наименование КАК АккаунтМаркетплейсаНаименование
		|ИЗ
		|	РегистрСведений.рар_мп_СопоставленныеСклады КАК рар_мп_СопоставленныеСклады
		|ГДЕ
		|	рар_мп_СопоставленныеСклады.АккаунтМаркетплейса.АктивныйАккаунт = ИСТИНА
		|	И рар_мп_СопоставленныеСклады.АккаунтМаркетплейса.Маркетплейс = ЗНАЧЕНИЕ(Перечисление.рар_мп_Маркетплейсы.Wildberries)
		|	И рар_мп_СопоставленныеСклады.АккаунтМаркетплейса.ПометкаУдаления = ЛОЖЬ
		|	И рар_мп_СопоставленныеСклады.Склад.ПометкаУдаления = ЛОЖЬ
		|	И рар_мп_СопоставленныеСклады.АккаунтМаркетплейса.СхемаРаботы = ЗНАЧЕНИЕ(Перечисление.рар_мп_СхемыРаботы.FBS)
		|
		|УПОРЯДОЧИТЬ ПО
		|	АккаунтМаркетплейса,
		|	УникальныйИдентификаторСклада";
	
	РезультатЗапроса = Запрос.Выполнить();
	
	СозданныеАккаунтыИСопоставленныеСклады = РезультатЗапроса.Выгрузить();
	
	АккаунтыВБ = СозданныеАккаунтыИСопоставленныеСклады.ВыгрузитьКолонку("АккаунтМаркетплейса");
	
	ОбщегоНазначенияУТ.УдалитьПовторяющиесяЭлементыМассива(АккаунтыВБ);
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	рар_мп_ВидыНоменклатурыДляУчетаЧестногоЗнака.Аккаунт КАК Аккаунт,
		|	рар_мп_ВидыНоменклатурыДляУчетаЧестногоЗнака.ВидНоменклатуры КАК ВидНоменклатуры
		|ИЗ
		|	РегистрСведений.рар_мп_ВидыНоменклатурыДляУчетаЧестногоЗнака КАК рар_мп_ВидыНоменклатурыДляУчетаЧестногоЗнака
		|ГДЕ
		|	рар_мп_ВидыНоменклатурыДляУчетаЧестногоЗнака.Аккаунт В(&Аккаунт)";
	
	Запрос.УстановитьПараметр("Аккаунт", АккаунтыВБ);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВидыНоменклатурыДляЧестногоЗнака = РезультатЗапроса.Выгрузить();
	
	СледующаяСтраница = "0";

	Для каждого Аккаунт Из АккаунтыВБ Цикл
	
		HTTPОтвет = рар_мп_Wildberries_Методы.Метод_ПолучитьИНформациюОСборочныхЗаданиях(Аккаунт, СледующаяСтраница);
		
		Если HTTPОтвет.Свойство("ОтветAPI") Тогда
			
			Если HTTPОтвет.КодСостояния <> 200 Тогда
							
				НазваниеОшибки = "Ошибка при получении заказов из Wildberries";
				
				Если HTTPОтвет.ОтветAPI.Свойство("message") Тогда
			
					ОписаниеОшибки = HTTPОтвет.ОтветAPI.message;	
				
				Иначе
				
					ОписаниеОшибки = HTTPОтвет.ОтветAPI.title;	
				
				КонецЕсли;
				
				Комментарий = СтрШаблон("Маркетплейс: Wildberries%1Аккаунт: %2%1Код состояния: %3%1Описание ошибки: %4", 
										Символы.ПС, Аккаунт, HTTPОтвет.КодСостояния, ОписаниеОшибки);
				
				ЗаписьЖурналаРегистрации(НазваниеОшибки,УровеньЖурналаРегистрации.Ошибка,,,Комментарий,);
			
			Иначе
				
				Если HTTPОтвет.ОтветAPI.Свойство("next") Тогда
				
					СледующаяСтраница = Строка(Формат(HTTPОтвет.ОтветAPI.next,"ЧГ=0"));
					
				Иначе
					
					СледующаяСтраница = "";
				
				КонецЕсли;
				
				Заказы = HTTPОтвет.ОтветAPI.orders;
				
				Wildberries_СозданиеЗаказов(Заказы, Аккаунт, СозданныеЗаказыКлиентов, СозданныеАккаунтыИСопоставленныеСклады, ВидыНоменклатурыДляЧестногоЗнака);
				
				Пока СледующаяСтраница <> "" Цикл
					
					HTTPОтвет = рар_мп_Wildberries_Методы.Метод_ПолучитьИНформациюОСборочныхЗаданиях(Аккаунт, СледующаяСтраница);
					
					Если HTTPОтвет.КодСостояния = 429 Тогда
		
						ВремяОжидания = 60;
							
						КонДата = ТекущаяДата() + ВремяОжидания;
						
						Пока ТекущаяДата() < КонДата Цикл
							
						КонецЦикла;
						
						HTTPОтвет = рар_мп_Wildberries_Методы.Метод_ПолучитьИНформациюОСборочныхЗаданиях(Аккаунт, СледующаяСтраница);
						
					КонецЕсли;
					
					Если HTTPОтвет.Свойство("ОтветAPI") Тогда
					
						Если HTTPОтвет.КодСостояния <> 200 Тогда
								
							НазваниеОшибки = "Ошибка при получении заказов из Wildberries";
							
							Если HTTPОтвет.ОтветAPI.Свойство("message") Тогда
				
								ОписаниеОшибки = HTTPОтвет.ОтветAPI.message;	
							
							Иначе
							
								ОписаниеОшибки = HTTPОтвет.ОтветAPI.title;	
							
							КонецЕсли;
							
							Комментарий = СтрШаблон("Маркетплейс: Wildberries%1Аккаунт: %2%1Код состояния: %3%1Описание ошибки: %4", 
													Символы.ПС, Аккаунт, HTTPОтвет.КодСостояния, ОписаниеОшибки);
							
							ЗаписьЖурналаРегистрации(НазваниеОшибки,УровеньЖурналаРегистрации.Ошибка,,,Комментарий,);
							
							Прервать;
						
						Иначе
							
							Если HTTPОтвет.ОтветAPI.Свойство("next") Тогда
					
								СледующаяСтраница = Строка(Формат(HTTPОтвет.ОтветAPI.next,"ЧГ=0"));
								
							Иначе
								
								СледующаяСтраница = "";
							
							КонецЕсли;
							
							Заказы = HTTPОтвет.ОтветAPI.orders;
							
							Wildberries_СозданиеЗаказов(Заказы, Аккаунт, СозданныеЗаказыКлиентов, СозданныеАккаунтыИСопоставленныеСклады, ВидыНоменклатурыДляЧестногоЗнака);
							
						КонецЕсли;
						
					Иначе
						
						Комментарий = "Ошибка при получении JSON. Некорректные значения JSON";
		
						ЗаписьЖурналаРегистрации("Ошибка при получении загрузке заказов", УровеньЖурналаРегистрации.Ошибка,,,
												 СтрШаблон("Аккаунт: %3. Код запроса:%1. Описание ошибки:%2", HTTPОтвет.КодСостояния, Комментарий, Аккаунт),);
						
					КонецЕсли;
				
				КонецЦикла;
				
			КонецЕсли;
			
		Иначе
				
			Комментарий = "Ошибка при получении JSON. Некорректные значения JSON";
		
			ЗаписьЖурналаРегистрации("Ошибка при получении загрузке заказов", УровеньЖурналаРегистрации.Ошибка,,,
									 СтрШаблон("Аккаунт: %3. Код запроса:%1. Описание ошибки:%2", HTTPОтвет.КодСостояния, Комментарий, Аккаунт),);
			
		КонецЕсли;
	
	КонецЦикла;

КонецПроцедуры

Процедура Wildberries_СозданиеЗаказов(Заказы, Аккаунт, СозданныеЗаказыКлиентов, СозданныеАккаунтыИСопоставленныеСклады, ВидыНоменклатурыДляЧестногоЗнака)

	Для каждого Заказ Из Заказы Цикл
	
		Номер = Формат(Заказ.id,"ЧГ=0");
		
		НайденныеСтроки = СозданныеЗаказыКлиентов.НайтиСтроки(Новый Структура("НомерПоДаннымКлиента, АккаунтМаркетплейса", Строка(Номер), Аккаунт));
		
		СтатусыЗаказа = Wildberries_ПолучитьСтатусЗаказа(Аккаунт, Число(Номер));
		
		Если НайденныеСтроки.Количество() = 0 Тогда
			
			Если СтатусыЗаказа.Получить("СтатусОбработкиЗаказа") = "new" И СтатусыЗаказа.Получить("СтатусЗаказа") = "waiting" Тогда
				
				Попытка
				
					ОтказЗаписи = Ложь;
				
					Документ = Документы.ЗаказКлиента.СоздатьДокумент(); 
					
					//Заполнение данными из 1с
					Документ.Статус 			   		= Аккаунт.СтатусЗаказа;
					Документ.Приоритет 			   		= Аккаунт.Приоритет;
					Документ.ХозяйственнаяОперация 		= Аккаунт.Операция;
					Документ.Организация		   		= Аккаунт.Организация;
					Документ.Договор 			  		= Аккаунт.Договор;
					Документ.рар_мп_СтатусДокументаВТСД	= Перечисления.рар_мп_СтатусыДокументовВТСД.Новый;
					
					НайденныеСтрокиСкладов = СозданныеАккаунтыИСопоставленныеСклады.НайтиСтроки(Новый Структура("АккаунтМаркетплейса,УникальныйИдентификаторСклада", 
																												Аккаунт, Формат(Заказ.warehouseId,"ЧГ=0")));
					
					Если НайденныеСтрокиСкладов.Количество() = 0 Тогда
					
						ОтказЗаписи = Истина;
						
						Комментарий = СтрШаблон("Аккаунт: %1. Номер заказа: %2. Описание ошибки: Не удалось найти сопоставленный склад с id: %3", 
												Аккаунт, Номер, Формат(Заказ.warehouseId,"ЧГ=0"));
						
						ЗаписьЖурналаРегистрации("Ошибка при загрузке 'Заказа клиента' из Wildberries", УровеньЖурналаРегистрации.Ошибка,,, Комментарий,);
						
						Продолжить;
						
					Иначе
						
						Склад 		   								  = НайденныеСтрокиСкладов.Получить(0).Склад;
						Документ.Склад 								  = Склад;
						Документ.рар_мп_УникальныйИдентификаторСклада = НайденныеСтрокиСкладов.Получить(0).УникальныйИдентификаторСклада;
					
					КонецЕсли;
					
					Если НЕ ОтказЗаписи Тогда
					
						Документ.Контрагент 		   		= Аккаунт.Контрагент;
						Документ.Партнер       		   		= Аккаунт.Партнер;
						Документ.Соглашение 		   		= Аккаунт.Соглашение;
						Документ.Валюта 			   		= Аккаунт.Валюта;
						Документ.рар_мп_АккаунтМаркетплейса = Аккаунт;
						
						ДатаСоздания  = Заказ.createdAt;
						ДатаСоздания  = СтрЗаменить(ДатаСоздания,"T","");
						ДатаСоздания  = СтрЗаменить(ДатаСоздания,"Z","");
						ДатаСоздания  = СтрЗаменить(ДатаСоздания,":","");
						ДатаСоздания  = СтрЗаменить(ДатаСоздания,"-","");
						Документ.Дата = Дата(ДатаСоздания);
						
						Если Документ.Соглашение <> Справочники.СоглашенияСКлиентами.ПустаяСсылка() Тогда
						
							Документ.КонтактноеЛицо = Аккаунт.Соглашение.КонтактноеЛицо;
							Документ.Менеджер       = Аккаунт.Соглашение.Менеджер;
							
						ИначеЕсли Документ.Договор <> Справочники.ДоговорыКонтрагентов.ПустаяСсылка() Тогда
							
							Документ.КонтактноеЛицо = Аккаунт.Договор.КонтактноеЛицо;
							Документ.Менеджер 		= Аккаунт.Договор.Менеджер;
							
						КонецЕсли; 
						
						Документ.Подразделение 		= Аккаунт.Подразделение;
						Документ.СпособДоставки 	= Перечисления.СпособыДоставки.Самовывоз;
						Документ.НалогообложениеНДС = Аккаунт.НалогообложениеНДС;
						Документ.ЦенаВключаетНДС    = Аккаунт.ЦенаВключаетНДС;
						Документ.Автор 				= ПользователиКлиентСервер.ТекущийПользователь();
						Документ.ДатаОтгрузки	    = ТекущаяДатаСеанса();
						Документ.НеОтгружатьЧастями = Истина;
						
						//Заполнение данными из маркетплейса
						СтатусЗаказа 		  = СтатусыЗаказа.Получить("СтатусЗаказа");
						СтатусОбработкиЗаказа = СтатусыЗаказа.Получить("СтатусОбработкиЗаказа");
						
						Документ.рар_мп_Wildberries_СтатусЗаказа 	      = Перечисления.рар_мп_Wildberries_СтатусыЗаказов[СтатусЗаказа];
						Документ.рар_мп_Wildberries_СтатусОбработкиЗаказа = Перечисления.рар_мп_Wildberries_СтатусыОбработкиЗаказов[СтатусОбработкиЗаказа];
						Документ.НомерПоДаннымКлиента				 	  = Строка(Номер);
						Документ.ДатаПоДаннымКлиента				 	  = СтроковыеФункцииКлиентСервер.СтрокаВДату(ДатаСоздания);
						
						СтрокаДокумента = Документ.Товары.Добавить();
						
						Запись 		     = РегистрыСведений.рар_мп_Wildberries_СопоставленныеТовары.СоздатьМенеджерЗаписи();
						Запись.Аккаунт   = Аккаунт;
						Запись.IDТовара  = Заказ.nmId;
						Запись.Артикул   = Заказ.article;
						Запись.Баракод   = Заказ.skus.Получить(0);
						
						Запись.Прочитать();
						
						Если Запись.Выбран() Тогда
							
							СтрокаДокумента.Номенклатура   	   = Запись.Номенклатура;
							СтрокаДокумента.Характеристика 	   = Запись.Характеристика;
							СтрокаДокумента.ВариантОбеспечения = Аккаунт.ВариантОбеспечения;
							СтрокаДокумента.ДатаОтгрузки	   = ТекущаяДатаСеанса();
							СтрокаДокумента.Упаковка	   	   = Запись.Упаковка;
							СтрокаДокумента.КоличествоУпаковок = 1;
							СтрокаДокумента.Количество		   = СтрокаДокумента.КоличествоУпаковок * Справочники.УпаковкиЕдиницыИзмерения.КоэффициентУпаковки(СтрокаДокумента.Упаковка, СтрокаДокумента.Номенклатура);
							СтрокаДокумента.Склад			   = Склад;
							СтрокаДокумента.Цена  	  		   = Заказ.convertedPrice / 100;
							СтрокаДокумента.Сумма 	  		   = СтрокаДокумента.Цена;
							
							СтавкаНДС = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Запись.Номенклатура, "СтавкаНДС");
							
							СтрокаДокумента.СтавкаНДС = СтавкаНДС;
							
							СтруктураПересчетаСуммы = Новый Структура;
							СтруктураПересчетаСуммы.Вставить("ЦенаВключаетНДС", Документ.ЦенаВключаетНДС);
							СтруктураПересчетаСуммы.Вставить("НалогообложениеНДС", Документ.НалогообложениеНДС);
							
							СтруктураДействий = Новый Структура;
							СтруктураДействий.Вставить("ПересчитатьСуммуНДС", СтруктураПересчетаСуммы);
							СтруктураДействий.Вставить("ПересчитатьСуммуСНДС", СтруктураПересчетаСуммы);
								
							КэшированныеЗначения = Неопределено;
									
							ПакетнаяОбработкаТабличнойЧастиКлиентСервер.ОбработатьСтрокуТЧ(СтрокаДокумента, СтруктураДействий, КэшированныеЗначения); 
							
							Для Счетчик = 1 По СтрокаДокумента.Количество Цикл
							
								СтрокаТоварыКРаспределению = Документ.рар_мп_ТоварыДляМаркировки.Добавить();
								
								СтрокаТоварыКРаспределению.рар_мп_СтрокаИзТЧТовары = Документ.Товары.Индекс(СтрокаДокумента) + 1;
								
								СтрокаТоварыКРаспределению.рар_мп_Номенклатура = СтрокаДокумента.Номенклатура; 
								
								СтрокаТоварыКРаспределению.рар_мп_Характеристика = СтрокаДокумента.Характеристика;
								
								СтрокаТоварыКРаспределению.рар_мп_IDТовара = Формат(Заказ.nmId,"ЧГ=0");
								
								ВидНоменклатуры = ВидыНоменклатурыДляЧестногоЗнака.НайтиСтроки(Новый Структура("Аккаунт, ВидНоменклатуры", 
																										Аккаунт,СтрокаДокумента.Номенклатура.ВидНоменклатуры));
									
								Если ВидНоменклатуры.Количество() > 0 Тогда
								
									СтрокаТоварыКРаспределению.рар_мп_ЗаполнениеМаркировки = Истина;	
								
								КонецЕсли;
								
							КонецЦикла;
								
						Иначе
							
							ОтказЗаписи = Истина;
							
							Комментарий = СтрШаблон("Аккаунт: %1. Номер заказа: %2. Описание ошибки: Не удалось найти сопоставленный товар с баракодом: %3",
													Аккаунт, Номер, Заказ.skus.Получить(0));
						
							ЗаписьЖурналаРегистрации("Ошибка при загрузке 'Заказа клиента' из Wildberries", УровеньЖурналаРегистрации.Ошибка,,, Комментарий,);
							
							Продолжить;
							
						КонецЕсли;
						
						Если Не ОтказЗаписи Тогда
							
							Попытка
							
								Документ.Записать(РежимЗаписиДокумента.Проведение);
							
							Исключение 
								  
								Документ.Записать(РежимЗаписиДокумента.Запись);
								
								Комментарий = СтрШаблон("Аккаунт: %1. Номер заказа: %2. Описание ошибки: %3", Аккаунт, Номер, ОписаниеОшибки());
								
								ЗаписьЖурналаРегистрации("Ошибка при проведении 'Заказа клиента' из Wildberries", 
														 УровеньЖурналаРегистрации.Ошибка,,,Комментарий,);
							
							КонецПопытки;
						
						КонецЕсли;
					
					КонецЕсли;
						
				Исключение
					
					Комментарий = СтрШаблон("Аккаунт: %1. Номер заказа: %2. Описание ошибки: %3", Аккаунт, Номер, ОписаниеОшибки());
					
					ЗаписьЖурналаРегистрации("Ошибка при загрузке 'Заказа клиента' из Wildberries", 
											 УровеньЖурналаРегистрации.Ошибка,,,Комментарий,);
					
				КонецПопытки;
				
			КонецЕсли;
			
		Иначе
			
			Попытка
			
				Документ = НайденныеСтроки.Получить(0).Ссылка.ПолучитьОбъект();
			
				СтатусЗаказа 		  = СтатусыЗаказа.Получить("СтатусЗаказа");	
				СтатусОбработкиЗаказа = СтатусыЗаказа.Получить("СтатусОбработкиЗаказа");
				
				Если СтатусЗаказа <> "" И СтатусОбработкиЗаказа <> "" Тогда
				
					Если Документ.рар_мп_Wildberries_СтатусЗаказа <> Перечисления.рар_мп_Wildberries_СтатусыЗаказов[СтатусЗаказа] 
					    ИЛИ Документ.рар_мп_Wildberries_СтатусОбработкиЗаказа <> 
								Перечисления.рар_мп_Wildberries_СтатусыОбработкиЗаказов[СтатусОбработкиЗаказа] Тогда
						 
						Попытка
						
							Документ.рар_мп_Wildberries_СтатусЗаказа          = Перечисления.рар_мп_Wildberries_СтатусыЗаказов[СтатусЗаказа];
							Документ.рар_мп_Wildberries_СтатусОбработкиЗаказа = Перечисления.рар_мп_Wildberries_СтатусыОбработкиЗаказов[СтатусОбработкиЗаказа];
							
							Если Перечисления.рар_мп_Wildberries_СтатусыЗаказов[СтатусЗаказа] = Перечисления.рар_мп_Wildberries_СтатусыЗаказов.canceled
								ИЛИ Перечисления.рар_мп_Wildberries_СтатусыЗаказов[СтатусЗаказа] = Перечисления.рар_мп_Wildberries_СтатусыЗаказов.canceled_by_client
								ИЛИ Перечисления.рар_мп_Wildberries_СтатусыЗаказов[СтатусЗаказа] = Перечисления.рар_мп_Wildberries_СтатусыЗаказов.declined_by_client
								ИЛИ Перечисления.рар_мп_Wildberries_СтатусыЗаказов[СтатусЗаказа] = Перечисления.рар_мп_Wildberries_СтатусыЗаказов.defect Тогда  
						
								ПричинаОтменыЗаказа = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Аккаунт, "ПричинаОтменыЗаказа");
								
								Если ЗначениеЗаполнено(ПричинаОтменыЗаказа) Тогда
								
									Для каждого СтрокаТчТовары Из Документ.Товары Цикл
									
										СтрокаТчТовары.Отменено = Истина;
										
										СтрокаТчТовары.ПричинаОтмены = ПричинаОтменыЗаказа;
									
									КонецЦикла;
									
									Документ.Статус = Перечисления.СтатусыЗаказовКлиентов.Закрыт;
								
								Иначе
									
									ОписаниеОшибки = "В личном кабинете не указана причина отмены заказа";
									
									Комментарий = СтрШаблон("Аккаунт: %1. Номер заказа: %2. Описание ошибки: %3", Аккаунт, Номер, ОписаниеОшибки);
								
									ЗаписьЖурналаРегистрации("Ошибка при закрытии документа 'Заказ клиента' после отмены заказа в Wildberries", 
													 УровеньЖурналаРегистрации.Ошибка,,,Комментарий,);	
								
								КонецЕсли;
							
							КонецЕсли;
							
							Документ.Записать(РежимЗаписиДокумента.Проведение);
						
						Исключение
							
							Документ.Записать(РежимЗаписиДокумента.Запись);
							
							Комментарий = СтрШаблон("Аккаунт: %1. Номер заказа: %2. Описание ошибки: %3", Аккаунт, Номер, ОписаниеОшибки());
							
							ЗаписьЖурналаРегистрации("Ошибка при изменении статуса 'Заказа клиента' из Wildberries", 
													 УровеньЖурналаРегистрации.Ошибка,,,Комментарий,); 
						
						КонецПопытки;
						 	
					КонецЕсли;	
				
				КонецЕсли;	
			
			Исключение
				
				Комментарий = СтрШаблон("Аккаунт: %1. Номер заказа: %2. Описание ошибки: %3", Аккаунт, Номер, ОписаниеОшибки());
						
				ЗаписьЖурналаРегистрации("Ошибка при изменении статуса 'Заказа клиента' из Wildberries", 
										  УровеньЖурналаРегистрации.Ошибка,,,Комментарий,); 
					

			КонецПопытки;
			
			
		КонецЕсли;
	
	КонецЦикла;		

КонецПроцедуры

Функция Wildberries_ПолучитьСтатусЗаказа(Аккаунт, НомерЗаказа)

	HTTPОтвет = рар_мп_Wildberries_Методы.Метод_ПолучитьСтатусыСборочныхЗаданий(Аккаунт, НомерЗаказа); 
	
	Если HTTPОтвет.КодСостояния = 429 Тогда
	
		ВремяОжидания = 60;
			
		КонДата = ТекущаяДата() + ВремяОжидания;
		
		Пока ТекущаяДата() < КонДата Цикл
			
		КонецЦикла;
		
		HTTPОтвет = рар_мп_Wildberries_Методы.Метод_ПолучитьСтатусыСборочныхЗаданий(Аккаунт, НомерЗаказа);
		
	КонецЕсли;
	
	Если HTTPОтвет.Свойство("ОтветAPI") Тогда
					
		Если HTTPОтвет.КодСостояния <> 200 Тогда
						
			НазваниеОшибки = "Ошибка при получении статусов заказа из Wildberries";
			
			Если HTTPОтвет.ОтветAPI.Свойство("message") Тогда
			
				ОписаниеОшибки = HTTPОтвет.ОтветAPI.message;	
			
			Иначе
			
				ОписаниеОшибки = HTTPОтвет.ОтветAPI.title;	
			
			КонецЕсли;
				
			Комментарий = СтрШаблон("Маркетплейс: Wildberries%1Аккаунт: %2%1Код состояния: %3%1Номер заказа: %4%1Описание ошибки: %5", 
									Символы.ПС, Аккаунт, HTTPОтвет.КодСостояния, НомерЗаказа, ОписаниеОшибки);
			
			ЗаписьЖурналаРегистрации(НазваниеОшибки,УровеньЖурналаРегистрации.Ошибка,,,Комментарий,); 
			
			СоответствиеСтатусыЗаказа = Новый Соответствие;
			
		    СоответствиеСтатусыЗаказа.Вставить("СтатусЗаказа", "");
			СоответствиеСтатусыЗаказа.Вставить("СтатусОбработкиЗаказа", "");
			
			Возврат СоответствиеСтатусыЗаказа;
			
		Иначе
			
			Попытка
			
				СтатусЗаказа = HTTPОтвет.ОтветAPI.orders.Получить(0).wbStatus;
				
				СтатусОбработкиЗаказа = HTTPОтвет.ОтветAPI.orders.Получить(0).supplierStatus;
				
				СоответствиеСтатусыЗаказа = Новый Соответствие;
				
				СоответствиеСтатусыЗаказа.Вставить("СтатусЗаказа", СтатусЗаказа);
				СоответствиеСтатусыЗаказа.Вставить("СтатусОбработкиЗаказа", СтатусОбработкиЗаказа);
				
				Возврат СоответствиеСтатусыЗаказа;
			
			Исключение
				
				НазваниеОшибки = "Ошибка при получении статусов заказа из Wildberries";
				
				Комментарий = СтрШаблон("Маркетплейс: Wildberries%1Аккаунт: %2%1Код состояния: %3%1Номер заказа: %4%1Описание ошибки: %5", 
									Символы.ПС, Аккаунт, HTTPОтвет.КодСостояния, НомерЗаказа, ОписаниеОшибки());
			
				ЗаписьЖурналаРегистрации(НазваниеОшибки,УровеньЖурналаРегистрации.Ошибка,,,Комментарий,); 
				
				СоответствиеСтатусыЗаказа = Новый Соответствие;
				
			    СоответствиеСтатусыЗаказа.Вставить("СтатусЗаказа", "");
				СоответствиеСтатусыЗаказа.Вставить("СтатусОбработкиЗаказа", "");
				
				Возврат СоответствиеСтатусыЗаказа;
		
			КонецПопытки;
			
		КонецЕсли;
		
	Иначе
		
		Комментарий = "Ошибка при получении JSON. Некорректные значения JSON";
		
		ЗаписьЖурналаРегистрации("Ошибка при получении загрузке заказов", УровеньЖурналаРегистрации.Ошибка,,,
								 СтрШаблон("Аккаунт: %3. Код запроса:%1. Описание ошибки:%2", HTTPОтвет.КодСостояния, Комментарий, Аккаунт),);
								 
		СоответствиеСтатусыЗаказа = Новый Соответствие;
			
	    СоответствиеСтатусыЗаказа.Вставить("СтатусЗаказа", "");
		СоответствиеСтатусыЗаказа.Вставить("СтатусОбработкиЗаказа", "");
		
		Возврат СоответствиеСтатусыЗаказа;
		
	КонецЕсли;

КонецФункции


