Функция Wildberries_СозданиеПоставки(Аккаунт, НазваниеПоставки) Экспорт
	
	HTTPОтвет = рар_мп_Wildberries_Методы.Метод_СоздатьНовуюПоставку(Аккаунт, НазваниеПоставки);
	
	КодЗапроса = HTTPОтвет.КодСостояния;
	
	Если HTTPОтвет.Свойство("ОтветAPI") Тогда
		
		Если КодЗапроса <> 201 Тогда
			
			НазваниеОшибки = "Ошибка при создании поставки в Wildberries";
			
			Если HTTPОтвет.ОтветAPI.Свойство("message") Тогда
				
				ОписаниеОшибки = HTTPОтвет.ОтветAPI.message;	
				
			Иначе
				
				ОписаниеОшибки = HTTPОтвет.ОтветAPI.title;	
				
			КонецЕсли;
			
			Сообщение = Новый СообщениеПользователю;
			Сообщение.Текст = "Ошибка при создании поставки. Подробное описание ошибки можно посмотреть в журнале регистрации";
			Сообщение.Сообщить();
			
			Комментарий = СтрШаблон("Маркетплейс: Wildberries%1Аккаунт: %2%1Код состояния: %3%1Описание ошибки: %4", 
			Символы.ПС, Аккаунт, КодЗапроса, ОписаниеОшибки);
			
			ЗаписьЖурналаРегистрации(НазваниеОшибки,УровеньЖурналаРегистрации.Ошибка,,,Комментарий,);
			
			Возврат "";
			
		Иначе
			
			Возврат HTTPОтвет.ОтветAPI.id;			
			
		КонецЕсли;
		
	Иначе
		
		НазваниеОшибки = "Ошибка при создании поставки в Wildberries";
		
		ОписаниеОшибки = "Ошибка при получении JSON. Некорректные значения JSON";	
		
		Сообщение = Новый СообщениеПользователю;
		Сообщение.Текст = "Ошибка при создании поставки. Подробное описание ошибки можно посмотреть в журнале регистрации";
		Сообщение.Сообщить();
		
		Комментарий = СтрШаблон("Маркетплейс: Wildberries%1Аккаунт: %2%1Код состояния: %3%1Описание ошибки: %4", 
		Символы.ПС, Аккаунт, КодЗапроса, ОписаниеОшибки);
		
		ЗаписьЖурналаРегистрации(НазваниеОшибки,УровеньЖурналаРегистрации.Ошибка,,,Комментарий,);
		
		Возврат "";
		
	КонецЕсли;
	
КонецФункции

Функция Wildberries_ДобавитьЗаказКПоставке(Аккаунт, НомерПоставки, МассивЗаказов) Экспорт
	
	МассивДобавленныхЗаказов = Новый Массив;
	
	КоличествоЗапросов = 0;
	
	Для каждого НомерЗаказа Из МассивЗаказов Цикл
		
		HTTPОтвет = рар_мп_Wildberries_Методы.Метод_ДобавитьСборочноеЗаданиеКПоставке(Аккаунт, НомерПоставки, НомерЗаказа);
		
		КодЗапроса = HTTPОтвет.КодСостояния;
		
		Если КодЗапроса <> 204 Тогда
			
			Если HTTPОтвет.Свойство("ОтветAPI") Тогда
				
				НазваниеОшибки = "Ошибка при добавлении заказа в поставку в Wildberries";
				
				Если HTTPОтвет.ОтветAPI.Свойство("message") Тогда
					
					ОписаниеОшибки = HTTPОтвет.ОтветAPI.message;	
					
				Иначе
					
					ОписаниеОшибки = HTTPОтвет.ОтветAPI.title;	
					
				КонецЕсли;
				
				Сообщение = Новый СообщениеПользователю;
				Сообщение.Текст = СтрШаблон("Ошибка при добавлении заказа %1 в поставку. Подробное описание ошибки можно посмотреть в журнале регистрации",
				НомерЗаказа);
				Сообщение.Сообщить();
				
				Комментарий = СтрШаблон("Маркетплейс: Wildberries%1Аккаунт: %2%1Код состояния: %3%1Номер поставки: %4%1Номер заказа: %5%1Описание ошибки: %6", 
				Символы.ПС, Аккаунт, КодЗапроса, НомерПоставки, НомерЗаказа, ОписаниеОшибки);
				
				ЗаписьЖурналаРегистрации(НазваниеОшибки,УровеньЖурналаРегистрации.Ошибка,,,Комментарий,);
				
			Иначе
				
				НазваниеОшибки = "Ошибка при добавлении заказа в поставку в Wildberries";
				
				ОписаниеОшибки = "Ошибка при получении JSON. Некорректные значения JSON";	
				
				Сообщение = Новый СообщениеПользователю;
				Сообщение.Текст = СтрШаблон("Ошибка при добавлении заказа %1 в поставку. Подробное описание ошибки можно посмотреть в журнале регистрации",
				НомерЗаказа);
				Сообщение.Сообщить();
				
				Комментарий = СтрШаблон("Маркетплейс: Wildberries%1Аккаунт: %2%1Код состояния: %3%1Номер поставки: %4%1Номер заказа: %5%1Описание ошибки: %6", 
				Символы.ПС, Аккаунт, КодЗапроса, НомерПоставки, НомерЗаказа, ОписаниеОшибки);
				
				ЗаписьЖурналаРегистрации(НазваниеОшибки,УровеньЖурналаРегистрации.Ошибка,,,Комментарий,);
				
				
			КонецЕсли;
			
		Иначе
			
			МассивДобавленныхЗаказов.Добавить(НомерЗаказа);			
			
		КонецЕсли; 
		
		КоличествоЗапросов = КоличествоЗапросов + 1;
		
		Если КоличествоЗапросов = 1000 Тогда
			
			КоличествоЗапросов = 0;
			
			ВремяОжидания = 60;
			
			КонДата = ТекущаяДата() + ВремяОжидания;
			
			Пока ТекущаяДата() < КонДата Цикл
				
			КонецЦикла;
			
		КонецЕсли;
		
	КонецЦикла;
	
	
	Возврат МассивДобавленныхЗаказов;
	
	
КонецФункции

Функция Wildberries_ПередачаМаркировкиВМаркетплейс(Аккаунт, Заказы, МаркируемыеТовары) Экспорт
	
	КоличествоЗапросов = 0;
	
	Для каждого Строка Из Заказы Цикл
		
		НомерЗаказа = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Строка.рар_мп_Заказ, "НомерПоДаннымКлиента");
		
		НайденныеСтроки = МаркируемыеТовары.НайтиСтроки(Новый Структура("рар_мп_НомерЗаказа", НомерЗаказа));
		
		МассивМаркировок = Новый Массив;
		
		Для каждого Строка Из НайденныеСтроки Цикл
			
			Если Строка.рар_мп_ЗаполнениеМаркировки Тогда
				
				Маркировка = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Строка.рар_мп_ЧестныйЗнак, "ЗначениеШтрихкода");
				
				МассивМаркировок.Добавить(Маркировка);	
				
			КонецЕсли;	
			
		КонецЦикла;
		
		Если МассивМаркировок.Количество() > 0 Тогда
			
			HTTPОтвет = рар_мп_Wildberries_Методы.Метод_ПередачаМаркировки(Аккаунт, НомерЗаказа, МассивМаркировок);
			
			КодЗапроса = HTTPОтвет.КодСостояния;
			
			Если КодЗапроса <> 204 Тогда
				
				НазваниеОшибки = "Ошибка при передаче маркировки в Wildberries";
				
				Если HTTPОтвет.Свойство("ОтветAPI") Тогда
					
					Если HTTPОтвет.ОтветAPI.Свойство("message") Тогда
						
						ОписаниеОшибки = HTTPОтвет.ОтветAPI.message;	
						
					Иначе
						
						ОписаниеОшибки = HTTPОтвет.ОтветAPI.detail;	
						
					КонецЕсли;
					
				Иначе
					
					ОписаниеОшибки = "Ошибка при получении JSON. Некорректные значения JSON";
					
				КонецЕсли;
				
				Сообщение = Новый СообщениеПользователю;
				Сообщение.Текст = СтрШаблон("Ошибка при передаче маркировки в маркетплейс (номер заказа: %1). Подробное описание ошибки можно посмотреть в журнале регистрации",
				НомерЗаказа);
				Сообщение.Сообщить();
				
				Комментарий = СтрШаблон("Маркетплейс: Wildberries%1Аккаунт: %2%1Код состояния: %3%1Номер заказа: %4%1Описание ошибки: %5", 
				Символы.ПС, Аккаунт, КодЗапроса, НомерЗаказа, ОписаниеОшибки);
				
				ЗаписьЖурналаРегистрации(НазваниеОшибки,УровеньЖурналаРегистрации.Ошибка,,,Комментарий,);
				
				Возврат Ложь;
				
			КонецЕсли;
			
			КоличествоЗапросов = КоличествоЗапросов + 1;
			
			Если КоличествоЗапросов = 1000 Тогда
				
				КоличествоЗапросов = 0;
				
				ВремяОжидания = 60;
				
				КонДата = ТекущаяДата() + ВремяОжидания;
				
				Пока ТекущаяДата() < КонДата Цикл
					
				КонецЦикла;
				
			КонецЕсли;	
			
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат Истина;
	
