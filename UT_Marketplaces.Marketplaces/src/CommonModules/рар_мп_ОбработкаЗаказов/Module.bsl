#Область Ozon

Функция Ozon_ПолучитьЭтикетки(Аккаунт, Заказы) Экспорт
	
	МассивФайлов = Новый Массив;
	
	HTTPОтвет = рар_мп_Ozon_Методы.Метод_СозданиеЗаданияНаФормированиеЭтикеток(Аккаунт, Заказы);
	
	КодЗапроса = HTTPОтвет.КодСостояния;
	
	Если HTTPОтвет.Свойство("ОтветAPI") Тогда
		
		Если КодЗапроса <> 200 Тогда
			
			НазваниеОшибки = "Ошибка при формировании задания на формирования этикеток в Ozon";
			
			ОписаниеОшибки = HTTPОтвет.ОтветAPI.message;	
			
			Сообщение = Новый СообщениеПользователю;
			Сообщение.Текст = "Ошибка при формировании задания на формирования этикеток. Подробное описание ошибки можно посмотреть в журнале регистрации";
			Сообщение.Сообщить();
			
