				Символы.ПС, Аккаунт, КодЗапроса, НомерЗаказа, ОписаниеОшибки);
				
				ЗаписьЖурналаРегистрации(НазваниеОшибки,УровеньЖурналаРегистрации.Ошибка,,,Комментарий,);
				
				Возврат Ложь;
				
			Иначе
				
				НазваниеОшибки = "Ошибка при изменении статуса заказа в Яндекс Маркет";
				
				Сообщение = Новый СообщениеПользователю;
				Сообщение.Текст = "Ошибка при изменении статуса заказа. Подробное описание ошибки можно посмотреть в журнале регистрации";
				Сообщение.Сообщить();
				
				ОписаниеОшибки = "Ошибка при получении JSON. Некорректные значения JSON";
				
				Комментарий = СтрШаблон("Маркетплейс: Яндекс Маркет%1Аккаунт: %2%1Код состояния: %3%1Номер заказа: %4%1Описание ошибки: %5", 
				Символы.ПС, Аккаунт, КодЗапроса, НомерЗаказа, ОписаниеОшибки);
				
				ЗаписьЖурналаРегистрации(НазваниеОшибки,УровеньЖурналаРегистрации.Ошибка,,,Комментарий,);
				
				Возврат Ложь;
				
			КонецЕсли;
			
		КонецЕсли;	
		
	КонецЦикла;
	
	Возврат Истина;				
	
КонецФункции

Функция ЯндексМаркет_ПодтверждениеОтгрузки(Аккаунт, ВыгрузкаCampaignId) Экспорт
	
	МассивCampaignId = ВыгрузкаCampaignId.ВыгрузитьКолонку("рар_мп_ИдентификаторСклада");
	
	Для каждого Идентификатор Из МассивCampaignId Цикл
		
		HTTPОтвет = рар_мп_ЯндексМаркет_Методы.Метод_ПодтверждениеОгрузки(Аккаунт, Идентификатор);
		
		КодЗапроса = HTTPОтвет.КодСостояния;
		
		Если КодЗапроса <> 200 Тогда
			
			НазваниеОшибки = "Ошибка при подтверждении отгрузки в Яндекс Маркет";
			
			Если HTTPОтвет.Свойство("ОтветAPI") Тогда
				
				ОписаниеОшибки = HTTPОтвет.ОтветAPI.errors.Получить(0).message;
				
			Иначе
				
				ОписаниеОшибки = "Ошибка при получении JSON. Некорректные значения JSON";
				
			КонецЕсли;
			
			Сообщение = Новый СообщениеПользователю;
			Сообщение.Текст = "Ошибка при подтверждении отгрузки. Подробное описание ошибки можно посмотреть в журнале регистрации";
			Сообщение.Сообщить();
			
			Комментарий = СтрШаблон("Маркетплейс: Яндекс Маркет%1Аккаунт: %2%1Код состояния: %3%1CampaignId: %4%1Описание ошибки: %5", 
			Символы.ПС, Аккаунт, КодЗапроса, Идентификатор, ОписаниеОшибки);
			
			ЗаписьЖурналаРегистрации(НазваниеОшибки,УровеньЖурналаРегистрации.Ошибка,,,Комментарий,);
			
			Возврат Ложь;			
			
		КонецЕсли;		
		
	КонецЦикла;
	
	Возврат Истина;
КонецФункции

Функция ЯндексМаркет_ПолучитьЭтикеткиЗаказов(Аккаунт, Заказы) Экспорт
	
	МассивФайлов = Новый Массив;
	
	МассивЗаказов = Новый Массив;
	
	Для каждого Заказ Из Заказы Цикл
		
		МассивЗаказов.Добавить(Заказ);
		
		Если МассивЗаказов.Количество() = 1000 ИЛИ МассивЗаказов.Количество() = Заказы.Количество() Тогда
			
			HTTPОтвет = рар_мп_ЯндексМаркет_Методы.Метод_ПолучитьЭтикетки(Аккаунт, Заказы);
			
			КодЗапроса = HTTPОтвет.КодСостояния;
			
			Если HTTPОтвет.Свойство("ОтветAPI") Тогда
				
				Если КодЗапроса <> 200 Тогда
					
					НазваниеОшибки = "Ошибка при получении этикеток в Яндекс Маркет";
					
					ОписаниеОшибки = HTTPОтвет.ОтветAPI.errors.Получить(0).message;	
					
					Сообщение = Новый СообщениеПользователю;
					Сообщение.Текст = "Ошибка при получении этикеток. Подробное описание ошибки можно посмотреть в журнале регистрации";
					Сообщение.Сообщить();
					
					Комментарий = СтрШаблон("Маркетплейс: Яндекс Маркет%1Аккаунт: %2%1Код состояния: %3%1Описание ошибки: %4", 
					Символы.ПС, Аккаунт, КодЗапроса, ОписаниеОшибки);
					
					ЗаписьЖурналаРегистрации(НазваниеОшибки,УровеньЖурналаРегистрации.Ошибка,,,Комментарий,);
					
					МассивФайлов.Очистить();
					
					Возврат МассивФайлов;
					
				Иначе
					
					Если HTTPОтвет.ОтветAPI.status = "OK" Тогда
						
						Если HTTPОтвет.ОтветAPI.result.Свойство("reportId") Тогда
							
							НомерОтчета = HTTPОтвет.ОтветAPI.result.reportId;
							
							Статус = "";
							
							Пока Статус <> "DONE" И Статус <> "FAILED" Цикл
								
								HTTPОтвет = рар_мп_ЯндексМаркет_Методы.Метод_ПолучитьГотовыйОтчет(Аккаунт, НомерОтчета);
								
								КодЗапроса = HTTPОтвет.КодСостояния;
								
								Если HTTPОтвет.Свойство("ОтветAPI") Тогда
									
									Если КодЗапроса <> 200 Тогда
										
										НазваниеОшибки = "Ошибка при получении этикеток в Яндекс Маркет";
										
										ОписаниеОшибки = HTTPОтвет.ОтветAPI.errors.Получить(0).message;	
										
										Сообщение = Новый СообщениеПользователю;
										Сообщение.Текст = "Ошибка при получении этикеток. Подробное описание ошибки можно посмотреть в журнале регистрации";
										Сообщение.Сообщить();
										
										Комментарий = СтрШаблон("Маркетплейс: Яндекс Маркет%1Аккаунт: %2%1Код состояния: %3%1Описание ошибки: %4", 
										Символы.ПС, Аккаунт, КодЗапроса, ОписаниеОшибки);
										
										ЗаписьЖурналаРегистрации(НазваниеОшибки,УровеньЖурналаРегистрации.Ошибка,,,Комментарий,);
										
										МассивФайлов.Очистить();
										
										Возврат МассивФайлов;
										
									Иначе
										
										Статус = HTTPОтвет.ОтветAPI.result.status;	
										
									КонецЕсли;
									
								Иначе
									
									НазваниеОшибки = "Ошибка при получении этикеток в Яндекс Маркет";
									
									ОписаниеОшибки = "Ошибка при получении JSON. Некорректные значения JSON";	
									
									Сообщение = Новый СообщениеПользователю;
									Сообщение.Текст = "Ошибка при получении этикеток. Подробное описание ошибки можно посмотреть в журнале регистрации";
									Сообщение.Сообщить();
									
									Комментарий = СтрШаблон("Маркетплейс: Яндекс Маркет%1Аккаунт: %2%1Описание ошибки: %3", 
									Символы.ПС, Аккаунт, ОписаниеОшибки);
									
									ЗаписьЖурналаРегистрации(НазваниеОшибки,УровеньЖурналаРегистрации.Ошибка,,,Комментарий,);
									
									МассивФайлов.Очистить();
									
									Возврат МассивФайлов;
									
								КонецЕсли;
								
							КонецЦикла;
							
							Если Статус = "DONE" Тогда
								
								СсылкаНаФайл = HTTPОтвет.ОтветAPI.result.file;
								
								СсылкаНаСоединение = "market-mbi-prod.s3-private.mds.yandex.net";
								
								СсылкаНаФайл = СтрЗаменить(СсылкаНаФайл, "https://" + СсылкаНаСоединение + "/", "");
								
								Соединение = Новый HTTPСоединение(СсылкаНаСоединение, 443,,,,, Новый ЗащищенноеСоединениеOpenSSL());
								Запрос = Новый HTTPЗапрос(СсылкаНаФайл);
								Ответ = Соединение.Получить(Запрос);
								ДвоичныеДанные = Ответ.ПолучитьТелоКакДвоичныеДанные();
								
								МассивФайлов.Добавить(ДвоичныеДанные);	
								
							Иначе
								
								НазваниеОшибки = "Ошибка при получении этикеток в Яндекс Маркет";
								
								ОписаниеОшибки = "Статус получения этикеток 'FAILED'";	
								
								Сообщение = Новый СообщениеПользователю;
								Сообщение.Текст = "Ошибка при получении этикеток. Подробное описание ошибки можно посмотреть в журнале регистрации";
								Сообщение.Сообщить();
								
								Комментарий = СтрШаблон("Маркетплейс: Яндекс Маркет%1Аккаунт: %2%1Описание ошибки: %3", 
								Символы.ПС, Аккаунт, ОписаниеОшибки);
								
								ЗаписьЖурналаРегистрации(НазваниеОшибки,УровеньЖурналаРегистрации.Ошибка,,,Комментарий,);
								
								МассивФайлов.Очистить();
								
								Возврат МассивФайлов;
								
							КонецЕсли;
							
						Иначе
							
							НазваниеОшибки = "Ошибка при получении этикеток в Яндекс Маркет";
							
							ОписаниеОшибки = ОписаниеОшибки();	
							
							Сообщение = Новый СообщениеПользователю;
							Сообщение.Текст = "Ошибка при получении этикеток. Подробное описание ошибки можно посмотреть в журнале регистрации";
							Сообщение.Сообщить();
							
							Комментарий = СтрШаблон("Маркетплейс: Яндекс Маркет%1Аккаунт: %2%1Описание ошибки: %3", 
							Символы.ПС, Аккаунт, ОписаниеОшибки);
							
							ЗаписьЖурналаРегистрации(НазваниеОшибки,УровеньЖурналаРегистрации.Ошибка,,,Комментарий,);
							
							МассивФайлов.Очистить();
							
							Возврат МассивФайлов;
							
							
						КонецЕсли;	
						
					Иначе
						
						НазваниеОшибки = "Ошибка при получении этикеток в Яндекс Маркет";
						
						ОписаниеОшибки = "При обработке запроса произошла ошибка";	
						
						Сообщение = Новый СообщениеПользователю;
						Сообщение.Текст = "Ошибка при получении этикеток. Подробное описание ошибки можно посмотреть в журнале регистрации";
						Сообщение.Сообщить();
						
						Комментарий = СтрШаблон("Маркетплейс: Яндекс Маркет%1Аккаунт: %2%1Описание ошибки: %3", 
						Символы.ПС, Аккаунт, ОписаниеОшибки);
						
						ЗаписьЖурналаРегистрации(НазваниеОшибки,УровеньЖурналаРегистрации.Ошибка,,,Комментарий,);
						
						МассивФайлов.Очистить();
						
						Возврат МассивФайлов;	
						
					КонецЕсли;
					
				КонецЕсли;
				
				МассивЗаказов.Очистить(); 
				
			Иначе
				
				НазваниеОшибки = "Ошибка при получении этикеток в Яндекс Маркет";
				
				ОписаниеОшибки = "Ошибка при получении JSON. Некорректные значения JSON";	
				
				Сообщение = Новый СообщениеПользователю;
				Сообщение.Текст = "Ошибка при получении этикеток. Подробное описание ошибки можно посмотреть в журнале регистрации";
				Сообщение.Сообщить();
				
				Комментарий = СтрШаблон("Маркетплейс: Яндекс Маркет%1Аккаунт: %2%1Описание ошибки: %3", 
				Символы.ПС, Аккаунт, ОписаниеОшибки);
				
				ЗаписьЖурналаРегистрации(НазваниеОшибки,УровеньЖурналаРегистрации.Ошибка,,,Комментарий,);
				
				МассивФайлов.Очистить();
				
				Возврат МассивФайлов;
				
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат МассивФайлов;
	
КонецФункции

