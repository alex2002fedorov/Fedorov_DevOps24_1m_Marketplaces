Функция Wildberries_УдалитьИзКоробки(Аккаунт, НомерПоставки, СтрокиДляУдаления) Экспорт
	
	МассивСтрокДляУдаления = Новый Массив;
	
	КоличествоЗапросов = 0;
	
	Для Счетчик = 0 По СтрокиДляУдаления.Количество() - 1 Цикл
		
		Строка = СтрокиДляУдаления[Счетчик];
		
		Если МассивСтрокДляУдаления.Найти(Строка) = Неопределено Тогда
			
			НомерКоробки = Строка.рар_мп_Коробка;
			НомерЗаказа	 = Строка.рар_мп_НомерЗаказа;
			НомерСтроки	 = Строка.рар_мп_СтрокаИзТЧТовары;
			Артикул		 = Строка.рар_мп_Артикул;
			
			HTTPОтвет = рар_мп_Wildberries_Методы.Метод_УдалитьЗаказИзКороба(Аккаунт, НомерПоставки, НомерКоробки, НомерЗаказа);
			
			КодЗапроса = HTTPОтвет.КодСостояния;
			
			Если КодЗапроса <> 204 Тогда
				
				НазваниеОшибки = "Ошибка при удалении заказов из поставки в Wildberries";
				
				Если HTTPОтвет.Свойство("ОтветAPI") Тогда
					
					Если HTTPОтвет.ОтветAPI.Свойство("message") Тогда
						
						ОписаниеОшибки = HTTPОтвет.ОтветAPI.message;	
						
					Иначе
						
						ОписаниеОшибки = HTTPОтвет.ОтветAPI.detail;	
						
					КонецЕсли;
					
				Иначе
					
					ОписаниеОшибки = "Ошибка при получении JSON. Некорректные значения JSON";	
					
				КонецЕсли;
				
				Сообщение = Новый СообщениеПользователю;
				Сообщение.Текст = "Ошибка при удалении заказов из поставки. Подробное описание ошибки можно посмотреть в журнале регистрации";
				Сообщение.Сообщить();
				
				Комментарий = СтрШаблон("Маркетплейс: Wildberries%1Аккаунт: %2%1Код состояния: %3%1НомерПоставки: %4%1НомерКоробки: %5
				|НомерЗаказа: %6%1Описание ошибки: %7", 
				Символы.ПС, Аккаунт, КодЗапроса, НомерПоставки, НомерКоробки, НомерЗаказа, ОписаниеОшибки);
				
				ЗаписьЖурналаРегистрации(НазваниеОшибки,УровеньЖурналаРегистрации.Ошибка,,,Комментарий,);
				
				Возврат МассивСтрокДляУдаления;
				
			Иначе
				
				МассивСтрокДляУдаления.Добавить(Строка);
				
				Если Счетчик + 1 <= СтрокиДляУдаления.Количество() - 1 Тогда
					
					Для Индекс = Счетчик + 1 По СтрокиДляУдаления.Количество() - 1 Цикл
						
						СледующаяСтрока = СтрокиДляУдаления[Индекс];
						
						СледующаяСтрока_НомерКоробки = СледующаяСтрока.рар_мп_Коробка;
						СледующаяСтрока_НомерЗаказа	 = СледующаяСтрока.рар_мп_НомерЗаказа;
						СледующаяСтрока_НомерСтроки	 = СледующаяСтрока.рар_мп_СтрокаИзТЧТовары;
						СледующаяСтрока_Артикул		 = СледующаяСтрока.рар_мп_Артикул;
						
						Если СледующаяСтрока_НомерКоробки = НомерКоробки И СледующаяСтрока_НомерЗаказа = НомерЗаказа И
							СледующаяСтрока_НомерСтроки = НомерСтроки И СледующаяСтрока_Артикул = Артикул Тогда
							
							МассивСтрокДляУдаления.Добавить(СледующаяСтрока);		
							
						КонецЕсли;
						
						
					КонецЦикла;	
					
				КонецЕсли;
				
			КонецЕсли;
			
			КоличествоЗапросов = КоличествоЗапросов + 1;
			
			Если КоличествоЗапросов = 300 Тогда
				
				КоличествоЗапросов = 0;
				
				ВремяОжидания = 60;
				
				КонДата = ТекущаяДата() + ВремяОжидания;
				
				Пока ТекущаяДата() < КонДата Цикл
					
				КонецЦикла;
				
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат МассивСтрокДляУдаления;	
	
КонецФункции

Функция Wildberries_ПолучитьЭтикеткиЗаказов(Аккаунт, МассивНомеровЗаказов) Экспорт
	
	МассивЭтикеток = Новый Массив;
	
	МассивИзСтаНомеровЗаказов = Новый Массив;
	
	КоличествоЗапросов = 0;
	
	Для каждого НомерЗаказа Из МассивНомеровЗаказов Цикл
		
		МассивИзСтаНомеровЗаказов.Добавить(НомерЗаказа);
		
		Если МассивИзСтаНомеровЗаказов.Количество() = 100 ИЛИ МассивНомеровЗаказов.Количество() = МассивИзСтаНомеровЗаказов.Количество() Тогда
			
			HTTPОтвет = рар_мп_Wildberries_Методы.Метод_ПолучитьСтикерыСборочныхЗаданий(Аккаунт, МассивИзСтаНомеровЗаказов);
			
			КодЗапроса = HTTPОтвет.КодСостояния;
			
			Если HTTPОтвет.Свойство("ОтветAPI") Тогда 
				
				Если КодЗапроса <> 200 Тогда
					
					НазваниеОшибки = "Ошибка при получении этикеток заказов в Wildberries";
					
					Если HTTPОтвет.ОтветAPI.Свойство("message") Тогда
						
						ОписаниеОшибки = HTTPОтвет.ОтветAPI.message;	
						
					Иначе
						
						ОписаниеОшибки = HTTPОтвет.ОтветAPI.detail;	
						
					КонецЕсли;
					
					Сообщение = Новый СообщениеПользователю;
					Сообщение.Текст = "Ошибка при получении этикеток заказов. Подробное описание ошибки можно посмотреть в журнале регистрации";
					Сообщение.Сообщить();
					
					Комментарий = СтрШаблон("Маркетплейс: Wildberries%1Аккаунт: %2%1Код состояния: %3%1Описание ошибки: %4", 
					Символы.ПС, Аккаунт, КодЗапроса, ОписаниеОшибки);
					
					ЗаписьЖурналаРегистрации(НазваниеОшибки,УровеньЖурналаРегистрации.Ошибка,,,Комментарий,);
					
					МассивЭтикеток.Очистить();
					
					Возврат МассивЭтикеток;
					
					
				Иначе
					
					Для каждого Строка Из HTTPОтвет.ОтветAPI.stickers Цикл
						
						МассивЭтикеток.Добавить(Base64Значение(Строка.file));	
						
					КонецЦикла;
					
					
				КонецЕсли;
				
			Иначе
				
				ОписаниеОшибки = "Ошибка при получении JSON. Некорректные значения JSON";
				
				Сообщение = Новый СообщениеПользователю;
				Сообщение.Текст = "Ошибка при получении этикеток заказов. Подробное описание ошибки можно посмотреть в журнале регистрации";
				Сообщение.Сообщить();
				
				Комментарий = СтрШаблон("Маркетплейс: Wildberries%1Аккаунт: %2%1Код состояния: %3%1Описание ошибки: %4", 
				Символы.ПС, Аккаунт, КодЗапроса, ОписаниеОшибки);
				
				ЗаписьЖурналаРегистрации(НазваниеОшибки,УровеньЖурналаРегистрации.Ошибка,,,Комментарий,);
				
				МассивЭтикеток.Очистить();
				
				Возврат МассивЭтикеток;
				
			КонецЕсли;
			
			МассивИзСтаНомеровЗаказов.Очистить();
			
			КоличествоЗапросов = КоличествоЗапросов + 1;
			
			Если КоличествоЗапросов = 300 Тогда
				
				КоличествоЗапросов = 0;
				
				ВремяОжидания = 60;
				
				КонДата = ТекущаяДата() + ВремяОжидания;
				
				Пока ТекущаяДата() < КонДата Цикл
					
				КонецЦикла;
				
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат МассивЭтикеток;
	
КонецФункции

