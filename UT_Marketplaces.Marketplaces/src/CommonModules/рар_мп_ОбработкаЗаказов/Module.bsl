						МассивЭтикеток.Добавить(Новый Структура("НомерЗаказа, partA, partB", Формат(Строка.orderId, "ЧГ="), Строка.partA, Строка.partB));	
						
					КонецЦикла;
					
					
				КонецЕсли;
				
			Иначе
				
				ОписаниеОшибки = "Ошибка при получении JSON. Некорректные значения JSON";
				
				Сообщение = Новый СообщениеПользователю;
				Сообщение.Текст = "Ошибка при получении  информации об этикетках для заказов. Подробное описание ошибки можно посмотреть в журнале регистрации";
				Сообщение.Сообщить();
				
				Комментарий = СтрШаблон("Маркетплейс: Wildberries%1Аккаунт: %2%1Код состояния: %3%1Описание ошибки: %4", 
				Символы.ПС, Аккаунт, КодЗапроса, ОписаниеОшибки);
				
				ЗаписьЖурналаРегистрации(НазваниеОшибки,УровеньЖурналаРегистрации.Ошибка,,,Комментарий,);
				
				МассивЭтикеток.Очистить();
				
				Возврат МассивЭтикеток;
				
			КонецЕсли;
			
			МассивИзСтаНомеровЗаказов.Очистить();
			
			КоличествоЗапросов = КоличествоЗапросов + 1;
			
			Если КоличествоЗапросов = 300 Тогда
				
				КоличествоЗапросов = 0;
				
				ВремяОжидания = 60;
				
				КонДата = ТекущаяДата() + ВремяОжидания;
				
				Пока ТекущаяДата() < КонДата Цикл
					
				КонецЦикла;
				
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат МассивЭтикеток;	
	
КонецФункции

