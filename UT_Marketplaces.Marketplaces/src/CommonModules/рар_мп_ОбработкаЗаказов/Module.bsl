#Область ЯндексМаркет

Функция ЯндексМаркет_ПередачаМаркировки(Аккаунт, Заказы, РаспределенныеТовары, МаркируемыеТовары, Коробки) Экспорт
	
	Для каждого Заказ Из Заказы Цикл
		
		НайденныеСтроки = МаркируемыеТовары.НайтиСтроки(Новый Структура("рар_мп_НомерЗаказа", Заказ.рар_мп_НомерЗаказа));
		
		МаркированныеТоварыДляДанногоЗаказа = МаркируемыеТовары.Скопировать(НайденныеСтроки);
		
		НайденныеСтроки = РаспределенныеТовары.НайтиСтроки(Новый Структура("рар_мп_НомерЗаказа", Заказ.рар_мп_НомерЗаказа)); 
		
		РаспределенныеТоварыДляДанногоЗаказа = РаспределенныеТовары.Скопировать(НайденныеСтроки);
		
		НайденныеСтроки = Коробки.НайтиСтроки(Новый Структура("рар_мп_НомерЗаказа", Заказ.рар_мп_НомерЗаказа));
		
		КоробкиДляДанногоЗаказа = Коробки.Скопировать(НайденныеСтроки);
		
		НомерЗаказа = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Заказ.рар_мп_Заказ, "НомерПоДаннымКлиента");
		
		УникальныйИдентификаторСклада = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Заказ.рар_мп_Заказ, "рар_мп_УникальныйИдентификаторСклада");
		
		HTTPОтвет = рар_мп_ЯндексМаркет_Методы.Метод_ПодготовкаЗаказов(Аккаунт, УникальныйИдентификаторСклада, НомерЗаказа, 
		РаспределенныеТоварыДляДанногоЗаказа, МаркированныеТоварыДляДанногоЗаказа,
		КоробкиДляДанногоЗаказа);
		
		КодЗапроса = HTTPОтвет.КодСостояния;
		
		Если КодЗапроса <> 200 Тогда
			
			Если HTTPОтвет.Свойство("ОтветAPI") Тогда
				
				НазваниеОшибки = "Ошибка при передаче маркировки в Яндекс Маркет";
				
				ОписаниеОшибки = HTTPОтвет.ОтветAPI.errors.Получить(0).message;	
				
				Сообщение = Новый СообщениеПользователю;
				Сообщение.Текст = "Ошибка при передаче маркировки. Подробное описание ошибки можно посмотреть в журнале регистрации";
				Сообщение.Сообщить();
				
				Комментарий = СтрШаблон("Маркетплейс: Яндекс Маркет%1Аккаунт: %2%1Код состояния: %3%1Описание ошибки: %4", 
				Символы.ПС, Аккаунт, КодЗапроса, ОписаниеОшибки);
				
				ЗаписьЖурналаРегистрации(НазваниеОшибки,УровеньЖурналаРегистрации.Ошибка,,,Комментарий,);
				
				Возврат Ложь; 
				
			Иначе
				
				НазваниеОшибки = "Ошибка при передаче маркировки в Яндекс Маркет";
				
				Сообщение = Новый СообщениеПользователю;
				Сообщение.Текст = "Ошибка при передаче маркировки. Подробное описание ошибки можно посмотреть в журнале регистрации";
				Сообщение.Сообщить();
				
				ОписаниеОшибки = "Ошибка при получении JSON. Некорректные значения JSON";
				
				Комментарий = СтрШаблон("Маркетплейс: Яндекс Маркет%1Аккаунт: %2%1Код состояния: %3%1Описание ошибки: %4", 
				Символы.ПС, Аккаунт, КодЗапроса, ОписаниеОшибки);
				
				ЗаписьЖурналаРегистрации(НазваниеОшибки, УровеньЖурналаРегистрации.Ошибка,,Комментарий,);
				
				Возврат Ложь;
				
			КонецЕсли;
			
		Иначе
			
			Продолжить;			
			
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат Истина;
	
КонецФункции

Функция ЯндексМаркет_ИзменениеСтатуса(Аккаунт, Заказы, Статус, Подстатус) Экспорт
	
	Для каждого Строка Из Заказы Цикл
		
		Заказ = Строка.рар_мп_Заказ;
		
		НомерЗаказа = Строка.рар_мп_НомерЗаказа;
		
		УникальныйИдентификаторСклада = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Заказ, "рар_мп_УникальныйИдентификаторСклада"); 
		
		HTTPОтвет = рар_мп_ЯндексМаркет_Методы.Метод_ИзменениеСтатуса(Аккаунт, УникальныйИдентификаторСклада, НомерЗаказа, Статус, Подстатус);
		
		КодЗапроса = HTTPОтвет.КодСостояния;
		
		Если КодЗапроса <> 200 Тогда
			
			Если HTTPОтвет.Свойство("ОтветAPI") Тогда
				
