
#Область ЯндексМаркет

Функция ПолучитьОтчетКомиссионера_ЯндексМаркет(Аккаунт, МесяцГод, campaignId) Экспорт
	
	ОтчетыЯндекс = ПолучитьОтчеты_ЯндексМаркет(Аккаунт, campaignId, МесяцГод);
	
	ПутьОтчетПоРеализации = ПолучитьПутьКОтчету_ЯндексМаркет(ОтчетыЯндекс);
	
	ТабЗначДанных = Новый ТаблицаЗначений;
	
	ТабЗначДанных.Колонки.Добавить("НомерСтроки", 				Новый ОписаниеТипов("Число"));
	ТабЗначДанных.Колонки.Добавить("ТипДокумента", 				Новый ОписаниеТипов("ПеречислениеСсылка.рар_мп_ТипДокументаОтчетаКомиссионера"));
	ТабЗначДанных.Колонки.Добавить("НомерЗаказа", 				Новый ОписаниеТипов("Число"));
	ТабЗначДанных.Колонки.Добавить("SKU", 						Новый ОписаниеТипов("Строка"));
	ТабЗначДанных.Колонки.Добавить("Номенклатура", 				Новый ОписаниеТипов("СправочникСсылка.Номенклатура"));
	ТабЗначДанных.Колонки.Добавить("ЕдиницаИзмерения", 			Новый ОписаниеТипов("СправочникСсылка.УпаковкиЕдиницыИзмерения"));
	ТабЗначДанных.Колонки.Добавить("Характеристика", 			Новый ОписаниеТипов("СправочникСсылка.ХарактеристикиНоменклатуры"));
	ТабЗначДанных.Колонки.Добавить("Продано", 					Новый ОписаниеТипов("Число"));
	ТабЗначДанных.Колонки.Добавить("ЦенаЗаШтукуБезУчетаСкидок", Новый ОписаниеТипов("Число"));
	ТабЗначДанных.Колонки.Добавить("ЦенаЗаШтукуСУчетомСкидок", 	Новый ОписаниеТипов("Число"));
	ТабЗначДанных.Колонки.Добавить("ЦенаСуммаБезУчетаСкидок", 	Новый ОписаниеТипов("Число"));
	ТабЗначДанных.Колонки.Добавить("ЦенаСуммаСУчетомСкидок", 	Новый ОписаниеТипов("Число"));
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	рар_мп_ЯндексМаркет_СопоставленныеТовары.SKUТовара КАК SKUТовара,
		|	рар_мп_ЯндексМаркет_СопоставленныеТовары.Номенклатура КАК Номенклатура,
		|	рар_мп_ЯндексМаркет_СопоставленныеТовары.Характеристика КАК Характеристика,
		|	рар_мп_ЯндексМаркет_СопоставленныеТовары.Номенклатура.ЕдиницаИзмерения КАК ЕдиницаИзмерения
		|ИЗ
		|	РегистрСведений.рар_мп_ЯндексМаркет_СопоставленныеТовары КАК рар_мп_ЯндексМаркет_СопоставленныеТовары
		|ГДЕ
		|	рар_мп_ЯндексМаркет_СопоставленныеТовары.Аккаунт = &Аккаунт";
	
	Запрос.УстановитьПараметр("Аккаунт", Аккаунт);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаСопоставленныхТоваров = РезультатЗапроса.Выгрузить();
	
	ПолучитьДанныеИзОтчетаПоРеализации_ЯндексМаркет(Аккаунт, ПутьОтчетПоРеализации, ТабЗначДанных, ВыборкаСопоставленныхТоваров);
	
	Возврат ТабЗначДанных;
	
КонецФункции

Функция ПолучитьОтчеты_ЯндексМаркет(Аккаунт, campaignId, МесяцГод)
	
	МассивФайлов = Новый Массив;
	
	HTTPОтвет = рар_мп_ЯндексМаркет_Методы.Метод_ПолучитьОтчетПоРеализации(Аккаунт, campaignId, Год(МесяцГод), Месяц(МесяцГод));
	
	КодЗапроса = HTTPОтвет.КодСостояния;
	
	Если HTTPОтвет.Свойство("ОтветAPI") Тогда
		
		Если КодЗапроса <> 200 Тогда
			
			НазваниеОшибки = "Ошибка при получении отчета по реализации в Яндекс Маркет";
			
			ОписаниеОшибки = HTTPОтвет.ОтветAPI.errors.Получить(0).message;	
			
			Сообщение = Новый СообщениеПользователю;
			Сообщение.Текст = "Ошибка при получении отчета по реализации. Подробное описание ошибки можно посмотреть в журнале регистрации";
			Сообщение.Сообщить();
			
			Комментарий = СтрШаблон("Маркетплейс: Яндекс Маркет%1Аккаунт: %2%1Код состояния: %3%1Описание ошибки: %4", 
										Символы.ПС, Аккаунт, КодЗапроса, ОписаниеОшибки);
			
			ЗаписьЖурналаРегистрации(НазваниеОшибки,УровеньЖурналаРегистрации.Ошибка,,,Комментарий,);
			
			МассивФайлов.Очистить();
			
			Возврат МассивФайлов;
			
		Иначе
			
			Если HTTPОтвет.ОтветAPI.status = "OK" Тогда
				
				Если HTTPОтвет.ОтветAPI.result.Свойство("reportId") Тогда
					
					НомерОтчета = HTTPОтвет.ОтветAPI.result.reportId;
					
					Статус = "";
					
					Пока Статус <> "DONE" И Статус <> "FAILED" Цикл
						
						HTTPОтвет = рар_мп_ЯндексМаркет_Методы.Метод_ПолучитьГотовыйОтчет(Аккаунт, НомерОтчета);
						
						КодЗапроса = HTTPОтвет.КодСостояния;
						
						Если HTTPОтвет.Свойство("ОтветAPI") Тогда
							
							Если КодЗапроса <> 200 Тогда
								
								НазваниеОшибки = "Ошибка при получении отчета по реализации в Яндекс Маркет";
								
								ОписаниеОшибки = HTTPОтвет.ОтветAPI.errors.Получить(0).message;	
								
								Сообщение = Новый СообщениеПользователю;
								Сообщение.Текст = "Ошибка при получении отчета по реализации. Подробное описание ошибки можно посмотреть в журнале регистрации";
								Сообщение.Сообщить();
								
								Комментарий = СтрШаблон("Маркетплейс: Яндекс Маркет%1Аккаунт: %2%1Код состояния: %3%1Описание ошибки: %4", 
															Символы.ПС, Аккаунт, КодЗапроса, ОписаниеОшибки);
								
								ЗаписьЖурналаРегистрации(НазваниеОшибки,УровеньЖурналаРегистрации.Ошибка,,,Комментарий,);
								
								МассивФайлов.Очистить();
								
								Возврат МассивФайлов;
								
							Иначе
								
								Статус = HTTPОтвет.ОтветAPI.result.status;	
								
							КонецЕсли;
							
						Иначе
							
							НазваниеОшибки = "Ошибка при получении отчета по реализации в Яндекс Маркет";
							
							ОписаниеОшибки = "Ошибка при получении JSON. Некорректные значения JSON";	
							
							Сообщение = Новый СообщениеПользователю;
							Сообщение.Текст = "Ошибка при получении отчета по реализации. Подробное описание ошибки можно посмотреть в журнале регистрации";
							Сообщение.Сообщить();
							
							Комментарий = СтрШаблон("Маркетплейс: Яндекс Маркет%1Аккаунт: %2%1Описание ошибки: %3", 
														Символы.ПС, Аккаунт, ОписаниеОшибки);
							
							ЗаписьЖурналаРегистрации(НазваниеОшибки,УровеньЖурналаРегистрации.Ошибка,,,Комментарий,);
							
							МассивФайлов.Очистить();
							
							Возврат МассивФайлов;
							
						КонецЕсли;
						
					КонецЦикла;
					
					Если Статус = "DONE" Тогда
						
						Если Не HTTPОтвет.ОтветAPI.result.Свойство("subStatus") Тогда
							
							СсылкаНаФайл = HTTPОтвет.ОтветAPI.result.file;
							
							СсылкаНаСоединение = "market-mbi-prod.s3-private.mds.yandex.net";
							
							СсылкаНаФайл = СтрЗаменить(СсылкаНаФайл, "https://" + СсылкаНаСоединение + "/", "");
							
							Соединение = Новый HTTPСоединение(СсылкаНаСоединение, 443,,,,, Новый ЗащищенноеСоединениеOpenSSL());
							Запрос = Новый HTTPЗапрос(СсылкаНаФайл);
							Ответ = Соединение.Получить(Запрос);
							ДвоичныеДанные = Ответ.ПолучитьТелоКакДвоичныеДанные();
							
							МассивФайлов.Добавить(ДвоичныеДанные);	
							
						Иначе
							
							НазваниеОшибки = "Ошибка при получении отчета по реализации в Яндекс Маркет";
							
							ОписаниеОшибки = СтрШаблон("Подстатус генерации отчета: %1", HTTPОтвет.ОтветAPI.result.subStatus);	
							
							Сообщение = Новый СообщениеПользователю;
							Сообщение.Текст = "Ошибка при получении отчета по реализации. Подробное описание ошибки можно посмотреть в журнале регистрации";
							Сообщение.Сообщить();
							
							Комментарий = СтрШаблон("Маркетплейс: Яндекс Маркет%1Аккаунт: %2%1Описание ошибки: %3", 
							Символы.ПС, Аккаунт, ОписаниеОшибки);
							
							ЗаписьЖурналаРегистрации(НазваниеОшибки,УровеньЖурналаРегистрации.Ошибка,,,Комментарий,);
							
							МассивФайлов.Очистить();
							
							Возврат МассивФайлов;
							
						КонецЕсли;
						
					Иначе
						
						НазваниеОшибки = "Ошибка при получении отчета по реализации в Яндекс Маркет";
						
						ОписаниеОшибки = "Статус получения отчета по реализации 'FAILED'";	
						
						Сообщение = Новый СообщениеПользователю;
						Сообщение.Текст = "Ошибка при получении отчета по реализации. Подробное описание ошибки можно посмотреть в журнале регистрации";
						Сообщение.Сообщить();
						
						Комментарий = СтрШаблон("Маркетплейс: Яндекс Маркет%1Аккаунт: %2%1Описание ошибки: %3", 
													Символы.ПС, Аккаунт, ОписаниеОшибки);
						
						ЗаписьЖурналаРегистрации(НазваниеОшибки,УровеньЖурналаРегистрации.Ошибка,,,Комментарий,);
						
						МассивФайлов.Очистить();
						
						Возврат МассивФайлов;
						
					КонецЕсли;
					
				Иначе
					
					НазваниеОшибки = "Ошибка при получении отчета по реализации в Яндекс Маркет";
					
					ОписаниеОшибки = ОписаниеОшибки();	
					
					Сообщение = Новый СообщениеПользователю;
					Сообщение.Текст = "Ошибка при получении отчета по реализации. Подробное описание ошибки можно посмотреть в журнале регистрации";
					Сообщение.Сообщить();
					
					Комментарий = СтрШаблон("Маркетплейс: Яндекс Маркет%1Аккаунт: %2%1Описание ошибки: %3", 
												Символы.ПС, Аккаунт, ОписаниеОшибки);
					
					ЗаписьЖурналаРегистрации(НазваниеОшибки,УровеньЖурналаРегистрации.Ошибка,,,Комментарий,);
					
					МассивФайлов.Очистить();
					
					Возврат МассивФайлов;
					
				КонецЕсли;
				
			Иначе
				
				НазваниеОшибки = "Ошибка при получении отчета по реализации в Яндекс Маркет";
				
				ОписаниеОшибки = "При обработке запроса произошла ошибка";	
				
				Сообщение = Новый СообщениеПользователю;
				Сообщение.Текст = "Ошибка при получении отчета по реализации. Подробное описание ошибки можно посмотреть в журнале регистрации";
				Сообщение.Сообщить();
				
				Комментарий = СтрШаблон("Маркетплейс: Яндекс Маркет%1Аккаунт: %2%1Описание ошибки: %3", 
											Символы.ПС, Аккаунт, ОписаниеОшибки);
				
				ЗаписьЖурналаРегистрации(НазваниеОшибки,УровеньЖурналаРегистрации.Ошибка,,,Комментарий,);
				
				МассивФайлов.Очистить();
				
				Возврат МассивФайлов;
				
			КонецЕсли;
			
		КонецЕсли;
		
	Иначе
		
		НазваниеОшибки = "Ошибка при получении отчета по реализации в Яндекс Маркет";
		
		ОписаниеОшибки = "Ошибка при получении JSON. Некорректные значения JSON";	
		
		Сообщение = Новый СообщениеПользователю;
		Сообщение.Текст = "Ошибка при получении отчета по реализации. Подробное описание ошибки можно посмотреть в журнале регистрации";
		Сообщение.Сообщить();
		
		Комментарий = СтрШаблон("Маркетплейс: Яндекс Маркет%1Аккаунт: %2%1Описание ошибки: %3", 
									Символы.ПС, Аккаунт, ОписаниеОшибки);
		
		ЗаписьЖурналаРегистрации(НазваниеОшибки,УровеньЖурналаРегистрации.Ошибка,,,Комментарий,);
		
		МассивФайлов.Очистить();
		
		Возврат МассивФайлов;
		
	КонецЕсли;
	
