Функция ПолучитьЦеныТоваров_Общая(Аккаунт, ТаблицаТоваров, ТипЗагрузки, ВидЦены, ПутьКФайлуЦен, МассивНомеровКолонок, НачальнаяСтрока) Экспорт
	
	Если ТипЗагрузки = "ВидЦен" Тогда
		
		СписокНоменклатуры = Новый Массив;
		
		ЗаполнитьМассивНоменклатурой(СписокНоменклатуры, ТаблицаТоваров);
		
		ЗаполнитьЦеныПоВидуЦены_Общая(ТаблицаТоваров, СписокНоменклатуры, ВидЦены, Аккаунт.Валюта);
		
	ИначеЕсли ТипЗагрузки = "ОтдельныйExcel" Тогда
		
		ЗаполнитьЦеныИзExcel_Общая(Аккаунт, ТаблицаТоваров, ПутьКФайлуЦен, МассивНомеровКолонок, НачальнаяСтрока);
		
	ИначеЕсли ТипЗагрузки = "СовместныйExcel" Тогда
		
		ЗаполнитьЦеныИзExcel_Общая(Аккаунт, ТаблицаТоваров, ПутьКФайлуЦен, МассивНомеровКолонок, НачальнаяСтрока);
		
	КонецЕсли;
	
	Возврат ТаблицаТоваров;
	
КонецФункции

Процедура ЗаполнитьЦеныПоВидуЦены_Общая(ТаблицаТоваров, СписокНоменклатуры, ВидЦены, Валюта)

	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ЦеныНоменклатурыСрезПоследних.Номенклатура КАК Номенклатура,
		|	ЦеныНоменклатурыСрезПоследних.Характеристика КАК Характеристика,
		|	ЦеныНоменклатурыСрезПоследних.Цена КАК Цена
		|ИЗ
		|	РегистрСведений.ЦеныНоменклатуры.СрезПоследних(
		|			&Дата,
		|			Номенклатура В (&СписокНоменклатуры)
		|				И ВидЦены = &ВидЦены
		|				И Валюта = &Валюта) КАК ЦеныНоменклатурыСрезПоследних";
	
	Запрос.УстановитьПараметр("Валюта", Валюта);
	Запрос.УстановитьПараметр("ВидЦены", ВидЦены);
	Запрос.УстановитьПараметр("Дата", ТекущаяДатаСеанса());
	Запрос.УстановитьПараметр("СписокНоменклатуры", СписокНоменклатуры);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Выборка = РезультатЗапроса.Выбрать();
	
	Пока Выборка.Следующий() Цикл
		
		НайденныеСтрокиНоменклатуры = ТаблицаТоваров.НайтиСтроки(Новый Структура("Номенклатура, Характеристика", Выборка.Номенклатура, Выборка.Характеристика));
		
		Если НайденныеСтрокиНоменклатуры.Количество() > 0 Тогда
			
			Для Каждого Строка Из НайденныеСтрокиНоменклатуры Цикл
				Строка.Цена = Выборка.Цена;
			КонецЦикла;
			
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

Процедура ЗаполнитьЦеныИзExcel_Общая(Аккаунт, ТаблицаТоваров, ПутьКФайлуЦен, МассивНомеровКолонок, НачальнаяСтрока)
	
	Маркетплейс = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Аккаунт, "Маркетплейс");
	
	Если Маркетплейс = Перечисления.рар_мп_Маркетплейсы.Wildberries Тогда
		Название 		= "WB";
		Идентификатор 	= "Баракод";
	ИначеЕсли Маркетплейс = Перечисления.рар_мп_Маркетплейсы.OZON Тогда
		Название 		= "OZON";
		Идентификатор 	= "SKU";
	ИначеЕсли Маркетплейс = Перечисления.рар_мп_Маркетплейсы.ЯндексМаркет Тогда	
		Название 		= "Яндекс Маркет";
		Идентификатор 	= "SKU";
	КонецЕсли;
	
	ТабДок = Новый ТабличныйДокумент;
	
	Попытка
		ТабДок.Прочитать(ПутьКФайлуЦен);
	Исключение
		Сообщение = Новый СообщениеПользователю;
		Сообщение.Текст = "Не удалось прочитать файл. Подробное описание в журнале регистрации";
		Сообщение.Сообщить();
		
		ЗаписьЖурналаРегистрации(СтрШаблон("Ошибка при чтении Excel файла. Загрузка первоначальных остатков %1", Название), 
										УровеньЖурналаРегистрации.Ошибка,,,
										СтрШаблон("Аккаунт: %1. Описание ошибки: %2", Аккаунт.Наименование, ОписаниеОшибки()));
	КонецПопытки;
									
	КоличествоСтрок = ТабДок.ВысотаТаблицы;
	
	НомерКолонкиИдентификатора 	= МассивНомеровКолонок[0];
	НомерКолонкиЦена 			= МассивНомеровКолонок[1];
	
	Для НомерСтроки = НачальнаяСтрока По КоличествоСтрок Цикл
		
		НайденныеСтрокиНоменклатуры = ТаблицаТоваров.НайтиСтроки(Новый Структура(Идентификатор, ТабДок.Область(НомерСтроки, НомерКолонкиИдентификатора).Текст));
		
		Если НайденныеСтрокиНоменклатуры.Количество() > 0 Тогда
			
			Для Каждого Строка Из НайденныеСтрокиНоменклатуры Цикл
				Строка.Цена = ТабДок.Область(НомерСтроки, НомерКолонкиЦена).Текст;
			КонецЦикла;
			
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

#КонецОбласти

#Область СозданиеДокументовПервоначальных

Функция СоздатьВводПервоначальныхОстатков(Данные, Аккаунт, Партия, ОстаткиПодДеятельность, Склад, Помещение, ЗонаПриемки) Экспорт
	
	НовыйДокумент = Документы.ВводОстатков.СоздатьДокумент();
	
	НовыйДокумент.Дата 						= ТекущаяДата();
	НовыйДокумент.ХозяйственнаяОперация 	= Перечисления.ХозяйственныеОперации.ВводОстатковСобственныхТоваров;
	НовыйДокумент.Организация 				= Аккаунт.Организация;
	НовыйДокумент.Партия					= Партия;
	НовыйДокумент.ВидДеятельностиНДС		= ОстаткиПодДеятельность;
	НовыйДокумент.Склад 					= Склад;
	НовыйДокумент.Помещение					= Помещение;
	НовыйДокумент.ЗонаПриемки				= ЗонаПриемки;
	НовыйДокумент.Контрагент 				= Аккаунт.Контрагент;
	НовыйДокумент.Партнер 					= Аккаунт.Контрагент.Партнер;
	НовыйДокумент.Договор 					= Аккаунт.Договор;
	НовыйДокумент.Валюта 					= Аккаунт.Валюта;
	НовыйДокумент.ЦенаВключаетНДС 			= Аккаунт.ЦенаВключаетНДС;
	НовыйДокумент.НалогообложениеНДС 		= Аккаунт.НалогообложениеНДС;
	НовыйДокумент.Подразделение				= Аккаунт.Подразделение;
	НовыйДокумент.Менеджер 					= Аккаунт.Менеджер;
	НовыйДокумент.ОтражатьВОперативномУчете = Истина;
	НовыйДокумент.ОтражатьСебестоимость 	= Истина;
	НовыйДокумент.ОтражатьВБУиНУ			= Аккаунт.ОтражатьВБУиНУ;
	НовыйДокумент.ОтражатьВУУ				= Аккаунт.ОтражатьВУУ;
	НовыйДокумент.Комментарий				= "Создано обработкой ""Загрузка первоначальных остатков (1С-Рарус)""";
	НовыйДокумент.Автор						= Пользователи.ТекущийПользователь();
	
	Для каждого Строка Из Данные Цикл
		
		Если ЗначениеЗаполнено(Строка.Номенклатура) Тогда
			
			СтрокаТЧДокумента = НовыйДокумент.Товары.Добавить();
			СтрокаТЧДокумента.Номенклатура 			= Строка.Номенклатура;
			СтрокаТЧДокумента.Упаковка 				= Строка.ЕдиницаИзмерения;
			СтрокаТЧДокумента.Характеристика 		= Строка.Характеристика;
			СтрокаТЧДокумента.КоличествоУпаковок 	= Строка.Количество;
			СтрокаТЧДокумента.Количество 			= Строка.Количество;
			СтрокаТЧДокумента.Цена					= Строка.Цена;
			СтрокаТЧДокумента.Сумма					= Строка.Количество * Строка. Цена;
			СтрокаТЧДокумента.СтавкаНДС 			= ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Строка.Номенклатура, "СтавкаНДС");
			СтрокаТЧДокумента.СуммаНДС				= УчетНДСКлиентСервер.РассчитатьСуммуНДС(СтрокаТЧДокумента.Сумма, НовыйДокумент.ЦенаВключаетНДС, СтрокаТЧДокумента.СтавкаНДС.Ставка);
			СтрокаТЧДокумента.СуммаБезНДС			= ?(Аккаунт.ЦенаВключаетНДС, СтрокаТЧДокумента.Сумма - СтрокаТЧДокумента.СуммаНДС, СтрокаТЧДокумента.Сумма);
			СтрокаТЧДокумента.СуммаСНДС				= ?(Аккаунт.ЦенаВключаетНДС, СтрокаТЧДокумента.Сумма, СтрокаТЧДокумента.Сумма + СтрокаТЧДокумента.СуммаНДС);
			СтрокаТЧДокумента.СуммаРегл				= СтрокаТЧДокумента.СуммаБезНДС;
			СтрокаТЧДокумента.НДСРегл				= СтрокаТЧДокумента.СуммаНДС;
			
		КонецЕсли;
	
	КонецЦикла;
	
	Попытка
	
		НовыйДокумент.Записать(РежимЗаписиДокумента.Проведение);
		
		Сообщение = Новый СообщениеПользователю;
		Сообщение.Текст = СтрШаблон("Ввод первоначальных остатков создан");
		Сообщение.Сообщить();
	
	Исключение
		
		НовыйДокумент.Записать(РежимЗаписиДокумента.Запись);
		
		Сообщение = Новый СообщениеПользователю;
		Сообщение.Текст = СтрШаблон("Не удалось провести ввод первоначальных остатков. Подробное описание можно посмотреть в журнале регистрации");
		Сообщение.Сообщить();
		
		ЗаписьЖурналаРегистрации("Не удалось провести ввод первоначальных остатков", 
									УровеньЖурналаРегистрации.Ошибка,,, СтрШаблон("Аккаунт: %1. Описание ошибки: %2", Аккаунт.Наименование, ОписаниеОшибки()));
	
	КонецПопытки;
	
	Возврат НовыйДокумент.Ссылка;
	
КонецФункции

Функция СоздатьВводПервоначальныхВзаиморасчетов(Данные, Аккаунт, Подразделение) Экспорт
	
	НовыйДокумент = Документы.ВводОстатковПрочихАктивовПассивов.СоздатьДокумент();
	
	НовыйДокумент.Дата 						= ТекущаяДата();                 
	НовыйДокумент.Организация 				= Аккаунт.Организация; 
	НовыйДокумент.Подразделение				= Подразделение;   
	НовыйДокумент.Валюта 					= Аккаунт.Валюта;
	НовыйДокумент.ХозяйственнаяОперация 	= Перечисления.ХозяйственныеОперации.ВводОстатковПрочихАктивовПассивов;
	НовыйДокумент.Комментарий				= "Создано обработкой ""Загрузка первоначальных остатков (1С-Рарус)""";	
	
	Для каждого Строка Из Данные Цикл
		
		Если ЗначениеЗаполнено(Строка.Сумма_ВР) Тогда
			
			СтрокаТЧДокумента = НовыйДокумент.ПрочиеАктивыПассивы.Добавить(); 
			
			СтрокаТЧДокумента.НаправлениеДеятельности = Строка.НаправлениеДеятельности_ВР; 
			СтрокаТЧДокумента.Статья                  = ПланыВидовХарактеристик.СтатьиАктивовПассивов.ПрибылиИУбытки;
			СтрокаТЧДокумента.Сумма 				  = Строка.Сумма_ВР;
			                                            			
		КонецЕсли;
	
	КонецЦикла;
	
	Попытка
	
		НовыйДокумент.Записать(РежимЗаписиДокумента.Проведение);
		
		Сообщение = Новый СообщениеПользователю;
		Сообщение.Текст = СтрШаблон("Ввод первоначальных взаиморасчетов создан");
		Сообщение.Сообщить();
	
	Исключение
		
		НовыйДокумент.Записать(РежимЗаписиДокумента.Запись);
		
		Сообщение = Новый СообщениеПользователю;
		Сообщение.Текст = СтрШаблон("Не удалось провести ввод первоначальных взаиморасчетов. Подробное описание можно посмотреть в журнале регистрации");
		Сообщение.Сообщить();
		
		ЗаписьЖурналаРегистрации("Не удалось провести ввод первоначальных взаиморасчетов", 
									УровеньЖурналаРегистрации.Ошибка,,, СтрШаблон("Аккаунт: %1. Описание ошибки: %2", Аккаунт.Наименование, ОписаниеОшибки()));
	
	КонецПопытки;
	
	Возврат НовыйДокумент.Ссылка;
	
КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Процедура ЗаполнитьМассивНоменклатурой(МассивНоменклатуры, ТаблицаТоваров)
	
	Для Каждого Строка Из ТаблицаТоваров Цикл
		
		Если ЗначениеЗаполнено(Строка.Номенклатура) Тогда
			
			МассивНоменклатуры.Добавить(Строка.Номенклатура);
			
		КонецЕсли;	
		
	КонецЦикла;
	
КонецПроцедуры

#КонецОбласти