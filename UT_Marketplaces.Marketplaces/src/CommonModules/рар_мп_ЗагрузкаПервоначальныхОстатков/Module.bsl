Процедура ПолучитьОстаткиИзExcel_Wildberries(Аккаунт, ТабЗначДанных, ПутьКФайлуОстатков, СопоставленныеТовары, МассивНомеровКолонок, НачальнаяСтрока)
	
	ТабДок = Новый ТабличныйДокумент;
	
	Попытка
		ТабДок.Прочитать(ПутьКФайлуОстатков);
	Исключение
		Сообщение = Новый СообщениеПользователю;
		Сообщение.Текст = "Не удалось прочитать файл. Подробное описание в журнале регистрации";
		Сообщение.Сообщить();
		
		ЗаписьЖурналаРегистрации("Ошибка при чтении Excel файла. Загрузка первоначальных остатков WB", 
										УровеньЖурналаРегистрации.Ошибка,,,
										СтрШаблон("Аккаунт: %1. Описание ошибки: %2", Аккаунт.Наименование, ОписаниеОшибки()));
	КонецПопытки;
									
	КоличествоСтрок = ТабДок.ВысотаТаблицы;
	
	НомерКолонкиБаракод 	= МассивНомеровКолонок[0];
	НомерКолонкиКоличество 	= МассивНомеровКолонок[1];
	
	Для НомерСтроки = НачальнаяСтрока По КоличествоСтрок Цикл
		
		Попытка
			
			Если ЗначениеЗаполнено(ТабДок.Область(НомерСтроки, НомерКолонкиБаракод).Текст) Тогда
				
				НоваяСтрока = ТабЗначДанных.Добавить();
				НоваяСтрока.НомерСтроки = ТабЗначДанных.Количество();
				НоваяСтрока.Баракод		= ТабДок.Область(НомерСтроки, НомерКолонкиБаракод).Текст;
				
				НайденныеСтрокиНоменклатуры = СопоставленныеТовары.НайтиСтроки(Новый Структура("Баракод", НоваяСтрока.Баракод));
				
				Если НайденныеСтрокиНоменклатуры.Количество() > 0 Тогда
					НоваяСтрока.Номенклатура 		= НайденныеСтрокиНоменклатуры.Получить(0).Номенклатура;
					НоваяСтрока.ЕдиницаИзмерения 	= НайденныеСтрокиНоменклатуры.Получить(0).ЕдиницаИзмерения;
					НоваяСтрока.Характеристика		= НайденныеСтрокиНоменклатуры.Получить(0).Характеристика;
				Иначе
					Сообщение = Новый СообщениеПользователю;
					Сообщение.Текст = СтрШаблон("Не удалось найти номенклатуру с баракодом: %1 в сопоставленных товарах (строка №%2)", НоваяСтрока.Баракод, НоваяСтрока.НомерСтроки);
					Сообщение.Сообщить();
				КонецЕсли;
				
				НоваяСтрока.Количество = ТабДок.Область(НомерСтроки, НомерКолонкиКоличество).Текст;
				
			КонецЕсли;
			
		Исключение
			
			Сообщение = Новый СообщениеПользователю;
			Сообщение.Текст = СтрШаблон("Ошибка при получении данных по номенклатуре с баркодом: %1", ТабДок.Область(НомерСтроки, НомерКолонкиБаракод).Текст);
			Сообщение.Сообщить();
			
			ЗаписьЖурналаРегистрации("Ошибка при получении данных по номенклатуре. Загрузка первоначальных остатков WB", 
										УровеньЖурналаРегистрации.Ошибка,,,
										СтрШаблон("Аккаунт: %1. Описание ошибки: %2", Аккаунт.Наименование, ОписаниеОшибки()));
			
		КонецПопытки;
		
	КонецЦикла;
	
КонецПроцедуры

