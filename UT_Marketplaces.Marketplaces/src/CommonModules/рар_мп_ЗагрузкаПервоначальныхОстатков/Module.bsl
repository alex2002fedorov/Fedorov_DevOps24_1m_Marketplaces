
#Область ЯндексМаркет

Функция ПолучитьКоличествоТоваров_ЯндексМаркет(Аккаунт, campaignId, ТипЗагрузки, ПутьКФайлуОстатков, МассивНомеровКолонок, НачальнаяСтрока) Экспорт
	
	МассивОтчетов = ПолучитьОтчет_ЯндексМаркет(Аккаунт, campaignId);
	
	ПутьОтчетПоОстаткамНаСкладах = ПолучитьПутьКОтчету_ЯндексМаркет(МассивОтчетов);
	
	ТабЗначДанных = Новый ТаблицаЗначений;
	
	ТабЗначДанных.Колонки.Добавить("НомерСтроки", 			Новый ОписаниеТипов("Число"));
	ТабЗначДанных.Колонки.Добавить("SKU", 					Новый ОписаниеТипов("Строка"));
	ТабЗначДанных.Колонки.Добавить("Номенклатура", 			Новый ОписаниеТипов("СправочникСсылка.Номенклатура"));
	ТабЗначДанных.Колонки.Добавить("ЕдиницаИзмерения", 		Новый ОписаниеТипов("СправочникСсылка.УпаковкиЕдиницыИзмерения"));
	ТабЗначДанных.Колонки.Добавить("Характеристика", 		Новый ОписаниеТипов("СправочникСсылка.ХарактеристикиНоменклатуры"));
	ТабЗначДанных.Колонки.Добавить("Количество", 			Новый ОписаниеТипов("Число"));
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	рар_мп_ЯндексМаркет_СопоставленныеТовары.SKUТовара КАК SKUТовара,
		|	рар_мп_ЯндексМаркет_СопоставленныеТовары.Номенклатура КАК Номенклатура,
		|	рар_мп_ЯндексМаркет_СопоставленныеТовары.Характеристика КАК Характеристика,
		|	рар_мп_ЯндексМаркет_СопоставленныеТовары.Номенклатура.ЕдиницаИзмерения КАК ЕдиницаИзмерения
		|ИЗ
		|	РегистрСведений.рар_мп_ЯндексМаркет_СопоставленныеТовары КАК рар_мп_ЯндексМаркет_СопоставленныеТовары
		|ГДЕ
		|	рар_мп_ЯндексМаркет_СопоставленныеТовары.Аккаунт = &Аккаунт";
	
	Запрос.УстановитьПараметр("Аккаунт", Аккаунт);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаСопоставленныхТоваров = РезультатЗапроса.Выгрузить();
	
	Если ТипЗагрузки = "API" Тогда
		
		ПолучитьДанныеИзОтчетаПоОстаткамНаСкладах_ЯндексМаркет(Аккаунт, ПутьОтчетПоОстаткамНаСкладах, ТабЗначДанных, ВыборкаСопоставленныхТоваров);
		
	ИначеЕсли ТипЗагрузки = "Excel" Тогда
		
		ПолучитьОстаткиИзExcel_ЯндексМаркет(Аккаунт, ТабЗначДанных, ПутьКФайлуОстатков, ВыборкаСопоставленныхТоваров, МассивНомеровКолонок, НачальнаяСтрока);
		
	КонецЕсли;
	
	Возврат ТабЗначДанных;
	
КонецФункции

Функция ПолучитьОтчет_ЯндексМаркет(Аккаунт, campaignId)
	
	МассивФайлов = Новый Массив;
	
	HTTPОтвет = рар_мп_ЯндексМаркет_Методы.Метод_ПолучитьОтчетПоОстаткамНаСкладах(Аккаунт, campaignId);
	
	КодЗапроса = HTTPОтвет.КодСостояния;
	
	Если HTTPОтвет.Свойство("ОтветAPI") Тогда
		
		Если КодЗапроса <> 200 Тогда
			
			НазваниеОшибки = "Ошибка при получении отчета по остаткам на складах в Яндекс Маркет";
			
			ОписаниеОшибки = HTTPОтвет.ОтветAPI.errors.Получить(0).message;	
			
			Сообщение = Новый СообщениеПользователю;
			Сообщение.Текст = "Ошибка при получении отчета по остаткам на складах. Подробное описание ошибки можно посмотреть в журнале регистрации";
			Сообщение.Сообщить();
			
			Комментарий = СтрШаблон("Маркетплейс: Яндекс Маркет%1Аккаунт: %2%1Код состояния: %3%1Описание ошибки: %4", 
										Символы.ПС, Аккаунт, КодЗапроса, ОписаниеОшибки);
			
			ЗаписьЖурналаРегистрации(НазваниеОшибки,УровеньЖурналаРегистрации.Ошибка,,,Комментарий,);
			
			МассивФайлов.Очистить();
			
			Возврат МассивФайлов;
			
		Иначе
			
			Если HTTPОтвет.ОтветAPI.status = "OK" Тогда
				
				Если HTTPОтвет.ОтветAPI.result.Свойство("reportId") Тогда
					
					НомерОтчета = HTTPОтвет.ОтветAPI.result.reportId;
					
					Статус = "";
					
					Пока Статус <> "DONE" И Статус <> "FAILED" Цикл
						
						HTTPОтвет = рар_мп_ЯндексМаркет_Методы.Метод_ПолучитьГотовыйОтчет(Аккаунт, НомерОтчета);
						
						КодЗапроса = HTTPОтвет.КодСостояния;
						
						Если HTTPОтвет.Свойство("ОтветAPI") Тогда
							
							Если КодЗапроса <> 200 Тогда
								
								НазваниеОшибки = "Ошибка при получении отчета по остаткам на складах в Яндекс Маркет";
								
								ОписаниеОшибки = HTTPОтвет.ОтветAPI.errors.Получить(0).message;	
								
								Сообщение = Новый СообщениеПользователю;
								Сообщение.Текст = "Ошибка при получении отчета по остаткам на складах. Подробное описание ошибки можно посмотреть в журнале регистрации";
								Сообщение.Сообщить();
								
								Комментарий = СтрШаблон("Маркетплейс: Яндекс Маркет%1Аккаунт: %2%1Код состояния: %3%1Описание ошибки: %4", 
															Символы.ПС, Аккаунт, КодЗапроса, ОписаниеОшибки);
								
								ЗаписьЖурналаРегистрации(НазваниеОшибки,УровеньЖурналаРегистрации.Ошибка,,,Комментарий,);
								
								МассивФайлов.Очистить();
								
								Возврат МассивФайлов;
								
							Иначе
								
								Статус = HTTPОтвет.ОтветAPI.result.status;	
								
							КонецЕсли;
							
						Иначе
							
							НазваниеОшибки = "Ошибка при получении отчета по остаткам на складах в Яндекс Маркет";
							
							ОписаниеОшибки = "Ошибка при получении JSON. Некорректные значения JSON";	
							
							Сообщение = Новый СообщениеПользователю;
							Сообщение.Текст = "Ошибка при получении отчета по остаткам на складах. Подробное описание ошибки можно посмотреть в журнале регистрации";
							Сообщение.Сообщить();
							
							Комментарий = СтрШаблон("Маркетплейс: Яндекс Маркет%1Аккаунт: %2%1Описание ошибки: %3", 
														Символы.ПС, Аккаунт, ОписаниеОшибки);
							
							ЗаписьЖурналаРегистрации(НазваниеОшибки,УровеньЖурналаРегистрации.Ошибка,,,Комментарий,);
							
							МассивФайлов.Очистить();
							
							Возврат МассивФайлов;
							
						КонецЕсли;
						
					КонецЦикла;
					
					Если Статус = "DONE" Тогда
						
						Если Не HTTPОтвет.ОтветAPI.result.Свойство("subStatus") Тогда
							
							СсылкаНаФайл = HTTPОтвет.ОтветAPI.result.file;
							
							СсылкаНаСоединение = "market-mbi-prod.s3-private.mds.yandex.net";
							
							СсылкаНаФайл = СтрЗаменить(СсылкаНаФайл, "https://" + СсылкаНаСоединение + "/", "");
							
							Соединение = Новый HTTPСоединение(СсылкаНаСоединение, 443,,,,, Новый ЗащищенноеСоединениеOpenSSL());
							Запрос = Новый HTTPЗапрос(СсылкаНаФайл);
							Ответ = Соединение.Получить(Запрос);
							ДвоичныеДанные = Ответ.ПолучитьТелоКакДвоичныеДанные();
							
							МассивФайлов.Добавить(ДвоичныеДанные);
							
						Иначе
							
							НазваниеОшибки = "Ошибка при получении отчета по остаткам на складах в Яндекс Маркет";
							
							ОписаниеОшибки = СтрШаблон("Подстатус генерации отчета: %1", HTTPОтвет.ОтветAPI.result.subStatus);	
							
							Сообщение = Новый СообщениеПользователю;
							Сообщение.Текст = "Ошибка при получении отчета по остаткам на складах. Подробное описание ошибки можно посмотреть в журнале регистрации";
							Сообщение.Сообщить();
							
							Комментарий = СтрШаблон("Маркетплейс: Яндекс Маркет%1Аккаунт: %2%1Описание ошибки: %3", 
							Символы.ПС, Аккаунт, ОписаниеОшибки);
							
							ЗаписьЖурналаРегистрации(НазваниеОшибки,УровеньЖурналаРегистрации.Ошибка,,,Комментарий,);
							
							МассивФайлов.Очистить();
							
							Возврат МассивФайлов;
							
						КонецЕсли;
						
					Иначе
						
						НазваниеОшибки = "Ошибка при получении отчета по остаткам на складах в Яндекс Маркет";
						
						ОписаниеОшибки = "Статус получения отчета по остаткам на складах 'FAILED'";	
						
						Сообщение = Новый СообщениеПользователю;
						Сообщение.Текст = "Ошибка при получении отчета по остаткам на складах. Подробное описание ошибки можно посмотреть в журнале регистрации";
						Сообщение.Сообщить();
						
						Комментарий = СтрШаблон("Маркетплейс: Яндекс Маркет%1Аккаунт: %2%1Описание ошибки: %3", 
													Символы.ПС, Аккаунт, ОписаниеОшибки);
						
						ЗаписьЖурналаРегистрации(НазваниеОшибки,УровеньЖурналаРегистрации.Ошибка,,,Комментарий,);
						
						МассивФайлов.Очистить();
						
						Возврат МассивФайлов;
						
					КонецЕсли;
					
				Иначе
					
					НазваниеОшибки = "Ошибка при получении отчета по остаткам на складах в Яндекс Маркет";
					
					ОписаниеОшибки = ОписаниеОшибки();	
					
					Сообщение = Новый СообщениеПользователю;
					Сообщение.Текст = "Ошибка при получении отчета по остаткам на складах. Подробное описание ошибки можно посмотреть в журнале регистрации";
					Сообщение.Сообщить();
					
					Комментарий = СтрШаблон("Маркетплейс: Яндекс Маркет%1Аккаунт: %2%1Описание ошибки: %3", 
												Символы.ПС, Аккаунт, ОписаниеОшибки);
					
					ЗаписьЖурналаРегистрации(НазваниеОшибки,УровеньЖурналаРегистрации.Ошибка,,,Комментарий,);
					
					МассивФайлов.Очистить();
					
					Возврат МассивФайлов;
					
				КонецЕсли;
				
			Иначе
				
				НазваниеОшибки = "Ошибка при получении отчета по остаткам на складах в Яндекс Маркет";
				
				ОписаниеОшибки = "При обработке запроса произошла ошибка";	
				
				Сообщение = Новый СообщениеПользователю;
				Сообщение.Текст = "Ошибка при получении отчета по остаткам на складах. Подробное описание ошибки можно посмотреть в журнале регистрации";
				Сообщение.Сообщить();
				
				Комментарий = СтрШаблон("Маркетплейс: Яндекс Маркет%1Аккаунт: %2%1Описание ошибки: %3", 
											Символы.ПС, Аккаунт, ОписаниеОшибки);
				
				ЗаписьЖурналаРегистрации(НазваниеОшибки,УровеньЖурналаРегистрации.Ошибка,,,Комментарий,);
				
				МассивФайлов.Очистить();
				
				Возврат МассивФайлов;
				
			КонецЕсли;
			
		КонецЕсли;
		
	Иначе
		
		НазваниеОшибки = "Ошибка при получении отчета по остаткам на складах в Яндекс Маркет";
		
		ОписаниеОшибки = "Ошибка при получении JSON. Некорректные значения JSON";	
		
		Сообщение = Новый СообщениеПользователю;
		Сообщение.Текст = "Ошибка при получении отчета по остаткам на складах. Подробное описание ошибки можно посмотреть в журнале регистрации";
		Сообщение.Сообщить();
		
		Комментарий = СтрШаблон("Маркетплейс: Яндекс Маркет%1Аккаунт: %2%1Описание ошибки: %3", 
									Символы.ПС, Аккаунт, ОписаниеОшибки);
		
		ЗаписьЖурналаРегистрации(НазваниеОшибки,УровеньЖурналаРегистрации.Ошибка,,,Комментарий,);
		
		МассивФайлов.Очистить();
		
		Возврат МассивФайлов;
		
	КонецЕсли;
	
	Возврат МассивФайлов;
	
КонецФункции

Функция ПолучитьПутьКОтчету_ЯндексМаркет(МассивОтчетов)
	
	Отчет = МассивОтчетов.Получить(0);
	
	Путь = ПолучитьИмяВременногоФайла("xlsx");
	
	Отчет.Записать(Путь);
	
	Возврат Путь;
	
КонецФункции

Функция ПолучитьДанныеИзОтчетаПоОстаткамНаСкладах_ЯндексМаркет(Аккаунт, ПутьКФайлу, ТабЗначДанных, СопоставленныеТовары)
	
	ТабДок = Новый ТабличныйДокумент;
	
	Попытка
		ТабДок.Прочитать(ПутьКФайлу, СпособЧтенияЗначенийТабличногоДокумента.Значение);
	Исключение                                                       
		Сообщение = Новый СообщениеПользователю;
		Сообщение.Текст = "Не удалось прочитать отчет по реализации. Подробное описание можно посмотреть в журнале регистрации";
		Сообщение.Сообщить();
		
		ЗаписьЖурналаРегистрации("Ошибка при чтении данных из отчета по реализации. Отчет комиссионера Яндекс Маркет", 
									УровеньЖурналаРегистрации.Ошибка,,,
									СтрШаблон("Аккаунт: %1. Описание ошибки: %2", Аккаунт.Наименование, ОписаниеОшибки()));
		
	КонецПопытки;
	
	ОбластьСписокТоваров = ТабДок.ПолучитьОбласть("Список_товаров");
	
	НачальнаяСтрока = 4;
	
	КоличествоСтрок = ОбластьСписокТоваров.ВысотаТаблицы;
	
	Для НомерСтроки = НачальнаяСтрока По КоличествоСтрок Цикл
		
		Попытка
			
			НоваяСтрока = ТабЗначДанных.Добавить();
			НоваяСтрока.НомерСтроки 	= ТабЗначДанных.Количество();
			НоваяСтрока.SKU				= ОбластьСписокТоваров.Область(НомерСтроки, 3).Текст;
			
			НайденныеСтрокиНоменклатуры = СопоставленныеТовары.НайтиСтроки(Новый Структура("SKUТовара", НоваяСтрока.SKU));
			
			Если НайденныеСтрокиНоменклатуры.Количество() > 0 Тогда
				НоваяСтрока.Номенклатура 		= НайденныеСтрокиНоменклатуры.Получить(0).Номенклатура;
				НоваяСтрока.ЕдиницаИзмерения 	= НайденныеСтрокиНоменклатуры.Получить(0).ЕдиницаИзмерения;
				НоваяСтрока.Характеристика		= НайденныеСтрокиНоменклатуры.Получить(0).Характеристика;
			Иначе
				Сообщение = Новый СообщениеПользователю;
				Сообщение.Текст = СтрШаблон("Не удалось найти номенклатуру с sku: %1 в сопоставленных товарах (строка №%2)", НоваяСтрока.SKU, НоваяСтрока.НомерСтроки);
				Сообщение.Сообщить();
			КонецЕсли;
			
			НоваяСтрока.Количество = ОбластьСписокТоваров.Область(НомерСтроки, 5).Текст;
			
		Исключение
			
			Сообщение = Новый СообщениеПользователю;
			Сообщение.Текст = СтрШаблон("Ошибка при получении данных по номенклатуре с sku: %1", ОбластьСписокТоваров.Область(НомерСтроки, 3).Текст);
			Сообщение.Сообщить();
			
			ЗаписьЖурналаРегистрации("Ошибка при получении данных по номенклатуре. Ввод первоначальных остатков Яндекс Маркет", 
										УровеньЖурналаРегистрации.Ошибка,,,
										СтрШаблон("Аккаунт: %1. Описание ошибки: %2", Аккаунт.Наименование, ОписаниеОшибки()));
			
		КонецПопытки;
		
	КонецЦикла;
	
КонецФункции

Процедура ПолучитьОстаткиИзExcel_ЯндексМаркет(Аккаунт, ТабЗначДанных, ПутьКФайлуОстатков, СопоставленныеТовары, МассивНомеровКолонок, НачальнаяСтрока)
	
	ТабДок = Новый ТабличныйДокумент;
	
	Попытка
		ТабДок.Прочитать(ПутьКФайлуОстатков);
	Исключение
		Сообщение = Новый СообщениеПользователю;
		Сообщение.Текст = "Не удалось прочитать файл. Подробное описание в журнале регистрации";
		Сообщение.Сообщить();
		
		ЗаписьЖурналаРегистрации("Ошибка при чтении Excel файла. Загрузка первоначальных остатков Яндекс Маркет", 
										УровеньЖурналаРегистрации.Ошибка,,,
										СтрШаблон("Аккаунт: %1. Описание ошибки: %2", Аккаунт.Наименование, ОписаниеОшибки()));
	КонецПопытки;
									
	КоличествоСтрок = ТабДок.ВысотаТаблицы;
	
	НомерКолонкиSKUТовара 	= МассивНомеровКолонок[0];
	НомерКолонкиКоличество 	= МассивНомеровКолонок[1];
	
	Для НомерСтроки = НачальнаяСтрока По КоличествоСтрок Цикл
		
		Попытка
			
			Если ЗначениеЗаполнено(ТабДок.Область(НомерСтроки, НомерКолонкиSKUТовара).Текст) Тогда
				
				НоваяСтрока = ТабЗначДанных.Добавить();
				НоваяСтрока.НомерСтроки = ТабЗначДанных.Количество();
				НоваяСтрока.SKU			= ТабДок.Область(НомерСтроки, НомерКолонкиSKUТовара).Текст;
				
				НайденныеСтрокиНоменклатуры = СопоставленныеТовары.НайтиСтроки(Новый Структура("SKUТовара", НоваяСтрока.SKU));
				
				Если НайденныеСтрокиНоменклатуры.Количество() > 0 Тогда
					НоваяСтрока.Номенклатура 		= НайденныеСтрокиНоменклатуры.Получить(0).Номенклатура;
					НоваяСтрока.ЕдиницаИзмерения 	= НайденныеСтрокиНоменклатуры.Получить(0).ЕдиницаИзмерения;
					НоваяСтрока.Характеристика		= НайденныеСтрокиНоменклатуры.Получить(0).Характеристика;
				Иначе
					Сообщение = Новый СообщениеПользователю;
					Сообщение.Текст = СтрШаблон("Не удалось найти номенклатуру с SKU: %1 в сопоставленных товарах (строка №%2)", НоваяСтрока.SKU, НоваяСтрока.НомерСтроки);
					Сообщение.Сообщить();
				КонецЕсли;
				
				НоваяСтрока.Количество = ТабДок.Область(НомерСтроки, НомерКолонкиКоличество).Текст;
				
			КонецЕсли;
			
		Исключение
			
			Сообщение = Новый СообщениеПользователю;
			Сообщение.Текст = СтрШаблон("Ошибка при получении данных по номенклатуре с SKU: %1", ТабДок.Область(НомерСтроки, НомерКолонкиSKUТовара).Текст);
			Сообщение.Сообщить();
			
			ЗаписьЖурналаРегистрации("Ошибка при получении данных по номенклатуре. Загрузка первоначальных остатков Яндекс Маркет", 
										УровеньЖурналаРегистрации.Ошибка,,,
										СтрШаблон("Аккаунт: %1. Описание ошибки: %2", Аккаунт.Наименование, ОписаниеОшибки()));
			
		КонецПопытки;
		
	КонецЦикла;
	
КонецПроцедуры

#КонецОбласти

#Область Ozon

Функция ПолучитьКоличествоТоваров_Ozon(Аккаунт, Склад, ТипЗагрузки, ПутьКФайлуОстатков, МассивНомеровКолонок, НачальнаяСтрока) Экспорт
	
	ТабЗначДанных = Новый ТаблицаЗначений;
	
	ТабЗначДанных.Колонки.Добавить("НомерСтроки", 			Новый ОписаниеТипов("Число"));
	ТабЗначДанных.Колонки.Добавить("SKU", 					Новый ОписаниеТипов("Строка"));
	ТабЗначДанных.Колонки.Добавить("IDТовара", 				Новый ОписаниеТипов("Строка"));
	ТабЗначДанных.Колонки.Добавить("Номенклатура", 			Новый ОписаниеТипов("СправочникСсылка.Номенклатура"));
	ТабЗначДанных.Колонки.Добавить("ЕдиницаИзмерения", 		Новый ОписаниеТипов("СправочникСсылка.УпаковкиЕдиницыИзмерения"));
	ТабЗначДанных.Колонки.Добавить("Характеристика", 		Новый ОписаниеТипов("СправочникСсылка.ХарактеристикиНоменклатуры"));
	ТабЗначДанных.Колонки.Добавить("Количество", 			Новый ОписаниеТипов("Число"));
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	рар_мп_Ozon_СопоставленныеТовары.Артикул КАК Артикул,
	|	рар_мп_Ozon_СопоставленныеТовары.Номенклатура КАК Номенклатура,
	|	рар_мп_Ozon_СопоставленныеТовары.Характеристика КАК Характеристика,
	|	рар_мп_Ozon_СопоставленныеТовары.Номенклатура.ЕдиницаИзмерения КАК ЕдиницаИзмерения,
	|	рар_мп_Ozon_СопоставленныеТовары.SKUТовара КАК SKUТовара
	|ИЗ
	|	РегистрСведений.рар_мп_Ozon_СопоставленныеТовары КАК рар_мп_Ozon_СопоставленныеТовары
	|ГДЕ
	|	рар_мп_Ozon_СопоставленныеТовары.Аккаунт = &Аккаунт"; 
		
	Запрос.УстановитьПараметр("Аккаунт", Аккаунт);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаСопоставленныхТоваров = РезультатЗапроса.Выгрузить();
	
	Если ТипЗагрузки = "API" Тогда
		
		МассивНоменклатуры = ТабЗначВМассив(ВыборкаСопоставленныхТоваров); 
				
		Если Аккаунт.СхемаРаботы = Перечисления.рар_мп_СхемыРаботы.FBO Тогда
			
			ОтветныеДанные = рар_мп_Ozon_Методы.Метод_ОтчетПоОстаткамИТоварамFBO(Аккаунт); 
			
			Если ОтветныеДанные.Свойство("ОтветAPI") Тогда
				
				Если ОтветныеДанные.КодСостояния <> 200 Тогда
					
					Сообщение = Новый СообщениеПользователю;
					Сообщение.Текст = СтрШаблон("Ошибка при получении данных. Ошибка: %1 (код ошибки: %2). Подробное описание можно посмотреть в журнале регистрации", 
													ОтветныеДанные.Заголовки, ОтветныеДанные.КодСостояния);
					Сообщение.Сообщить();
					
					ЗаписьЖурналаРегистрации("Ошибка при получении данных. Загрузка первоначальных остатков Ozon", 
												УровеньЖурналаРегистрации.Ошибка,,,
												СтрШаблон("Аккаунт: %1. Описание ошибки: %2", Аккаунт.Наименование, ОтветныеДанные.ОтветAPI.message));
					
				Иначе
					
					Если ОтветныеДанные.ОтветAPI.Количество() <> 0 Тогда
						
						ПолучениеДанныхИзОтчетаОбОстатках_FBO_Ozon(Аккаунт, ОтветныеДанные, ТабЗначДанных, ВыборкаСопоставленныхТоваров);
						
					КонецЕсли;
					
				КонецЕсли;
				
			Иначе
				
				НазваниеОшибки = "Ошибка при получении данных в Ozon";
				
				ОписаниеОшибки = "Ошибка при получении JSON. Некорректные значения JSON";	
				
				Сообщение = Новый СообщениеПользователю;
				Сообщение.Текст = "Ошибка при получении данных. Подробное описание ошибки можно посмотреть в журнале регистрации";
				Сообщение.Сообщить();
				
				Комментарий = СтрШаблон("Маркетплейс: Ozon%1Аккаунт: %2%1Описание ошибки: %3", 
											Символы.ПС, Аккаунт, ОписаниеОшибки);
				
				ЗаписьЖурналаРегистрации(НазваниеОшибки,УровеньЖурналаРегистрации.Ошибка,,,Комментарий,);
				
			КонецЕсли;
			
		ИначеЕсли Аккаунт.СхемаРаботы = Перечисления.рар_мп_СхемыРаботы.FBS Тогда  
			
			ОтветныеДанные = ПолучитьОтчетОбОстаткахFBS_Ozon(Аккаунт, МассивНоменклатуры);
			
			Если ОтветныеДанные <> Null Тогда
				
				Если ОтветныеДанные.Количество() <> 0 Тогда
					
					ПолучениеДанныхИзОтчетаОбОстатках_FBS_Ozon(Аккаунт, ОтветныеДанные, ТабЗначДанных, ВыборкаСопоставленныхТоваров);
					
				КонецЕсли;
				
			КонецЕсли;
			
		КонецЕсли;
		
	ИначеЕсли ТипЗагрузки = "Excel" Тогда
		
		ПолучитьОстаткиИзExcel_Ozon(Аккаунт, ТабЗначДанных, ПутьКФайлуОстатков, ВыборкаСопоставленныхТоваров, МассивНомеровКолонок, НачальнаяСтрока);
		
	КонецЕсли;
		
	Возврат ТабЗначДанных;
		
КонецФункции  

Функция ПолучитьОтчетОбОстаткахFBS_Ozon(Аккаунт, МассивНоменклатуры)
	
	Если МассивНоменклатуры.Количество() <= 500 Тогда           
		
		ОтветныеДанные = рар_мп_Ozon_Методы.Метод_ИнформацияОбОстаткахНаСкладахПродавца_FBS_rFBS(Аккаунт, МассивНоменклатуры);
		
		Если ОтветныеДанные.Свойство("ОтветAPI") Тогда
			
			Если ОтветныеДанные.КодСостояния <> 200 Тогда
				
				Сообщение = Новый СообщениеПользователю;
				Сообщение.Текст = СтрШаблон("Ошибка при получении данных. Ошибка: %1 (код ошибки: %2). Подробное описание можно посмотреть в журнале регистрации", 
												ОтветныеДанные.Заголовки, ОтветныеДанные.КодСостояния);
				Сообщение.Сообщить();
				
				ЗаписьЖурналаРегистрации("Ошибка при получении данных. Загрузка первоначальных остатков Ozon", 
											УровеньЖурналаРегистрации.Ошибка,,,
											СтрШаблон("Аккаунт: %1. Описание ошибки: %2", Аккаунт.Наименование, ОтветныеДанные.ОтветAPI.message));
				
				Возврат Null;
			Иначе
				
				Возврат ОтветныеДанные.ОтветAPI;
				
			КонецЕсли;
			
		Иначе
			
			НазваниеОшибки = "Ошибка при получении данных в Ozon";
			
			ОписаниеОшибки = "Ошибка при получении JSON. Некорректные значения JSON";	
			
			Сообщение = Новый СообщениеПользователю;
			Сообщение.Текст = "Ошибка при получении данных. Подробное описание ошибки можно посмотреть в журнале регистрации";
			Сообщение.Сообщить();
			
			Комментарий = СтрШаблон("Маркетплейс: Ozon%1Аккаунт: %2%1Описание ошибки: %3", 
										Символы.ПС, Аккаунт, ОписаниеОшибки);
			
			ЗаписьЖурналаРегистрации(НазваниеОшибки,УровеньЖурналаРегистрации.Ошибка,,,Комментарий,);
			
		КонецЕсли;
		
	Иначе
		
		КоличествоЗапросов = 0;
		
		ИтоговыйОтвет = Новый Структура;
		
		ВсегоСтрок = МассивНоменклатуры.Количество();
		
		РазмерПакета = 500;
		
		КоличествоИтераций = Цел(ВсегоСТрок/РазмерПакета);
		Если ВсегоСтрок % РазмерПакета > 0 Тогда
			КоличествоИтераций = КоличествоИтераций + 1;
		КонецЕсли;
		
		Для НомерИтерации = 0 По КоличествоИтераций - 1 Цикл
			
			НачальныйИндекс = НомерИтерации * РазмерПакета;
			КонечныйИндекс = Мин(НачальныйИндекс + РазмерПакета - 1, ВсегоСтрок - 1);
			
			ВременнаяТаблица = Новый ТаблицаЗначений;
			ВременнаяТаблица.Колонки.Добавить("SKUТовара");
			
			Для Индекс = НачальныйИндекс По КонечныйИндекс Цикл
				Если ЗначениеЗаполнено(МассивНоменклатуры[Индекс].SKUТовара) Тогда	
					НоваяСтрока = ВременнаяТаблица.Добавить();
					НоваяСтрока.SKUТовара = МассивНоменклатуры[Индекс].SKUТовара; 
				КонецЕсли;
			КонецЦикла;
			
			Если КоличествоЗапросов = 50 Тогда
				
				КоличествоЗапросов = 0;
				
				ВремяОжидания = 5;
				
				ВремяСледующегоЗапроса = ТекущаяДата() + ВремяОжидания;
				
				Пока ТекущаяДата() < ВремяСледующегоЗапроса Цикл
					// Ожидаем время для следующего запроса	
				КонецЦикла;
				
			КонецЕсли;
			
			ОтветныеДанные = рар_мп_Ozon_Методы.Метод_ИнформацияОбОстаткахНаСкладахПродавца_FBS_rFBS(Аккаунт, ВременнаяТаблица);
			
			КоличествоЗапросов = КоличествоЗапросов + 1;
			
			Если ОтветныеДанные.Свойство("ОтветAPI") Тогда
				
				Если ОтветныеДанные.КодСостояния <> 200 Тогда
					
					Сообщение = Новый СообщениеПользователю;
					Сообщение.Текст = СтрШаблон("Ошибка при получении данных. Ошибка: %1 (код ошибки: %2). Подробное описание можно посмотреть в журнале регистрации", 
													ОтветныеДанные.Заголовки, ОтветныеДанные.КодСостояния);
					Сообщение.Сообщить();
					
					ЗаписьЖурналаРегистрации("Ошибка при получении данных. Загрузка первоначальных остатков Ozon", 
												УровеньЖурналаРегистрации.Ошибка,,,
												СтрШаблон("Аккаунт: %1. Описание ошибки: %2", Аккаунт.Наименование, ОтветныеДанные.ОтветAPI.message));
					
				Иначе
					
					Для Каждого КлючЗначение Из ОтветныеДанные.ОтветAPI Цикл
						ИтоговыйОтвет.Вставить(КлючЗначение.Ключ + Строка(НомерИтерации), КлючЗначение.Значение);
					КонецЦикла;
					
				КонецЕсли;
				
			Иначе
				
				НазваниеОшибки = "Ошибка при получении данных в Ozon";
				
				ОписаниеОшибки = "Ошибка при получении JSON. Некорректные значения JSON";	
				
				Сообщение = Новый СообщениеПользователю;
				Сообщение.Текст = "Ошибка при получении данных. Подробное описание ошибки можно посмотреть в журнале регистрации";
				Сообщение.Сообщить();
				
				Комментарий = СтрШаблон("Маркетплейс: Ozon%1Аккаунт: %2%1Описание ошибки: %3", 
											Символы.ПС, Аккаунт, ОписаниеОшибки);
				
				ЗаписьЖурналаРегистрации(НазваниеОшибки,УровеньЖурналаРегистрации.Ошибка,,,Комментарий,);
				
			КонецЕсли;
			
		КонецЦикла;
		
		Возврат ИтоговыйОтвет;
		
	КонецЕсли;
	
КонецФункции
	
Функция ПолучениеДанныхИзОтчетаОбОстатках_FBO_Ozon(Аккаунт, Данные, ТабЗначДанных, СопоставленныеТовары)
	
	Для Каждого Строка Из Данные.ОтветAPI.result.rows Цикл
		
		Количество = Строка.free_to_sell_amount;
		
		Если Количество = 0 Тогда
			Продолжить;
		КонецЕсли;
		
		Попытка
			
			НоваяСтрока = ТабЗначДанных.Добавить();
			НоваяСтрока.НомерСтроки = ТабЗначДанных.Количество();
			НоваяСтрока.SKU			= Строка.sku;
			НоваяСтрока.IDТовара	= Строка.item_code;
			
			Если ЗначениеЗаполнено(Строка.Sku) Тогда
				
				НайденныеСтрокиНоменклатуры = СопоставленныеТовары.НайтиСтроки(Новый Структура("SKUТовара", Строка(Строка.sku)));
				
				Если НайденныеСтрокиНоменклатуры.Количество() > 0 Тогда
					НоваяСтрока.Номенклатура 		= НайденныеСтрокиНоменклатуры.Получить(0).Номенклатура;
					НоваяСтрока.ЕдиницаИзмерения 	= НайденныеСтрокиНоменклатуры.Получить(0).ЕдиницаИзмерения;
					НоваяСтрока.Характеристика		= НайденныеСтрокиНоменклатуры.Получить(0).Характеристика;
				Иначе
					Сообщение = Новый СообщениеПользователю;
					Сообщение.Текст = СтрШаблон("Не удалось найти номенклатуру с sku: %1 в сопоставленных товарах (строка №%2)", Строка.sku, НоваяСтрока.НомерСтроки);
					Сообщение.Сообщить();
				КонецЕсли;
				
			КонецЕсли;
			
			НоваяСтрока.Количество = Количество;
			
		Исключение
			
			Сообщение = Новый СообщениеПользователю;
			Сообщение.Текст = СтрШаблон("Ошибка при получении данных по номенклатуре с sku: %1", Строка.sku);
			Сообщение.Сообщить();
			
			ЗаписьЖурналаРегистрации("Ошибка при получении данных по номенклатуре. Загрузка первоначальных остатков Ozon", 
			УровеньЖурналаРегистрации.Ошибка,,,
			СтрШаблон("Аккаунт: %1. Описание ошибки: %2", Аккаунт.Наименование, ОписаниеОшибки()));
			
		КонецПопытки; 
		
	КонецЦикла;
	
КонецФункции
	
Функция ПолучениеДанныхИзОтчетаОбОстатках_FBS_Ozon(Аккаунт, Данные, ТабЗначДанных, СопоставленныеТовары)
	
	Для Каждого Пакет Из Данные Цикл
		
