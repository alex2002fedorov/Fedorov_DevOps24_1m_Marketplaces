Функция ПолучениеДанныхИзОтчетаОбОстаткахFBO_Wildberries(Аккаунт, Данные, ТабЗначДанных, СопоставленныеТовары)
	
	Для Каждого Строка Из Данные Цикл
		
		Количество = 0;
		
		Если Строка.warehouses.Количество() <> 0 Тогда
			Для Каждого Склад Из Строка.warehouses Цикл
				Если Склад.warehouseName = "Всего находится на складах" Тогда
					Количество = Склад.quantity;
				КонецЕсли;
			КонецЦикла;
		КонецЕсли;
		
		Если Количество = 0 Тогда
			Продолжить;
		КонецЕсли;
		
		Попытка
			
			НоваяСтрока = ТабЗначДанных.Добавить();
			НоваяСтрока.НомерСтроки = ТабЗначДанных.Количество();
			НоваяСтрока.Баракод		= Строка.barcode;
			
			Если ЗначениеЗаполнено(Строка.barcode) Тогда
				
				НайденныеСтрокиНоменклатуры = СопоставленныеТовары.НайтиСтроки(Новый Структура("Баракод", Строка.barcode));
				
				Если НайденныеСтрокиНоменклатуры.Количество() > 0 Тогда
					НоваяСтрока.Номенклатура 		= НайденныеСтрокиНоменклатуры.Получить(0).Номенклатура;
					НоваяСтрока.ЕдиницаИзмерения 	= НайденныеСтрокиНоменклатуры.Получить(0).ЕдиницаИзмерения;
					НоваяСтрока.Характеристика		= НайденныеСтрокиНоменклатуры.Получить(0).Характеристика;
				Иначе
					Сообщение = Новый СообщениеПользователю;
					Сообщение.Текст = СтрШаблон("Не удалось найти номенклатуру с баракодом: %1 в сопоставленных товарах (строка №%2)", Строка.barcode, НоваяСтрока.НомерСтроки);
					Сообщение.Сообщить();
				КонецЕсли;
				
			КонецЕсли;
			
			НоваяСтрока.Количество = Количество;
			
		Исключение
			
			Сообщение = Новый СообщениеПользователю;
			Сообщение.Текст = СтрШаблон("Ошибка при получении данных по номенклатуре с баркодом: %1", Строка.barcode);
			Сообщение.Сообщить();
			
			ЗаписьЖурналаРегистрации("Ошибка при получении данных по номенклатуре. Загрузка первоначальных остатков WB", 
										УровеньЖурналаРегистрации.Ошибка,,,
										СтрШаблон("Аккаунт: %1. Описание ошибки: %2", Аккаунт.Наименование, ОписаниеОшибки()));
			
		КонецПопытки;
		
	КонецЦикла;
	
КонецФункции

Функция ПолучитьОтчетОбОстаткахFBS_Wildberries(Аккаунт, ИдентификаторСклада, Данные)
	
	Если Данные.Количество() <= 1000 Тогда
		
		ОтветныеДанные = рар_мп_Wildberries_Методы.Метод_ПолучитьОстаткиТоваров(Аккаунт, Данные, ИдентификаторСклада);
		
		Если ОтветныеДанные.Свойство("ОтветAPI") Тогда
			
			Если ОтветныеДанные.КодСостояния <> 200 Тогда
				
				Если ОтветныеДанные.ОтветAPI.Свойство("errorText") Тогда
					ОписаниеОшибки = ОтветныеДанные.ОтветAPI.errorText;	
				Иначе
					ОписаниеОшибки = ОтветныеДанные.ОтветAPI.detail;	
				КонецЕсли;
				
				Сообщение = Новый СообщениеПользователю;
				Сообщение.Текст = "Ошибка при получении данных об остатках. Подробное описание можно посмотреть в журнале регистрации";
				Сообщение.Сообщить();
				
				ЗаписьЖурналаРегистрации("Ошибка при получении данных. Загрузка первоначальных остатков WB", 
											УровеньЖурналаРегистрации.Ошибка,,,
											СтрШаблон("Аккаунт: %1. Описание ошибки: %2", Аккаунт.Наименование, ОписаниеОшибки));
				
				Возврат Null;
				
			Иначе
				
				Возврат ОтветныеДанные.ОтветAPI;
				
			КонецЕсли;
			
		Иначе
			
			НазваниеОшибки = "Ошибка при получении данных в Wildberries";
			
			ОписаниеОшибки = "Ошибка при получении JSON. Некорректные значения JSON";	
			
			Сообщение = Новый СообщениеПользователю;
			Сообщение.Текст = "Ошибка при получении данных. Подробное описание ошибки можно посмотреть в журнале регистрации";
			Сообщение.Сообщить();
			
			Комментарий = СтрШаблон("Маркетплейс: Wildberries%1Аккаунт: %2%1Описание ошибки: %3", 
										Символы.ПС, Аккаунт, ОписаниеОшибки);
			
			ЗаписьЖурналаРегистрации(НазваниеОшибки,УровеньЖурналаРегистрации.Ошибка,,,Комментарий,);
			
			Возврат Null;
			
		КонецЕсли;
		
	Иначе
		
		ИтоговыйОтвет = Новый Структура;
		
		ВсегоСтрок = Данные.Количество();
		
		РазмерПакета = 1000;
		
		КоличествоИтераций = Цел(ВсегоСТрок/РазмерПакета);
		Если ВсегоСтрок % РазмерПакета > 0 Тогда
			КоличествоИтераций = КоличествоИтераций + 1;
		КонецЕсли;
		
		Для НомерИтерации = 0 По КоличествоИтераций - 1 Цикл
			
			НачальныйИндекс = НомерИтерации * РазмерПакета;
			КонечныйИндекс = Мин(НачальныйИндекс + РазмерПакета - 1, ВсегоСтрок - 1);
			
			ВременнаяТаблица = Новый ТаблицаЗначений;
			ВременнаяТаблица.Колонки.Добавить("Баракод");
			
			Для Индекс = НачальныйИндекс По КонечныйИндекс Цикл
				НоваяСтрока = ВременнаяТаблица.Добавить();
				НоваяСтрока.Баракод = Данные[Индекс].Баракод;
			КонецЦикла;
			
			ОтветныеДанные = рар_мп_Wildberries_Методы.Метод_ПолучитьОстаткиТоваров(Аккаунт, ВременнаяТаблица, ИдентификаторСклада);
			
			Если ОтветныеДанные.Свойство("ОтветAPI") Тогда
				
				Если ОтветныеДанные.КодСостояния <> 200 Тогда
					
					Если ОтветныеДанные.ОтветAPI.Свойство("errorText") Тогда
						ОписаниеОшибки = ОтветныеДанные.ОтветAPI.errorText;	
					Иначе
						ОписаниеОшибки = ОтветныеДанные.ОтветAPI.detail;	
					КонецЕсли;
					
					Сообщение = Новый СообщениеПользователю;
					Сообщение.Текст = "Ошибка при получении данных об остатках. Подробное описание можно посмотреть в журнале регистрации";
					Сообщение.Сообщить();
					
					ЗаписьЖурналаРегистрации("Ошибка при получении данных. Загрузка первоначальных остатков WB", 
												УровеньЖурналаРегистрации.Ошибка,,,
												СтрШаблон("Аккаунт: %1. Описание ошибки: %2", Аккаунт.Наименование, ОписаниеОшибки));
					
					Возврат Null;
					
				Иначе
					
					Для Каждого КлючЗначение Из ОтветныеДанные.ОтветAPI Цикл
						ИтоговыйОтвет.Вставить(КлючЗначение.Ключ + Строка(НомерИтерации), КлючЗначение.Значение);
					КонецЦикла;
					
				КонецЕсли;
				
			Иначе
				
				НазваниеОшибки = "Ошибка при получении данных в Wildberries";
				
				ОписаниеОшибки = "Ошибка при получении JSON. Некорректные значения JSON";	
				
				Сообщение = Новый СообщениеПользователю;
				Сообщение.Текст = "Ошибка при получении данных. Подробное описание ошибки можно посмотреть в журнале регистрации";
				Сообщение.Сообщить();
				
				Комментарий = СтрШаблон("Маркетплейс: Wildberries%1Аккаунт: %2%1Описание ошибки: %3", 
										Символы.ПС, Аккаунт, ОписаниеОшибки);
				
				ЗаписьЖурналаРегистрации(НазваниеОшибки,УровеньЖурналаРегистрации.Ошибка,,,Комментарий,);
				
				Возврат Null;
				
			КонецЕсли;
			
		КонецЦикла;
		
		Возврат ИтоговыйОтвет;
		
	КонецЕсли;
	
	Возврат Null;
	
КонецФункции

Функция ПолучениеДанныхИзОтчетаОбОстаткахFBS_Wildberries(Аккаунт, Данные, ТабЗначДанных, СопоставленныеТовары)
	
