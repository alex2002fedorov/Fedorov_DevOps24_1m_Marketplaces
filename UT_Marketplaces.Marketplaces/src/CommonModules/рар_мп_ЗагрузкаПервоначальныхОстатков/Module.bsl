						НайденныеСтрокиНоменклатуры = СопоставленныеТовары.НайтиСтроки(Новый Структура("SKUТовара", Строка(Строка.sku)));
						
						Если НайденныеСтрокиНоменклатуры.Количество() > 0 Тогда
							НоваяСтрока.Номенклатура 		= НайденныеСтрокиНоменклатуры.Получить(0).Номенклатура;
							НоваяСтрока.ЕдиницаИзмерения 	= НайденныеСтрокиНоменклатуры.Получить(0).ЕдиницаИзмерения;
							НоваяСтрока.Характеристика		= НайденныеСтрокиНоменклатуры.Получить(0).Характеристика;
						Иначе
							Сообщение = Новый СообщениеПользователю;
							Сообщение.Текст = СтрШаблон("Не удалось найти номенклатуру с sku: %1 в сопоставленных товарах (строка №%2)", Строка.sku, НоваяСтрока.НомерСтроки);
							Сообщение.Сообщить();
						КонецЕсли;
						
						
					КонецЕсли;
					
					НоваяСтрока.Количество = Строка.present;
					
				Исключение
					
					Сообщение = Новый СообщениеПользователю;
					Сообщение.Текст = СтрШаблон("Ошибка при получении данных по номенклатуре с sku: %1", Строка.sku);
					Сообщение.Сообщить();
					
					ЗаписьЖурналаРегистрации("Ошибка при получении данных по номенклатуре. Загрузка первоначальных остатков Ozon", 
					УровеньЖурналаРегистрации.Ошибка,,,
					СтрШаблон("Аккаунт: %1. Описание ошибки: %2", Аккаунт.Наименование, ОписаниеОшибки()));
					
				КонецПопытки;
				
			КонецЕсли;
			
		КонецЦикла;
		
	КонецЦикла;
	
КонецФункции

Функция ТабЗначВМассив(ТаблицаЗначений) Экспорт
	
    ПреобразованныйМассив = Новый Массив; 
	
	Для Каждого СтрокаТаблицы из ТаблицаЗначений Цикл 
		
        НоваяСтруктура = Новый Структура;
        Счетчик 	   = 0;  
		
		Для Каждого СтрокаСтруктуры из СтрокаТаблицы Цикл 
			
			Если НЕ ТипЗнч(СтрокаСтруктуры) = Тип(ТаблицаЗначений) тогда 
				
                НоваяСтруктура.Вставить(ТаблицаЗначений.Колонки[Счетчик].Имя,СтрокаТаблицы[Счетчик]);
				
			Иначе
				
                НоваяСтруктура.Вставить(ТаблицаЗначений.Колонки[Счетчик].Имя,ТабЗначВМассив(СтрокаСтруктуры)); 
				
			КонецЕсли;  
			
            Счетчик = Счетчик + 1; 
			
		КонецЦикла;   
		
        ПреобразованныйМассив.Добавить(НоваяСтруктура); 
		
	КонецЦикла;     
	
    Возврат(ПреобразованныйМассив);  
	
КонецФункции

Процедура ПолучитьОстаткиИзExcel_Ozon(Аккаунт, ТабЗначДанных, ПутьКФайлуОстатков, СопоставленныеТовары, МассивНомеровКолонок, НачальнаяСтрока)
	
	ТабДок = Новый ТабличныйДокумент;
	
	Попытка
		ТабДок.Прочитать(ПутьКФайлуОстатков);
	Исключение
		Сообщение = Новый СообщениеПользователю;
		Сообщение.Текст = "Не удалось прочитать файл. Подробное описание в журнале регистрации";
		Сообщение.Сообщить();
		
		ЗаписьЖурналаРегистрации("Ошибка при чтении Excel файла. Загрузка первоначальных остатков Ozon", 
										УровеньЖурналаРегистрации.Ошибка,,,
										СтрШаблон("Аккаунт: %1. Описание ошибки: %2", Аккаунт.Наименование, ОписаниеОшибки()));
	КонецПопытки;
									
	КоличествоСтрок = ТабДок.ВысотаТаблицы;
	
	НомерКолонкиIDТовара	= МассивНомеровКолонок[0];
	НомерКолонкиSKUТовара 	= МассивНомеровКолонок[1];
	НомерКолонкиКоличество 	= МассивНомеровКолонок[2];
	
	Для НомерСтроки = НачальнаяСтрока По КоличествоСтрок Цикл
		
		Попытка
			
			Если ЗначениеЗаполнено(ТабДок.Область(НомерСтроки, НомерКолонкиSKUТовара).Текст) Тогда
				
				НоваяСтрока = ТабЗначДанных.Добавить();
				НоваяСтрока.НомерСтроки = ТабЗначДанных.Количество();
				НоваяСтрока.SKU			= ТабДок.Область(НомерСтроки, НомерКолонкиSKUТовара).Текст;
				НоваяСтрока.IDТовара	= ТабДок.Область(НомерСтроки, НомерКолонкиIDТовара).Текст;
				
				НайденныеСтрокиНоменклатуры = СопоставленныеТовары.НайтиСтроки(Новый Структура("SKUТовара", НоваяСтрока.SKU));
				
				Если НайденныеСтрокиНоменклатуры.Количество() > 0 Тогда
					НоваяСтрока.Номенклатура 		= НайденныеСтрокиНоменклатуры.Получить(0).Номенклатура;
					НоваяСтрока.ЕдиницаИзмерения 	= НайденныеСтрокиНоменклатуры.Получить(0).ЕдиницаИзмерения;
					НоваяСтрока.Характеристика		= НайденныеСтрокиНоменклатуры.Получить(0).Характеристика;
				Иначе
					Сообщение = Новый СообщениеПользователю;
					Сообщение.Текст = СтрШаблон("Не удалось найти номенклатуру с SKU: %1 в сопоставленных товарах (строка №%2)", НоваяСтрока.SKU, НоваяСтрока.НомерСтроки);
					Сообщение.Сообщить();
				КонецЕсли;
				
				НоваяСтрока.Количество = ТабДок.Область(НомерСтроки, НомерКолонкиКоличество).Текст;
				
			КонецЕсли;
			
		Исключение
			
			Сообщение = Новый СообщениеПользователю;
			Сообщение.Текст = СтрШаблон("Ошибка при получении данных по номенклатуре с SKU: %1", ТабДок.Область(НомерСтроки, НомерКолонкиSKUТовара).Текст);
			Сообщение.Сообщить();
			
			ЗаписьЖурналаРегистрации("Ошибка при получении данных по номенклатуре. Загрузка первоначальных остатков Ozon", 
										УровеньЖурналаРегистрации.Ошибка,,,
										СтрШаблон("Аккаунт: %1. Описание ошибки: %2", Аккаунт.Наименование, ОписаниеОшибки()));
			
		КонецПопытки;
		
	КонецЦикла;
	
КонецПроцедуры

#КонецОбласти

#Область Wildberries

Функция ПолучитьКоличествоТоваров_Wildberries(Аккаунт, Склад, ТипЗагрузки, ПутьКФайлуОстатков, МассивНомеровКолонок, НачальнаяСтрока) Экспорт
	
	ТабЗначДанных = Новый ТаблицаЗначений;
	
	ТабЗначДанных.Колонки.Добавить("НомерСтроки", 			Новый ОписаниеТипов("Число")); 
	ТабЗначДанных.Колонки.Добавить("Баракод", 				Новый ОписаниеТипов("Строка"));
	ТабЗначДанных.Колонки.Добавить("Номенклатура", 			Новый ОписаниеТипов("СправочникСсылка.Номенклатура"));
	ТабЗначДанных.Колонки.Добавить("ЕдиницаИзмерения", 		Новый ОписаниеТипов("СправочникСсылка.УпаковкиЕдиницыИзмерения"));
	ТабЗначДанных.Колонки.Добавить("Характеристика", 		Новый ОписаниеТипов("СправочникСсылка.ХарактеристикиНоменклатуры"));
	ТабЗначДанных.Колонки.Добавить("Количество", 			Новый ОписаниеТипов("Число"));
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	рар_мп_Wildberries_СопоставленныеТовары.Баракод КАК Баракод,
		|	рар_мп_Wildberries_СопоставленныеТовары.Номенклатура КАК Номенклатура,
		|	рар_мп_Wildberries_СопоставленныеТовары.Характеристика КАК Характеристика,
		|	рар_мп_Wildberries_СопоставленныеТовары.Номенклатура.ЕдиницаИзмерения КАК ЕдиницаИзмерения
		|ИЗ
		|	РегистрСведений.рар_мп_Wildberries_СопоставленныеТовары КАК рар_мп_Wildberries_СопоставленныеТовары
		|ГДЕ
		|	рар_мп_Wildberries_СопоставленныеТовары.Аккаунт = &Аккаунт";
	
	Запрос.УстановитьПараметр("Аккаунт", Аккаунт);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаСопоставленныхТоваров = РезультатЗапроса.Выгрузить();
	
	Если ТипЗагрузки = "API" Тогда
		
		Если Аккаунт.СхемаРаботы = Перечисления.рар_мп_СхемыРаботы.FBO Тогда
			
			ОтветныеДанные = ПолучитьОтчетОбОстаткахFBO_Wildberries(Аккаунт);
			
			ПолучениеДанныхИзОтчетаОбОстаткахFBO_Wildberries(Аккаунт, ОтветныеДанные, ТабЗначДанных, ВыборкаСопоставленныхТоваров);
			
		Иначе
			
			Запрос = Новый Запрос;
			Запрос.Текст = 
			"ВЫБРАТЬ
			|	рар_мп_СопоставленныеСклады.УникальныйИдентификаторСклада КАК УникальныйИдентификаторСклада
			|ИЗ
			|	РегистрСведений.рар_мп_СопоставленныеСклады КАК рар_мп_СопоставленныеСклады
			|ГДЕ
			|	рар_мп_СопоставленныеСклады.АккаунтМаркетплейса = &АккаунтМаркетплейса
			|	И рар_мп_СопоставленныеСклады.Склад = &Склад";
			
			Запрос.УстановитьПараметр("АккаунтМаркетплейса", Аккаунт);
			Запрос.УстановитьПараметр("Склад", Склад);
			
			РезультатЗапроса = Запрос.Выполнить();
			
			Выборка = РезультатЗапроса.Выбрать();
			
			Пока Выборка.Следующий() Цикл
				ИдентификаторСклада = Выборка.УникальныйИдентификаторСклада;
			КонецЦикла;
			
			ОтветныеДанные = ПолучитьОтчетОбОстаткахFBS_Wildberries(Аккаунт, ИдентификаторСклада, ВыборкаСопоставленныхТоваров);
			
			ПолучениеДанныхИзОтчетаОбОстаткахFBS_Wildberries(Аккаунт, ОтветныеДанные, ТабЗначДанных, ВыборкаСопоставленныхТоваров);
			
		КонецЕсли;
		
	ИначеЕсли ТипЗагрузки = "Excel" Тогда
		
		ПолучитьОстаткиИзExcel_Wildberries(Аккаунт, ТабЗначДанных, ПутьКФайлуОстатков, ВыборкаСопоставленныхТоваров, МассивНомеровКолонок, НачальнаяСтрока);
		
	КонецЕсли;

	Возврат ТабЗначДанных;
	
КонецФункции

Функция ПолучитьОтчетОбОстаткахFBO_Wildberries(Аккаунт)
	
	ОтветныеДанные = рар_мп_Wildberries_Методы.Метод_СоздатьОтчетОбОстаткахНаСкладах(Аккаунт);
	
	Если ОтветныеДанные.Свойство("ОтветAPI") Тогда
		
		Если ОтветныеДанные.КодСостояния <> 200 Тогда
			
			Если ОтветныеДанные.ОтветAPI.Свойство("errorText") Тогда
				ОписаниеОшибки = ОтветныеДанные.ОтветAPI.errorText;	
			Иначе
				ОписаниеОшибки = ОтветныеДанные.ОтветAPI.detail;	
			КонецЕсли;
			
			Сообщение = Новый СообщениеПользователю;
			Сообщение.Текст = "Ошибка при создании отчета об остатках. Подробное описание можно посмотреть в журнале регистрации";
			Сообщение.Сообщить();
			
			ЗаписьЖурналаРегистрации("Ошибка при получении данных. Загрузка первоначальных остатков WB", 
										УровеньЖурналаРегистрации.Ошибка,,,
										СтрШаблон("Аккаунт: %1. Описание ошибки: %2", Аккаунт.Наименование, ОписаниеОшибки));
			
			Возврат Null;
			
		Иначе
			
			ИдентификаторГенерации = ОтветныеДанные.ОтветAPI.data.taskId;
			
			ВремяОжидания = 60;
			
			ВремяСледующегоЗапроса = ТекущаяДата() + ВремяОжидания;
			
			Пока ТекущаяДата() < ВремяСледующегоЗапроса Цикл
				// Ожидаем время для следующего запроса
			КонецЦикла;
			
			ОтветныеДанные = рар_мп_Wildberries_Методы.Метод_ПроверитьСтатусСозданияОтчетаОбОстаткахНаСкладах(Аккаунт, ИдентификаторГенерации);
			
			Если ОтветныеДанные.Свойство("ОтветAPI") Тогда
				
				Если ОтветныеДанные.КодСостояния <> 200 Тогда
					
					Если ОтветныеДанные.ОтветAPI.Свойство("errorText") Тогда
						ОписаниеОшибки = ОтветныеДанные.ОтветAPI.errorText;	
					Иначе
						ОписаниеОшибки = ОтветныеДанные.ОтветAPI.detail;	
					КонецЕсли;
					
					Сообщение = Новый СообщениеПользователю;
					Сообщение.Текст = "Ошибка при проверке статуса готовности отчета об остатках. Подробное описание можно посмотреть в журнале регистрации";
					Сообщение.Сообщить();
					
					ЗаписьЖурналаРегистрации("Ошибка при получении данных. Загрузка первоначальных остатков WB", 
												УровеньЖурналаРегистрации.Ошибка,,,
												СтрШаблон("Аккаунт: %1. Описание ошибки: %2", Аккаунт.Наименование, ОписаниеОшибки));
					
					Возврат Null;
					
				Иначе
					
					Пока ОтветныеДанные.ОтветAPI.data.status <> "done" И ОтветныеДанные.ОтветAPI.data.status <> "canceled" Цикл
						
						ВремяОжидания = 5;
						
						ВремяСледующегоЗапроса = ТекущаяДата() + ВремяОжидания;
						
						Пока ТекущаяДата() < ВремяСледующегоЗапроса Цикл
							// Ожидаем время для следующего запроса
						КонецЦикла;
						
						ОтветныеДанные = рар_мп_Wildberries_Методы.Метод_ПроверитьСтатусСозданияОтчетаОбОстаткахНаСкладах(Аккаунт, ИдентификаторГенерации);
						
