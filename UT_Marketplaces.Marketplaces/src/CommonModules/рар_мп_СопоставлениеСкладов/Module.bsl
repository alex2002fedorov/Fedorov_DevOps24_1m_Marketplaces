#Область Ozon

Функция ПолучитьСписокСкладов_Ozon(Аккаунт) Экспорт

	Запрос = рар_мп_Ozon_Методы.Метод_СписокСкладов(Аккаунт);
	
	КодЗапроса = Запрос.КодСостояния; 
	
	ТЗ = Новый ТаблицаЗначений;
	
	ТЗ.Колонки.Добавить("УникальныйИдентификаторСклада", Новый ОписаниеТипов("Строка"));
	ТЗ.Колонки.Добавить("НазваниеСклада", Новый ОписаниеТипов("Строка"));
	
	Если Запрос.Свойство("ОтветAPI") Тогда
	
		Если КодЗапроса = 200 Тогда
		
			Попытка
			
				СписокСкладов = Запрос.ОтветAPI.result;
				
				Для каждого Стр Из СписокСкладов Цикл
					
					УникальныйИдентификаторСклада = СтрЗаменить(Стр.warehouse_id, Символы.НПП, "");
					
					Запись = РегистрыСведений.рар_мп_СопоставленныеСклады.СоздатьМенеджерЗаписи();
					
					Запись.АккаунтМаркетплейса = Аккаунт;
					
					Запись.УникальныйИдентификаторСклада = УникальныйИдентификаторСклада;
					
					Запись.Прочитать();

					Если НЕ Запись.Выбран() Тогда
			
						НоваяСтрока = ТЗ.Добавить();
						
						НоваяСтрока.УникальныйИдентификаторСклада = УникальныйИдентификаторСклада;
						
						НоваяСтрока.НазваниеСклада = Стр.name;
						
					КонецЕсли;
				
				КонецЦикла; 
				
				Возврат ТЗ;
			
			Исключение
				
				ТЗ.Очистить();
				
				Сообщение = Новый СообщениеПользователю;
				Сообщение.Текст = СтрШаблон("Ошибка при получении данных о складах. Подробное описание ошибки можно посмотреть в журнале регистрации", КодЗапроса);
				Сообщение.Сообщить();
				
				ЗаписьЖурналаРегистрации("Ошибка при получении данных о складах", УровеньЖурналаРегистрации.Ошибка,,,СтрШаблон("Аккаунт: %3. Код запроса:%1. Описание ошибки:%2", КодЗапроса, ОписаниеОшибки(), Аккаунт),);
				
				Возврат ТЗ;
			
			КонецПопытки;
		
				
			
		Иначе
			
			Сообщение = Новый СообщениеПользователю;
			Сообщение.Текст = СтрШаблон("Ошибка при получении данных о складах. Код ошибки: %1. Подробное описание ошибки можно посмотреть в журнале регистрации", КодЗапроса);
			Сообщение.Сообщить();
			
			ЗаписьЖурналаРегистрации("Ошибка при получении данных о складах", УровеньЖурналаРегистрации.Ошибка,,,СтрШаблон("Аккаунт: %3. Код запроса:%1. Описание ошибки:%2", КодЗапроса, Запрос.ОтветAPI.message, Аккаунт),);
			
			Возврат ТЗ;
			
		
		КонецЕсли;	
	
	Иначе
	
		Сообщение = Новый СообщениеПользователю;
		Сообщение.Текст = "Ошибка при получении данных о складах. Подробное описание ошибки можно посмотреть в журнале регистрации";
		Сообщение.Сообщить();
		
		Комментарий = "Ошибка при получении JSON. Некорректные значения JSON";
		
		ЗаписьЖурналаРегистрации("Ошибка при получении данных о складах", УровеньЖурналаРегистрации.Ошибка,,,СтрШаблон("Аккаунт: %3. Код запроса:%1. Описание ошибки:%2", КодЗапроса, Комментарий, Аккаунт),);
		
		Возврат ТЗ;	
	
	КонецЕсли;
		

КонецФункции

