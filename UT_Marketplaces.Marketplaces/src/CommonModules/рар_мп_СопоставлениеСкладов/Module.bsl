#Область СохранениеСопоставления

Функция СохранениеСопоставления(СопоставлениеСкладов, АккаунтМаркетплейса) Экспорт

	ВыбранныеСтроки = СопоставлениеСкладов.НайтиСтроки(Новый Структура("ВыборСтроки", Истина));
	
	Если ВыбранныеСтроки.Количество() = 0 Тогда
	
		Сообщение = Новый СообщениеПользователю;
		Сообщение.Текст = "Не выбрано ни одной строки для сохранения сопоставления складов";
		Сообщение.Сообщить();
		
	Иначе
			
		Для каждого Стр Из ВыбранныеСтроки Цикл
		
			Если ЗначениеЗаполнено(Стр.Склад) Тогда
			
				МенеджерЗаписи = РегистрыСведений.рар_мп_СопоставленныеСклады.СоздатьМенеджерЗаписи(); 
				МенеджерЗаписи.АккаунтМаркетплейса = АккаунтМаркетплейса; 
				МенеджерЗаписи.УникальныйИдентификаторСклада = Стр.УникальныйИдентификаторСклада; 
				МенеджерЗаписи.Склад = Стр.Склад;
				МенеджерЗаписи.рар_мп_ЯМ_campaignId = Стр.campaignId;
				МенеджерЗаписи.НазваниеСкладаНаМаркетплейсе = Стр.НазваниеСклада;
				
				Попытка
				
					МенеджерЗаписи.Записать();
					
					СопоставлениеСкладов.Удалить(СопоставлениеСкладов.Индекс(Стр));
				
				Исключение
					
					Сообщение = Новый СообщениеПользователю;
					Сообщение.Текст = СтрШаблон("Ошибка при сопоставлении склада с уникальным идентификатором: %1 и названием: %2. 
												|Продробную ошибку можно посмотреть в журнале регистрации", 
												Стр.УникальныйИдентификаторСклада, Стр.НазваниеСклада);
					Сообщение.Сообщить();
					
					ЗаписьЖурналаРегистрации(СтрШаблон("Ошибка при сопоставлении склада с уникальным идентификатором: %1 и названием: %2", 
														Стр.УникальныйИдентификаторСклада, Стр.НазваниеСклада), УровеньЖурналаРегистрации.Ошибка,,,ОписаниеОшибки(),);
				
				КонецПопытки;
				    			
			
			Иначе
			
				Сообщение = Новый СообщениеПользователю;
				Сообщение.Текст = СтрШаблон("Не удалось сохранить сопоставление так как не указано значение в поле 'Склад' для склада 
											|с уникальным идентификатором: %1 и названием: %2", Стр.УникальныйИдентификаторСклада, Стр.НазваниеСклада);
				Сообщение.Сообщить();	
			
			КонецЕсли;
		
		КонецЦикла;
		
		Сообщение = Новый СообщениеПользователю;
		Сообщение.Текст = "Сохранение сопоставления складов завершено";
		Сообщение.Сообщить();
		
	КонецЕсли;
	
	Возврат СопоставлениеСкладов;

КонецФункции

