Функция УдалениеСопоставления(СопоставленныеСклады, АккаунтМаркетплейса) Экспорт

	ВыбранныеСтроки = СопоставленныеСклады.НайтиСтроки(Новый Структура("ВыборСтроки", Истина));
	
	Если ВыбранныеСтроки.Количество() = 0 Тогда
	
		Сообщение = Новый СообщениеПользователю;
		Сообщение.Текст = "Не выбрано ни одной строки для удаления сопоставления складов";
		Сообщение.Сообщить();
		
	Иначе
			
		Для каждого Стр Из ВыбранныеСтроки Цикл
			
			МенеджерЗаписи = РегистрыСведений.рар_мп_СопоставленныеСклады.СоздатьМенеджерЗаписи(); 
			МенеджерЗаписи.АккаунтМаркетплейса = АккаунтМаркетплейса; 
			МенеджерЗаписи.УникальныйИдентификаторСклада = Стр.УникальныйИдентификаторСклада; 
			
			Попытка
			
				МенеджерЗаписи.Удалить();
				
				СопоставленныеСклады.Удалить(СопоставленныеСклады.Индекс(Стр));
			
			Исключение
				
				Сообщение = Новый СообщениеПользователю;
				Сообщение.Текст = СтрШаблон("Ошибка при удалении сопоставления склада с уникальным идентификатором: %1 и названием: %2. 
											|Продробную ошибку можно посмотреть в журнале регистрации", 
											Стр.УникальныйИдентификаторСклада, Стр.НазваниеСклада);
				Сообщение.Сообщить();
				
				ЗаписьЖурналаРегистрации(СтрШаблон("Ошибка при удалении сопоставления склада с уникальным идентификатором: %1 и названием: %2", 
													Стр.УникальныйИдентификаторСклада, Стр.НазваниеСклада), УровеньЖурналаРегистрации.Ошибка,,,ОписаниеОшибки(),);
			
			КонецПопытки;
		
		КонецЦикла;
		
		Сообщение = Новый СообщениеПользователю;
		Сообщение.Текст = "Удаление сопоставления складов завершено";
		Сообщение.Сообщить();
		
	КонецЕсли;	
	
	Возврат СопоставленныеСклады;

КонецФункции

