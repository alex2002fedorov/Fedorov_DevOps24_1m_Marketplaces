#Область СлужебныеПроцедурыИФункцииДляПроверкиПЛС

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	Если ПриПовторномОткрытииНаСервере() = Ложь Тогда
		Сообщение = Новый СообщениеПользователю;
		Сообщение.Текст = НСтр("ru='Вы не приняли лицензионное соглашение 1С-Рарус, функционал расширения не доступен'");
		Сообщение.Сообщить();
		ЭтотОбъект.Закрыть();
	Иначе
		АккаунтМаркетплейсаПриИзмененииНаСервере();
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Функция ПриПовторномОткрытииНаСервере()
	Возврат Константы.рар_мп_Согласие.Получить();
КонецФункции

&НаКлиенте
Процедура ПриПовторномОткрытии()
	Если ПриПовторномОткрытииНаСервере() = Ложь Тогда
		Сообщение = Новый СообщениеПользователю;
		Сообщение.Текст = НСтр("ru='Вы не приняли лицензионное соглашение 1С-Рарус, функционал расширения не доступен'");
		Сообщение.Сообщить();
		ЭтотОбъект.Закрыть();
	КонецЕсли;
КонецПроцедуры  

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
Процедура АккаунтМаркетплейсаПриИзменении(Элемент)
	
	СписокНоменклатуры.Очистить();
	
	АккаунтМаркетплейсаПриИзмененииНаСервере();
	
КонецПроцедуры

&НаСервере
Процедура АккаунтМаркетплейсаПриИзмененииНаСервере()
	
	Если ЗначениеЗаполнено(АккаунтМаркетплейса) Тогда
		Организация = АккаунтМаркетплейса.Организация;
	Иначе
		Организация = Справочники.Организации.ПустаяСсылка();
	КонецЕсли;
	
	Склад 					= Справочники.Склады.ПустаяСсылка();
	Помещение 				= Справочники.СкладскиеПомещения.ПустаяСсылка();
	ЗонаПриемки 			= Справочники.СкладскиеЯчейки.ПустаяСсылка();
	Партия					= Документы.ПервичныйДокумент.ПустаяСсылка();
	ОстаткиПодДеятельность 	= Перечисления.ТипыНалогообложенияНДС.ПустаяСсылка();
	ВводОстатков 			= Документы.ВводОстатков.ПустаяСсылка();
	
	СистемаНалогообложения = УчетнаяПолитикаПереопределяемый.СистемаНалогообложения(Организация, ТекущаяДата());
	ИспользуетсяПСН = УчетнаяПолитикаПереопределяемый.ПрименяетсяПСН(Организация, ТекущаяДата());
	
	Если ИспользуетсяПСН И СистемаНалогообложения = Перечисления.СистемыНалогообложения.Упрощенная Тогда
		Элементы.ОстаткиПодДеятельность.Видимость = Истина;
		
		ПараметрыЗаполненияВидаДеятельности = ЗаполнитьПараметрыЗаполненияВидаДеятельности();
		
		УчетНДСУП.ЗаполнитьСписокВыбораВидаДеятельностиНДС(Элементы.ОстаткиПодДеятельность, ОстаткиПодДеятельность, ПараметрыЗаполненияВидаДеятельности);
	Иначе
		Элементы.ОстаткиПодДеятельность.Видимость = Ложь;
	КонецЕсли;
	
	ПараметрыУчетнойПолитики = НастройкиНалоговУчетныхПолитик.ДействующиеПараметрыНалоговУчетныхПолитикНаДату("УчетнаяПолитикаФинансовогоУчета",
		Организация,
		НачалоМесяца(ТекущаяДата()));
		
	Если ПараметрыУчетнойПолитики <> Неопределено Тогда
		МетодОценкиСтоимости = ПараметрыУчетнойПолитики.МетодОценкиСтоимостиТоваров;
	КонецЕсли;
	
	Если МетодОценкиСтоимости = Перечисления.МетодыОценкиСтоимостиТоваров.СредняяЗаМесяц Тогда
		Элементы.Партия.Видимость = Ложь;
	Иначе
		Элементы.Партия.Видимость = Истина;
	КонецЕсли;
	
	Маркетплейс = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(АккаунтМаркетплейса, "Маркетплейс");
	
	Если Маркетплейс = Перечисления.рар_мп_Маркетплейсы.Wildberries Тогда
		
		Элементы.СписокНоменклатурыБаракод.Видимость 	= Истина;
		
		Элементы.СписокНоменклатурыSKUТовара.Видимость 	= Ложь; 
		Элементы.СписокНоменклатурыIDТовара.Видимость	= Ложь;
		
	ИначеЕсли Маркетплейс = Перечисления.рар_мп_Маркетплейсы.OZON Тогда
		
		Элементы.СписокНоменклатурыIDТовара.Видимость	= Истина;
		Элементы.СписокНоменклатурыSKUТовара.Видимость 	= Истина;
		
		Элементы.СписокНоменклатурыБаракод.Видимость 	= Ложь;
				
	ИначеЕсли Маркетплейс = Перечисления.рар_мп_Маркетплейсы.ЯндексМаркет Тогда
		
		Элементы.СписокНоменклатурыSKUТовара.Видимость 	= Истина;
		
		Элементы.СписокНоменклатурыБаракод.Видимость 	= Ложь;
		Элементы.СписокНоменклатурыIDТовара.Видимость	= Ложь;
		
	КонецЕсли;
	
	СброситьРеквизитыЗагрузки();
	
	Если ЗначениеЗаполнено(АккаунтМаркетплейса) Тогда
		Элементы.ГруппаДанныеЗагрузки.Видимость = Истина;
	Иначе
		Элементы.ГруппаДанныеЗагрузки.Видимость = Ложь;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура СкладНачалоВыбора(Элемент, ДанныеВыбора, ВыборДобавлением, СтандартнаяОбработка) 
	
	Если Не ПроверитьУсловиеВыбораСклада() Тогда
		
		СтандартнаяОбработка = Ложь;
		
		ПараметрыФормы = Новый Структура;
		ПараметрыФормы.Вставить("АккаунтМаркетплейса", АккаунтМаркетплейса); 
		ОткрытьФорму("ОбщаяФорма.рар_мп_ФормаВыбораСопоставленныхСкладов", ПараметрыФормы, Элементы.Склад);
		
	КонецЕсли; 
	
КонецПроцедуры

&НаКлиенте
Процедура СкладОбработкаВыбора(Элемент, ВыбранноеЗначение, ДополнительныеДанные, ВыборДобавлением, СтандартнаяОбработка)
	
	Если Не ПроверитьУсловиеВыбораСклада() Тогда
		
		СтандартнаяОбработка = Ложь;
		
		Склад = ВыбранноеЗначение.Склад;
		campaignID = ВыбранноеЗначение.campaignID;
		
		СписокНоменклатуры.Очистить();
		
		СкладПриИзмененииНаСервере();
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура СкладПриИзменении(Элемент)
	
	СписокНоменклатуры.Очистить();
	
	СкладПриИзмененииНаСервере();
	
КонецПроцедуры

&НаСервере
Процедура СкладПриИзмененииНаСервере()
	
	Помещение = Справочники.СкладскиеПомещения.ПустаяСсылка();
	
	Если Склад.ИспользоватьСкладскиеПомещения Тогда
		Элементы.Помещение.Видимость = Истина;
	Иначе
		Элементы.Помещение.Видимость = Ложь;
	КонецЕсли;
	
	ЗонаПриемки = Справочники.СкладскиеЯчейки.ПустаяСсылка();
	
	Если Склад.НастройкаАдресногоХранения = Перечисления.НастройкиАдресногоХранения.ЯчейкиОстатки Тогда
		Элементы.ЗонаПриемки.Видимость = Истина;
	Иначе
		Элементы.ЗонаПриемки.Видимость = Ложь;
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ПомещениеПриИзмененииНаСервере()
	
	ЗонаПриемки = Справочники.СкладскиеЯчейки.ПустаяСсылка();
	
	Если Помещение.ИспользованиеРабочихУчастков = Перечисления.ИспользованиеСкладскихРабочихУчастков.Использовать Тогда
		Элементы.ЗонаПриемки.Видимость = Истина;
	Иначе
		Элементы.ЗонаПриемки.Видимость = Ложь;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПомещениеПриИзменении(Элемент)
	ПомещениеПриИзмененииНаСервере();
КонецПроцедуры

&НаСервере
Процедура ВидЗагрузкиОстатковПриИзмененииНаСервере()
	
	Маркетплейс = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(АккаунтМаркетплейса, "Маркетплейс");
	
	ПутьКФайлуОстатков = "";
	
	ВидЗагрузкиЦен 				= "";
	ПутьКФайлуЦен 				= "";
	ВидЦены 					= Справочники.ВидыЦен.ПустаяСсылка();
	НомерКолонкиSKUТовараЦены 	= 0;
	НомерКолонкиБаракодЦены 	= 0;
	НомерКолонкиЦена 			= 0;
	НачальнаяСтрокаЦен			= 0;
	
	Элементы.ПутьКФайлуЦен.Видимость 	= Ложь;
	Элементы.ВидЦены.Видимость			= Ложь;
	Элементы.ГруппаКолонкиЦен.Видимость = Ложь;
	
	Если ВидЗагрузкиОстатков = "Excel" Тогда
		
		Элементы.ПутьКФайлуОстатков.Видимость = Истина;
		
		Элементы.ВидЗагрузкиЦен.СписокВыбора.Очистить();
		
		Элементы.ВидЗагрузкиЦен.СписокВыбора.Добавить("ВидЦен", 			"По виду цены");
		Элементы.ВидЗагрузкиЦен.СписокВыбора.Добавить("ОтдельныйExcel", 	"Из отдельного Excel файла");
		Элементы.ВидЗагрузкиЦен.СписокВыбора.Добавить("СовместныйExcel", 	"Из Excel файла остатков");
			
		Элементы.ГруппаКолонкиОстатков.Видимость = Истина;
		
		Если Маркетплейс = Перечисления.рар_мп_Маркетплейсы.Wildberries Тогда
			
			Элементы.НомерКолонкиБаракодОстатков.Видимость 		= Истина;
			
			Элементы.НомерКолонкиSKUТовараОстатков.Видимость 	= Ложь;
			Элементы.НомерКолонкиIDТовара.Видимость				= Ложь;
			
		ИначеЕсли Маркетплейс = Перечисления.рар_мп_Маркетплейсы.OZON Тогда
			
			Элементы.НомерКолонкиSKUТовараОстатков.Видимость 	= Истина;
			Элементы.НомерКолонкиIDТовара.Видимость				= Истина;
			
			Элементы.НомерКолонкиБаракодОстатков.Видимость 		= Ложь;
			
		ИначеЕсли Маркетплейс = Перечисления.рар_мп_Маркетплейсы.ЯндексМаркет Тогда
			
			Элементы.НомерКолонкиSKUТовараОстатков.Видимость 	= Истина;
			
			Элементы.НомерКолонкиБаракодОстатков.Видимость 		= Ложь;
			Элементы.НомерКолонкиIDТовара.Видимость				= Ложь;
			
		КонецЕсли;
		
	ИначеЕсли ВидЗагрузкиОстатков = "API" Тогда
		
		Элементы.ПутьКФайлуОстатков.Видимость 		= Ложь;
		Элементы.ГруппаКолонкиОстатков.Видимость 	= Ложь;
		
		Элементы.ВидЗагрузкиЦен.СписокВыбора.Очистить();
		
		Элементы.ВидЗагрузкиЦен.СписокВыбора.Добавить("ВидЦен", 			"По виду цены");
		Элементы.ВидЗагрузкиЦен.СписокВыбора.Добавить("ОтдельныйExcel", 	"Из Excel файла");
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ВидЗагрузкиОстатковПриИзменении(Элемент)
	ВидЗагрузкиОстатковПриИзмененииНаСервере();
КонецПроцедуры

&НаСервере
Процедура ВидЗагрузкиЦенПриИзмененииНаСервере()
	
	Маркетплейс = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(АккаунтМаркетплейса, "Маркетплейс");
	
	ПутьКФайлуЦен 	= "";
	ВидЦены 		= Справочники.ВидыЦен.ПустаяСсылка();
	
	Если ВидЗагрузкиЦен = "ВидЦен" Тогда
		
		Элементы.ВидЦены.Видимость 			= Истина;
		
		Элементы.ПутьКФайлуЦен.Видимость 	= Ложь;
		Элементы.ГруппаКолонкиЦен.Видимость = Ложь;
		
	ИначеЕсли ВидЗагрузкиЦен = "ОтдельныйExcel" Тогда
		
		Элементы.ПутьКФайлуЦен.Видимость 	= Истина;
		
		Элементы.ВидЦены.Видимость 			= Ложь;
		
		Элементы.ГруппаКолонкиЦен.Видимость = Истина;
		
		Если Маркетплейс = Перечисления.рар_мп_Маркетплейсы.Wildberries Тогда
			
			Элементы.НомерКолонкиБаракодЦены.Видимость 		= Истина;
			
			Элементы.НомерКолонкиSKUТовараЦены.Видимость 	= Ложь;
			Элементы.НомерКолонкиБаракодЦены.ТолькоПросмотр = Ложь;
			
		Иначе
			
			Элементы.НомерКолонкиSKUТовараЦены.Видимость 		= Истина;
			
			Элементы.НомерКолонкиБаракодЦены.Видимость 			= Ложь;
			Элементы.НомерКолонкиSKUТовараЦены.ТолькоПросмотр 	= Ложь;
			
		КонецЕсли;
		
	ИначеЕсли ВидЗагрузкиЦен = "СовместныйExcel" Тогда
		
		Элементы.ВидЦены.Видимость 			= Ложь;
		
		Элементы.ПутьКФайлуЦен.Видимость 	= Ложь;
		
		Если ЗначениеЗаполнено(Маркетплейс) Тогда
			
			Элементы.ГруппаКолонкиЦен.Видимость = Истина;
			
			Если Маркетплейс = Перечисления.рар_мп_Маркетплейсы.Wildberries Тогда
				
				Элементы.НомерКолонкиБаракодЦены.Видимость 		= Истина;
				Элементы.НомерКолонкиБаракодЦены.ТолькоПросмотр = Истина;
				Элементы.НачальнаяСтрокаЦен.ТолькоПросмотр		= Истина;
				
				Элементы.НомерКолонкиSKUТовараЦены.Видимость 	= Ложь;
				
				НомерКолонкиБаракодЦены 	= НомерКолонкиБаракодОстатков;
				НачальнаяСтрокаЦен 			= НачальнаяСтрокаОстатков;
				
			Иначе
				
				Элементы.НомерКолонкиSKUТовараЦены.Видимость 		= Истина;
				Элементы.НомерКолонкиSKUТовараЦены.ТолькоПросмотр 	= Истина;
				Элементы.НачальнаяСтрокаЦен.ТолькоПросмотр		= Истина;
				
				Элементы.НомерКолонкиБаракодЦены.Видимость 			= Ложь;
				
				НомерКолонкиSKUТовараЦены 	= НомерКолонкиSKUТовараОстатков;
				НачальнаяСтрокаЦен 			= НачальнаяСтрокаОстатков;
				
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ВидЗагрузкиЦенПриИзменении(Элемент)
	ВидЗагрузкиЦенПриИзмененииНаСервере();
КонецПроцедуры

&НаКлиенте
Процедура НомерКолонкиSKUТовараОстатковПриИзменении(Элемент)
	
	Если ВидЗагрузкиЦен = "СовместныйExcel" Тогда
		НомерКолонкиSKUТовараЦены = НомерКолонкиSKUТовараОстатков;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура НомерКолонкиБаракодОстатковПриИзменении(Элемент)
	
	Если ВидЗагрузкиЦен = "СовместныйExcel" Тогда
		НомерКолонкиБаракодЦены = НомерКолонкиБаракодОстатков;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура НачальнаяСтрокаОстатковПриИзменении(Элемент)
	
	Если ВидЗагрузкиЦен = "СовместныйExcel" Тогда
		НачальнаяСтрокаЦен = НачальнаяСтрокаОстатков;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПутьКФайлуОстатковНачалоВыбора(Элемент, ДанныеВыбора, ВыборДобавлением, СтандартнаяОбработка)
	
	Обработчик = Новый ОписаниеОповещения("КаталогДокументовОстатковЗавершение", ЭтотОбъект);
	
	ПараметрыДиалога = Новый ДиалогВыбораФайла(РежимДиалогаВыбораФайла.Открытие);
	ПараметрыДиалога.Фильтр = НСтр("ru = 'Excel'; en = 'Excel'") + "(*.xls, *.xlsx)|*.xl*";
	ПараметрыДиалога.ИндексФильтра = 0;
	ПараметрыДиалога.Заголовок = НСтр("ru = 'Выберите файл'");
	ПараметрыДиалога.МножественныйВыбор = Ложь;
	
	ФайловаяСистемаКлиент.ПоказатьДиалогВыбора(Обработчик, ПараметрыДиалога);
	
КонецПроцедуры

&НаКлиенте
Процедура КаталогДокументовОстатковЗавершение(ИмяКаталогаДокументов, ДополнительныеПараметры) Экспорт   
	Если ИмяКаталогаДокументов <> НЕОПРЕДЕЛЕНО Тогда	   
		ПутьКФайлуОстатков = ИмяКаталогаДокументов[0];
	КонецЕсли;  
КонецПроцедуры

&НаКлиенте
Процедура ПутьКФайлуЦенНачалоВыбора(Элемент, ДанныеВыбора, ВыборДобавлением, СтандартнаяОбработка)
	
	Обработчик = Новый ОписаниеОповещения("КаталогДокументовЦенЗавершение", ЭтотОбъект);
	
	ПараметрыДиалога = Новый ДиалогВыбораФайла(РежимДиалогаВыбораФайла.Открытие);
	ПараметрыДиалога.Фильтр = НСтр("ru = 'Excel'; en = 'Excel'") + "(*.xls, *.xlsx)|*.xl*";
	ПараметрыДиалога.ИндексФильтра = 0;
	ПараметрыДиалога.Заголовок = НСтр("ru = 'Выберите файл'");
	ПараметрыДиалога.МножественныйВыбор = Ложь;
	
	ФайловаяСистемаКлиент.ПоказатьДиалогВыбора(Обработчик, ПараметрыДиалога);
	
КонецПроцедуры

&НаКлиенте
Процедура КаталогДокументовЦенЗавершение(ИмяКаталогаДокументов, ДополнительныеПараметры) Экспорт   
	Если ИмяКаталогаДокументов <> НЕОПРЕДЕЛЕНО Тогда	   
		ПутьКФайлуЦен = ИмяКаталогаДокументов[0];
	КонецЕсли;  
КонецПроцедуры

#КонецОбласти

#Область ЗагрузкаДанных

&НаКлиенте
Асинх Процедура ЗагрузитьНоменклатуру(Команда)
	
	Если ПроверитьЗаполнение() Тогда
		
		СписокНоменклатуры.Очистить();
		
		//Проверяем вид загрузки остатков и реквизиты
		Если Не ПроверитьРеквизитыОстатков() Тогда
			Возврат;
		КонецЕсли;
		
		ПутьКФайлу = "";
		
		Если ВидЗагрузкиОстатков = "Excel" Тогда
			
			Файл = Ждать СоздатьДвоичныеДанныеИзФайлаАсинх(ПутьКФайлуОстатков);
			
			ПутьКФайлу = ПолучитьФайлПриемник(Файл);
			
		КонецЕсли;
		
		ДлительнаяОперация = СформироватьТаблицуНаСервере(ПутьКФайлу);
		ПараметрыОжидания = ДлительныеОперацииКлиент.ПараметрыОжидания(ЭтотОбъект);
		ПараметрыОжидания.ВыводитьСообщения = Истина;
		ПараметрыОжидания.ВыводитьОкноОжидания = Истина;
		ПараметрыОжидания.ТекстСообщения = "Получение данных по остаткам...";
		Оповещение = Новый ОписаниеОповещения("ЗавершениеЗагрузки", ЭтотОбъект);
		ДлительныеОперацииКлиент.ОжидатьЗавершение(ДлительнаяОперация, Оповещение, ПараметрыОжидания);
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Функция СформироватьТаблицуНаСервере(ПутьКФайлу)
	
	Маркетплейс = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(АккаунтМаркетплейса, "Маркетплейс");
	
	МассивНомеровКолонок = Новый Массив;
	
	ЗаполнитьМассивКолонок(Маркетплейс, МассивНомеровКолонок, "Остатки");
	
	Если Маркетплейс = Перечисления.рар_мп_Маркетплейсы.Wildberries Тогда
		
		ПараметрыВыполнения = ДлительныеОперации.ПараметрыВыполненияФункции(УникальныйИдентификатор); 
			
		ВозвратныеДанные = ДлительныеОперации.ВыполнитьФункцию(ПараметрыВыполнения,
			"рар_мп_ЗагрузкаПервоначальныхОстатков.ПолучитьКоличествоТоваров_Wildberries", 
			АккаунтМаркетплейса, Склад, ВидЗагрузкиОстатков, ПутьКФайлу, МассивНомеровКолонок, НачальнаяСтрокаОстатков);
		
	ИначеЕсли Маркетплейс = Перечисления.рар_мп_Маркетплейсы.OZON Тогда
		
		ПараметрыВыполнения = ДлительныеОперации.ПараметрыВыполненияФункции(УникальныйИдентификатор);
			
		ВозвратныеДанные = ДлительныеОперации.ВыполнитьФункцию(ПараметрыВыполнения,
			"рар_мп_ЗагрузкаПервоначальныхОстатков.ПолучитьКоличествоТоваров_Ozon", 
			АккаунтМаркетплейса, Склад, ВидЗагрузкиОстатков, ПутьКФайлу, МассивНомеровКолонок, НачальнаяСтрокаОстатков);
		
	ИначеЕсли Маркетплейс = Перечисления.рар_мп_Маркетплейсы.ЯндексМаркет Тогда
		
		ПараметрыВыполнения = ДлительныеОперации.ПараметрыВыполненияФункции(УникальныйИдентификатор);
			
		ВозвратныеДанные = ДлительныеОперации.ВыполнитьФункцию(ПараметрыВыполнения,
			"рар_мп_ЗагрузкаПервоначальныхОстатков.ПолучитьКоличествоТоваров_ЯндексМаркет", 
			АккаунтМаркетплейса, campaignId, ВидЗагрузкиОстатков, ПутьКФайлу, МассивНомеровКолонок, НачальнаяСтрокаОстатков);
		
	КонецЕсли;
			
	Возврат ВозвратныеДанные;
	
КонецФункции

&НаКлиенте
Процедура ЗавершениеЗагрузки(Результат, СтруктураПараметров) Экспорт
	
	Если Результат = НЕОПРЕДЕЛЕНО Тогда
		Возврат;	
	КонецЕсли;
	
	Если Результат.Статус = "Выполнено" Тогда
	
		ЗавершениеЗагрузкиНаСервере(Результат);
		
	ИначеЕсли Результат.Статус = "Ошибка" Тогда
		
		ЗавершениеЗагрузкиОшибкаНаСервере();

	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ЗавершениеЗагрузкиНаСервере(Результат)
	
	ТЗ = ПолучитьИзВременногоХранилища(Результат.АдресРезультата);
	
	Попытка
		
		СписокНоменклатуры.Загрузить(ТЗ);
		
		Если СписокНоменклатуры.Количество() = 0 Тогда
			Сообщение = Новый СообщениеПользователю;
			Сообщение.Текст = "Для данного аккаунта нет данных об остатках";
			Сообщение.Сообщить();
		Иначе
			Сообщение = Новый СообщениеПользователю;
			Сообщение.Текст = "Загрузка завершена";
			Сообщение.Сообщить();
		КонецЕсли
	
	Исключение
		
		ОбщегоНазначения.СообщитьПользователю("Ошибка при загрузке данных. Подробное описание ошибки можно посмотреть в журнале регистрации");
		
		ЗаписьЖурналаРегистрации("Ошибка при загрузке данных в табличную часть", 
									УровеньЖурналаРегистрации.Ошибка,,, СтрШаблон("Аккаунт: %1. Описание ошибки: %2", АккаунтМаркетплейса.Наименование, ОписаниеОшибки()));
		
	КонецПопытки;
	
КонецПроцедуры

#КонецОбласти

#Область ЗагрузкаЦенНоменклатуры

&НаКлиенте
Асинх Процедура ЗагрузитьЦенуНоменклатуры(Команда)
	
	Если ПроверитьЗаполнение() Тогда
		
		//Проверяем реквизиты цен
		Если Не ПроверитьРеквизитыЦен() Тогда
			Возврат;
		КонецЕсли;
		
		Если СписокНоменклатуры.Количество() = 0 Тогда
			
			Сообщение = Новый СообщениеПользователю;
			Сообщение.Текст = "Таблица товаров пуста";
			Сообщение.Сообщить();
			
			Возврат;
			
		КонецЕсли;
		
		ПутьКФайлу = "";
		
		Если ВидЗагрузкиЦен = "ОтдельныйExcel" Тогда
			
			Файл = Ждать СоздатьДвоичныеДанныеИзФайлаАсинх(ПутьКФайлуЦен);
			
			ПутьКФайлу = ПолучитьФайлПриемник(Файл);
			
		ИначеЕсли ВидЗагрузкиЦен = "СовместныйExcel" Тогда
			
			Файл = Ждать СоздатьДвоичныеДанныеИзФайлаАсинх(ПутьКФайлуОстатков);
			
			ПутьКФайлу = ПолучитьФайлПриемник(Файл);
			
		КонецЕсли;
		
		ДлительнаяОперация = СформироватьТаблицуЦенНаСервере(ПутьКФайлу);
		ПараметрыОжидания = ДлительныеОперацииКлиент.ПараметрыОжидания(ЭтотОбъект);
		ПараметрыОжидания.ВыводитьСообщения = Истина;
		ПараметрыОжидания.ВыводитьОкноОжидания = Истина;
		ПараметрыОжидания.ТекстСообщения = "Получение данных по ценам...";
		Оповещение = Новый ОписаниеОповещения("ЗавершениеЗагрузкиЦен", ЭтотОбъект);
		ДлительныеОперацииКлиент.ОжидатьЗавершение(ДлительнаяОперация, Оповещение, ПараметрыОжидания);
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Функция СформироватьТаблицуЦенНаСервере(ПутьКФайлу)
	
	Маркетплейс = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(АккаунтМаркетплейса, "Маркетплейс");
	
	МассивНомеровКолонок = Новый Массив;
	
	ЗаполнитьМассивКолонок(Маркетплейс, МассивНомеровКолонок, "Цены", ВидЗагрузкиЦен);
	
	ПараметрыВыполнения = ДлительныеОперации.ПараметрыВыполненияФункции(УникальныйИдентификатор);
	
	ВозвратныеДанные = ДлительныеОперации.ВыполнитьФункцию(ПараметрыВыполнения,
							"рар_мп_ЗагрузкаПервоначальныхОстатков.ПолучитьЦеныТоваров_Общая", 
							АккаунтМаркетплейса, СписокНоменклатуры.Выгрузить(), ВидЗагрузкиЦен, ВидЦены, ПутьКФайлу, МассивНомеровКолонок, НачальнаяСтрокаЦен);
	
	
	Возврат ВозвратныеДанные;
	
КонецФункции

&НаКлиенте
Процедура ЗавершениеЗагрузкиЦен(Результат, СтруктураПараметров) Экспорт
	
	Если Результат = НЕОПРЕДЕЛЕНО Тогда
		Возврат;	
	КонецЕсли;
	
	Если Результат.Статус = "Выполнено" Тогда
	
		ЗавершениеЗагрузкиЦенНаСервере(Результат);
		
	ИначеЕсли Результат.Статус = "Ошибка" Тогда
		
		ЗавершениеЗагрузкиОшибкаНаСервере();

	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ЗавершениеЗагрузкиЦенНаСервере(Результат)
	
	ТЗ = ПолучитьИзВременногоХранилища(Результат.АдресРезультата);
	
	Попытка
		
		СписокНоменклатуры.Загрузить(ТЗ);
		
		Сообщение = Новый СообщениеПользователю;
		Сообщение.Текст = "Загрузка завершена";
		Сообщение.Сообщить();
	
	Исключение
		
		ОбщегоНазначения.СообщитьПользователю("Ошибка при загрузке данных. Подробное описание ошибки можно посмотреть в журнале регистрации");
		
		ЗаписьЖурналаРегистрации("Ошибка при загрузке данных в табличную часть", 
									УровеньЖурналаРегистрации.Ошибка,,, СтрШаблон("Аккаунт: %1. Описание ошибки: %2", АккаунтМаркетплейса.Наименование, ОписаниеОшибки()));
		
	КонецПопытки;
	
КонецПроцедуры

#КонецОбласти

#Область СозданиеДокументаПервоначальныхОстатков

&НаСервере
Процедура СформироватьДокументНаСервере()
	
	Если ПроверитьЗаполнение() Тогда
		
		Если СписокНоменклатуры.Количество() = 0 Тогда
			
			Сообщение = Новый СообщениеПользователю;
			Сообщение.Текст = "Таблица пустая";
			Сообщение.Сообщить();
			
			Возврат;
			
		КонецЕсли;
		
		Если ЗначениеЗаполнено(ВводОстатков) Тогда
			
			Сообщение = Новый СообщениеПользователю;
			Сообщение.Текст = "Документ первоначальных остатков уже создан";
			Сообщение.Сообщить();
			
			Возврат;
			
		КонецЕсли;
		
		Если Не ПроверитьРеквизиты() Тогда
			Возврат;
		КонецЕсли;
		
		Если Не ПроверитьНоменклатуру() Тогда
			Возврат;
		КонецЕсли;
		
		Если Не ПроверитьЗаполнениеЦен() Тогда
			Возврат;
		КонецЕсли;
		
		Маркетплейс = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(АккаунтМаркетплейса, "Маркетплейс");
		
		ВводОстатков = рар_мп_ЗагрузкаПервоначальныхОстатков.СоздатьВводПервоначальныхОстатков(
								СписокНоменклатуры, АккаунтМаркетплейса, Партия, ОстаткиПодДеятельность, Склад, Помещение, ЗонаПриемки);
								
		ДокОстатковЗаполнениеПолей(ВводОстатков);  
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура СформироватьДокумент(Команда)
	СформироватьДокументНаСервере();
КонецПроцедуры

#КонецОбласти     

#Область СозданиеДокументаПервоначальныхВзаиморасчетов

&НаСервере
Процедура СформироватьДокВзаиморасчетыНаСервере()
	
	Если ПроверитьЗаполнение() Тогда
				
		Если ЗначениеЗаполнено(ВводВзаиморасчетов) Тогда
			
			Сообщение = Новый СообщениеПользователю;
			Сообщение.Текст = "Документ первоначальных взаиморасчетов уже создан";
			Сообщение.Сообщить();
			
			Возврат;
			
		КонецЕсли;
		
		Если Взаиморасчеты.Количество() = 0 Тогда
			
			Сообщение = Новый СообщениеПользователю;
			Сообщение.Текст = "Таблица пустая";
			Сообщение.Сообщить();
			
			Возврат;
			
		КонецЕсли;
		
		Для Каждого Строка Из Взаиморасчеты Цикл
			
			Если Не ЗначениеЗаполнено(Строка.Сумма_ВР) Тогда
				
				Сообщение = Новый СообщениеПользователю;
				Сообщение.Текст = СтрШаблон("Отсутствует сумма (строка №%1)", Строка.НомерСтроки);
				Сообщение.Сообщить();
				
				ОтсутствуетНоменклатура = Истина;
				
			КонецЕсли;
			
		КонецЦикла;
		
		Если Взаиморасчеты.Итог("Сумма_ВР") <> СуммаДокОстатков Тогда
			
			Сообщение = Новый СообщениеПользователю;
			Сообщение.Текст = "Сумма табличной части отличается от суммы документа ввода остатков номенклатуры";
			Сообщение.Сообщить();
			
			Возврат;
	
		КонецЕсли;
		
		Маркетплейс = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(АккаунтМаркетплейса, "Маркетплейс");
		
		ВводВзаиморасчетов = рар_мп_ЗагрузкаПервоначальныхОстатков.СоздатьВводПервоначальныхВзаиморасчетов(
								Взаиморасчеты, АккаунтМаркетплейса, Подразделение);
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура СформироватьДокВзаиморасчеты(Команда) 
	
	Если ДокОстатковНоменклатуры.Пустая() Тогда
		
		Сообщение = Новый СообщениеПользователю;
		Сообщение.Текст = СтрШаблон("Отсутствует документ ввода остатков номенклатуры");
		Сообщение.Сообщить();
		
	Иначе
		
		СформироватьДокВзаиморасчетыНаСервере(); 
		
	КонецЕсли;

КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаСервере
Функция ПроверитьЗаполнениеЦен()
	
	ЦеныЗаполнены = Истина;
	
	Для Каждого Строка Из СписокНоменклатуры Цикл
		
		Если Не ЗначениеЗаполнено(Строка.Цена) Тогда
			
			Сообщение = Новый СообщениеПользователю;
			Сообщение.Текст = СтрШаблон("Не указана цена у номенклатуры (строка %1)", Строка.НомерСтроки);
			Сообщение.Сообщить();
			
			ЦеныЗаполнены = Ложь;;
			
		КонецЕсли;	
		
	КонецЦикла;
	
	Возврат ЦеныЗаполнены;
	
КонецФункции

&НаСервере
Функция ПроверитьНоменклатуру()
	
	ОтсутствуетНоменклатура = Ложь;
	
	Для Каждого Строка Из СписокНоменклатуры Цикл
		
		Если Не ЗначениеЗаполнено(Строка.Номенклатура) Тогда
			
			Сообщение = Новый СообщениеПользователю;
			Сообщение.Текст = СтрШаблон("Отсутствует сопоставленная номенклатура (строка №%1)", Строка.НомерСтроки);
			Сообщение.Сообщить();
			
			ОтсутствуетНоменклатура = Истина;
			
		КонецЕсли;
		
	КонецЦикла;
	
	Если ОтсутствуетНоменклатура Тогда
		
		Сообщение = Новый СообщениеПользователю;
		Сообщение.Текст = "Не удалось создать ввод первоначальных остатков, так как в таблице отсутствует сопоставленная номенклатура";
		Сообщение.Сообщить();
		
		Возврат Ложь;
		
	КонецЕсли;
	
	Возврат Истина;
	
КонецФункции

&НаСервере
Функция ПроверитьРеквизиты()
	
	РеквизитыЗаполнены = Истина;
	
	Если Элементы.Помещение.Видимость = Истина Тогда
		Если Не ЗначениеЗаполнено(Помещение) Тогда
			
			Сообщение = Новый СообщениеПользователю;
			Сообщение.Текст = "Выберите помещение";
			Сообщение.Сообщить();
			
			РеквизитыЗаполнены = Ложь;
			
		КонецЕсли;
	КонецЕсли;
	
	Если Элементы.ЗонаПриемки.Видимость = Истина Тогда
		Если Не ЗначениеЗаполнено(ЗонаПриемки) Тогда
			
			Сообщение = Новый СообщениеПользователю;
			Сообщение.Текст = "Выберите зону приемки";
			Сообщение.Сообщить();
			
			РеквизитыЗаполнены = Ложь;
			
		КонецЕсли;
