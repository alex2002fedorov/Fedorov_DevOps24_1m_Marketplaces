				МассивНомеровКолонок.Добавить(НомерКолонкиSKUТовараЦены);
				МассивНомеровКолонок.Добавить(НомерКолонкиЦена);
				
			ИначеЕсли Маркетплейс = Перечисления.рар_мп_Маркетплейсы.Ozon Тогда
				
				МассивНомеровКолонок.Добавить(НомерКолонкиSKUТовараЦены);
				МассивНомеровКолонок.Добавить(НомерКолонкиЦена);
				
