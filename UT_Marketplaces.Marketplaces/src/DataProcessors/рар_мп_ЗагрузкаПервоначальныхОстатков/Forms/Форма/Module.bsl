&НаКлиенте
Процедура ДокОстатковНоменклатурыПриИзменении(Элемент) 
	
	Если ДокОстатковНоменклатуры.Пустая() Тогда
		
		СуммаДокОстатков = 0; 
		
	Иначе
		
		ДокОстатковЗаполнениеПолей(ДокОстатковНоменклатуры);
		
	КонецЕсли;
	
КонецПроцедуры

