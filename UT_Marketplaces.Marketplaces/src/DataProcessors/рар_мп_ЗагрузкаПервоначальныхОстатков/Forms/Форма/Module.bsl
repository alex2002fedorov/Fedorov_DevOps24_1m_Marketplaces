&НаСервере
Процедура ДокОстатковЗаполнениеПолей(ДокОстатков)
	
	ДокОстатковНоменклатуры = ДокОстатков.Ссылка;
	
	Если ДокОстатковНоменклатуры.Проведен Тогда
		
		СуммаДокОстатков = ДокОстатковНоменклатуры.Товары.Итог("Сумма");
		
	КонецЕсли;

