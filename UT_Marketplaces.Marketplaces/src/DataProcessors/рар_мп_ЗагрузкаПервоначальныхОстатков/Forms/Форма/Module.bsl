&НаСервере
Процедура ЗавершениеЗагрузкиОшибкаНаСервере()
	
	Сообщение = Новый СообщениеПользователю;
	Сообщение.Текст = "Ошибка при загрузке данных. Подробное описание можно посмотреть в журнале регистрации";
	Сообщение.Сообщить();
	
	ЗаписьЖурналаРегистрации("Ошибка при загрузке данных", 
								УровеньЖурналаРегистрации.Ошибка,,, СтрШаблон("Аккаунт: %1. Описание ошибки: %2", АккаунтМаркетплейса.Наименование, ОписаниеОшибки()));
	
							КонецПроцедуры
							
&НаСервере
Функция ПроверитьУсловиеВыбораСклада()
	
	Маркетплейс = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(АккаунтМаркетплейса, "Маркетплейс");
	
	Если Маркетплейс <> Перечисления.рар_мп_Маркетплейсы.ЯндексМаркет Тогда
		
		Если АккаунтМаркетплейса.СхемаРаботы = Перечисления.рар_мп_СхемыРаботы.FBO Тогда
			Возврат Истина;	
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат Ложь;
	
