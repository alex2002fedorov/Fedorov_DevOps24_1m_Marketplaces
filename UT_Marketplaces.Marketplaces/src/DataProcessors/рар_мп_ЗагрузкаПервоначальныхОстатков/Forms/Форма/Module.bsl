					РеквизитыЗаполнены = Ложь;
					
				КонецЕсли;
				
				Если НомерКолонкиSKUТовараОстатков = 0 Тогда
					
					Сообщение = Новый СообщениеПользователю;
					Сообщение.Текст = "Укажите номер колонки ""SKU товара""";
					Сообщение.Сообщить();
					
					РеквизитыЗаполнены = Ложь;
					
				КонецЕсли;
				
			ИначеЕсли Маркетплейс = Перечисления.рар_мп_Маркетплейсы.ЯндексМаркет Тогда
				
				Если НомерКолонкиSKUТовараОстатков = 0 Тогда
					
					Сообщение = Новый СообщениеПользователю;
					Сообщение.Текст = "Укажите номер колонки ""SKU товара""";
					Сообщение.Сообщить();
					
					РеквизитыЗаполнены = Ложь;
					
				КонецЕсли;
				
			КонецЕсли;
			
			Если НомерКолонкиКоличество = 0 Тогда
				
				Сообщение = Новый СообщениеПользователю;
				Сообщение.Текст = "Укажите номер колонки ""Количество""";
				Сообщение.Сообщить();
				
				РеквизитыЗаполнены = Ложь;
				
			КонецЕсли;
			
			Возврат РеквизитыЗаполнены;
			
		КонецЕсли;
		
	Иначе
		
		Сообщение = Новый СообщениеПользователю;
		Сообщение.Текст = "Укажите вид загрузки товаров";
		Сообщение.Сообщить();
		
		Возврат Ложь;
		
