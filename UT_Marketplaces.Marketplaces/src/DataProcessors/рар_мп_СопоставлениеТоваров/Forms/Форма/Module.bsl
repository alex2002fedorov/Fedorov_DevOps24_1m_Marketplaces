#КонецОбласти   

#Область ЗагрузкаСопоставленныхТоваров

&НаКлиенте
Процедура ЗагрузитьСопоставленныеТовары(Команда)
	
	Если ПроверитьЗаполнение() Тогда
	
		ЗагрузитьСопоставленныеТоварыНаСервере();	
	
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ЗагрузитьСопоставленныеТоварыНаСервере()

	Если ОбщегоНазначения.ЗначениеРеквизитаОбъекта(АккаунтМаркетплейса, "Маркетплейс") = Перечисления.рар_мп_Маркетплейсы.Wildberries Тогда
				
		Запрос = Новый Запрос;
		Запрос.Текст = 
			"ВЫБРАТЬ
			|	рар_мп_Wildberries_СопоставленныеТовары.Аккаунт КАК Аккаунт,
			|	рар_мп_Wildberries_СопоставленныеТовары.IDТовара КАК IDТовара,
			|	рар_мп_Wildberries_СопоставленныеТовары.Артикул КАК Артикул,
			|	рар_мп_Wildberries_СопоставленныеТовары.Баракод КАК Баракод,
			|	рар_мп_Wildberries_СопоставленныеТовары.Размер КАК Размер,
			|	рар_мп_Wildberries_СопоставленныеТовары.Номенклатура КАК Номенклатура,
			|	рар_мп_Wildberries_СопоставленныеТовары.Характеристика КАК Характеристика,
			|	рар_мп_Wildberries_СопоставленныеТовары.Упаковка КАК Упаковка,
			|	рар_мп_Wildberries_СопоставленныеТовары.НаименованиеТовара КАК НаименованиеТовара
			|ИЗ
			|	РегистрСведений.рар_мп_Wildberries_СопоставленныеТовары КАК рар_мп_Wildberries_СопоставленныеТовары
			|ГДЕ
			|	рар_мп_Wildberries_СопоставленныеТовары.Аккаунт = &Аккаунт";	
		
	ИначеЕсли ОбщегоНазначения.ЗначениеРеквизитаОбъекта(АккаунтМаркетплейса, "Маркетплейс") = Перечисления.рар_мп_Маркетплейсы.ЯндексМаркет  Тогда
		
		Запрос = Новый Запрос;
		Запрос.Текст = 
			"ВЫБРАТЬ
			|	рар_мп_ЯндексМаркет_СопоставленныеТовары.Аккаунт КАК Аккаунт,
			|	рар_мп_ЯндексМаркет_СопоставленныеТовары.SKUТовара КАК SKUТовара,
			|	рар_мп_ЯндексМаркет_СопоставленныеТовары.Артикул КАК Артикул,
