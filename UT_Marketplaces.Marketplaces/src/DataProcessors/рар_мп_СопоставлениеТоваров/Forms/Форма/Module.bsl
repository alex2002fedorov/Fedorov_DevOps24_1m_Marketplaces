		Элементы.ТоварыКСопоставлению.ПодчиненныеЭлементы.ТоварыКСопоставлениюSKUЯндексМаркета.Видимость = Истина;
		Элементы.СопоставленныеТовары.ПодчиненныеЭлементы.СопоставленныеТоварыSKUЯндексМаркета.Видимость = Истина;
			
	ИначеЕсли ОбщегоНазначения.ЗначениеРеквизитаОбъекта(АккаунтМаркетплейса, "Маркетплейс") = Перечисления.рар_мп_Маркетплейсы.OZON Тогда
	
		Элементы.ТоварыКСопоставлению.ПодчиненныеЭлементы.ТоварыКСопоставлениюБаракод.Видимость = Истина;
		Элементы.ТоварыКСопоставлению.ПодчиненныеЭлементы.ТоварыКСопоставлениюРазмер.Видимость  = Ложь;
		
		Элементы.СопоставленныеТовары.ПодчиненныеЭлементы.СопоставленныеТоварыБаракод.Видимость = Ложь;
	    Элементы.СопоставленныеТовары.ПодчиненныеЭлементы.СопоставленныеТоварыРазмер.Видимость  = Ложь;
		
		Элементы.ТоварыКСопоставлению.ПодчиненныеЭлементы.ТоварыКСопоставлениюSKUТовара.Видимость = Истина;
		Элементы.СопоставленныеТовары.ПодчиненныеЭлементы.СопоставленныеТоварыSKUТовара.Видимость = Истина;
		
		Элементы.ТоварыКСопоставлению.ПодчиненныеЭлементы.ТоварыКСопоставлениюIDТовара.Видимость = Истина;
		Элементы.СопоставленныеТовары.ПодчиненныеЭлементы.СопоставленныеТоварыIDТовара.Видимость = Истина;
		
		Элементы.ТоварыКСопоставлению.ПодчиненныеЭлементы.ТоварыКСопоставлениюIDРазмера.Видимость = Ложь;
		Элементы.СопоставленныеТовары.ПодчиненныеЭлементы.СопоставленныеТоварыIDРазмера.Видимость = Ложь;
		
		Элементы.ТоварыКСопоставлению.ПодчиненныеЭлементы.ТоварыКСопоставлениюSKUЯндексМаркета.Видимость = Ложь;
		Элементы.СопоставленныеТовары.ПодчиненныеЭлементы.СопоставленныеТоварыSKUЯндексМаркета.Видимость = Ложь;

	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура АккаунтПриИзменении(Элемент)
	АккаунтПриИзмененииНаСервере();
КонецПроцедуры 

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	рар_мп_УправлениеЭлементамиФормыКлиентСервер.УстановитьСвязиПараметровВыбораХарактеристикиИУпаковки(ЭтотОбъект, "ТоварыКСопоставлению","ТоварыКСопоставлениюХарактеристика","ТоварыКСопоставлениюУпаковка");
	
	//Добавил kolchs
	Если Параметры.Свойство("АккаунтМаркетплейса") Тогда
		
		Если ЗначениеЗаполнено(Параметры.АккаунтМаркетплейса) Тогда
		
			АккаунтМаркетплейса = Параметры.АккаунтМаркетплейса;
			АккаунтПриИзмененииНаСервере();
		
		КонецЕсли;	
		
	КонецЕсли;	


КонецПроцедуры

&НаКлиенте
Процедура ТоварыКСопоставлениюНоменклатураПриИзменении(Элемент)
	ТекущаяСтрока = Элементы.ТоварыКСопоставлению.ТекущиеДанные;
	
	ТекущаяСтрока.ИзменитьПозицию = Истина;
КонецПроцедуры

#КонецОбласти 

#Область КнопкиУстановкиИСнятияГалочек

&НаКлиенте
Процедура ВыбратьВсеСтроки(Команда)
	
	Если Элементы.ГруппаТоварыКСопоставлениюИСопоставленныеТовары.ТекущаяСтраница.Имя = "ГруппаТоварыКСопоставлению" Тогда
	
		Для каждого Стр Из ТоварыКСопоставлению Цикл
		
			Стр.ИзменитьПозицию = Истина;	
		
		КонецЦикла;	
	
	Иначе
	
		Для каждого Стр Из СопоставленныеТовары Цикл
		
			Стр.ИзменитьПозицию = Истина;	
		
		КонецЦикла;	
	
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура СнятьВыделениеВсехСтрок(Команда)
	
	Если Элементы.ГруппаТоварыКСопоставлениюИСопоставленныеТовары.ТекущаяСтраница.Имя = "ГруппаТоварыКСопоставлению" Тогда
	
		Для каждого Стр Из ТоварыКСопоставлению Цикл
		
			Стр.ИзменитьПозицию = Ложь;	
		
		КонецЦикла;	
	
	Иначе
	
		Для каждого Стр Из СопоставленныеТовары Цикл
		
			Стр.ИзменитьПозицию = Ложь;	
		
		КонецЦикла;	
	
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти 

#Область УдалениеСопоставленияТоваров

&НаКлиенте
Процедура УдалитьСопоставлениеТоваров(Команда)
	
	Если ПроверитьЗаполнение() Тогда
	
		ДлительнаяОперация     = УдалитьСопоставлениеТоваровНаСервере();
		ПараметрыОжидания      = ДлительныеОперацииКлиент.ПараметрыОжидания(ЭтотОбъект);
		ПараметрыОжидания.ВыводитьСообщения = Истина;
		ПараметрыОжидания.ВыводитьОкноОжидания = Истина;
		ПараметрыОжидания.ТекстСообщения = "Удаление сопоставления ...";
		Оповещение = Новый ОписаниеОповещения("ЗавершениеУдаленияСопоставления", ЭтотОбъект);
		ДлительныеОперацииКлиент.ОжидатьЗавершение(ДлительнаяОперация, Оповещение, ПараметрыОжидания);	
	
	КонецЕсли;

	
	
КонецПроцедуры

&НаСервере
Функция УдалитьСопоставлениеТоваровНаСервере()
	
	ПараметрыВыполнения = ДлительныеОперации.ПараметрыВыполненияФункции(УникальныйИдентификатор); 
			
	ВозвратныеДанные = ДлительныеОперации.ВыполнитьФункцию(ПараметрыВыполнения, 
		"рар_мп_СопоставлениеТоваров.УдалениеСопоставления", СопоставленныеТовары.Выгрузить(), АккаунтМаркетплейса);
		
	Возврат ВозвратныеДанные;		
	
КонецФункции

&НаКлиенте
Процедура ЗавершениеУдаленияСопоставления(Результат, СтруктураПараметров) Экспорт
	
    Если Результат = НЕОПРЕДЕЛЕНО Тогда
	
		Возврат;	
	
	КонецЕсли;
	
	Если Результат.Статус = "Выполнено" Тогда
	
		ЗавершениеУдаленияСопоставленияНаСервере(Результат);
		
	ИначеЕсли Результат.Статус = "Ошибка" Тогда
		
		Сообщение = Новый СообщениеПользователю;
		Сообщение.Текст = СтрШаблон("Ошибка при удалении сопоставления. Описание ошибки: %1", Результат.КраткоеПредставлениеОшибки);
		Сообщение.Сообщить();
	
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ЗавершениеУдаленияСопоставленияНаСервере(Результат)
	
	ТЗ = ПолучитьИзВременногоХранилища(Результат.АдресРезультата);
	
	Попытка
	
		СопоставленныеТовары.Загрузить(ТЗ);
	
	Исключение
		
		ОбщегоНазначения.СообщитьПользователю("Ошибка при удалении сопоставленных товаров из табличной части. Подробное описание ошибки можно посмотреть в журнале регистрации");
		
		ЗаписьЖурналаРегистрации("Ошибка при удалении сопоставленных товаров из табличной части", УровеньЖурналаРегистрации.Ошибка,,, ОписаниеОшибки(),);
		
	КонецПопытки;
	
	
КонецПроцедуры

#КонецОбласти

#Область СохранениеСопоставления

&НаСервере
Функция СохранитьСопоставлениеНаСервере()
	
	ПараметрыВыполнения = ДлительныеОперации.ПараметрыВыполненияФункции(УникальныйИдентификатор); 
			
	ВозвратныеДанные = ДлительныеОперации.ВыполнитьФункцию(ПараметрыВыполнения, 
		"рар_мп_СопоставлениеТоваров.СохранениеСопоставления", ТоварыКСопоставлению.Выгрузить(), АккаунтМаркетплейса);
		
	Возврат ВозвратныеДанные;	
	
КонецФункции 

&НаКлиенте
Процедура СохранитьСопоставление(Команда)

	Если ПроверитьЗаполнение() Тогда
		
		ДлительнаяОперация     = СохранитьСопоставлениеНаСервере();
		ПараметрыОжидания      = ДлительныеОперацииКлиент.ПараметрыОжидания(ЭтотОбъект);
		ПараметрыОжидания.ВыводитьСообщения = Истина;
		ПараметрыОжидания.ВыводитьОкноОжидания = Истина;
		ПараметрыОжидания.ТекстСообщения = "Сохранение сопоставления ...";
		Оповещение = Новый ОписаниеОповещения("ЗавершениеСопоставления", ЭтотОбъект);
		ДлительныеОперацииКлиент.ОжидатьЗавершение(ДлительнаяОперация, Оповещение, ПараметрыОжидания);	
	
	КонецЕсли;	

КонецПроцедуры

&НаКлиенте
Процедура ЗавершениеСопоставления(Результат, СтруктураПараметров) Экспорт
	
    Если Результат = НЕОПРЕДЕЛЕНО Тогда
	
		Возврат;	
	
	КонецЕсли;
	
	Если Результат.Статус = "Выполнено" Тогда
	
		ЗавершениеСопоставленияНаСервере(Результат);
		
	ИначеЕсли Результат.Статус = "Ошибка" Тогда
		
		Сообщение = Новый СообщениеПользователю;
