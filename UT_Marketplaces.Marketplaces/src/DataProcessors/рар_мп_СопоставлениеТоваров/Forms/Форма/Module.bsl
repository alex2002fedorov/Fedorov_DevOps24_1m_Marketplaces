			|ГДЕ
			|	рар_мп_Ozon_СопоставленныеТовары.Аккаунт = &Аккаунт";
							
	КонецЕсли;
	
	Запрос.УстановитьПараметр("Аккаунт", АккаунтМаркетплейса);
	
	РезультатЗапроса = Запрос.Выполнить(); 
	
	Если НЕ РезультатЗапроса.Пустой() Тогда
	
		Выборка = РезультатЗапроса.Выгрузить();
		
