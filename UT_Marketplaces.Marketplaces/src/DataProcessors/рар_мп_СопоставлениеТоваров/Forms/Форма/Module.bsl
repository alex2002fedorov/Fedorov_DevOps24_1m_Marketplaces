#Область ЗагрузаТоваровКСопоставлению

&НаКлиенте
Процедура ЗагрузитьТоварыКСопоставлению(Команда)
	
	Если ПроверитьЗаполнение() Тогда
	
		ТоварыКСопоставлению.Очистить();
		
		ДлительнаяОперация     = ЗагрузитьТоварыКСопоставлениюНаСервере();
		ПараметрыОжидания      = ДлительныеОперацииКлиент.ПараметрыОжидания(ЭтотОбъект);
		ПараметрыОжидания.ВыводитьСообщения = Истина;
		ПараметрыОжидания.ВыводитьОкноОжидания = Истина;
		ПараметрыОжидания.ТекстСообщения = "Получение товаров из маркетплейса ...";
		Оповещение = Новый ОписаниеОповещения("ЗавершениеЗагрузкиТоваровКСопоставлению", ЭтотОбъект);
		ДлительныеОперацииКлиент.ОжидатьЗавершение(ДлительнаяОперация, Оповещение, ПараметрыОжидания); 
	
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Функция ЗагрузитьТоварыКСопоставлениюНаСервере()
	
	Маркетплейс = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(АккаунтМаркетплейса, "Маркетплейс");
	
	Если Маркетплейс = Перечисления.рар_мп_Маркетплейсы.Ozon Тогда
		
		ПараметрыВыполнения = ДлительныеОперации.ПараметрыВыполненияФункции(УникальныйИдентификатор); 
			
		ВозвратныеДанные = ДлительныеОперации.ВыполнитьФункцию(ПараметрыВыполнения, 
			"рар_мп_СопоставлениеТоваров.ПолучитьСписокТоваровКСопоставлению_Ozon", АккаунтМаркетплейса);
			
		Возврат ВозвратныеДанные;

		
	ИначеЕсли Маркетплейс = Перечисления.рар_мп_Маркетплейсы.ЯндексМаркет Тогда
		
		ПараметрыВыполнения = ДлительныеОперации.ПараметрыВыполненияФункции(УникальныйИдентификатор); 
			
		ВозвратныеДанные = ДлительныеОперации.ВыполнитьФункцию(ПараметрыВыполнения, 
			"рар_мп_СопоставлениеТоваров.ПолучитьСписокТоваровКСопоставлению_ЯндексМаркет", АккаунтМаркетплейса);
			
		Возврат ВозвратныеДанные;
			
		
	ИначеЕсли Маркетплейс = Перечисления.рар_мп_Маркетплейсы.Wildberries Тогда 
		
		ПараметрыВыполнения = ДлительныеОперации.ПараметрыВыполненияФункции(УникальныйИдентификатор); 
		
    	ВозвратныеДанные = ДлительныеОперации.ВыполнитьФункцию(ПараметрыВыполнения, 
        	"рар_мп_СопоставлениеТоваров.ПолучитьСписокТоваровКСопоставлению_Wildberries",АккаунтМаркетплейса);
	
				
		 Возврат ВозвратныеДанные;
		
	КонецЕсли;   
	
КонецФункции

&НаСервере
Процедура ЗавершениеЗагрузкиТоваровКСопоставлениюНаСервере(Результат)
	
	ТЗ = ПолучитьИзВременногоХранилища(Результат.АдресРезультата);
	
	Попытка
	
		ТоварыКСопоставлению.Загрузить(ТЗ);
		
		
		Если ТоварыКСопоставлению.Количество() = 0 Тогда
			
			ОбщегоНазначения.СообщитьПользователю("Для данного аккаунта нет товаров для сопоставления");
			
		Иначе
			
			ОбщегоНазначения.СообщитьПользователю("Загрузка товаров завершена");
		
		КонецЕсли;
	
	Исключение
		
		ОбщегоНазначения.СообщитьПользователю("Ошибка при загрузке товаров из маркетплейса. Подробное описание ошибки можно посмотреть в журнале регистрации");
		
		ЗаписьЖурналаРегистрации("Ошибка при загрузке товаров из маркетплейса в табличную часть", УровеньЖурналаРегистрации.Ошибка,,, ОписаниеОшибки(),);
		
	КонецПопытки;
	
	
КонецПроцедуры

&НаКлиенте
Процедура ЗавершениеЗагрузкиТоваровКСопоставлению(Результат, СтруктураПараметров) Экспорт
	
    Если Результат = НЕОПРЕДЕЛЕНО Тогда
	
		Возврат;	
	
	КонецЕсли;
	
	Если Результат.Статус = "Выполнено" Тогда
	
		ЗавершениеЗагрузкиТоваровКСопоставлениюНаСервере(Результат);
		
	ИначеЕсли Результат.Статус = "Ошибка" Тогда
		
		Сообщение = Новый СообщениеПользователю;
		Сообщение.Текст = СтрШаблон("Ошибка при загрузке товаров к сопоставлению. Описание ошибки: %1", Результат.КраткоеПредставлениеОшибки);
		Сообщение.Сообщить();

	КонецЕсли;
	
КонецПроцедуры
	
