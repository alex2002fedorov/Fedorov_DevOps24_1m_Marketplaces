КонецПроцедуры  

#КонецОбласти
 
#Область ЗагрузкаЗаказов

 &НаСервере
Функция ЗагрузкаЗаказовНаСервере()
	
	Если Маркетплейс = Перечисления.рар_мп_Маркетплейсы.OZON Тогда
		
		ПараметрыВыполнения = ДлительныеОперации.ПараметрыВыполненияФункции(УникальныйИдентификатор);
		
		ВозвратныеДанные = ДлительныеОперации.ВыполнитьПроцедуру(ПараметрыВыполнения, "рар_мп_ЗагрузкаЗаказов.Ozon_ЗагрузкаЗаказов");
	
	ИначеЕсли Маркетплейс = Перечисления.рар_мп_Маркетплейсы.Wildberries Тогда
		
		ПараметрыВыполнения = ДлительныеОперации.ПараметрыВыполненияФункции(УникальныйИдентификатор);
		
		ВозвратныеДанные = ДлительныеОперации.ВыполнитьПроцедуру(ПараметрыВыполнения, "рар_мп_ЗагрузкаЗаказов.Wildberries_ЗагрузкаЗаказов");
	
	ИначеЕсли Маркетплейс = Перечисления.рар_мп_Маркетплейсы.ЯндексМаркет Тогда
		
		ПараметрыВыполнения = ДлительныеОперации.ПараметрыВыполненияФункции(УникальныйИдентификатор);
		
		ВозвратныеДанные = ДлительныеОперации.ВыполнитьПроцедуру(ПараметрыВыполнения, "рар_мп_ЗагрузкаЗаказов.ЯндексМаркет_ЗагрузкаЗаказов");
	
	КонецЕсли;
	
	Возврат ВозвратныеДанные;
	
КонецФункции

&НаКлиенте
Процедура ЗагрузкаЗаказов(Команда)
	
	Если ПроверитьЗаполнение() Тогда
		
		ДлительнаяОперация     = ЗагрузкаЗаказовНаСервере();
		ПараметрыОжидания      = ДлительныеОперацииКлиент.ПараметрыОжидания(ЭтотОбъект);
	    ПараметрыОжидания.ВыводитьСообщения = Истина;
	    ПараметрыОжидания.ВыводитьОкноОжидания = Истина;
	    ПараметрыОжидания.ТекстСообщения = "Получение информации о заказах...";                                    
	    Оповещение = Новый ОписаниеОповещения("ЗавершениеПолученияЗаказов", ЭтотОбъект);
	    ДлительныеОперацииКлиент.ОжидатьЗавершение(ДлительнаяОперация, Оповещение, ПараметрыОжидания);	
	
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ЗавершениеПолученияЗаказов(Результат, СтруктураПараметров) Экспорт

	 Если Результат = НЕОПРЕДЕЛЕНО Тогда
	
		Возврат;	
	
	КонецЕсли;
	
	Если Результат.Статус = "Ошибка" Тогда
		
		СтандартныеПодсистемыКлиент.ВывестиИнформациюОбОшибке(Результат.ИнформацияОбОшибке);
		
		Возврат;
	
	ИначеЕсли Результат.Статус = "Выполнено" Тогда
		
		Сообщение = Новый СообщениеПользователю;
		Сообщение.Текст = "Загрузка заказов завершена";
		Сообщение.Сообщить();
		
	КонецЕсли;

КонецПроцедуры


#КонецОбласти  

