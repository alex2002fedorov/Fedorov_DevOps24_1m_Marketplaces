&НаКлиенте
Процедура СохранитьНастройкиПодключения(Команда)
	ЗаписатьКонстанты();
	ОбщегоНазначенияКлиент.СообщитьПользователю("Данные сохранены!");
КонецПроцедуры

&НаСервере
Процедура ЗаписатьКонстанты()
	Константы.АдресПубликацииИнформационнойБазыДляТСД.Установить(АдресПубликацииИнформационнойБазыДляТСД);
	Константы.ЛогинДляСервисов.Установить(ЛогинСервисы);
	Константы.ПарольДляСервисов.Установить(РаботаСШифрованием.ЗашифроватьСообщение(ПарольСервисы)); 
КонецПроцедуры

&НаКлиенте
Процедура СформироватьQRКоды(Команда)
	Если ПользователиДляПечатиQRКодов.Количество() > 0 Тогда
		СформироватьQRКодыНаСервере();
	Иначе
		ОбщегоНазначенияКлиент.СообщитьПользователю("Заполните таблицу пользователей для которых нужно распечатать QR-код!");
	КонецЕсли;
КонецПроцедуры   

&НаСервере
Процедура СформироватьQRКодыНаСервере()
	МассивИдентификаторовПользователейИБ = ПолучитьМассивИдентификаторовПользователейИБ();
	ГрупповаяТаблицаQRКодов.Очистить();
	
	Для Каждого ИдентификаторПользователяИБ Из МассивИдентификаторовПользователейИБ Цикл
		ПользовательИБ = ПользователиИнформационнойБазы.НайтиПоУникальномуИдентификатору(ИдентификаторПользователяИБ);
		ВывестиQRПользователя(ПользовательИБ, ГрупповаяТаблицаQRКодов);	
	КонецЦикла;
КонецПроцедуры

Функция ПолучитьМассивИдентификаторовПользователейИБ()
	МассивИдентификаторовПользователейИБ = Новый Массив;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	Пользователи.Пользователь КАК Пользователь
		|ПОМЕСТИТЬ ВТ_Пользователи
		|ИЗ
		|	&Пользователи КАК Пользователи
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТ_Пользователи.Пользователь.ИдентификаторПользователяИБ КАК ИдентификаторПользователяИБ
		|ИЗ
		|	ВТ_Пользователи КАК ВТ_Пользователи";
	
	Запрос.УстановитьПараметр("Пользователи", ПользователиДляПечатиQRКодов.Выгрузить());
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Пока Выборка.Следующий() Цикл
		МассивИдентификаторовПользователейИБ.Добавить(Выборка.ИдентификаторПользователяИБ);
	КонецЦикла;
	
	Возврат МассивИдентификаторовПользователейИБ;
КонецФункции




