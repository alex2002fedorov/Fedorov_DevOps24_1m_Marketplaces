&НаСервере
Функция ПроверитьЗаполнениеОрганизацииИПочты()
	
	Если Организация = Справочники.Организации.ПустаяСсылка() Тогда
		
		Сообщить("Пожалуйста заполните реквизит Организация");	
		
		Возврат Ложь;
		
	КонецЕсли;	
	
	Если СтрНайти(Email,"@") = 0 Или СтрНайти(Email,".") = 0 Тогда
		
		Сообщить("Необходимо ввести правильный адрес электронной почты");
		
		Возврат Ложь;
		
	КонецЕсли;
	
	Возврат Истина;  
	
КонецФункции

&НаСервере
Процедура ОрганизацияПриИзмененииНаСервере()
	
	ИНН = Организация.ИНН;
	Email = "";
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ОрганизацииКонтактнаяИнформация.АдресЭП КАК АдресЭП
	|ИЗ
	|	Справочник.Организации.КонтактнаяИнформация КАК ОрганизацииКонтактнаяИнформация
	|ГДЕ
	|	ОрганизацииКонтактнаяИнформация.Ссылка = &Ссылка
	|	И ОрганизацииКонтактнаяИнформация.Тип = ЗНАЧЕНИЕ(Перечисление.ТипыКонтактнойИнформации.АдресЭлектроннойПочты)";
	
	Запрос.УстановитьПараметр("Ссылка", Организация);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Если НЕ РезультатЗапроса.Пустой() Тогда
		
		Результат = РезультатЗапроса.Выгрузить();
		Email = Результат[0].АдресЭП;
		
	КонецЕсли;	
	
КонецПроцедуры

&НаСервере
Процедура ОтправитьНаРегистрациюНаСервере()
	
	Если ПроверитьЗаполнениеОрганизацииИПочты() Тогда
		
		Результат = ОбменДаннымиЛицензированиеТСД.ОтправитьНаРегистрацию(ПолучитьРегДанныеОрганизации());
		
		Элементы.СтраницаВыбора.Видимость = Ложь; 
		Элементы.СтраницаРегистрации.Видимость = Ложь;
		Элементы.СтраницаПеререгистрации.Видимость = Ложь;
		Элементы.СтраницаБезДоступаКСети.Видимость = Ложь;
		Элементы.СтраницаОтветаСервера.Видимость = Истина;
		
		Если Результат.Успешно Тогда
			
			Элементы.Успешно.Видимость = Истина;
			
			Элементы.НадписьУспешныйОтвет.Заголовок = "Данные для регистрации лицензии успешно отправлены!";   
			
			ЗаписатьСтатусРегистрацииТСД(0);
			
		Иначе    
			
			Элементы.Ошибка.Видимость = Истина;
			
			Элементы.НадписьУспешныйОтвет.Заголовок = "Данные для регистрации лицензии не отправлены!";
			
		КонецЕсли;    
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ПолучитьЛицензиюНаСервере()
	
	Если ПроверитьЗаполнениеОрганизацииИПочты() Тогда
		
		РегДанные = Новый Структура;
		
		РегДанные.Вставить("Организация",Организация.Наименование); 
		
		Результат = ОбменДаннымиЛицензированиеТСД.ПолучитьЛицензию(РегДанные); 
		
		Элементы.СтраницаВыбора.Видимость = Ложь; 
		Элементы.СтраницаРегистрации.Видимость = Ложь;
		Элементы.СтраницаПеререгистрации.Видимость = Ложь;
		Элементы.СтраницаБезДоступаКСети.Видимость = Ложь;
		Элементы.СтраницаОтветаСервера.Видимость = Истина;
		
		Если Результат.Успешно Тогда 
			
			Элементы.Успешно.Видимость = Истина;    
			
			ЗаписатьСтатусРегистрацииТСД(1,Результат.ЛицензионныйКлюч); 
									
			Элементы.НадписьУспешныйОтвет.Заголовок = "Лицензионный ключ успешно получен";
			
		Иначе
			
			Элементы.Ошибка.Видимость = Истина;
			
			Элементы.НадписьУспешныйОтвет.Заголовок = "Лицензионный ключ для выбранной организации отсутсвует, пожалуйста свяжитесь с компанией 1С-Рарус";
			
		КонецЕсли;    
		
		
	КонецЕсли;
	
КонецПроцедуры

