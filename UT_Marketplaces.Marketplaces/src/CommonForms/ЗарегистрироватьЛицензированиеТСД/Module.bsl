&НаКлиенте
Процедура СохранитьДанныеВФайл(Команда)
	
	Режим = РежимДиалогаВыбораФайла.ВыборКаталога;   
	
	ДиалогОткрытия = Новый ДиалогВыбораФайла(Режим); 
	
	ДиалогОткрытия.Каталог = ""; 
	
	ДиалогОткрытия.МножественныйВыбор = Ложь; 
	
	ДиалогОткрытия.Заголовок = "Выберите каталог"; 
	
	Если ДиалогОткрытия.Выбрать() Тогда 
		
		ПутьККаталогу = ДиалогОткрытия.Каталог; 
		
	КонецЕсли; 
	
	Если ПроверитьЗаполнениеОрганизацииИПочты() Тогда
		
		ТекстовыйФайл = Новый ТекстовыйДокумент;
		
		ТекстовыйФайл.ДобавитьСтроку(ИНН + "/" + Организация + "/" + Email);
		
		СписокIDТСД = ПолучитьСписокIDТСД();		
		
		Для Каждого Стр Из СписокIDТСД Цикл 
			
			ТекстовыйФайл.ДобавитьСтроку(Строка(Стр) + "//"); 
			
		КонецЦикла;
		
		Если ПутьККаталогу <> Неопределено Тогда
			
			ТекстовыйФайл.Записать(
			ПутьККаталогу + "\ДанныеДляРегистрацииТСД.txt",        
			КодировкаТекста.UTF8, 
			Символы.ВК + Символы.ПС
			);
			
			Сообщение = Новый СообщениеПользователю();
			Сообщение.Текст = "Данные для регистрации ТСД успешно сохранены в файл";
			Сообщение.Сообщить();
			
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры  

&НаСервере
Функция ПолучитьСписокIDТСД()
	
	СписокIDТСД = Новый Массив;
		
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	РегистрацияТСД.IDТСД КАК IDТСД
		|ИЗ
		|	РегистрСведений.РегистрацияТСД КАК РегистрацияТСД";
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		СписокIDТСД.Добавить(ВыборкаДетальныеЗаписи.IDТСД);	
	КонецЦикла;
	
	Возврат СписокIDТСД;
	
КонецФункции

