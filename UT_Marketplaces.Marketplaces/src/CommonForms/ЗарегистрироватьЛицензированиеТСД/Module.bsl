&НаСервере
Процедура ЗаписатьСтатусРегистрацииТСД(Статус,ЛицензионныйКлюч = "")   
	
	НаборЗаписей = РегистрыСведений.СтатусыРегистрацийТСД.СоздатьНаборЗаписей();
	НаборЗаписей.Отбор.Организация.Установить(Организация);
	НаборЗаписей.Прочитать();
	
	Если НаборЗаписей.Количество() = 0 Тогда		
		НоваяЗапись = НаборЗаписей.Добавить();
		НоваяЗапись.Организация = Организация;
		НоваяЗапись.ЛицензионныйКлючЛицензированиеТСД = ЛицензионныйКлюч;
		НоваяЗапись.Статус = ?(Статус = 0, 
								Перечисления.СтатусыРегистрацийТСД.ОтправленаНаРегистрацию,
								Перечисления.СтатусыРегистрацийТСД.ЛицензияПолучена);	
	Иначе	
		НаборЗаписей[0].ЛицензионныйКлючЛицензированиеТСД = ЛицензионныйКлюч;
		НаборЗаписей[0].Статус = ?(Статус = 0, 
								Перечисления.СтатусыРегистрацийТСД.ОтправленаНаРегистрацию,
								Перечисления.СтатусыРегистрацийТСД.ЛицензияПолучена);			
	КонецЕсли;
	
	НаборЗаписей.Записать();
	
КонецПроцедуры

&НаКлиенте
Процедура ЗагрузитьЛицензионныйКлючИзФайла(Команда)
	
	ДиалогВыбора = Новый ДиалогВыбораФайла(РежимДиалогаВыбораФайла.Открытие);	
	ДиалогВыбора.Заголовок = "Выберите файл";
	ДиалогВыбора.Фильтр = "Текст(*.txt)|*.txt";	
	ДиалогВыбора.МножественныйВыбор=Ложь;
	
	Если ДиалогВыбора.Выбрать() Тогда
		
		ИмяФайла = ДиалогВыбора.ПолноеИмяФайла;
		
	КонецЕсли; 
	
	Текст = Новый ЧтениеТекста(ИмяФайла);	
	Строка = Текст.ПрочитатьСтроку();
	
	Если Строка <> Неопределено Тогда
		ЗаписатьСтатусРегистрацииТСД(1,Строка);
		
		Сообщение = Новый СообщениеПользователю();
		Сообщение.Текст = "Лицензия для организации " + Организация + " успешно получена";
		Сообщение.Сообщить(); 
	Иначе
		Сообщение = Новый СообщениеПользователю();
		Сообщение.Текст = "Лицензионный ключ отсутствует в выбранном файле";
		Сообщение.Сообщить();
	КонецЕсли;   
	
КонецПроцедуры
                                                                               
