Процедура ОбновитьИдентификацонныеНомера(Команда)
	
	ОбновитьИдентификацонныеНомераНаСервере();  
	//После удаления ТСД обновим список ТСД и подключим обновление в фоне для новых ТСД
	Элементы.IDТСД.Обновить(); 
