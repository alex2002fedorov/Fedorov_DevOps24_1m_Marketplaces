&НаСервере
Функция ПолучитьРегДанныеОрганизации()

	РегДанные = Новый Структура;
	
	РегДанные.Вставить("ИНН",ИНН);
	РегДанные.Вставить("Организация",Организация.Наименование); 
	РегДанные.Вставить("Email",Email);
	
	СтрокаIDТСД = "";
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	РегистрацияТСД.IDТСД КАК IDТСД
	|ИЗ
	|	РегистрСведений.РегистрацияТСД КАК РегистрацияТСД";
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		
		Если СтрокаIDТСД = "" Тогда
			СтрокаIDТСД = СтрокаIDТСД + ВыборкаДетальныеЗаписи.IDТСД;
		Иначе
			СтрокаIDТСД = СтрокаIDТСД + "//" + ВыборкаДетальныеЗаписи.IDТСД;
		КонецЕсли;
		
	КонецЦикла;
	
	РегДанные.Вставить("IDТСД",СтрокаIDТСД);
	
	Возврат РегДанные; 
		
КонецФункции

