		НомерЗаказа = Элементы.ЗаказыИзМаркетплейса.ТекущиеДанные.рар_мп_НомерЗаказа;
		
		ДлительнаяОперация     = ПолучениеЭтикетки(НомерЗаказа);
		ПараметрыОжидания      = ДлительныеОперацииКлиент.ПараметрыОжидания(ЭтотОбъект);
		ПараметрыОжидания.ВыводитьСообщения = Истина;
		ПараметрыОжидания.ВыводитьОкноОжидания = Истина;
		ПараметрыОжидания.ТекстСообщения = "Получение этикетки для заказа...";                                    
		Оповещение = Новый ОписаниеОповещения("ЗавершениеПолученияЭтикети", ЭтотОбъект);
		ДлительныеОперацииКлиент.ОжидатьЗавершение(ДлительнаяОперация, Оповещение, ПараметрыОжидания);	
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Функция ПолучениеЭтикетки(НомерЗаказа)
	
	Маркетплейс = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Объект.рар_мп_АккаунтМаркетплейса, "Маркетплейс");
	
	Если Маркетплейс = Перечисления.рар_мп_Маркетплейсы.OZON Тогда 
		
		МассивНомеровЗаказов = Новый Массив; 
		МассивНомеровЗаказов.Добавить(НомерЗаказа);
		
		ПараметрыВыполнения = ДлительныеОперации.ПараметрыВыполненияФункции(УникальныйИдентификатор);
		
		ВозвратныеДанные = ДлительныеОперации.ВыполнитьФункцию(ПараметрыВыполнения, "рар_мп_ОбработкаЗаказов.Ozon_ПолучитьЭтикетки", 
		Объект.рар_мп_АккаунтМаркетплейса, МассивНомеровЗаказов);		
		
	ИначеЕсли Маркетплейс = Перечисления.рар_мп_Маркетплейсы.ЯндексМаркет Тогда
		
		МассивНомеровЗаказов = Новый Массив; 
		МассивНомеровЗаказов.Добавить(НомерЗаказа);
		
		ПараметрыВыполнения = ДлительныеОперации.ПараметрыВыполненияФункции(УникальныйИдентификатор);
		
		ВозвратныеДанные = ДлительныеОперации.ВыполнитьФункцию(ПараметрыВыполнения, "рар_мп_ОбработкаЗаказов.ЯндексМаркет_ПолучитьЭтикеткиЗаказов", 
		Объект.рар_мп_АккаунтМаркетплейса, МассивНомеровЗаказов);
		
	ИначеЕсли Маркетплейс = Перечисления.рар_мп_Маркетплейсы.Wildberries Тогда 
		
		МассивНомеровЗаказов = Новый Массив; 
		МассивНомеровЗаказов.Добавить(НомерЗаказа);
		
		ПараметрыВыполнения = ДлительныеОперации.ПараметрыВыполненияФункции(УникальныйИдентификатор);
		
		ВозвратныеДанные = ДлительныеОперации.ВыполнитьФункцию(ПараметрыВыполнения, "рар_мп_ОбработкаЗаказов.Wildberries_ПолучитьЭтикеткиЗаказов", 
		Объект.рар_мп_АккаунтМаркетплейса, МассивНомеровЗаказов);
		
	КонецЕсли; 
	
	Возврат ВозвратныеДанные;
	
КонецФункции

&НаКлиенте
Процедура ЗавершениеПолученияЭтикети(Результат, СтруктураПараметров) Экспорт
	
	Если Результат = НЕОПРЕДЕЛЕНО Тогда
		
		Возврат;	
		
	КонецЕсли;
	
	Если Результат.Статус = "Ошибка" Тогда
		
		СтандартныеПодсистемыКлиент.ВывестиИнформациюОбОшибке(Результат.ИнформацияОбОшибке);
		
		Возврат;
		
	ИначеЕсли Результат.Статус = "Выполнено" Тогда
		
		ТипФайла = ПолучитьТипФайлаЭтикеток();
		
		Если ТипФайла = "PDF" Тогда
			
			Попытка
				
				МассивДокументов = ПолучитьИзВременногоХранилища(Результат.АдресРезультата);
				
				Если МассивДокументов.Количество() > 0 Тогда
					
					Страница = 1;
					
					Для каждого Документ Из МассивДокументов Цикл
						
						ДокументPDF = Новый ДокументPDF;
						
						Поток = Документ.ОткрытьПотокДляЧтения();
						
						//@skip-check bsl-legacy-check-dynamic-feature-access
						ДокументPDF.Прочитать(Поток);
						
						ДокументPDF.Показать(СтрШаблон("Этикетки. Страница %1", Страница));
						
						Страница = Страница + 1;
						
					КонецЦикла;	
					
				КонецЕсли;
				
			Исключение
				
				Сообщение = Новый СообщениеПользователю;
				Сообщение.Текст = "Не удалось вывести этикетки на печать. Описание ошибки в журнале регистрации";
				Сообщение.Сообщить(); 
				
				//@skip-check undefined-function
				ЖурналРегистрацииКлиент.ДобавитьСообщениеДляЖурналаРегистрации("Ошибка при выводе этикеток на печать", "Ошибка", 
				ОписаниеОшибки(), ТекущаяДатаСеанса(), Истина);
				
			КонецПопытки;
			
			
		ИначеЕсли ТипФайла = "PNG" Тогда
			
			Попытка
				
				МассивЭтикеток = ПолучитьИзВременногоХранилища(Результат.АдресРезультата);
				
				Если МассивЭтикеток.Количество() <> 0 Тогда
					
					ТабДок = СформироватьПечатнуюФормуЭтикетки(МассивЭтикеток);
					
					КоллекцияПечатныхФорм =  УправлениеПечатьюКлиент.НоваяКоллекцияПечатныхФорм("Этикетки");    
					
					КоллекцияПечатныхФорм[0].ТабличныйДокумент = ТабДок; 
					КоллекцияПечатныхФорм[0].СинонимМакета = "Этикетка сборочного задания";			
					ПараметрыВывода = Новый Структура("ЗаголовокФормы", "Этикетка сборочного задания");
					УправлениеПечатьюКлиент.ПечатьДокументов(КоллекцияПечатныхФорм,"Этикетки",ПараметрыВывода);	
					
				КонецЕсли;
				
			Исключение
				
				Сообщение = Новый СообщениеПользователю;
				Сообщение.Текст = "Не удалось вывести этикетки на печать. Описание ошибки в журнале регистрации";
				Сообщение.Сообщить(); 
				
				//@skip-check use-non-recommended-method
				ЖурналРегистрацииКлиент.ДобавитьСообщениеДляЖурналаРегистрации("Ошибка при выводе этикеток на печать", "Ошибка", 
				ОписаниеОшибки(), ТекущаяДата(), Истина);
				
			КонецПопытки;
			
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

