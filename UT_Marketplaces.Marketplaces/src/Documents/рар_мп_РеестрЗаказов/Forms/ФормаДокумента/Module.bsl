			Иначе
				
				ДлительнаяОперация     = СформироватьЛистПодбораНаСервере();
				ПараметрыОжидания      = ДлительныеОперацииКлиент.ПараметрыОжидания(ЭтотОбъект);
				ПараметрыОжидания.ВыводитьСообщения = Истина;
				ПараметрыОжидания.ВыводитьОкноОжидания = Истина;
				ПараметрыОжидания.ТекстСообщения = "Формирование листа подбора...";     
				
				Оповещение = Новый ОписаниеОповещения("ЗавершениеФормированияЛистаПодбора", ЭтотОбъект);
				
