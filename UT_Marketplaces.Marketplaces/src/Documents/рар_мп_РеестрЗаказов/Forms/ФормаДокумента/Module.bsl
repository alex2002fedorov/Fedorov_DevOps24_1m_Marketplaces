		Элементы.СоздатьКоробку.Видимость = Истина;
		
		Элементы.УдалитьКоробку.Видимость = Истина;
		
		Элементы.рар_мп_Коробки.Видимость = Истина;
		 
		Элементы.рар_мп_РаспределенныеТовары.Видимость = Истина;
		
		Элементы.рар_мп_Коробки.ПодчиненныеЭлементы.рар_мп_Коробкирар_мп_НомерЗаказа.Видимость = Истина;
		
		Элементы.ГруппаКнопокПеремещенияТоваров.Видимость = Истина;
		
		Элементы.ПечатьQRКороба.Видимость = Ложь;
		
		Элементы.ФормаСформироватьЛистПодбора.Видимость = Истина; 
		
		Элементы.ФормаСформироватьЛистОтгрузки.Видимость = Истина;
		
		ПодключенаДоверительнаяПриемка = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Объект.рар_мп_АккаунтМаркетплейса, "ПодключенаДоверительнаяПриемка");
		
		Если ПодключенаДоверительнаяПриемка Тогда
			
			Элементы.СтраницаКоличествоГрузовыхМест.Видимость = Истина;	
			
		Иначе
			
			Элементы.СтраницаКоличествоГрузовыхМест.Видимость = Ложь;	
			
		КонецЕсли;
		
		Элементы.ПечатьСтикеровДляКоробов.Видимость = Ложь;
		
	ИначеЕсли Маркетплейс = Перечисления.рар_мп_Маркетплейсы.ЯндексМаркет Тогда
		
		//Элементы.СозданиеПоставки.Видимость = Ложь;
		
		Элементы.рар_мп_Wildberries_НомерПоставки.Видимость = Ложь;
		
		Элементы.СоздатьПоставку.Видимость = Ложь;
		
		Элементы.ДобавитьЗаказыВПоставку.Видимость = Ложь;
		
		Элементы.Вторая.Видимость = Ложь;
		
		Элементы.ПередатьМаркировкиВМаркетплейс.Видимость = Истина;
		
		Элементы.ИзменитьСтатусУЗаказов.Видимость = Истина; 
		
		Элементы.ЗаказКлиента.Видимость = Истина;
		
		Элементы.СоздатьКоробку.Видимость = Истина;
		
		Элементы.УдалитьКоробку.Видимость = Истина;
		
		Элементы.рар_мп_Коробки.Видимость = Истина;
		
		Элементы.рар_мп_РаспределенныеТовары.Видимость = Истина;
		
		Элементы.рар_мп_Коробки.ПодчиненныеЭлементы.рар_мп_Коробкирар_мп_НомерЗаказа.Видимость = Истина;
		
		Элементы.ГруппаКнопокПеремещенияТоваров.Видимость = Истина;
		
		Элементы.ПечатьQRКороба.Видимость = Ложь;
		
		Элементы.СтраницаКоличествоГрузовыхМест.Видимость = Ложь; 
		
