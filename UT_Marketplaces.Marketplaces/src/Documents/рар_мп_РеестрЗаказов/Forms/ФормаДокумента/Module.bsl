//@skip-check module-structure-form-event-regions
&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Если Параметры.Ключ.Пустая() Тогда
		
		Объект.рар_мп_ДатаОтгрузки        = ТекущаяДатаСеанса();
		Объект.рар_мп_СтатусДокументаВТСД = Перечисления.рар_мп_СтатусыДокументовВТСД.Новый;
		
	Иначе
		
		АккаунтМаркетплейсаПриИзмененииНаСервере();	
		
	КонецЕсли;
КонецПроцедуры

//@skip-check module-structure-form-event-regions
&НаКлиенте
Процедура рар_мп_КоробкиВыборСтрокиПриИзменении(Элемент)
	
	Если Элементы.рар_мп_Коробки.ТекущиеДанные <> Неопределено Тогда
		
		//@skip-check bsl-legacy-check-dynamic-feature-access
		НовоеЗначение = Объект.рар_мп_Коробки[Элементы.рар_мп_Коробки.ТекущиеДанные.НомерСтроки-1].ВыборСтроки;
		
		Для Каждого Стр из Объект.рар_мп_Коробки Цикл
			
			Стр.ВыборСтроки = Ложь;    
			
		КонецЦикла;
		
		//@skip-check bsl-legacy-check-dynamic-feature-access
		Объект.рар_мп_Коробки[Элементы.рар_мп_Коробки.ТекущиеДанные.НомерСтроки-1].ВыборСтроки = НовоеЗначение;
		
	КонецЕсли;
	
КонецПроцедуры 

//@skip-check module-structure-form-event-regions
&НаКлиенте
Процедура рар_мп_ТоварыИзЗаказовВыборСтрокиПриИзменении(Элемент)
	
	Если Элементы.рар_мп_ТоварыИзЗаказов.ТекущиеДанные <> Неопределено Тогда
		
		//@skip-check bsl-legacy-check-dynamic-feature-access
		НомерСтроки = Элементы.рар_мп_ТоварыИзЗаказов.ТекущиеДанные.НомерСтроки;
		
		ВыбраннаяСтрока = Объект.рар_мп_ТоварыИзЗаказов[НомерСтроки-1];
		
		Если ВыбраннаяСтрока.ВыборСтроки Тогда
			
			НужныеСтроки = Объект.рар_мп_ТоварыИзЗаказов.НайтиСтроки(Новый Структура("рар_мп_НомерЗаказа, рар_мп_СтрокаИзТЧТовары, рар_мп_Артикул", 
			ВыбраннаяСтрока.рар_мп_НомерЗаказа, 
			ВыбраннаяСтрока.рар_мп_СтрокаИзТЧТовары, 
			ВыбраннаяСтрока.рар_мп_Артикул));
			
			Для каждого Строка Из НужныеСтроки Цикл
				
				Строка.ВыборСтроки = ВыбраннаяСтрока.ВыборСтроки; 			
				
			КонецЦикла;	
			
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

//@skip-check module-structure-form-event-regions
&НаКлиенте
Процедура рар_мп_РаспределенныеТоварыВыборСтрокиПриИзменении(Элемент)
	
	Если Элементы.рар_мп_РаспределенныеТовары.ТекущиеДанные <> Неопределено Тогда
		
		//@skip-check bsl-legacy-check-dynamic-feature-access
		НомерСтроки = Элементы.рар_мп_РаспределенныеТовары.ТекущиеДанные.НомерСтроки;
		
		ВыбраннаяСтрока = Объект.рар_мп_РаспределенныеТовары[НомерСтроки-1];
		
		НужныеСтроки = Объект.рар_мп_РаспределенныеТовары.НайтиСтроки(Новый Структура("рар_мп_НомерЗаказа, рар_мп_СтрокаИзТЧТовары, рар_мп_Артикул", 
		ВыбраннаяСтрока.рар_мп_НомерЗаказа, 
		ВыбраннаяСтрока.рар_мп_СтрокаИзТЧТовары, 
		ВыбраннаяСтрока.рар_мп_Артикул));
		
		Для каждого Строка Из НужныеСтроки Цикл
			
			Строка.ВыборСтроки = ВыбраннаяСтрока.ВыборСтроки; 			
			
		КонецЦикла;
		
	КонецЕсли;
	
КонецПроцедуры

//@skip-check module-structure-form-event-regions
&НаКлиенте
Процедура ЗаказыИзМаркетплейсаПриАктивизацииЯчейки(Элемент)
	
	Если Элемент.ТекущийЭлемент.Имя = "ЗаказыИзМаркетплейсаСкачатьЭтикетку" Тогда
		
		Если ПроверитьЗаполнение() Тогда
			
			Если Элементы.ЗаказыИзМаркетплейса.ТекущиеДанные <> Неопределено Тогда
				
				НомерЗаказа = Элементы.ЗаказыИзМаркетплейса.ТекущиеДанные.рар_мп_НомерЗаказа;
				
				ЗаказыИзМаркетплейсаСкачатьЭтикетку(НомерЗаказа);	
				
			КонецЕсли;	
			
		КонецЕсли;
		
	ИначеЕсли Элемент.ТекущийЭлемент.Имя = "ЗаказыИзМаркетплейсаПечатьЭтикетки" Тогда
		
		Если ПроверитьЗаполнение() Тогда
			
			ЗаказыИзМаркетплейсаПечатьЭтикетки();
			
		КонецЕсли;
		
	КонецЕсли;
	
	
	
КонецПроцедуры

&НаСервере
Функция ПолучитьСсылкиНаЗаказы()
	
	ВыгруженныеСтроки = Объект.рар_мп_ЗаказыИзМаркетплейса.Выгрузить(,"рар_мп_Заказ");
	СсылкиНаДокументы = ВыгруженныеСтроки.ВыгрузитьКолонку("рар_мп_Заказ");
	
	Возврат СсылкиНаДокументы;
	
КонецФункции

//@skip-check module-structure-form-event-regions
&НаКлиенте
Процедура ЗаказКлиентаНачалоВыбора(Элемент, ДанныеВыбора, ВыборДобавлением, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	
	СсылкиНаДокументы = ПолучитьСсылкиНаЗаказы();	
	
	ЗначениеОтбора = Новый Структура("Ссылка", СсылкиНаДокументы);
	
	ПараметрыВыбораЗаказов = Новый Структура("Отбор, МножественныйВыбор", ЗначениеОтбора, Истина);
	
	ОткрытьФорму("Документ.ЗаказКлиента.ФормаВыбора",ПараметрыВыбораЗаказов, Элемент);
КонецПроцедуры

&НаСервере
Функция АккаунтИзWildberries()
	
	Маркетплейс = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Объект.рар_мп_АккаунтМаркетплейса, "Маркетплейс");
	
	Возврат Маркетплейс = Перечисления.рар_мп_Маркетплейсы.Wildberries;	
	
КонецФункции

&НаСервере
Функция АккаунтИзЯндексМаркет()
	
	Маркетплейс = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Объект.рар_мп_АккаунтМаркетплейса, "Маркетплейс");
	
	Возврат Маркетплейс = Перечисления.рар_мп_Маркетплейсы.ЯндексМаркет;	
	
КонецФункции

&НаСервере
Функция АккаунтИзOzon()
	
	Маркетплейс = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Объект.рар_мп_АккаунтМаркетплейса, "Маркетплейс");
	
	Возврат Маркетплейс = Перечисления.рар_мп_Маркетплейсы.OZON;	
	
КонецФункции

//@skip-check module-structure-form-event-regions
&НаСервере
Процедура ПередЗаписьюНаСервере(Отказ, ТекущийОбъект, ПараметрыЗаписи)
	
	Для каждого Строка Из Объект.рар_мп_ЗаказыИзМаркетплейса Цикл
		
		Заказ = Строка.рар_мп_Заказ;
		
		Маркетплейс = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Объект.рар_мп_АккаунтМаркетплейса, "Маркетплейс");
		
		НомерЗаказа = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Заказ, "НомерПоДаннымКлиента");
		
		ОбъектЗаказ = Заказ.ПолучитьОбъект();
		
		ОбъектЗаказ.рар_мп_ТоварыДляМаркировки.Очистить();
		
		НомерЗаказа = Строка.рар_мп_НомерЗаказа;
		
		НайденныеСтроки = Объект.рар_мп_МаркируемыеТовары.НайтиСтроки(Новый Структура("рар_мп_НомерЗаказа", НомерЗаказа));
		
		Для каждого СтрокаТч Из НайденныеСтроки Цикл
			
			НоваяСтрока = ОбъектЗаказ.рар_мп_ТоварыДляМаркировки.Добавить();
			
			НоваяСтрока.рар_мп_СтрокаИзТЧТовары     = СтрокаТч.рар_мп_СтрокаИзТЧТовары;
			НоваяСтрока.рар_мп_Номенклатура         = СтрокаТч.рар_мп_Номенклатура;
			НоваяСтрока.рар_мп_Характеристика       = СтрокаТч.рар_мп_Характеристика;
			НоваяСтрока.рар_мп_IDТовара             = СтрокаТч.рар_мп_IDТовара; 
			НоваяСтрока.рар_мп_ЗаполнениеМаркировки = СтрокаТч.рар_мп_ЗаполнениеМаркировки;
			НоваяСтрока.рар_мп_Exemplar_Id          = СтрокаТч.рар_мп_Exemplar_Id;
			НоваяСтрока.рар_мп_ЧестныйЗнак          = СтрокаТч.рар_мп_ЧестныйЗнак;
			НоваяСтрока.рар_мп_ЗаполнениеГТД		= СтрокаТч.рар_мп_ЗаполнениеГТД;
			НоваяСтрока.рар_мп_НомерГТД				= СтрокаТч.рар_мп_НомерГТД;
			
		КонецЦикла;
		
		Если Маркетплейс = Перечисления.рар_мп_Маркетплейсы.OZON Тогда
			
			ОбъектЗаказ.рар_мп_Ozon_СтатусЗаказа 	= Строка.рар_мп_СтатусЗаказа;
			ОбъектЗаказ.рар_мп_Ozon_ПодстатусЗаказа = Строка.рар_мп_СтатусОбработкиЗаказа;	
			
		ИначеЕсли Маркетплейс = Перечисления.рар_мп_Маркетплейсы.Wildberries Тогда
			
			ОбъектЗаказ.рар_мп_Wildberries_СтатусЗаказа 		 = Строка.рар_мп_СтатусЗаказа;
			ОбъектЗаказ.рар_мп_Wildberries_СтатусОбработкиЗаказа = Строка.рар_мп_СтатусОбработкиЗаказа;
			
		ИначеЕсли Маркетплейс = Перечисления.рар_мп_Маркетплейсы.ЯндексМаркет Тогда
			
			ОбъектЗаказ.рар_мп_ЯндексМаркет_СтатусЗаказа 	= Строка.рар_мп_СтатусЗаказа;
			ОбъектЗаказ.рар_мп_ЯндексМаркет_ПодстатусЗаказа = Строка.рар_мп_СтатусОбработкиЗаказа;
			
		КонецЕсли;
		
		Попытка
			
			ОбъектЗаказ.Записать(РежимЗаписиДокумента.Проведение);		
			
		Исключение
			
			ОбъектЗаказ.Записать(РежимЗаписиДокумента.Запись);
			
			Отказ = Истина;
			
			Сообщение = Новый СообщениеПользователю;
			Сообщение.Текст = СтрШаблон("Ошибка при проведении документа заказ клиента %1. Полное описание ошибки в журнале регистрации", НомерЗаказа);
			Сообщение.Сообщить(); 
			
			ЗаписьЖурналаРегистрации(СтрШаблон("Ошибка при проведении документа заказ клиента %1", НомерЗаказа), УровеньЖурналаРегистрации.Ошибка,,, ОписаниеОшибки(),);
			
		КонецПопытки;
		
	КонецЦикла;
КонецПроцедуры

