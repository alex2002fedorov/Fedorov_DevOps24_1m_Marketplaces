&НаСервере
Функция ЗавершениеФормированияЛистаПодбораНаСервере_Ozon(МассивОтправлений)
	
	ТабличныйДокумент 						= Новый ТабличныйДокумент;
	ТабличныйДокумент.АвтоМасштаб			= Истина;
	ТабличныйДокумент.ОриентацияСтраницы	= ОриентацияСтраницы.Ландшафт;
	ТабличныйДокумент.КлючПараметровПечати	= "ПАРАМЕТРЫ_ПЕЧАТИ_ДанныеЭтикетокИЗаказов";
	Макет = УправлениеПечатью.МакетПечатнойФормы("Документ.рар_мп_РеестрЗаказов.рар_мп_Ozon_ЛистПодбора");
	
	ОбластьЗаголовок	    = Макет.ПолучитьОбласть("Заголовок");
	ОбластьТЧДляПФШапка	    = Макет.ПолучитьОбласть("ТЧДляПФШапка");
	ОбластьТЧДляПФ   	    = Макет.ПолучитьОбласть("ТЧДляПФ");
	
	ОбластьЗаголовок.Параметры.Дата = Формат(ТекущаяДатаСеанса(), "ДФ=dd.MM.yyyy");     
	ОбластьЗаголовок.Параметры.КоличествоОтправлений = МассивОтправлений.Количество();
	
	ТабличныйДокумент.Вывести(ОбластьЗаголовок);
	ТабличныйДокумент.Вывести(ОбластьТЧДляПФШапка);  
	
	НомерСтроки = 1;
	
	Для каждого Отправление Из МассивОтправлений Цикл
		
		Для каждого Товар Из Отправление.products Цикл
		
			ОбластьТЧДляПФ.Параметры.НомерСтроки      = НомерСтроки;
			ОбластьТЧДляПФ.Параметры.НомерОтправления = Отправление.posting_number;
			ОбластьТЧДляПФ.Параметры.Номенклатура     = Товар.name;
			ОбластьТЧДляПФ.Параметры.Артикул          = Товар.offer_id;
			ОбластьТЧДляПФ.Параметры.Количество       = Товар.quantity;

			
		    НомерСтроки = НомерСтроки + 1;   
			
			Если НЕ ТабличныйДокумент.ПроверитьВывод(ОбластьТЧДляПФ) Тогда
				ТабличныйДокумент.ВывестиГоризонтальныйРазделительСтраниц();
				ТабличныйДокумент.Вывести(ОбластьТЧДляПФШапка);
			КонецЕсли;	
			
			ТабличныйДокумент.Вывести(ОбластьТЧДляПФ);
			
		КонецЦикла;
	КонецЦикла;
	
		
		
	Возврат ТабличныйДокумент;	
	
КонецФункции

&НаСервере
Функция СформироватьЛистПодбораНаСервере()
	
	Заказы = Объект.рар_мп_ЗаказыИзМаркетплейса.Выгрузить(,"рар_мп_НомерЗаказа");
	
	МассивНомеровЗаказов = Заказы.ВыгрузитьКолонку("рар_мп_НомерЗаказа");
	
	ПараметрыВыполнения = ДлительныеОперации.ПараметрыВыполненияФункции(УникальныйИдентификатор);     
	
	Если АккаунтИзOzon() Тогда
	
		ВозвратныеДанные = ДлительныеОперации.ВыполнитьФункцию(ПараметрыВыполнения, "рар_мп_ОбработкаЗаказов.Ozon_СформироватьЛистПодбора", 
		Объект.рар_мп_АккаунтМаркетплейса, Объект.рар_мп_Wildberries_НомерПоставки); 
		
	ИначеЕсли АккаунтИзWildberries() Тогда
		
		ВозвратныеДанные = ДлительныеОперации.ВыполнитьФункцию(ПараметрыВыполнения, "рар_мп_ОбработкаЗаказов.Wildberries_СформироватьЛистПодбора", 
		Объект.рар_мп_АккаунтМаркетплейса, МассивНомеровЗаказов); 
	
	КонецЕсли;
		
	Возврат ВозвратныеДанные;
	
КонецФункции

