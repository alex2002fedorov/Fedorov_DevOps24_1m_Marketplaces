&НаКлиенте
Процедура ПередатьМаркировкиВМаркетплейс(Команда)
	
	Если ПроверитьЗаполнение() Тогда
		
		Если АккаунтИзWildberries() Тогда
			
			Если Объект.рар_мп_ЗаказыИзМаркетплейса.Количество() <> 0 Тогда	
				
				Если ПроверкаЗаполненияМаркируемыхТоваров() Тогда
					
					ДлительнаяОперация     = Wildberries_ПередатьМаркировкиВМаркетплейсНаСервере();
					ПараметрыОжидания      = ДлительныеОперацииКлиент.ПараметрыОжидания(ЭтотОбъект);
					ПараметрыОжидания.ВыводитьСообщения = Истина;
					ПараметрыОжидания.ВыводитьОкноОжидания = Истина;
					ПараметрыОжидания.ТекстСообщения = "Передача маркировки в маркетплейс ...";
					Оповещение = Новый ОписаниеОповещения("ЗавершениеПередачиМаркировкиВМаркетплейс", ЭтотОбъект);
					ДлительныеОперацииКлиент.ОжидатьЗавершение(ДлительнаяОперация, Оповещение, ПараметрыОжидания);
					
				КонецЕсли;	
				
			Иначе
				
				Сообщение = Новый СообщениеПользователю;
				Сообщение.Текст = "Не возможно передать марвировки на маркетплейс, так как не загружены заказы или не все товары распределны по коробкам";
				Сообщение.Сообщить();	
				
			КонецЕсли;
			
		ИначеЕсли АккаунтИзЯндексМаркет() Тогда
			
			Если ПроверкаЗаполненияМаркируемыхТоваров() Тогда
				
				Если Объект.рар_мп_ТоварыИзЗаказов.Количество() = 0 И Объект.рар_мп_Коробки. Количество() <> 0 И Объект.рар_мп_РаспределенныеТовары.Количество() <> 0 Тогда
					
					ДлительнаяОперация     = ЯндексМаркет_ПередатьМаркировкиВМаркетплейсНаСервере();
					ПараметрыОжидания      = ДлительныеОперацииКлиент.ПараметрыОжидания(ЭтотОбъект);
					ПараметрыОжидания.ВыводитьСообщения = Истина;
					ПараметрыОжидания.ВыводитьОкноОжидания = Истина;
					ПараметрыОжидания.ТекстСообщения = "Передача маркировки в маркетплейс ...";
					Оповещение = Новый ОписаниеОповещения("ЗавершениеПередачиМаркировкиВМаркетплейс", ЭтотОбъект);
					ДлительныеОперацииКлиент.ОжидатьЗавершение(ДлительнаяОперация, Оповещение, ПараметрыОжидания);	
					
				Иначе
					
					Сообщение = Новый СообщениеПользователю;
					Сообщение.Текст = "Не все товары распределены по коробкам";
					Сообщение.Сообщить();
					
				КонецЕсли;	
				
			КонецЕсли;	
			
		ИначеЕсли АккаунтИзOzon() Тогда
			
			Если ПроверкаЗаполненияМаркируемыхТоваров() Тогда
				
				Если Объект.рар_мп_ТоварыИзЗаказов.Количество() = 0 И Объект.рар_мп_Коробки.Количество() <> 0 И Объект.рар_мп_РаспределенныеТовары.Количество() <> 0 Тогда
					
					ДлительнаяОперация     = Ozon_ПередатьМаркировкиВМаркетплейсНаСервере();
					ПараметрыОжидания      = ДлительныеОперацииКлиент.ПараметрыОжидания(ЭтотОбъект);
					ПараметрыОжидания.ВыводитьСообщения = Истина;
					ПараметрыОжидания.ВыводитьОкноОжидания = Истина;
					ПараметрыОжидания.ТекстСообщения = "Передача маркировки в маркетплейс ...";
					Оповещение = Новый ОписаниеОповещения("ЗавершениеПередачиМаркировкиВМаркетплейс", ЭтотОбъект);
					ДлительныеОперацииКлиент.ОжидатьЗавершение(ДлительнаяОперация, Оповещение, ПараметрыОжидания);	
					
				Иначе
					
					Сообщение = Новый СообщениеПользователю;
					Сообщение.Текст = "Не все товары распределены по коробкам";
					Сообщение.Сообщить();
					
				КонецЕсли;	
				
			КонецЕсли;	
			
		КонецЕсли;
		
		
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Функция Wildberries_ПередатьМаркировкиВМаркетплейсНаСервере()
	
	МаркируемыеТовары = Объект.рар_мп_МаркируемыеТовары.Выгрузить();
	Заказы 			  = Объект.рар_мп_ЗаказыИзМаркетплейса.Выгрузить();
	
	ПараметрыВыполнения = ДлительныеОперации.ПараметрыВыполненияФункции(УникальныйИдентификатор); 
	
	ВозвратныеДанные = ДлительныеОперации.ВыполнитьФункцию(ПараметрыВыполнения, 
	"рар_мп_ОбработкаЗаказов.Wildberries_ПередачаМаркировкиВМаркетплейс", 
	Объект.рар_мп_АккаунтМаркетплейса, Заказы, МаркируемыеТовары);
	
	Возврат ВозвратныеДанные;
	
КонецФункции

&НаСервере
Функция ЯндексМаркет_ПередатьМаркировкиВМаркетплейсНаСервере()
	
	Заказы				 = Объект.рар_мп_ЗаказыИзМаркетплейса.Выгрузить();
	РаспределенныеТовары = Объект.рар_мп_РаспределенныеТовары.Выгрузить();
	МаркируемыеТовары	 = Объект.рар_мп_МаркируемыеТовары.Выгрузить();
	Коробки				 = Объект.рар_мп_Коробки.Выгрузить();
	
	ПараметрыВыполнения = ДлительныеОперации.ПараметрыВыполненияФункции(УникальныйИдентификатор); 
	
	ВозвратныеДанные = ДлительныеОперации.ВыполнитьФункцию(ПараметрыВыполнения, 
	"рар_мп_ОбработкаЗаказов.ЯндексМаркет_ПередачаМаркировки", Объект.рар_мп_АккаунтМаркетплейса, 
	Заказы, РаспределенныеТовары, МаркируемыеТовары,Коробки);
	
	Возврат ВозвратныеДанные;
	
КонецФункции

&НаСервере
Функция Ozon_ПередатьМаркировкиВМаркетплейсНаСервере()
	
	МаркируемыеТовары = Объект.рар_мп_МаркируемыеТовары.Выгрузить();
	СозданныеКоробки  = Объект.рар_мп_Коробки.Выгрузить();
	Заказы			  = Объект.рар_мп_ЗаказыИзМаркетплейса.Выгрузить();
	
	ПараметрыВыполнения = ДлительныеОперации.ПараметрыВыполненияФункции(УникальныйИдентификатор); 
	
	ВозвратныеДанные = ДлительныеОперации.ВыполнитьФункцию(ПараметрыВыполнения, 
	"рар_мп_ОбработкаЗаказов.Ozon_ПередачаМаркировкиВМаркетплейс", 
	Объект.рар_мп_АккаунтМаркетплейса, МаркируемыеТовары, СозданныеКоробки, Заказы);
	
	Возврат ВозвратныеДанные;
	
КонецФункции

&НаСервере
Функция ПроверкаЗаполненияМаркируемыхТоваров()
	
	ТаблицаЗаполненаПравильно = Истина;
	
	Для каждого Строка Из Объект.рар_мп_МаркируемыеТовары Цикл
		
		Если Строка.рар_мп_ЗаполнениеМаркировки И НЕ ЗначениеЗаполнено(Строка.рар_мп_ЧестныйЗнак) Тогда
			
			ТаблицаЗаполненаПравильно = Ложь;
			
			Сообщение = Новый СообщениеПользователю;
			Сообщение.Текст = СтрШаблон("Не указана маркировка для номенклатуры: %1 (артикул %2) из заказа номер: %3", 
			Строка.рар_мп_Номенклатура, Строка.рар_мп_Артикул, Строка.рар_мп_НомерЗаказа);
			Сообщение.Сообщить();
			
		КонецЕсли;
		
	КонецЦикла;	
	
	Возврат ТаблицаЗаполненаПравильно;
	
КонецФункции

&НаКлиенте
Процедура ЗавершениеПередачиМаркировкиВМаркетплейс(Результат, СтруктураПараметров) Экспорт
	
	Если Результат = НЕОПРЕДЕЛЕНО Тогда
		
		Возврат;	
		
	КонецЕсли;
	
	Если Результат.Статус = "Выполнено" Тогда 
		
		ВозвратноеЗначение = ПолучитьИзВременногоХранилища(Результат.АдресРезультата);
		
		Если ВозвратноеЗначение Тогда
			
			Сообщение = Новый СообщениеПользователю;
			Сообщение.Текст = "Передача маркировки на маркетплейс завершена успешно";
			Сообщение.Сообщить();
			
			Объект.рар_мп_ЗапрещеноИзменятьСоставаРеестра = Истина;
			
		Иначе
			
			Сообщение = Новый СообщениеПользователю;
			Сообщение.Текст = "Ошибка при передаче маркировок на маркетплейс";
			Сообщение.Сообщить();	
			
		КонецЕсли;
		
		
	ИначеЕсли Результат.Статус = "Ошибка" Тогда 
		
		СтандартныеПодсистемыКлиент.ВывестиИнформациюОбОшибке(Результат.ИнформацияОбОшибке);
		
		Возврат;
		
	КонецЕсли;
	
КонецПроцедуры

