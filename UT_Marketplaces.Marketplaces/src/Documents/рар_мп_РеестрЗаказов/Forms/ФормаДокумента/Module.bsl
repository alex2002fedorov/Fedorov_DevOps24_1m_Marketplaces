			Сообщение.Сообщить();	
			
		Иначе
			
			Попытка
				
				Объект.рар_мп_ЗаказыИзМаркетплейса.Загрузить(ВыгрузкаЗаказов);
				Объект.рар_мп_ПередачаНаКомиссию.Загрузить(ВыгрузкаЗаказов);
				Объект.рар_мп_МаркируемыеТовары.Загрузить(ВыгрузкаМаркируемыхТоваров);
				Объект.рар_мп_КоличествоГрузовыхМест.Загрузить(ВыгрузкаСкладов);
				
				Для каждого Строка Из ВыгрузкаЗаказов Цикл
					
					Для каждого СтрокаТЧ Из Строка.рар_мп_ТЧТовары Цикл
						
						Для Счетчик = 1 По СтрокаТЧ.рар_мп_КоличествоУпаковок Цикл
							
							НоваяСтрока = Объект.рар_мп_ТоварыИзЗаказов.Добавить();
							
							НоваяСтрока.рар_мп_НомерЗаказа 		  = Строка.рар_мп_НомерЗаказа;
							НоваяСтрока.рар_мп_СтрокаИзТЧТовары   = СтрокаТЧ.рар_мп_СтрокаИзТЧТовары;
							НоваяСтрока.рар_мп_Номенклатура		  = СтрокаТЧ.рар_мп_Номенклатура;
							НоваяСтрока.рар_мп_Характеристика	  = СтрокаТЧ.рар_мп_Характеристика;
							НоваяСтрока.рар_мп_Артикул			  = СтрокаТЧ.рар_мп_Артикул;
							НоваяСтрока.рар_мп_КоличествоУпаковок = 1;
							НоваяСтрока.рар_мп_Количество		  = СтрокаТЧ.рар_мп_Количество / СтрокаТЧ.рар_мп_КоличествоУпаковок;
							
						КонецЦикла;	
						
						
					КонецЦикла;	
					
				КонецЦикла;
				
				Сообщение = Новый СообщениеПользователю;
				Сообщение.Текст = "Загрузка заказов завершена";
				Сообщение.Сообщить();
				
			Исключение
				
				Сообщение = Новый СообщениеПользователю;
				Сообщение.Текст = "Ошибка загрузки заказов. Подробное описание ошибки можно посмотреть в журнале регистрации";
				Сообщение.Сообщить(); 
				
				ЗаписьЖурналаРегистрации("Ошибка загрузки заказов в реестр заказов", УровеньЖурналаРегистрации.Ошибка,,, ОписаниеОшибки(),);
				
				Объект.рар_мп_ЗаказыИзМаркетплейса.Очистить();
				Объект.рар_мп_ПередачаНаКомиссию.Очистить();
				Объект.рар_мп_ТоварыИзЗаказов.Очистить();
				
				
			КонецПопытки;
			
		КонецЕсли;
		
	КонецЕсли;
КонецПроцедуры

#КонецОбласти 

//@skip-check module-structure-top-region
#Область СозданиеПередачиНаКомиссию

&НаСервере
Процедура СоздатьПередачуНаКомиссиюНаСервере()
	
	Для каждого Строка Из Объект.рар_мп_ПередачаНаКомиссию Цикл 
		
		Если НЕ ЗначениеЗаполнено(Строка.рар_мп_ПередачаНаКомиссию) Тогда
			
			Заказ = Строка.рар_мп_Заказ.ПолучитьОбъект();
			
			Маркетплейс = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Объект.рар_мп_АккаунтМаркетплейса, "Маркетплейс");
			
			Если Маркетплейс = Перечисления.рар_мп_Маркетплейсы.Wildberries Тогда
				
				//@skip-check bsl-legacy-check-static-feature-access-for-unknown-left-part
				Если Заказ.НеОтгружатьЧастями <> Истина Тогда
					
					//@skip-check bsl-legacy-check-static-feature-access-for-unknown-left-part
					Заказ.НеОтгружатьЧастями = Истина;
					
					Заказ.ДатаОтгрузки = ТекущаяДатаСеанса();
					
				КонецЕсли;
				
			КонецЕсли;
			
			Для каждого СтрокаТЧ Из Заказ.Товары Цикл
				
				//@skip-check bsl-legacy-check-static-feature-access-for-unknown-left-part
				Если СтрокаТЧ.ВариантОбеспечения <> Перечисления.ВариантыОбеспечения.Отгрузить Тогда
					
					//@skip-check bsl-legacy-check-static-feature-access-for-unknown-left-part
					СтрокаТЧ.ВариантОбеспечения = Перечисления.ВариантыОбеспечения.Отгрузить;	
					
				КонецЕсли;
				
				
			КонецЦикла;
			
			Попытка
				
				Заказ.Записать(РежимЗаписиДокумента.Проведение);
				
				НовыйДокумент = Документы.ПередачаТоваровХранителю.СоздатьДокумент();
				НовыйДокумент.Заполнить(Строка.рар_мп_Заказ); 
				//@skip-check reading-attribute-from-database
				НовыйДокумент.Товары.Загрузить(Строка.рар_мп_Заказ.Товары.Выгрузить());
				
				Попытка
					
					НовыйДокумент.Записать(РежимЗаписиДокумента.Проведение);
					
				Исключение
					
					НовыйДокумент.Записать(РежимЗаписиДокумента.Запись);
					
					Сообщение = Новый СообщениеПользователю;
					Сообщение.Текст = СтрШаблон("Ошибка при проведении документа 'Передача на комиссию' для заказа %1", Строка.рар_мп_НомерЗаказа);
					Сообщение.Сообщить();
					
					ЗаписьЖурналаРегистрации(СтрШаблон("Ошибка при проведении документа 'Передача на комиссию' для заказа %1", Строка.рар_мп_НомерЗаказа), УровеньЖурналаРегистрации.Ошибка,,,ОписаниеОшибки(),);
					
				КонецПопытки;
				
				Строка.рар_мп_ПередачаНаКомиссию = НовыйДокумент.Ссылка;
				
			Исключение
				
				Заказ.Записать(РежимЗаписиДокумента.Запись);
				
				Сообщение = Новый СообщениеПользователю;
				Сообщение.Текст = СтрШаблон("Ошибка при проведении документа 'Заказ клиента'  %1", Строка.рар_мп_НомерЗаказа);
				Сообщение.Сообщить();
				
				ЗаписьЖурналаРегистрации(СтрШаблон("Ошибка при проведении документа 'Заказ клиента'  %1", Строка.рар_мп_НомерЗаказа), УровеньЖурналаРегистрации.Ошибка,,,ОписаниеОшибки(),);
				
			КонецПопытки;	
			
		КонецЕсли;
		
	КонецЦикла;
	
	Сообщение = Новый СообщениеПользователю;
	Сообщение.Текст = "Создание передач на комиссию завершено";
	Сообщение.Сообщить();
	
КонецПроцедуры

//@skip-check module-structure-form-event-regions
&НаКлиенте
Асинх Процедура СоздатьПередачуНаКомиссию(Команда)
	Если Объект.рар_мп_ПередачаНаКомиссию.Количество() = 0 Тогда
		
		Сообщение = Новый СообщениеПользователю;
		Сообщение.Текст = "Заказов для создания документа передача на комиссию нет. Необходимо их загрузить";
		Сообщение.Сообщить();
		
	Иначе
		
		Ответ = Ждать ВопросАсинх(НСтр("ru = 'Данное действие приведет к созданию документов передача на комиссию по всем заказам в табличной части. 
		|Продолжить?'"), РежимДиалогаВопрос.ДаНет);
		
		Если Ответ <> КодВозвратаДиалога.Да Тогда 
			
			Возврат;
			
		КонецЕсли;
		
		СоздатьПередачуНаКомиссиюНаСервере();	
		
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти 

//@skip-check module-structure-top-region
#Область СозданиеПоставки

//@skip-check module-structure-form-event-regions
&НаКлиенте
Процедура СоздатьПоставку(Команда)
	Если ПроверитьЗаполнение() Тогда 
		
		Если НЕ ЗначениеЗаполнено(Объект.рар_мп_Wildberries_НомерПоставки) Тогда
			
			Если Объект.рар_мп_ЗаказыИзМаркетплейса.Количество() <> 0 Тогда
				
				СоздатьПоставкуНаСервере();	
				
			Иначе
				
				Сообщение = Новый СообщениеПользователю;
				Сообщение.Текст = "Не возможно создать поставку, так как не загружены заказы";
				Сообщение.Сообщить();	
				
			КонецЕсли;	
			
			
		Иначе
			
			Сообщение = Новый СообщениеПользователю;
			Сообщение.Текст = "Поставка уже создана. Повторное создание не возможно";
			Сообщение.Сообщить();	
			
		КонецЕсли;
		
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура СоздатьПоставкуНаСервере()
	
	Объект.рар_мп_Wildberries_НомерПоставки = рар_мп_ОбработкаЗаказов.Wildberries_СозданиеПоставки(Объект.рар_мп_АккаунтМаркетплейса, 
	"Поставка заказов от "+ ТекущаяДатаСеанса());      
	
	Сообщение = Новый СообщениеПользователю;
	Сообщение.Текст = "Создание поставки завершено";
	Сообщение.Сообщить();
	
КонецПроцедуры

#КонецОбласти

//@skip-check module-structure-top-region
#Область ДабавлениеЗаказовВПоставку

//@skip-check module-structure-form-event-regions
&НаКлиенте
Асинх Процедура ДобавитьЗаказыВПоставку(Команда)
	
	Если ПроверитьЗаполнение() Тогда
		
		Если ЗначениеЗаполнено(Объект.рар_мп_Wildberries_НомерПоставки) Тогда
			
			Если Объект.рар_мп_ЗаказыИзМаркетплейса.Количество() <> 0 Тогда
				
				Ответ = Ждать ВопросАсинх(НСтр("ru = 'Данное действие к добавлению всех заказов в поставку. 
				|Продолжить?'"), РежимДиалогаВопрос.ДаНет);
				
				Если Ответ <> КодВозвратаДиалога.Да Тогда 
					
					Возврат;
					
				КонецЕсли;
				
				ДлительнаяОперация     = ДобавитьЗаказыВПоставкуНаСервере();
				ПараметрыОжидания      = ДлительныеОперацииКлиент.ПараметрыОжидания(ЭтотОбъект);
				ПараметрыОжидания.ВыводитьСообщения = Истина;
				ПараметрыОжидания.ВыводитьОкноОжидания = Истина;
				ПараметрыОжидания.ТекстСообщения = "Добавление заказов в поставку ...";
				Оповещение = Новый ОписаниеОповещения("ЗавершениеДобавленияЗаказовВПоставку", ЭтотОбъект);
				ДлительныеОперацииКлиент.ОжидатьЗавершение(ДлительнаяОперация, Оповещение, ПараметрыОжидания);	
				
			Иначе
				
				Сообщение = Новый СообщениеПользователю;
				Сообщение.Текст = "Не возможно создать поставку, так как не загружены заказы";
				Сообщение.Сообщить();	
				
			КонецЕсли;	
			
			
		Иначе
			
			Сообщение = Новый СообщениеПользователю;
			Сообщение.Текст = "Поставка не создана. Перед добавлением заказов в поставку необходимо создать поставку";
			Сообщение.Сообщить();	
			
		КонецЕсли;				
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Функция ДобавитьЗаказыВПоставкуНаСервере()
	
	ЗагруженныеЗаказы = Объект.рар_мп_ЗаказыИзМаркетплейса.Выгрузить(,"рар_мп_НомерЗаказа");
	МассивЗаказов 	  = ЗагруженныеЗаказы.ВыгрузитьКолонку("рар_мп_НомерЗаказа");
	
	ПараметрыВыполнения = ДлительныеОперации.ПараметрыВыполненияФункции(УникальныйИдентификатор); 
	
	ВозвратныеДанные = ДлительныеОперации.ВыполнитьФункцию(ПараметрыВыполнения, 
	"рар_мп_ОбработкаЗаказов.Wildberries_ДобавитьЗаказКПоставке", 
	Объект.рар_мп_АккаунтМаркетплейса, 
	Объект.рар_мп_Wildberries_НомерПоставки, МассивЗаказов);	
	Возврат ВозвратныеДанные;
	
КонецФункции

&НаКлиенте
Процедура ЗавершениеДобавленияЗаказовВПоставку(Результат, СтруктураПараметров) Экспорт
	
	Если Результат = НЕОПРЕДЕЛЕНО Тогда
		
		Возврат;	
		
	КонецЕсли;
	
	Если Результат.Статус = "Выполнено" Тогда
		
		ЗавершениеДобавленияЗаказовВПоставкуНаСервере(Результат);	
		
	ИначеЕсли Результат.Статус = "Ошибка" Тогда 
		
		СтандартныеПодсистемыКлиент.ВывестиИнформациюОбОшибке(Результат.ИнформацияОбОшибке);
		
		Возврат;
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ЗавершениеДобавленияЗаказовВПоставкуНаСервере(Результат)
	
	МассивНомеровЗаказов = ПолучитьИзВременногоХранилища(Результат.АдресРезультата);
	
	Для каждого НомерЗаказа Из МассивНомеровЗаказов Цикл
		
		НайденныеСтроки = Объект.рар_мп_ЗаказыИзМаркетплейса.НайтиСтроки(Новый Структура("рар_мп_НомерЗаказа", НомерЗаказа));
		
		Если НайденныеСтроки.Количество() <> 0 Тогда
			
			НужнаяСтрока = НайденныеСтроки.Получить(0);
			
			НужнаяСтрока.рар_мп_СтатусОбработкиЗаказа = Перечисления.рар_мп_Wildberries_СтатусыОбработкиЗаказов.confirm;
			
		КонецЕсли;
		
	КонецЦикла;
	
	Объект.рар_мп_ЗапрещеноИзменятьСоставаРеестра = Истина;
	
	Сообщение = Новый СообщениеПользователю;
	Сообщение.Текст = "Добавление заказов в поставку завершено";
	Сообщение.Сообщить();
	
КонецПроцедуры

#КонецОбласти 

//@skip-check module-structure-top-region
#Область ИзменениеВидимостиРеквизитов
&НаСервере
Процедура АккаунтМаркетплейсаПриИзмененииНаСервере()
	
	Маркетплейс = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Объект.рар_мп_АккаунтМаркетплейса, "Маркетплейс");
	
	Если Маркетплейс = Перечисления.рар_мп_Маркетплейсы.OZON Тогда
		
		//alsalt 09.06.25
		//Элементы.СозданиеПоставки.Видимость = Истина;
		
		Элементы.рар_мп_Wildberries_НомерПоставки.Видимость = Истина;
		
