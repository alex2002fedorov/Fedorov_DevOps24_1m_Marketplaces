&НаКлиенте
Процедура ЗавершениеФормированияЛистаПодбора(Результат, СтруктураПараметров) Экспорт
	
	Если Результат = НЕОПРЕДЕЛЕНО Тогда
		
		Возврат;	
		
	КонецЕсли;
	
	Если Результат.Статус = "Выполнено" Тогда
		
		Попытка
			
			МассивЭтикеток = ПолучитьИзВременногоХранилища(Результат.АдресРезультата);
			
			Если МассивЭтикеток.Количество() = 0 Тогда
				
				Сообщение = Новый СообщениеПользователю;
				Сообщение.Текст = "Ошибка при формировании листа подбора. Подробное описание ошибки можно посмотреть в журнале регистрации";
				Сообщение.Сообщить();
				
			Иначе
				
				ТабДок = ЗавершениеФормированияЛистаПодбораНаСервере(МассивЭтикеток);
				
				КоллекцияПечатныхФорм = УправлениеПечатьюКлиент.НоваяКоллекцияПечатныхФорм("рар_мп_Wildberries_ЛистПодбора");    
				
				КоллекцияПечатныхФорм[0].ТабличныйДокумент = ТабДок; 
				КоллекцияПечатныхФорм[0].СинонимМакета = "Лист подбора Wildberries"; 
				
				ПараметрыВывода = Новый Структура("ЗаголовокФормы", "Лист подбора Wildberries");
				УправлениеПечатьюКлиент.ПечатьДокументов(КоллекцияПечатныхФорм,"рар_мп_Wildberries_ЛистПодбора",ПараметрыВывода);	
				
			КонецЕсли;		
			
		Исключение 
			
			Сообщение = Новый СообщениеПользователю;
			Сообщение.Текст = "Ошибка при формировании листа подбора. Подробное описание в журнале регистрации";
			Сообщение.Сообщить();
			
			ЖурналРегистрацииКлиент.ДобавитьСообщениеДляЖурналаРегистрации("Ошибка при формировании листа подбора", "Ошибка", ОписаниеОшибки(),,Истина); 
			
		КонецПопытки;
		
		
	ИначеЕсли Результат.Статус = "Ошибка" Тогда 
		
		СтандартныеПодсистемыКлиент.ВывестиИнформациюОбОшибке(Результат.ИнформацияОбОшибке);
		
		Возврат;
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Функция ЗавершениеФормированияЛистаПодбораНаСервере(МассивЭтикеток)
	
	ТабличныйДокумент 						= Новый ТабличныйДокумент;
	ТабличныйДокумент.АвтоМасштаб			= Истина;
	ТабличныйДокумент.ОриентацияСтраницы	= ОриентацияСтраницы.Ландшафт;
	ТабличныйДокумент.КлючПараметровПечати	= "ПАРАМЕТРЫ_ПЕЧАТИ_ДанныеЭтикетокИЗаказов";
	Макет = УправлениеПечатью.МакетПечатнойФормы("Документ.рар_мп_РеестрЗаказов.рар_мп_Wildberries_ЛистПодбора");
	
	ОбластьЗаголовок	    = Макет.ПолучитьОбласть("Заголовок");
	ОбластьТЧДляПФШапка	    = Макет.ПолучитьОбласть("ТЧДляПФШапка");
	ОбластьТЧДляПФ   	    = Макет.ПолучитьОбласть("ТЧДляПФ");
	
	ТабличныйДокумент.Вывести(ОбластьЗаголовок);
	ТабличныйДокумент.Вывести(ОбластьТЧДляПФШапка);
	
	Счетчик = 0;
	
	Для каждого Элемент Из МассивЭтикеток Цикл
		
		НомерЗаказа = Элемент.НомерЗаказа;
		
		НужныеСтроки = Объект.рар_мп_РаспределенныеТовары.НайтиСтроки(Новый Структура("рар_мп_НомерЗаказа", НомерЗаказа));
		
		Для каждого Строка Из НужныеСтроки Цикл
			
			Счетчик = Счетчик + 1;
			
			ОбластьТЧДляПФ.Параметры.НомерСтроки = Счетчик;
			
			ОбластьТЧДляПФ.Параметры.НомерСборочногоЗадания = НомерЗаказа;
			
			ОбластьТЧДляПФ.Параметры.Номенклатура = Строка.рар_мп_Номенклатура;
			
			ОбластьТЧДляПФ.Параметры.Характеристика = Строка.рар_мп_Характеристика;
			
			ОбластьТЧДляПФ.Параметры.Артикул = Строка.рар_мп_Артикул;
			
			ОбластьТЧДляПФ.Параметры.СерияЭтикетки = Элемент.partA;
			
			ОбластьТЧДляПФ.Параметры.НомерЭтикетки = Элемент.partB;
			
			Если НЕ ТабличныйДокумент.ПроверитьВывод(ОбластьТЧДляПФ) Тогда
				ТабличныйДокумент.ВывестиГоризонтальныйРазделительСтраниц();
				ТабличныйДокумент.Вывести(ОбластьТЧДляПФШапка);
			КонецЕсли;	
			
			ТабличныйДокумент.Вывести(ОбластьТЧДляПФ);	
			
		КонецЦикла;
		
	КонецЦикла;
	
	Возврат ТабличныйДокумент;	
	
КонецФункции

&НаКлиенте
Процедура ЗавершениеФормированияЛистаПодбора_Ozon(Результат, СтруктураПараметров) Экспорт
	
	Если Результат = НЕОПРЕДЕЛЕНО Тогда
		
		Возврат;	
		
	КонецЕсли;
	
	Если Результат.Статус = "Выполнено" Тогда
		
		Попытка
			
			МассивОтправлений = ПолучитьИзВременногоХранилища(Результат.АдресРезультата);
			
			Если МассивОтправлений.Количество() = 0 Тогда
				
				Сообщение = Новый СообщениеПользователю;
				Сообщение.Текст = "Ошибка при формировании листа подбора. Подробное описание ошибки можно посмотреть в журнале регистрации";
				Сообщение.Сообщить();
				
			Иначе
				
				ТабДок = ЗавершениеФормированияЛистаПодбораНаСервере_Ozon(МассивОтправлений);
				
				КоллекцияПечатныхФорм = УправлениеПечатьюКлиент.НоваяКоллекцияПечатныхФорм("рар_мп_Ozon_ЛистПодбора");    
				
				КоллекцияПечатныхФорм[0].ТабличныйДокумент = ТабДок; 
				КоллекцияПечатныхФорм[0].СинонимМакета = "Лист подбора Ozon"; 
				
