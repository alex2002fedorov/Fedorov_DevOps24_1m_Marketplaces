&НаСервере
Процедура ЗаказыИзМаркетплейсаСкачатьЭтикетку(НомерЗаказа)
	
	Если Не ПустаяСтрока(Константы.рар_мп_МестоХраненияФайлов.Получить()) Тогда
		
		МассивНомеровЗаказов = Новый Массив;
		
		МассивНомеровЗаказов.Добавить(НомерЗаказа);
		
		Маркетплейс = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Объект.рар_мп_АккаунтМаркетплейса, "Маркетплейс");
		
		Если Маркетплейс = Перечисления.рар_мп_Маркетплейсы.OZON Тогда 
			
			Попытка
				
				МассивЭтикеток = рар_мп_ОбработкаЗаказов.Ozon_ПолучитьЭтикетки(Объект.рар_мп_АккаунтМаркетплейса, МассивНомеровЗаказов);
				
				Если МассивЭтикеток.Количество() > 0 Тогда
					
					МестоСохранения = Константы.рар_мп_МестоХраненияФайлов.Получить();
					
					Этикетка = МассивЭтикеток.Получить(0);
					
					Путь = МестоСохранения + СтрШаблон("\Этикетка_Заказ_%1.pdf", НомерЗаказа);
					
					Этикетка.Записать(Путь);
					
					Сообщение = Новый СообщениеПользователю;
					Сообщение.Текст = "Файл загружен в папку";
					Сообщение.Сообщить();
					
				КонецЕсли;
				
			Исключение
				
				Сообщение = Новый СообщениеПользователю;
				Сообщение.Текст = "Не удалось сохранить этикетку. Описание ошибки в журнале регистрации";
				Сообщение.Сообщить(); 
				
				ЗаписьЖурналаРегистрации("Ошибка при сохранении этикеток", УровеньЖурналаРегистрации.Ошибка,,,ОписаниеОшибки(), );
				
			КонецПопытки;
			
			
		ИначеЕсли  Маркетплейс = Перечисления.рар_мп_Маркетплейсы.ЯндексМаркет Тогда
			
			Попытка
				
				МассивЭтикеток = рар_мп_ОбработкаЗаказов.ЯндексМаркет_ПолучитьЭтикеткиЗаказов(Объект.рар_мп_АккаунтМаркетплейса, МассивНомеровЗаказов);
				
				Если МассивЭтикеток.Количество() > 0 Тогда
					
					МестоСохранения = Константы.рар_мп_МестоХраненияФайлов.Получить();
					
					Этикетка = МассивЭтикеток.Получить(0);
					
					Путь = МестоСохранения + СтрШаблон("\Этикетка_Заказ_%1.pdf", НомерЗаказа);
					
					Этикетка.Записать(Путь);
					
					Сообщение = Новый СообщениеПользователю;
					Сообщение.Текст = "Файл загружен в папку";
					Сообщение.Сообщить();
					
				КонецЕсли;
				
			Исключение
				
				Сообщение = Новый СообщениеПользователю;
				Сообщение.Текст = "Не удалось сохранить этикетку. Описание ошибки в журнале регистрации";
				Сообщение.Сообщить();  
				
				ЗаписьЖурналаРегистрации("Ошибка при сохранении этикеток", УровеньЖурналаРегистрации.Ошибка,,,ОписаниеОшибки(), );
				
			КонецПопытки;
			
			
		ИначеЕсли Маркетплейс = Перечисления.рар_мп_Маркетплейсы.Wildberries Тогда
			
			Попытка
				
				МассивЭтикеток = рар_мп_ОбработкаЗаказов.Wildberries_ПолучитьЭтикеткиЗаказов(Объект.рар_мп_АккаунтМаркетплейса, МассивНомеровЗаказов);
				
				Если МассивЭтикеток.Количество() > 0 Тогда
					
					ДвоичныеДанные = МассивЭтикеток.Получить(0);
					
					МестоСохранения = Константы.рар_мп_МестоХраненияФайлов.Получить();
					
					Путь = МестоСохранения + СтрШаблон("\Этикетка_СборочноеЗадание_%1.png", НомерЗаказа); 
					
