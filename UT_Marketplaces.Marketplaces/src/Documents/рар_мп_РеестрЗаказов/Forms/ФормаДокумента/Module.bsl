#Область ИзменениеСтатуса

//@skip-check module-structure-form-event-regions
&НаКлиенте
Процедура ИзменитьСтатусУЗаказов(Команда)
	
	Если ПроверитьЗаполнение() Тогда
		
		Если Объект.рар_мп_ЗаказыИзМаркетплейса.Количество() <> 0 Тогда
			
			Если АккаунтИзЯндексМаркет() Тогда	
				
				ДлительнаяОперация     = ЯндексМаркет_ИзменитьСтатусУЗаказовНаСервере();
				ПараметрыОжидания      = ДлительныеОперацииКлиент.ПараметрыОжидания(ЭтотОбъект);
				ПараметрыОжидания.ВыводитьСообщения = Истина;
				ПараметрыОжидания.ВыводитьОкноОжидания = Истина;
				ПараметрыОжидания.ТекстСообщения = "Изменение статусов заказов...";                                    
				Оповещение = Новый ОписаниеОповещения("ЯндексМаркет_ЗавершениеИзмененияСтатусов", ЭтотОбъект);
				ДлительныеОперацииКлиент.ОжидатьЗавершение(ДлительнаяОперация, Оповещение, ПараметрыОжидания);
				
			ИначеЕсли АккаунтИзOzon() Тогда
				
				ДлительнаяОперация     = Ozon_ИзменитьСтатусУЗаказовНаСервере();
				ПараметрыОжидания      = ДлительныеОперацииКлиент.ПараметрыОжидания(ЭтотОбъект);
				ПараметрыОжидания.ВыводитьСообщения = Истина;
				ПараметрыОжидания.ВыводитьОкноОжидания = Истина;
				ПараметрыОжидания.ТекстСообщения = "Изменение статусов заказов...";                                    
				Оповещение = Новый ОписаниеОповещения("Ozon_ЗавершениеИзмененияСтатусов", ЭтотОбъект);
				ДлительныеОперацииКлиент.ОжидатьЗавершение(ДлительнаяОперация, Оповещение, ПараметрыОжидания);		
				
			КонецЕсли;		
			
		Иначе
			
			Сообщение = Новый СообщениеПользователю;
			Сообщение.Текст = "Изменить статусы нельзя. Не загружены заказы";
			Сообщение.Сообщить();	
			
		КонецЕсли;	
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Функция ЯндексМаркет_ИзменитьСтатусУЗаказовНаСервере()
	
	ЗаказыИзМаркетплейса = Объект.рар_мп_ЗаказыИзМаркетплейса.Выгрузить();
	
	Статус = ЯндексМаркет_ПолучитьИмяПеречисления(Перечисления.рар_мп_ЯндексМаркет_СтатусыЗаказов.PROCESSING);
	
	Подстатус = ЯндексМаркет_ПолучитьИмяПеречисления(Перечисления.рар_мп_ЯндексМаркет_ПодстатусыЗаказов.READY_TO_SHIP);
	
	ПараметрыВыполнения = ДлительныеОперации.ПараметрыВыполненияФункции(УникальныйИдентификатор);
	
	ВозвратныеДанные = ДлительныеОперации.ВыполнитьФункцию(ПараметрыВыполнения, "рар_мп_ОбработкаЗаказов.ЯндексМаркет_ИзменениеСтатуса", 
	Объект.рар_мп_АккаунтМаркетплейса, ЗаказыИзМаркетплейса, Статус, Подстатус); 
	
	Возврат ВозвратныеДанные;
	
КонецФункции

&НаСервере
Функция ЯндексМаркет_ПолучитьИмяПеречисления(ЗначениеПеречисления)
	
	ИмяПеречисления = ЗначениеПеречисления.Метаданные().Имя;
	
	ИндексЗначенияПеречисления = Перечисления[ИмяПеречисления].Индекс(ЗначениеПеречисления);
	
	ИмяЗначенияПеречисления = Метаданные.Перечисления[ИмяПеречисления].ЗначенияПеречисления[ИндексЗначенияПеречисления].Имя;
	
	Возврат ИмяЗначенияПеречисления; 
	
КонецФункции

&НаСервере
Функция Ozon_ИзменитьСтатусУЗаказовНаСервере()
	
	ЗаказыИзМаркетплейса = Объект.рар_мп_ЗаказыИзМаркетплейса.Выгрузить();
	
	РаспределенныеТовары = Объект.рар_мп_РаспределенныеТовары.Выгрузить();
	
	МаркируемыеТовары = Объект.рар_мп_МаркируемыеТовары.Выгрузить();
	
	Коробки = Объект.рар_мп_Коробки.Выгрузить();
	
	ПараметрыВыполнения = ДлительныеОперации.ПараметрыВыполненияФункции(УникальныйИдентификатор);
	
	ВозвратныеДанные = ДлительныеОперации.ВыполнитьФункцию(ПараметрыВыполнения, "рар_мп_ОбработкаЗаказов.Ozon_СобратьЗаказ", 
	Объект.рар_мп_АккаунтМаркетплейса, РаспределенныеТовары, ЗаказыИзМаркетплейса, МаркируемыеТовары, Коробки); 
	
	Возврат ВозвратныеДанные;
	
КонецФункции

&НаКлиенте
Процедура Ozon_ЗавершениеИзмененияСтатусов(Результат, СтруктураПараметров) Экспорт
	
	Если Результат = НЕОПРЕДЕЛЕНО Тогда
		
		Возврат;	
		
	КонецЕсли;
	
	Если Результат.Статус = "Выполнено" Тогда
		
		СтатусИзмененияСтатусов = ПолучитьИзВременногоХранилища(Результат.АдресРезультата);
		
		Если СтатусИзмененияСтатусов Тогда
			
			Для каждого Заказ Из Объект.рар_мп_ЗаказыИзМаркетплейса Цикл
				
				Заказ.рар_мп_СтатусЗаказа = ПолучитьСтатусЗаказа_awaiting_deliver();
				
			КонецЦикла;
			
			Сообщение = Новый СообщениеПользователю;
			Сообщение.Текст = "Статусы изменены";
			Сообщение.Сообщить();
			
		КонецЕсли;
		
	ИначеЕсли Результат.Статус = "Ошибка" Тогда 
		
		СтандартныеПодсистемыКлиент.ВывестиИнформациюОбОшибке(Результат.ИнформацияОбОшибке);
		
		Возврат;
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Функция ПолучитьСтатусЗаказа_awaiting_deliver()
	
	Возврат Перечисления.рар_мп_Ozon_СтатусыЗаказов.awaiting_deliver;	
	
КонецФункции

