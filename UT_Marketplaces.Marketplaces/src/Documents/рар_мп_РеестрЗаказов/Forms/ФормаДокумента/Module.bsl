&НаСервере
Процедура ПодтвердитьОтгрузкуНаСервере()
	
	Маркетплейс = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Объект.рар_мп_АккаунтМаркетплейса, "Маркетплейс");
	
	Если Маркетплейс = Перечисления.рар_мп_Маркетплейсы.OZON Тогда
		
		ТаблицаЗаполнена = Истина;
		
		ПодключенаДоверительнаяПриемка = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Объект.рар_мп_АккаунтМаркетплейса, "ПодключенаДоверительнаяПриемка");
		
		Если ПодключенаДоверительнаяПриемка Тогда
			
			Для каждого Строка Из Объект.рар_мп_КоличествоГрузовыхМест Цикл
				
				Если Строка.рар_мп_КоличествоГрузовыхМест = 0 Тогда
					
					ТаблицаЗаполнена = Ложь;
					
					Сообщение = Новый СообщениеПользователю;
					Сообщение.Текст = СтрШаблон("Для идентификатора склада %1 не указано количество грузовых мест", Строка.рар_мп_ИдентификаторСклада);
					Сообщение.Сообщить();
					
				КонецЕсли;	
				
			КонецЦикла;		
			
		КонецЕсли;
		
		Если ТаблицаЗаполнена Тогда
			
			КоличествоГрузовыхМест = Объект.рар_мп_КоличествоГрузовыхМест.Выгрузить();
			
			ДанныеОтгрузки = рар_мп_ОбработкаЗаказов.Ozon_ПодтверждениеОтгрузки(Объект.рар_мп_АккаунтМаркетплейса, КоличествоГрузовыхМест, ПодключенаДоверительнаяПриемка);
			
			Если ДанныеОтгрузки.Подтверждена Тогда
				
				Сообщение = Новый СообщениеПользователю;
				Сообщение.Текст = "Отгрузка подтверждена";
				Сообщение.Сообщить();
				
				Объект.рар_мп_Wildberries_НомерПоставки = СтрЗаменить(ДанныеОтгрузки.НомерПеревозки, " ", "");
				
			КонецЕсли;	
			
		КонецЕсли;	
		
	ИначеЕсли Маркетплейс = Перечисления.рар_мп_Маркетплейсы.Wildberries Тогда
		
		ОтгрузкаПодтверждена = рар_мп_ОбработкаЗаказов.Wildberries_ПодтверждениеОтгрузки(Объект.рар_мп_АккаунтМаркетплейса, Объект.рар_мп_Wildberries_НомерПоставки);
		
		Если ОтгрузкаПодтверждена Тогда
			
			Для каждого Строка Из Объект.рар_мп_ЗаказыИзМаркетплейса Цикл
				
				Строка.рар_мп_СтатусОбработкиЗаказа = Перечисления.рар_мп_Wildberries_СтатусыОбработкиЗаказов.complete;	
				
			КонецЦикла;
			
			Сообщение = Новый СообщениеПользователю;
			Сообщение.Текст = "Отгрузка подтвеждена";
			Сообщение.Сообщить();
			
		КонецЕсли;
		
	ИначеЕсли Маркетплейс = Перечисления.рар_мп_Маркетплейсы.ЯндексМаркет Тогда
		
		ВыгрузкаCampaignId = Объект.рар_мп_КоличествоГрузовыхМест.Выгрузить();
		
		СтатусПодтверждения = рар_мп_ОбработкаЗаказов.ЯндексМаркет_ПодтверждениеОтгрузки(Объект.рар_мп_АккаунтМаркетплейса, ВыгрузкаCampaignId);
		
		Если СтатусПодтверждения Тогда
			
			Сообщение = Новый СообщениеПользователю;
			Сообщение.Текст = "Отгрузка подтверждена";
			Сообщение.Сообщить();
			
		Иначе
			
			Сообщение = Новый СообщениеПользователю;
			Сообщение.Текст = "Отгрузка не подтверждена";
			Сообщение.Сообщить();	
			
		КонецЕсли;
		
	КонецЕсли;
КонецПроцедуры

