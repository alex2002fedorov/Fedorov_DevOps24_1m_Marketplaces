#Область ЗагрузкаЗаказовКлиентов

//@skip-check module-structure-form-event-regions
&НаКлиенте
Процедура ЗагрузитьЗаказы(Команда)
	
	Если ПроверитьЗаполнение() Тогда
		
		Объект.рар_мп_ЗаказыИзМаркетплейса.Очистить();
		Объект.рар_мп_ПередачаНаКомиссию.Очистить();
		Объект.рар_мп_ТоварыИзЗаказов.Очистить();
		Объект.рар_мп_Коробки.Очистить();
		Объект.рар_мп_РаспределенныеТовары.Очистить();
		Объект.рар_мп_МаркируемыеТовары.Очистить();
		Объект.рар_мп_КоличествоГрузовыхМест.Очистить();
		
		ЗагрузитьЗаказыНаСервере();	
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ЗагрузитьЗаказыНаСервере()
	
	Маркетплейс = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Объект.рар_мп_АккаунтМаркетплейса, "Маркетплейс");
	
	Если Маркетплейс = Перечисления.рар_мп_Маркетплейсы.OZON Тогда
		
		Запрос = Новый Запрос;
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	ЗаказКлиента.Ссылка КАК рар_мп_Заказ,
		|	ЗаказКлиента.НомерПоДаннымКлиента КАК рар_мп_НомерЗаказа,
		|	ЗаказКлиента.рар_мп_Ozon_СтатусЗаказа КАК рар_мп_СтатусЗаказа,
		|	ЗаказКлиента.рар_мп_Ozon_ПодстатусЗаказа КАК рар_мп_СтатусОбработкиЗаказа
		|ПОМЕСТИТЬ ВТ_Заказы
		|ИЗ
		|	Документ.ЗаказКлиента КАК ЗаказКлиента
		|ГДЕ
		|	ЗаказКлиента.ПометкаУдаления = ЛОЖЬ
		|	И ЗаказКлиента.Проведен = ИСТИНА
		|	И ЗаказКлиента.рар_мп_АккаунтМаркетплейса = &рар_мп_АккаунтМаркетплейса
		|	И ЗаказКлиента.рар_мп_Ozon_СтатусЗаказа = ЗНАЧЕНИЕ(Перечисление.рар_мп_Ozon_СтатусыЗаказов.awaiting_packaging)
		|	И ЗаказКлиента.ДатаОтгрузки <= &рар_мп_ДатаОтгрузки
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТ_Заказы.рар_мп_Заказ КАК рар_мп_Заказ,
		|	ВТ_Заказы.рар_мп_НомерЗаказа КАК рар_мп_НомерЗаказа,
		|	ВТ_Заказы.рар_мп_СтатусЗаказа КАК рар_мп_СтатусЗаказа,
		|	ВТ_Заказы.рар_мп_СтатусОбработкиЗаказа КАК рар_мп_СтатусОбработкиЗаказа,
		|	ВТ_Заказы.рар_мп_Заказ.Товары.(
		|		НомерСтроки КАК рар_мп_СтрокаИзТЧТовары,
		|		Номенклатура КАК рар_мп_Номенклатура,
		|		Характеристика КАК рар_мп_Характеристика,
		|		Номенклатура.Артикул КАК рар_мп_Артикул,
		|		КоличествоУпаковок КАК рар_мп_КоличествоУпаковок,
		|		Количество КАК рар_мп_Количество
		|	) КАК рар_мп_ТЧТовары
		|ИЗ
		|	ВТ_Заказы КАК ВТ_Заказы
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ЗаказКлиентарар_мп_ТоварыДляМаркировки.Ссылка.НомерПоДаннымКлиента КАК рар_мп_НомерЗаказа,
		|	ЗаказКлиентарар_мп_ТоварыДляМаркировки.рар_мп_СтрокаИзТЧТовары КАК рар_мп_СтрокаИзТЧТовары,
		|	ЗаказКлиентарар_мп_ТоварыДляМаркировки.рар_мп_Exemplar_Id КАК рар_мп_Exemplar_Id,
		|	ЗаказКлиентарар_мп_ТоварыДляМаркировки.рар_мп_Номенклатура КАК рар_мп_Номенклатура,
		|	ЗаказКлиентарар_мп_ТоварыДляМаркировки.рар_мп_Номенклатура.Артикул КАК рар_мп_Артикул,
		|	ЗаказКлиентарар_мп_ТоварыДляМаркировки.рар_мп_Характеристика КАК рар_мп_Характеристика,
		|	ЗаказКлиентарар_мп_ТоварыДляМаркировки.рар_мп_ЗаполнениеМаркировки КАК рар_мп_ЗаполнениеМаркировки,
		|	ЗаказКлиентарар_мп_ТоварыДляМаркировки.рар_мп_ЧестныйЗнак КАК рар_мп_ЧестныйЗнак,
		|	ЗаказКлиентарар_мп_ТоварыДляМаркировки.рар_мп_IDТовара КАК рар_мп_IDТовара,
		|	ЗаказКлиентарар_мп_ТоварыДляМаркировки.рар_мп_ЗаполнениеГТД КАК рар_мп_ЗаполнениеГТД,
		|	ЗаказКлиентарар_мп_ТоварыДляМаркировки.рар_мп_НомерГТД КАК рар_мп_НомерГТД
		|ИЗ
		|	Документ.ЗаказКлиента.рар_мп_ТоварыДляМаркировки КАК ЗаказКлиентарар_мп_ТоварыДляМаркировки
		|ГДЕ
		|	ЗаказКлиентарар_мп_ТоварыДляМаркировки.Ссылка В
		|			(ВЫБРАТЬ
		|				ВТ_Заказы.рар_мп_Заказ
		|			ИЗ
		|				ВТ_Заказы)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	ВТ_Заказы.рар_мп_Заказ.рар_мп_УникальныйИдентификаторСклада КАК рар_мп_ИдентификаторСклада,
		|	0 КАК рар_мп_КоличествоГрузовыхМест
		|ИЗ
		|	ВТ_Заказы КАК ВТ_Заказы";
		
		Запрос.УстановитьПараметр("рар_мп_АккаунтМаркетплейса", Объект.рар_мп_АккаунтМаркетплейса);
		Запрос.УстановитьПараметр("рар_мп_ДатаОтгрузки", Объект.рар_мп_ДатаОтгрузки);
		
