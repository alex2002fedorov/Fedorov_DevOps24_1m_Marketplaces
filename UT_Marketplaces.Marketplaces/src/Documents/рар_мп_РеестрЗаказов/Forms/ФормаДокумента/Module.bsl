		ДвоичныеДанные = рар_мп_ОбработкаЗаказов.Wildberries_ПолучитьЭтикеткуПоставки(Объект.рар_мп_АккаунтМаркетплейса, 
		Объект.рар_мп_Wildberries_НомерПоставки); 
		
		Если ДвоичныеДанные <> "" Тогда
			
			МассивЭтикеток = Новый Массив;
			МассивЭтикеток.Добавить(ДвоичныеДанные);
			
			Попытка
				
				ТабДок = СформироватьПечатнуюФормуЭтикетки(МассивЭтикеток);
				
				КоллекцияПечатныхФорм =  УправлениеПечатьюКлиент.НоваяКоллекцияПечатныхФорм("Этикетки");    
				
				КоллекцияПечатныхФорм[0].ТабличныйДокумент = ТабДок; 
				КоллекцияПечатныхФорм[0].СинонимМакета = "Этикетка поставки";			
				ПараметрыВывода = Новый Структура("ЗаголовокФормы", "Этикетка поставки");
				УправлениеПечатьюКлиент.ПечатьДокументов(КоллекцияПечатныхФорм,"Этикетки",ПараметрыВывода);	
				
			Исключение 
				
				Сообщение = Новый СообщениеПользователю;
