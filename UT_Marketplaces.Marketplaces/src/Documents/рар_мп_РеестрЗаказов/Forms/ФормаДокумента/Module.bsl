&НаКлиенте
Процедура СоздатьКоробку(Команда)
	
	Если АккаунтИзЯндексМаркет() Или АккаунтИзOzon() Тогда
		
		Если ЗначениеЗаполнено(ЗаказКлиента) Тогда
			
			СоздатьКоробкуНаСервере();
			
		Иначе
			
			Сообщение = Новый СообщениеПользователю;
			Сообщение.Текст = "Выберите заказы, для которых нужно создать коробоку";
			Сообщение.Сообщить();	
			
		КонецЕсли;
		
	ИначеЕсли АккаунтИзWildberries() Тогда
		
		Если ПроверитьЗаполнение() Тогда
			
			Если ЗначениеЗаполнено(Объект.рар_мп_Wildberries_НомерПоставки) Тогда
				
				Wildberries_СоздатьКоробкуНаСервере();
				
			Иначе
				
				Сообщение = Новый СообщениеПользователю;
				Сообщение.Текст = "Нельзя создать коробку, так как не создана поставка";
				Сообщение.Сообщить();
				
			КонецЕсли;	
			
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура СоздатьКоробкуНаСервере()
	
	Для каждого Заказ Из ЗаказКлиента Цикл
		
		//@skip-check reading-attribute-from-database
		НомерЗаказа = Заказ.Значение.НомерПоДаннымКлиента;
		
		КоличествоКоробок = Объект.рар_мп_Коробки.НайтиСтроки(Новый Структура("рар_мп_НомерЗаказа", НомерЗаказа)).Количество();		
		
		Строка = Объект.рар_мп_Коробки.Добавить();
		
		Строка.рар_мп_Коробка 	  = СтрШаблон("Коробка №%1", КоличествоКоробок + 1);
		Строка.рар_мп_НомерЗаказа = НомерЗаказа;	
		
	КонецЦикла;	
	
КонецПроцедуры


&НаСервере
Процедура Wildberries_СоздатьКоробкуНаСервере()
	
	Маркетплейс = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Объект.рар_мп_АккаунтМаркетплейса, "Маркетплейс");
	
	Если Маркетплейс = Перечисления.рар_мп_Маркетплейсы.OZON Тогда
		
		Сообщение = Новый СообщениеПользователю;
		Сообщение.Текст = "Для Ozon нельзя создавать коробки";
		Сообщение.Сообщить();	
		
	ИначеЕсли Маркетплейс = Перечисления.рар_мп_Маркетплейсы.ЯндексМаркет Тогда
		
		Сообщение = Новый СообщениеПользователю;
		Сообщение.Текст = "Функциионал не реализован";
		Сообщение.Сообщить();	
		
	ИначеЕсли Маркетплейс = Перечисления.рар_мп_Маркетплейсы.Wildberries Тогда
		
		УникальныйИдентификаторКоробки = рар_мп_ОбработкаЗаказов.Wildberries_СоздатьКоробкуВПоставке(Объект.рар_мп_АккаунтМаркетплейса,
		Объект.рар_мп_Wildberries_НомерПоставки);
		
		Если УникальныйИдентификаторКоробки <> "" Тогда
			
			НоваяСтрока = Объект.рар_мп_Коробки.Добавить();
			
			НоваяСтрока.рар_мп_Коробка = УникальныйИдентификаторКоробки;
			
			Сообщение = Новый СообщениеПользователю;
			Сообщение.Текст = "Коробка создана";
			Сообщение.Сообщить();
			
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти 

