&НаКлиенте
Процедура ДобавитьВКоробку(Команда)
	
	Если ПроверитьЗаполнение() Тогда
		
		ДобавитьВКоробкуНаСервере();	
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ДобавитьВКоробкуНаСервере()
	Маркетплейс = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Объект.рар_мп_АккаунтМаркетплейса, "Маркетплейс");	
	
	Если Маркетплейс = Перечисления.рар_мп_Маркетплейсы.ЯндексМаркет Или
		Маркетплейс = Перечисления.рар_мп_Маркетплейсы.OZON Тогда
		
		ВыбраннаяКоробка = Объект.рар_мп_Коробки.НайтиСтроки(Новый Структура("ВыборСтроки", Истина));
		
		Если ВыбраннаяКоробка.Количество() > 0 Тогда
			
			НужнаяКоробка = ВыбраннаяКоробка.Получить(0);
			
			ВыбранныеСтроки = Объект.рар_мп_ТоварыИзЗаказов.НайтиСтроки(Новый Структура("ВыборСтроки", Истина));
			
			Если ВыбранныеСтроки.Количество() > 0 Тогда
				
				Если ПроверитьЗаполнениеТабличнойЧастиТоварыИзЗаказов(ВыбранныеСтроки) Тогда
					
					Для каждого Строка Из ВыбранныеСтроки Цикл
						
						Если Строка.рар_мп_НомерЗаказа <> НужнаяКоробка.рар_мп_НомерЗаказа Тогда
							
							Сообщение = Новый СообщениеПользователю;
							Сообщение.Текст = СтрШаблон("Номерклатура: %1 (Артикул: %2. Номер заказа: %3) не содержиться в заказе: %4",
							Строка.рар_мп_Номенклатура, Строка.рар_мп_Артикул, 
							Строка.рар_мп_НомерЗаказа, НужнаяКоробка.рар_мп_НомерЗаказа);
							Сообщение.Сообщить();
							
						Иначе
							
							НоваяСтрока = Объект.рар_мп_РаспределенныеТовары.Добавить();
							
							НоваяСтрока.рар_мп_Коробка			    = НужнаяКоробка.рар_мп_Коробка;
							НоваяСтрока.рар_мп_НомерЗаказа          = Строка.рар_мп_НомерЗаказа;
							НоваяСтрока.рар_мп_СтрокаИзТЧТовары     = Строка.рар_мп_СтрокаИзТЧТовары;
							НоваяСтрока.рар_мп_Артикул              = Строка.рар_мп_Артикул;
							НоваяСтрока.рар_мп_Номенклатура         = Строка.рар_мп_Номенклатура;
							НоваяСтрока.рар_мп_Характеристика       = Строка.рар_мп_Характеристика;
							НоваяСтрока.рар_мп_КоличествоУпаковок	= Строка.рар_мп_КоличествоУпаковок;
							НоваяСтрока.рар_мп_Количество			= Строка.рар_мп_Количество;
							
							Объект.рар_мп_ТоварыИзЗаказов.Удалить(Объект.рар_мп_ТоварыИзЗаказов.Индекс(Строка));	
							
						КонецЕсли;
						
						
					КонецЦикла;
					
					Сообщение = Новый СообщениеПользователю;
					Сообщение.Текст = "Добавление в коробку завершено";
					Сообщение.Сообщить();
					
				КонецЕсли;
				
			Иначе
				
				Сообщение = Новый СообщениеПользователю;
				Сообщение.Текст = "Для добавления в коробку необходимо выбрать заказы (отметить строку галочкой)";
				Сообщение.Сообщить();	
				
			КонецЕсли;
			
			
		Иначе
			
			Сообщение = Новый СообщениеПользователю;
			Сообщение.Текст = "Для добавления в коробку необходимо выбрать коробку (отметить строку галочкой)";
			Сообщение.Сообщить();
			
		КонецЕсли;
		
	ИначеЕсли Маркетплейс = Перечисления.рар_мп_Маркетплейсы.Wildberries Тогда
		
		ВыбраннаяКоробка = Объект.рар_мп_Коробки.НайтиСтроки(Новый Структура("ВыборСтроки", Истина));
		
		Если ВыбраннаяКоробка.Количество() > 0 Тогда
			
			НужнаяКоробка = ВыбраннаяКоробка.Получить(0);
			
			ВыбранныеСтроки = Объект.рар_мп_ТоварыИзЗаказов.НайтиСтроки(Новый Структура("ВыборСтроки", Истина));
			
			Если ВыбранныеСтроки.Количество() > 0 Тогда
				
				Если ПроверитьЗаполнениеТабличнойЧастиТоварыИзЗаказов(ВыбранныеСтроки) Тогда
					
					МассивНомеровЗаказов = Новый Массив;
					
					Для каждого Строка Из ВыбранныеСтроки Цикл
						
						НомерЗаказа = Строка.рар_мп_НомерЗаказа;
						
						Если МассивНомеровЗаказов.Найти(НомерЗаказа) = Неопределено Тогда
							
							МассивНомеровЗаказов.Добавить(НомерЗаказа);		
							
						КонецЕсли;
						
					КонецЦикла;
					
					СтатусДобавления = рар_мп_ОбработкаЗаказов.Wildberries_ДобавитьВКоробку(Объект.рар_мп_АккаунтМаркетплейса,
					Объект.рар_мп_Wildberries_НомерПоставки,
					НужнаяКоробка.рар_мп_Коробка,
					МассивНомеровЗаказов);
					
					Если СтатусДобавления Тогда
						
						Для каждого Строка Из ВыбранныеСтроки Цикл
							
							НоваяСтрока = Объект.рар_мп_РаспределенныеТовары.Добавить();
							
							НоваяСтрока.рар_мп_Коробка			    = НужнаяКоробка.рар_мп_Коробка;
							НоваяСтрока.рар_мп_НомерЗаказа          = Строка.рар_мп_НомерЗаказа;
							НоваяСтрока.рар_мп_СтрокаИзТЧТовары     = Строка.рар_мп_СтрокаИзТЧТовары;
							НоваяСтрока.рар_мп_Артикул              = Строка.рар_мп_Артикул;
							НоваяСтрока.рар_мп_Номенклатура         = Строка.рар_мп_Номенклатура;
							НоваяСтрока.рар_мп_Характеристика       = Строка.рар_мп_Характеристика;
							НоваяСтрока.рар_мп_КоличествоУпаковок	= Строка.рар_мп_КоличествоУпаковок;
							НоваяСтрока.рар_мп_Количество			= Строка.рар_мп_Количество;
							
							Объект.рар_мп_ТоварыИзЗаказов.Удалить(Объект.рар_мп_ТоварыИзЗаказов.Индекс(Строка));		
							
						КонецЦикла;
						
						Сообщение = Новый СообщениеПользователю;
						Сообщение.Текст = "Добавление в коробку завершено";
						Сообщение.Сообщить();
						
					КонецЕсли;
					
				КонецЕсли;	
				
			Иначе
				
				Сообщение = Новый СообщениеПользователю;
				Сообщение.Текст = "Для добавления в коробку необходимо выбрать заказы (отметить строку галочкой)";
				Сообщение.Сообщить();	
				
			КонецЕсли;
			
			
		Иначе
			
			Сообщение = Новый СообщениеПользователю;
			Сообщение.Текст = "Для добавления в коробку необходимо выбрать коробку (отметить строку галочкой)";
			Сообщение.Сообщить();
			
		КонецЕсли;
		
	КонецЕсли;	
КонецПроцедуры

&НаСервере
Функция ПроверитьЗаполнениеТабличнойЧастиТоварыИзЗаказов(ВыбранныеСтроки)
	
	ВсеЗаполнено = Истина;
	
	Для каждого Строка_ТоварыИзЗаказов Из ВыбранныеСтроки Цикл
		
		//@skip-check structure-consructor-too-many-keys
		НужныеСтроки = Объект.рар_мп_МаркируемыеТовары.НайтиСтроки(Новый Структура("рар_мп_НомерЗаказа, рар_мп_СтрокаИзТЧТовары, рар_мп_Артикул, рар_мп_Номенклатура, рар_мп_Характеристика", 
		Строка_ТоварыИзЗаказов.рар_мп_НомерЗаказа, Строка_ТоварыИзЗаказов.рар_мп_СтрокаИзТЧТовары,
		Строка_ТоварыИзЗаказов.рар_мп_Артикул, Строка_ТоварыИзЗаказов.рар_мп_Номенклатура,
		Строка_ТоварыИзЗаказов.рар_мп_Характеристика));
		
		Для каждого Строка Из НужныеСтроки Цикл
			
			Если Строка.рар_мп_ЗаполнениеМаркировки Тогда
				
				Если НЕ ЗначениеЗаполнено(Строка.рар_мп_ЧестныйЗнак) Тогда
					
					Сообщение = Новый СообщениеПользователю;
					Сообщение.Текст = СтрШаблон("Не заполнена маркировка у номерклатуры: %1 (Заказ: %2. Номер строки из табличной части Товары: %3. Артикул: %4)",
					Строка.рар_мп_Номенклатура, Строка.рар_мп_НомерЗаказа, Строка.рар_мп_СтрокаИзТЧТовары, Строка.рар_мп_Артикул);
					Сообщение.Сообщить();
					
					ВсеЗаполнено = Ложь;
					
				КонецЕсли;	
				
			КонецЕсли;	
			
		КонецЦикла;															
		
		
	КонецЦикла;	
	
	Возврат ВсеЗаполнено; 
	
КонецФункции

