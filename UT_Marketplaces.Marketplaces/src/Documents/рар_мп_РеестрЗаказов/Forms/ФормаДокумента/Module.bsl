&НаКлиенте
Процедура УдалитьИзКоробки(Команда)
	
	Если ПроверитьЗаполнение() Тогда
		
		ВыбранныеСтроки = Объект.рар_мп_РаспределенныеТовары.НайтиСтроки(Новый Структура("ВыборСтроки", Истина));
		
		Если ВыбранныеСтроки.Количество() > 0 Тогда
			
			Если АккаунтИзWildberries() Тогда
				
				ДлительнаяОперация     = Wildberries_УдалитьИзКоробкиНаСервере();
				ПараметрыОжидания      = ДлительныеОперацииКлиент.ПараметрыОжидания(ЭтотОбъект);
				ПараметрыОжидания.ВыводитьСообщения = Истина;
				ПараметрыОжидания.ВыводитьОкноОжидания = Истина;
				ПараметрыОжидания.ТекстСообщения = "Удаление из коробки ...";
				Оповещение = Новый ОписаниеОповещения("ЗавершениеУдаленияИзКоробки", ЭтотОбъект);
				ДлительныеОперацииКлиент.ОжидатьЗавершение(ДлительнаяОперация, Оповещение, ПараметрыОжидания);	
				
			ИначеЕсли АккаунтИзЯндексМаркет() Или АккаунтИзOzon() Тогда
				
				Для каждого Строка из ВыбранныеСтроки Цикл
					
					НоваяСтрока = Объект.рар_мп_ТоварыИзЗаказов.Добавить();
					
					НоваяСтрока.рар_мп_НомерЗаказа          = Строка.рар_мп_НомерЗаказа;
					НоваяСтрока.рар_мп_СтрокаИзТЧТовары     = Строка.рар_мп_СтрокаИзТЧТовары;
					НоваяСтрока.рар_мп_Артикул              = Строка.рар_мп_Артикул;
					НоваяСтрока.рар_мп_Номенклатура         = Строка.рар_мп_Номенклатура;
					НоваяСтрока.рар_мп_Характеристика       = Строка.рар_мп_Характеристика;
					НоваяСтрока.рар_мп_КоличествоУпаковок	= Строка.рар_мп_КоличествоУпаковок;
					НоваяСтрока.рар_мп_Количество			= Строка.рар_мп_Количество;
					
					
					Объект.рар_мп_РаспределенныеТовары.Удалить(Объект.рар_мп_РаспределенныеТовары.Индекс(Строка));
					
				КонецЦикла;	
				
				Сообщение = Новый СообщениеПользователю;
				Сообщение.Текст = "Удаление из коробки завершено";
				Сообщение.Сообщить();
				
			Иначе
				
				Сообщение = Новый СообщениеПользователю;
				Сообщение.Текст = "Для данного аккаунта нельзя удалять коробки";
				Сообщение.Сообщить();
				
			КонецЕсли;
			
			
			
		Иначе
			
			Сообщение = Новый СообщениеПользователю;
			Сообщение.Текст = "Для удаления из коробки необходимо выбрать заказы (отметить строку галочкой)";
			Сообщение.Сообщить();
			
		КонецЕсли; 
		
	КонецЕсли;
КонецПроцедуры

&НаСервере
Функция Wildberries_УдалитьИзКоробкиНаСервере()
	
	ВыбранныеСтроки = Объект.рар_мп_РаспределенныеТовары.НайтиСтроки(Новый Структура("ВыборСтроки", Истина));
	
	НужныеСтроки = Объект.рар_мп_РаспределенныеТовары.Выгрузить(ВыбранныеСтроки);
	
	ПараметрыВыполнения = ДлительныеОперации.ПараметрыВыполненияФункции(УникальныйИдентификатор); 
	
	ВозвратныеДанные = ДлительныеОперации.ВыполнитьФункцию(ПараметрыВыполнения, 
	"рар_мп_ОбработкаЗаказов.Wildberries_УдалитьИзКоробки", 
	Объект.рар_мп_АккаунтМаркетплейса, Объект.рар_мп_Wildberries_НомерПоставки,
	НужныеСтроки);		
	
	Возврат ВозвратныеДанные;
	
КонецФункции

&НаКлиенте
Процедура ЗавершениеУдаленияИзКоробки(Результат, СтруктураПараметров) Экспорт
	
	Если Результат = НЕОПРЕДЕЛЕНО Тогда
		
		Возврат;	
		
	КонецЕсли;
	
	Если Результат.Статус = "Выполнено" Тогда
		
		ЗавершениеУдаленияИзКоробкиНаСервере(Результат);	
		
	ИначеЕсли Результат.Статус = "Ошибка" Тогда 
		
		СтандартныеПодсистемыКлиент.ВывестиИнформациюОбОшибке(Результат.ИнформацияОбОшибке);
		
		Возврат;
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ЗавершениеУдаленияИзКоробкиНаСервере(Результат) 
	
	МассивСтрокДляУдаления = ПолучитьИзВременногоХранилища(Результат.АдресРезультата);
	
	Для каждого Строка Из МассивСтрокДляУдаления Цикл
		
		НоваяСтрока = Объект.рар_мп_ТоварыИзЗаказов.Добавить();
		
		НоваяСтрока.рар_мп_НомерЗаказа          = Строка.рар_мп_НомерЗаказа;
		НоваяСтрока.рар_мп_СтрокаИзТЧТовары     = Строка.рар_мп_СтрокаИзТЧТовары;
		НоваяСтрока.рар_мп_Артикул              = Строка.рар_мп_Артикул;
		НоваяСтрока.рар_мп_Номенклатура         = Строка.рар_мп_Номенклатура;
		НоваяСтрока.рар_мп_Характеристика       = Строка.рар_мп_Характеристика;
		НоваяСтрока.рар_мп_КоличествоУпаковок	= Строка.рар_мп_КоличествоУпаковок;
		НоваяСтрока.рар_мп_Количество			= Строка.рар_мп_Количество;
		
		//@skip-check structure-consructor-too-many-keys
		СтуктураПоискаСтроки = Новый Структура("рар_мп_Коробка, рар_мп_НомерЗаказа, рар_мп_СтрокаИзТЧТовары, рар_мп_Номенклатура,рар_мп_Характеристика, рар_мп_Артикул", 
		Строка.рар_мп_Коробка, Строка.рар_мп_НомерЗаказа, Строка.рар_мп_СтрокаИзТЧТовары, Строка.рар_мп_Номенклатура, 
		Строка.рар_мп_Характеристика, Строка.рар_мп_Артикул);		
		НужнаяСтрока = Объект.рар_мп_РаспределенныеТовары.НайтиСтроки(СтуктураПоискаСтроки);
		
		Если НужнаяСтрока.Количество() <> 0 Тогда
			
			Объект.рар_мп_РаспределенныеТовары.Удалить(Объект.рар_мп_РаспределенныеТовары.Индекс(НужнаяСтрока.Получить(0)));
			
		КонецЕсли;
		
	КонецЦикла;
	
	Сообщение = Новый СообщениеПользователю;
	Сообщение.Текст = "Удаление из коробки завершено";
	Сообщение.Сообщить();	
	
КонецПроцедуры

