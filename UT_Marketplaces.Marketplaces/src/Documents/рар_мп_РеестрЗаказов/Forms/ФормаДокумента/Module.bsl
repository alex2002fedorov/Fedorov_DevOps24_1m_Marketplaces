//@skip-check module-structure-form-event-regions
&НаКлиенте
Процедура УдалитьЗаказИзРеестра(Команда)
	
	Если НЕ(Объект.рар_мп_ЗапрещеноИзменятьСоставаРеестра) Тогда
		
		ВыбранныеСтроки = Объект.рар_мп_ЗаказыИзМаркетплейса.НайтиСтроки(Новый Структура("ВыборСтроки", Истина));
		
		Если ВыбранныеСтроки.Количество() = 0 Тогда
			
			Сообщение = Новый СообщениеПользователю;
			Сообщение.Текст = "Не выбран ни один заказ на удаление";
			Сообщение.Сообщить();	
			
		Иначе
			
			Для каждого Строка Из ВыбранныеСтроки Цикл
				
				НомерЗаказ = Строка.рар_мп_НомерЗаказа;
				
				СтрокиДляУдаленияИзТоварыИзЗаказов = Объект.рар_мп_ТоварыИзЗаказов.НайтиСтроки(Новый Структура("рар_мп_НомерЗаказа", НомерЗаказ));
				
				Для каждого СтрокаДляУдаления Из СтрокиДляУдаленияИзТоварыИзЗаказов Цикл
					
					Объект.рар_мп_ТоварыИзЗаказов.Удалить(Объект.рар_мп_ТоварыИзЗаказов.Индекс(СтрокаДляУдаления));		
					
				КонецЦикла;
				
				СтрокиДляУдаленияИзПередачаНаКомиссию = Объект.рар_мп_ПередачаНаКомиссию.НайтиСтроки(Новый Структура("рар_мп_НомерЗаказа", НомерЗаказ));
				
				Для каждого СтрокаДляУдаления Из СтрокиДляУдаленияИзПередачаНаКомиссию Цикл
					
					Объект.рар_мп_ПередачаНаКомиссию.Удалить(Объект.рар_мп_ПередачаНаКомиссию.Индекс(СтрокаДляУдаления));		
					
				КонецЦикла;
				
				СтрокиДляУдаленияИзРаспределенныеТовары = Объект.рар_мп_РаспределенныеТовары.НайтиСтроки(Новый Структура("рар_мп_НомерЗаказа", НомерЗаказ));
				
				Для каждого СтрокаДляУдаления Из СтрокиДляУдаленияИзРаспределенныеТовары Цикл
					
					Объект.рар_мп_РаспределенныеТовары.Удалить(Объект.рар_мп_РаспределенныеТовары.Индекс(СтрокаДляУдаления));		
					
				КонецЦикла;
				
				СтрокиДляУдаленияИзКоробки = Объект.рар_мп_Коробки.НайтиСтроки(Новый Структура("рар_мп_НомерЗаказа", НомерЗаказ));
				
				Для каждого СтрокаДляУдаления Из СтрокиДляУдаленияИзКоробки Цикл
					
					Объект.рар_мп_Коробки.Удалить(Объект.рар_мп_Коробки.Индекс(СтрокаДляУдаления));		
					
				КонецЦикла;
				
				СтрокиДляУдаленияИзМаркируемыеТовары = Объект.рар_мп_МаркируемыеТовары.НайтиСтроки(Новый Структура("рар_мп_НомерЗаказа", НомерЗаказ));
				
				Для каждого СтрокаДляУдаления Из СтрокиДляУдаленияИзМаркируемыеТовары Цикл
					
					Объект.рар_мп_МаркируемыеТовары.Удалить(Объект.рар_мп_МаркируемыеТовары.Индекс(СтрокаДляУдаления));		
					
				КонецЦикла;
				
				Объект.рар_мп_ЗаказыИзМаркетплейса.Удалить(Объект.рар_мп_ЗаказыИзМаркетплейса.Индекс(Строка));
				
				СтруктураНомерСклада = ОбщегоНазначенияУТВызовСервера.ЗначенияРеквизитовОбъекта(Строка.рар_мп_Заказ, "рар_мп_УникальныйИдентификаторСклада");
				
				НомерСклада = СтруктураНомерСклада.рар_мп_УникальныйИдентификаторСклада;
				
				КоличествоСтрокСНомеромСклада = 0;
				
				Для каждого СтрокаТЧ Из Объект.рар_мп_ЗаказыИзМаркетплейса Цикл
					
					НомерСкладаИзТекущегоЗаказа = ОбщегоНазначенияУТВызовСервера.ЗначенияРеквизитовОбъекта(СтрокаТЧ.рар_мп_Заказ, "рар_мп_УникальныйИдентификаторСклада");
					
					Если НомерСклада = НомерСкладаИзТекущегоЗаказа.рар_мп_УникальныйИдентификаторСклада Тогда
						
						КоличествоСтрокСНомеромСклада = КоличествоСтрокСНомеромСклада + 1;
						
						Прервать;
						
					КонецЕсли;
					
				КонецЦикла;
				
				Если КоличествоСтрокСНомеромСклада = 0 Тогда
					
					СтрокиДляУдаленияИзКоличествоГрузовыхМест = Объект.рар_мп_КоличествоГрузовыхМест.НайтиСтроки(Новый Структура("рар_мп_ИдентификаторСклада", НомерСклада));
					
					Для каждого СтрокаДляУдаления Из СтрокиДляУдаленияИзКоличествоГрузовыхМест Цикл
						
						Объект.рар_мп_КоличествоГрузовыхМест.Удалить(Объект.рар_мп_КоличествоГрузовыхМест.Индекс(СтрокаДляУдаления));		
						
					КонецЦикла;		
					
				КонецЕсли;
				
			КонецЦикла;	
			
		КонецЕсли;
		
		Сообщение = Новый СообщениеПользователю;
		Сообщение.Текст = "Удаление заказов завершено";
		Сообщение.Сообщить();
		
	Иначе
		
		Сообщение = Новый СообщениеПользователю;
		Сообщение.Текст = "Удалить заказы из реестра на данном этапе не возвожно";
		Сообщение.Сообщить();
	КонецЕсли;
КонецПроцедуры

