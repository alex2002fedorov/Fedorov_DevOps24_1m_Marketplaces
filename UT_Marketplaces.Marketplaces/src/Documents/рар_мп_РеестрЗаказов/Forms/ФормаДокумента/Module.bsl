&НаКлиенте
Процедура УдалитьКоробку(Команда)
	
	Если ПроверитьЗаполнение() Тогда
		
		УдалитьКоробкуНаСервере();	
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура УдалитьКоробкуНаСервере()
	
	Маркетплейс = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Объект.рар_мп_АккаунтМаркетплейса, "Маркетплейс");	
	
	Если Маркетплейс = Перечисления.рар_мп_Маркетплейсы.ЯндексМаркет 
		Или Маркетплейс = Перечисления.рар_мп_Маркетплейсы.OZON Тогда
		
		ВыбраннаяСтрока = Объект.рар_мп_Коробки.НайтиСтроки(Новый Структура("ВыборСтроки", Истина));
		
		Если ВыбраннаяСтрока.Количество() > 0 Тогда
			
			НужнаяСтрока = ВыбраннаяСтрока.Получить(0);
			
			СтрокиДляУдаления = Объект.рар_мп_РаспределенныеТовары.НайтиСтроки(Новый Структура("рар_мп_Коробка, рар_мп_НомерЗаказа", 
			НужнаяСтрока.рар_мп_Коробка,
			НужнаяСтрока.рар_мп_НомерЗаказа));
			
			Для каждого Строка Из СтрокиДляУдаления Цикл
				
				НоваяСтрока = Объект.рар_мп_ТоварыИзЗаказов.Добавить();
				
				НоваяСтрока.рар_мп_НомерЗаказа          = Строка.рар_мп_НомерЗаказа;
				НоваяСтрока.рар_мп_СтрокаИзТЧТовары     = Строка.рар_мп_СтрокаИзТЧТовары;
				НоваяСтрока.рар_мп_Артикул              = Строка.рар_мп_Артикул;
				НоваяСтрока.рар_мп_Номенклатура         = Строка.рар_мп_Номенклатура;
				НоваяСтрока.рар_мп_Характеристика       = Строка.рар_мп_Характеристика;
				НоваяСтрока.рар_мп_КоличествоУпаковок	= Строка.рар_мп_КоличествоУпаковок;
				НоваяСтрока.рар_мп_Количество			= Строка.рар_мп_Количество;
				
				Объект.рар_мп_РаспределенныеТовары.Удалить(Объект.рар_мп_РаспределенныеТовары.Индекс(Строка));		
				
			КонецЦикла;
			
			Объект.рар_мп_Коробки.Удалить(Объект.рар_мп_Коробки.Индекс(НужнаяСтрока));
			
			Сообщение = Новый СообщениеПользователю;
			Сообщение.Текст = "Коробка удалена";
			Сообщение.Сообщить();
			
		Иначе
			
			Сообщение = Новый СообщениеПользователю;
			Сообщение.Текст = "Для удаления необходимо выбрать коробку (отметить строку галочкой)";
			Сообщение.Сообщить();
			
		КонецЕсли;
		
	ИначеЕсли Маркетплейс = Перечисления.рар_мп_Маркетплейсы.Wildberries Тогда
		
		ВыбраннаяСтрока = Объект.рар_мп_Коробки.НайтиСтроки(Новый Структура("ВыборСтроки", Истина));
		
		Если ВыбраннаяСтрока.Количество() > 0 Тогда
			
			НужнаяСтрока = ВыбраннаяСтрока.Получить(0);
			
			СтатусУдаления = рар_мп_ОбработкаЗаказов.Wildberries_УдалитьКоробкуВПоставке(Объект.рар_мп_АккаунтМаркетплейса,
			Объект.рар_мп_Wildberries_НомерПоставки,
			НужнаяСтрока.рар_мп_Коробка);
			
			Если СтатусУдаления Тогда
			
				СтрокиДляУдаления = Объект.рар_мп_РаспределенныеТовары.НайтиСтроки(Новый Структура("рар_мп_Коробка", НужнаяСтрока.рар_мп_Коробка));
				
				Для каждого Строка Из СтрокиДляУдаления Цикл
					
					НоваяСтрока = Объект.рар_мп_ТоварыИзЗаказов.Добавить();
					
					НоваяСтрока.рар_мп_НомерЗаказа          = Строка.рар_мп_НомерЗаказа;
					НоваяСтрока.рар_мп_СтрокаИзТЧТовары     = Строка.рар_мп_СтрокаИзТЧТовары;
					НоваяСтрока.рар_мп_Артикул              = Строка.рар_мп_Артикул;
					НоваяСтрока.рар_мп_Номенклатура         = Строка.рар_мп_Номенклатура;
					НоваяСтрока.рар_мп_Характеристика       = Строка.рар_мп_Характеристика;
					НоваяСтрока.рар_мп_КоличествоУпаковок	= Строка.рар_мп_КоличествоУпаковок;
					НоваяСтрока.рар_мп_Количество			= Строка.рар_мп_Количество;
					
					
					Объект.рар_мп_РаспределенныеТовары.Удалить(Объект.рар_мп_РаспределенныеТовары.Индекс(Строка));		
					
				КонецЦикла;  
				
				Объект.рар_мп_Коробки.Удалить(Объект.рар_мп_Коробки.Индекс(НужнаяСтрока));
				
				Сообщение = Новый СообщениеПользователю;
				Сообщение.Текст = "Коробка удалена";
				Сообщение.Сообщить();
				
			КонецЕсли;
		Иначе
			
			Сообщение = Новый СообщениеПользователю;
			Сообщение.Текст = "Для удаления необходимо выбрать коробку (отметить строку галочкой)";
			Сообщение.Сообщить();
			
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

