//@skip-check module-structure-top-region
#Область ЗагрузкаЦенВФорму  

&НаСервере
Функция ЗагрузитьЦеныНаСервере()
	
	Если НЕ Объект.Номенклатура.Количество() = 0 Тогда
		
		Если Не Объект.Аккаунт.Пустая() Тогда 
			
			Аккаунт = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Объект.Аккаунт, "Маркетплейс");
			
			Если Аккаунт = Перечисления.рар_мп_Маркетплейсы.OZON Тогда
				
				ЦеныАккаунта = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(Объект.Аккаунт, 
																			"ВидЦены_МинимальнаяЦена, ВидЦены_Себестоимость, ВидЦены_ЦенаДоСкидок, ВидЦены_ЦенаТовараСУчётомСкидок"); 
				
				Возврат ЦеныАккаунта;  
				
			ИначеЕсли Аккаунт = Перечисления.рар_мп_Маркетплейсы.ЯндексМаркет Тогда	
				
				ЦеныАккаунта = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(Объект.Аккаунт, 
																			"ВидЦены_ЦенаДоСкидок, ВидЦены_ЦенаТовараСУчётомСкидок");
				
				Возврат ЦеныАккаунта;
				
			ИначеЕсли Аккаунт = Перечисления.рар_мп_Маркетплейсы.Wildberries Тогда
				
				ЦеныАккаунта = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(Объект.Аккаунт, 
																			"ВидЦены_Цена");
				
				Возврат ЦеныАккаунта;
				
			КонецЕсли;                                                   
			
		Иначе                               
			
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Не заполнен аккаунт маркетплейса"); 
			
		КонецЕсли; 
		
	Иначе
		
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Заполните товары, для которых необходимо передать цены");  
		
	КонецЕсли;  
	
КонецФункции

//@skip-check module-structure-form-event-regions
&НаКлиенте
Процедура ЗагрузитьЦены(Команда) 
	
	ЦеныАккаунта = ЗагрузитьЦеныНаСервере(); 
	
	Если ЦеныАккаунта <> Неопределено Тогда
		
		ДлительнаяОперация = ЗапросПоВидамЦен(ЦеныАккаунта);
		
		ПараметрыОжидания = ДлительныеОперацииКлиент.ПараметрыОжидания(ЭтотОбъект); 
		ПараметрыОжидания.ВыводитьОкноОжидания = Истина;
		Оповещение = Новый ОписаниеОповещения("ПриЗавершенииЗапроса", ЭтотОбъект);
		ДлительныеОперацииКлиент.ОжидатьЗавершение(ДлительнаяОперация, Оповещение, ПараметрыОжидания);
		
	КонецЕсли;  
	
КонецПроцедуры  
 
&НаСервере
Функция ЗапросПоВидамЦен(ЦеныАккаунта)       
	
	Маркетплейс = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Объект.Аккаунт, "Маркетплейс"); 
	
	Валюта  = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Объект.Аккаунт, "Валюта");
	
	МассивНоменклатуры = Объект.Номенклатура.Выгрузить();
	
	//@skip-check form-self-reference
	ПараметрыВыполнения = ДлительныеОперации.ПараметрыВыполненияФункции(ЭтаФорма.УникальныйИдентификатор);
	
	СкидкиWB = Новый Структура("СкидкаWB, СкидкаWBКлуба", Объект.СкидкаWB, Объект.СкидкаWBКлуба);
	
	Возврат ДлительныеОперации.ВыполнитьФункцию(ПараметрыВыполнения, "рар_мп_ОбновлениеЦен.ПолучитьЦеныНоменклатурыПоАккаунту_Общее", 
													Объект.Аккаунт, Маркетплейс, ЦеныАккаунта, МассивНоменклатуры, Объект.Дата, Валюта, СкидкиWB);
	
КонецФункции  

&НаКлиенте
Процедура ПриЗавершенииЗапроса(РезультатИзВремХран, ДопПараметры) Экспорт
	
	Если РезультатИзВремХран = Неопределено Тогда  // пользователь отменил задание
		Возврат;
	КонецЕсли;
	
	Если РезультатИзВремХран.Статус = "Ошибка" Тогда
		ВызватьИсключение РезультатИзВремХран.ПодробноеПредставлениеОшибки;
	КонецЕсли;
	
	ЗаполнениеТаблицСверки(РезультатИзВремХран);
	
	//ПоказатьПредупреждение( , "Таблицы обновлены!");      
	
КонецПроцедуры  

&НаСервере
Процедура ЗаполнениеТаблицСверки(РезультатИзВремХран)
	
	Результат = ПолучитьИзВременногоХранилища(РезультатИзВремХран.АдресРезультата); 
	
	Если Результат =  0 Тогда  
		
		ОбщегоНазначения.СообщитьПользователю("Запрос на формирования цен не выполнен, ошибка в установке цен номенклатуры или в настройка аккаунта");
		
	Иначе 
		
		Объект.Номенклатура.Загрузить(Результат);
		
	КонецЕсли;	
	
КонецПроцедуры 

#КонецОбласти

//@skip-check module-structure-top-region
#Область ОбновитьЦены

&НаСервере
Функция ОбновитьЦеныНаСервере()  
	
	Аккаунт = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Объект.Аккаунт, "Маркетплейс");
	Валюта  = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Объект.Аккаунт, "Валюта");
	
	СтруктураДанных = Новый Структура();
	СтруктураДанных.Вставить("Аккаунт", Аккаунт); 
	СтруктураДанных.Вставить("Валюта",  Валюта);
	
	Если Объект.Номенклатура.Количество() = 0 Тогда
		
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Заполните товары, для которых необходимо передать цены"); 
		ТаблицаЗаполнена = Ложь;
		
	Иначе
		
		Если Аккаунт = Перечисления.рар_мп_Маркетплейсы.ЯндексМаркет Тогда
			
			Если campaignId.Количество() > 0 Тогда
				
				ТаблицаЗаполнена = Истина;  
				
			Иначе  
				
				ТаблицаЗаполнена = Ложь;   
				
				ОбщегоНазначения.СообщитьПользователю("Заполните магазин, для которого производится обновления цен");
				
			КонецЕсли;
		Иначе
			
			ТаблицаЗаполнена = Истина;  
			
		КонецЕсли;    
		
	КонецЕсли;
	
	СтруктураДанных.Вставить("ТаблицаЗаполнена", ТаблицаЗаполнена);  
	
	Возврат СтруктураДанных;   
	
КонецФункции

//@skip-check module-structure-form-event-regions
&НаКлиенте
Процедура ОбновитьЦены(Команда)
	
	Данные = ОбновитьЦеныНаСервере(); 
	
	Если Данные.ТаблицаЗаполнена Тогда
		
		ДлительнаяОперация = ИзменитьЦеныНаМаркетПлейсе(Данные);
		ПараметрыОжидания = ДлительныеОперацииКлиент.ПараметрыОжидания(ЭтотОбъект); 
		ПараметрыОжидания.ВыводитьОкноОжидания = Истина;
	    Оповещение = Новый ОписаниеОповещения("ПриЗавершенииОбновленияЦен", ЭтотОбъект);
	    ДлительныеОперацииКлиент.ОжидатьЗавершение(ДлительнаяОперация, Оповещение, ПараметрыОжидания);
		
	КонецЕсли;
	
КонецПроцедуры

//@skip-check bsl-legacy-check-method-for-statements-after-return
&НаСервере
Функция ИзменитьЦеныНаМаркетПлейсе(Данные)
	
	Если Данные.Аккаунт = Перечисления.рар_мп_Маркетплейсы.OZON Тогда
		
		//@skip-check form-self-reference
		ПараметрыВыполнения = ДлительныеОперации.ПараметрыВыполненияФункции(ЭтаФорма.УникальныйИдентификатор);              
		
		Возврат ДлительныеОперации.ВыполнитьФункцию(ПараметрыВыполнения, "рар_мп_ОбновлениеЦен.ОбновитьЦеныПоАккаунту_OZON", 
														Объект.Номенклатура.Выгрузить(), Объект.Аккаунт);  
		
	ИначеЕсли Данные.Аккаунт = Перечисления.рар_мп_Маркетплейсы.ЯндексМаркет Тогда
		
		//@skip-check form-self-reference
		ПараметрыВыполнения = ДлительныеОперации.ПараметрыВыполненияФункции(ЭтаФорма.УникальныйИдентификатор);   
		
		Возврат ДлительныеОперации.ВыполнитьФункцию(ПараметрыВыполнения, "рар_мп_ОбновлениеЦен.ОбновитьЦеныПоАккаунту_ЯндексМаркет", 
														Объект.Номенклатура.Выгрузить(), Объект.Аккаунт, campaignId.ВыгрузитьЗначения());  
														
	ИначеЕсли Данные.Аккаунт = Перечисления.рар_мп_Маркетплейсы.Wildberries Тогда
														
		//@skip-check form-self-reference
		ПараметрыВыполнения = ДлительныеОперации.ПараметрыВыполненияФункции(ЭтаФорма.УникальныйИдентификатор);   
		
		Возврат ДлительныеОперации.ВыполнитьФункцию(ПараметрыВыполнения, "рар_мп_ОбновлениеЦен.ОбновитьЦеныПоАккаунту_Wildberries", 
														Объект.Номенклатура.Выгрузить(), Объект.Аккаунт, УстановитьСкидкуWBКлуба); 												
														
	КонецЕсли;
	
КонецФункции

&НаКлиенте
Процедура ПриЗавершенииОбновленияЦен(РезультатИзВремХран, ДопПараметры) Экспорт
	
	Если РезультатИзВремХран = Неопределено Тогда  // пользователь отменил задание
		Возврат;
	КонецЕсли;
	
	Если РезультатИзВремХран.Статус = "Ошибка" Тогда
		ВызватьИсключение РезультатИзВремХран.ПодробноеПредставлениеОшибки;
	КонецЕсли;
	
	ПроверкаОбновленияЦен(РезультатИзВремХран); 
	
КонецПроцедуры

&НаСервере
Процедура ПроверкаОбновленияЦен(РезультатИзВремХран)
 
	Результат = ПолучитьИзВременногоХранилища(РезультатИзВремХран.АдресРезультата); 
	
	Если Результат.КодСостояния = 200 Тогда
		
		Сообщение = Новый СообщениеПользователю;
		Сообщение.Текст = "Цены обновлены";
		Сообщение.Сообщить();
		
	Иначе  
		
		Сообщение = Новый СообщениеПользователю;
		Сообщение.Текст = "Произошла ошибка передачи цен номенклатуры. Подробности в журнале регистрации" ;
		Сообщение.Сообщить();
		
	КонецЕсли;
	
КонецПроцедуры 

#КонецОбласти

//@skip-check module-structure-top-region
#Область ОбработкаСпискаЗначенийСampaignId  

//@skip-check module-structure-form-event-regions
&НаКлиенте
Процедура campaignIdНачалоВыбора(Элемент, ДанныеВыбора, ВыборДобавлением, СтандартнаяОбработка)
	
    СтандартнаяОбработка = Ложь;	

	ПараметрыФормы = Новый Структура;
	ПараметрыФормы.Вставить("АккаунтМаркетплейса", Объект.Аккаунт);
	ПараметрыФормы.Вставить("МножественныйВыбор", Истина);
	
	ОткрытьФорму("ОбщаяФорма.рар_мп_ФормаВыбораСопоставленныхСкладов", ПараметрыФормы, Элементы.campaignId);
	
КонецПроцедуры

//@skip-check module-structure-form-event-regions
&НаКлиенте
Процедура campaignIdОбработкаВыбора(Элемент, ВыбранноеЗначение, ДополнительныеДанные, ВыборДобавлением, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	
	campaignId.Очистить();
	
	Для Каждого Склад Из ВыбранноеЗначение Цикл
		
		campaignId.Добавить(Склад.campaignId, Склад.Наименование + "(" + Склад.campaignId + ")");
		
	КонецЦикла;
	
КонецПроцедуры

#КонецОбласти

