&НаСервере
Функция ОпределенияМаркетплейса()
	
	Если Объект.Аккаунт.Пустая() Тогда
		
		Возврат Неопределено;  
		
	Иначе
		
		Если ОпределитьТекМаркетплейс_Ozon() Тогда  
			
			Возврат Истина;
			
		ИначеЕсли ОпределитьТекМаркетплейс_Wildberries() Тогда 
			
			Возврат Истина;
			
		ИначеЕсли ОпределитьТекМаркетплейс_ЯндексМаркет() Тогда  
			
			Возврат Истина;
			
		КонецЕсли;
		
	КонецЕсли;
	

КонецФункции 

&НаСервере
Функция ОпределитьТекМаркетплейс_Ozon() 
	
	Маркетплейс = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Объект.Аккаунт, "Маркетплейс");
	
	Если Маркетплейс = Перечисления.рар_мп_Маркетплейсы.OZON Тогда
		
		Возврат Истина
		
	Иначе  
		
		Возврат Ложь
		
	КонецЕсли;
	
КонецФункции  

