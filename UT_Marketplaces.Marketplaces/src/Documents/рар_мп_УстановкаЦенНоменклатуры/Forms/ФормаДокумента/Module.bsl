#Область ОбработкаКомандыВыбрать

//@skip-check module-structure-form-event-regions
&НаКлиенте
Процедура Выбрать(Команда) 
	
	Если ЗначениеЗаполнено(Объект.Аккаунт) Тогда
		
		ПараметрыФормы = Новый Структура;
		ПараметрыФормы.Вставить("Аккаунт", Объект.Аккаунт);
		
		//@skip-check form-self-reference
		ОткрытьФорму("Обработка.рар_мп_ОбновлениеЦен_ПодборНоменклатуры.Форма.ФормаПодбора", ПараметрыФормы, ЭтаФорма);
		
	Иначе                                                            
		
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Не заполнен аккаунт маркетплейса");
		
	КонецЕсли;   
	
КонецПроцедуры   

&НаКлиенте
Процедура ОбработатьПодбор(АдресВХ) Экспорт
	
	ОбработатьПодборНаСервере(АдресВХ);
	Модифицированность = Истина;
	
КонецПроцедуры  

&НаСервере
Процедура ОбработатьПодборНаСервере(АдресВХ)

	НоменклатураИзПодбора = ПолучитьИзВременногоХранилища(АдресВХ); 
	
	Если НоменклатураИзПодбора.Количество() > 0 Тогда
		
		Для каждого Элем из НоменклатураИзПодбора Цикл  
			
			СтруктураОтбора = Новый Структура; 
			СтруктураОтбора.Вставить("Номенклатура", 	Элем.Номенклатура);
			СтруктураОтбора.Вставить("Упаковка", 		Элем.Упаковка);
			СтруктураОтбора.Вставить("Характеристика", 	Элем.Характеристика);
			СтруктураОтбора.Вставить("Артикул", 		Элем.Артикул);
			СтруктураОтбора.Вставить("УникальныйНомер", Элем.IDТовара);
			СтруктураОтбора.Вставить("Баракод", 		Элем.Баракод);
			СтруктураОтбора.Вставить("SKUТовара", 		Элем.SKUТовара);
			
			Если Объект.Номенклатура.НайтиСтроки(СтруктураОтбора).Количество() = 0 Тогда
				
				НоваяСтрока 				  				= Объект.Номенклатура.Добавить();
				НоваяСтрока.Номенклатура     				= Элем.Номенклатура; 
				НоваяСтрока.Характеристика   				= Элем.Характеристика;
				НоваяСтрока.Упаковка		  				= Элем.Упаковка;
				НоваяСтрока.Артикул          				= Элем.Артикул;
				НоваяСтрока.УникальныйНомер  				= Элем.IDТовара;
				НоваяСтрока.Баракод						= Элем.Баракод;
				НоваяСтрока.SKUТовара						= Элем.SKUТовара;
				НоваяСтрока.Размер			  				= Элем.Размер;
				НоваяСтрока.IDРазмера		  				= Элем.IDРазмера;
				НоваяСтрока.ВозможностьСменыЦенДляРазмеров = Элем.ВозможностьСменыЦенДляРазмеров;
				
			КонецЕсли;
			
		КонецЦикла;
		
	КонецЕсли;
	
КонецПроцедуры       

#КонецОбласти   

