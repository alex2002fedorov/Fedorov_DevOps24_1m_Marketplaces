#Область СлужебныеПроцедурыИФункцииДляПроверкиПЛС

&НаСервере
Функция ПриПовторномОткрытииНаСервере()
    Возврат Константы.рар_мп_Согласие.Получить();
КонецФункции

//@skip-check module-structure-form-event-regions
&НаКлиенте
Процедура ПриПовторномОткрытии()
    Если ПриПовторномОткрытииНаСервере() = Ложь Тогда
        Сообщение = Новый СообщениеПользователю;
        Сообщение.Текст = НСтр("ru='Вы не приняли лицензионное соглашение 1С-Рарус, функционал механизма не доступен'");
        Сообщение.Сообщить();
        //@skip-check module-self-reference
ЭтотОбъект.Закрыть();
    КонецЕсли;
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийФормы

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	Если ПриПовторномОткрытииНаСервере() = Ложь Тогда
		Сообщение = Новый СообщениеПользователю;
		Сообщение.Текст = НСтр("ru='Вы не приняли лицензионное соглашение 1С-Рарус, функционал механизма не доступен'");
		Сообщение.Сообщить();
		//@skip-check module-self-reference
		ЭтотОбъект.Закрыть();
	Иначе
		Аккаунт = ОпределенияМаркетплейса();	
		
		Если Аккаунт <> Неопределено Тогда
			
			ИзменениеВидимостиЦен();
			
		КонецЕсли;
	КонецЕсли;	
КонецПроцедуры 

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
Процедура УстановитьСкидкуWBКлубаПриИзменении(Элемент)
	
	Если УстановитьСкидкуWBКлуба Тогда
		Элементы.Номенклатура.ПодчиненныеЭлементы.НоменклатураСкидкаWBКлуба.Видимость 	= Истина;
		Элементы.СкидкаWBКлуба.Видимость												= Истина;
	Иначе
		Элементы.Номенклатура.ПодчиненныеЭлементы.НоменклатураСкидкаWBКлуба.Видимость 	= Ложь;
		Элементы.СкидкаWBКлуба.Видимость												= Ложь;
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

