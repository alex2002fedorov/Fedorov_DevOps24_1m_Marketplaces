		ВыбранныеСтроки = Объект.рар_мп_РаспределенныеТовары.НайтиСтроки(Новый Структура("ВыборСтроки", Истина));
		
		Если ВыбранныеСтроки.Количество() > 0 Тогда
			
			Если ОпределитьТекМаркетплейс_Wildberries() Тогда
				
				Wildberries_УдалитьИзКоробкиНаСервере();	
				
			Иначе
				
				Сообщение = Новый СообщениеПользователю;
				Сообщение.Текст = "Для данного аккаунта нельзя удалять коробки";
				Сообщение.Сообщить();
				
			КонецЕсли;
			
		Иначе
			
			Сообщение = Новый СообщениеПользователю;
			Сообщение.Текст = "Для удаления из коробки необходимо выбрать заказы (отметить строку галочкой)";
			Сообщение.Сообщить();
			
		КонецЕсли; 
		
	КонецЕсли;
КонецПроцедуры

&НаСервере
Процедура Wildberries_УдалитьИзКоробкиНаСервере()
	
	ВыбранныеСтроки = Объект.рар_мп_РаспределенныеТовары.НайтиСтроки(Новый Структура("ВыборСтроки", Истина));
	
	НужныеСтроки = Объект.рар_мп_РаспределенныеТовары.Выгрузить(ВыбранныеСтроки);
	
	Для каждого Строка Из НужныеСтроки Цикл
		
		НоваяСтрока = Объект.рар_мп_ТоварыИзЗаказов.Добавить();
		
		НоваяСтрока.рар_мп_Баркод               = Строка.рар_мп_Баркод;
		НоваяСтрока.рар_мп_Номенклатура         = Строка.рар_мп_Номенклатура;
		НоваяСтрока.рар_мп_Характеристика       = Строка.рар_мп_Характеристика;   
		НоваяСтрока.рар_мп_Упаковка             = Строка.рар_мп_Упаковка;
		НоваяСтрока.рар_мп_Количество			= Строка.рар_мп_Количество;
		
		//@skip-check structure-consructor-too-many-keys
		СтуктураПоискаСтроки = Новый Структура("рар_мп_Коробка, рар_мп_Номенклатура,рар_мп_Характеристика, рар_мп_Упаковка, рар_мп_Баркод", 
		Строка.рар_мп_Коробка, Строка.рар_мп_Номенклатура, 
		Строка.рар_мп_Характеристика, Строка.рар_мп_Упаковка, Строка.рар_мп_Баркод);		
		НужнаяСтрока = Объект.рар_мп_РаспределенныеТовары.НайтиСтроки(СтуктураПоискаСтроки);
		
		Если НужнаяСтрока.Количество() <> 0 Тогда
			
			Объект.рар_мп_РаспределенныеТовары.Удалить(Объект.рар_мп_РаспределенныеТовары.Индекс(НужнаяСтрока.Получить(0)));
			
		КонецЕсли;
		
	КонецЦикла;
	
	Сообщение = Новый СообщениеПользователю;
	Сообщение.Текст = "Удаление из коробки завершено";
	Сообщение.Сообщить();	
	
КонецПроцедуры

#КонецОбласти    

//@skip-check module-structure-top-region
#Область РазделениеТовара

//@skip-check module-structure-form-event-regions
&НаКлиенте
Процедура РазделитьТовар(Команда)
	ВыбранныйТовар = Объект.рар_мп_ТоварыИзЗаказов.НайтиСтроки(Новый Структура("ВыборСтроки", Истина));    
	
	Если ВыбранныйТовар.Количество() > 0 Тогда
		
		Если ВыбранныйТовар.Количество() > 1 Тогда
			
			Сообщение = Новый СообщениеПользователю;
			Сообщение.Текст = "Выбрано несколько товаров. Для разделения товара необходимо выбрать только один товар";
			Сообщение.Сообщить();
			
		Иначе        
			
			Если ВыбранныйТовар[0].рар_мп_Количество = 0 Тогда
				
				Сообщение = Новый СообщениеПользователю;
				Сообщение.Текст = "Для разделения выбран товар с нулевым количеством. Пожалуста, укажите количество выбранного товара";
				Сообщение.Сообщить();
				
			Иначе
				
				СтруктураПараметров = Новый Структура;
				СтруктураПараметров.Вставить("Баркод", ВыбранныйТовар[0].рар_мп_Баркод);
				СтруктураПараметров.Вставить("Номенклатура", ВыбранныйТовар[0].рар_мп_Номенклатура);
				СтруктураПараметров.Вставить("Характеристика", ВыбранныйТовар[0].рар_мп_Характеристика);
				СтруктураПараметров.Вставить("Упаковка", ВыбранныйТовар[0].рар_мп_Упаковка);
				СтруктураПараметров.Вставить("Количество", ВыбранныйТовар[0].рар_мп_Количество);
				
				//@skip-check form-self-reference
				ОткрытьФорму("Документ.рар_мп_ПодготовкаФайловПоставки.Форма.ФормаРазделенияТовара", СтруктураПараметров, ЭтаФорма);
				
			КонецЕсли;
			
		КонецЕсли;
		
		
	Иначе
		
		Сообщение = Новый СообщениеПользователю;
		Сообщение.Текст = "Для разделения товара необходимо выбрать товар (отметить строку галочкой)";
		Сообщение.Сообщить();
		
	КонецЕсли;
КонецПроцедуры

#КонецОбласти


//@skip-check module-structure-top-region
#Область ДобавлениеШтрихкодовКоробок

//@skip-check module-structure-form-event-regions
&НаКлиенте
Процедура ПутьКФайлу_ШтрихкодНачалоВыбора(Элемент, ДанныеВыбора, ВыборДобавлением, СтандартнаяОбработка)     
	
	СтандартнаяОбработка = Ложь;
	Режим = РежимДиалогаВыбораФайла.Открытие;
	ДиалогВыбора = Новый ДиалогВыбораФайла(Режим);
	
	ДиалогВыбора.ПолноеИмяФайла = "";
	ДиалогВыбора.Фильтр = "Книга Excel (*.xlsx; *.xls) | *.xlsx; *.xls";
	ДиалогВыбора.МножественныйВыбор = Ложь;
	ДиалогВыбора.Заголовок = "Выберите файл Excel формата";
	
	ДиалогВыбора.Показать(Новый ОписаниеОповещения("ПутьКФайлуНачалоВыбораЗавершение", ЭтотОбъект, Новый Структура("ДиалогВыбора", ДиалогВыбора))); 
	
КонецПроцедуры           

//@skip-check module-structure-form-event-regions
//@skip-check doc-comment-parameter-section
&НаКлиенте
Процедура ПутьКФайлуНачалоВыбораЗавершение(ВыбранныеФайлы, ДополнительныеПараметры) Экспорт
	ДиалогВыбора = ДополнительныеПараметры.ДиалогВыбора;
	
	Если ВыбранныеФайлы <> Неопределено Тогда 
		
		ПутьКФайлу_Штрихкод = ДиалогВыбора.ПолноеИмяФайла;
		
	КонецЕсли;
	
КонецПроцедуры 

&НаСервере
Процедура ЗагрузитьШтрихкодыНаСервере()   
	
	Объект.рар_мп_Коробки.Очистить();
	
	ТабДок = Новый ТабличныйДокумент;
	
	Попытка
		
		ТабДок.Прочитать(ПутьКФайлу_Штрихкод);
		
	Исключение       
		
		Сообщение = Новый СообщениеПользователю;
		Сообщение.Текст = "Не удалось прочитать файл с штрихкодами коробов. Описание ошибки в журнале регистрации";
		Сообщение.Сообщить();
		
		Комментарий = СтрШаблон("Не удалось прочитать файл с штрихкодами коробов. Описание ошибки: %1", ОписаниеОшибки());
		ЗаписьЖурналаРегистрации("Ошибка при удалении", УровеньЖурналаРегистрации.Ошибка, , , Комментарий, );
		
		Возврат;
	КонецПопытки;  
	
	КоличествоСтрок = ТабДок.ВысотаТаблицы;
	//КоличествоКолонок = ТабДок.ШиринаТаблицы;
	
	Для НомерСтроки = 1 По КоличествоСтрок Цикл
		
		Если НомерСтроки = 1 Тогда
			
			Продолжить;
			
		КонецЕсли;     
		
		НоваяСтрока = Объект.рар_мп_Коробки.Добавить();
		НоваяСтрока.рар_мп_Коробка = ТабДок.Область(НомерСтроки, 3).Текст;
		
	КонецЦикла;    
	
	Сообщение = Новый СообщениеПользователю;
	Сообщение.Текст = "Штрихкоды коробов успешно загружены.";
	Сообщение.Сообщить();
	
КонецПроцедуры

//@skip-check module-structure-form-event-regions
&НаКлиенте
Процедура ЗагрузитьШтрихкоды(Команда)
	Если Не ЗначениеЗаполнено(ПутьКФайлу_Штрихкод) Тогда
		
		Сообщение = Новый СообщениеПользователю;
		Сообщение.Текст = "Ошибка загрузки штрихкодов коробов. Укажите путь к файлу с штрихкодами коробов.";
		Сообщение.Сообщить();   
		
	Иначе
		
		ЗагрузитьШтрихкодыНаСервере();
		
	КонецЕсли;
КонецПроцедуры

#КонецОбласти 

//@skip-check module-structure-top-region
#Область ФормированиеДокументаРеализации

&НаСервере
Процедура СформироватьДокументРеализацииНаСервере()
	
	Если ЗначениеЗаполнено(Объект.рар_мп_Реализация) Тогда
		
		Сообщение = Новый СообщениеПользователю;
		Сообщение.Текст = "Передача на комиссию уже создана для данного документа.";
		Сообщение.Сообщить();
		
	Иначе
		
		Если Не ПроверкаОстатковТоваров() Тогда
			
			РеквизитыАккаунта = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(Объект.рар_мп_АккаунтМаркетплейса, 
									"Организация, Контрагент, ОперацияПередачаНаКомиссию, Соглашение, Договор, Валюта, Менеджер, Подразделение");
			ОперацияПередачаНаКомиссию = РеквизитыАккаунта.ОперацияПередачаНаКомиссию;
			Организация 			   = РеквизитыАккаунта.Организация;
			Контрагент 				   = РеквизитыАккаунта.Контрагент;
			Соглашение 				   = РеквизитыАккаунта.Соглашение;
			Договор 				   = РеквизитыАккаунта.Договор;
			Валюта 					   = РеквизитыАккаунта.Валюта;
			Менеджер 				   = РеквизитыАккаунта.Менеджер;
			Подразделение 			   = РеквизитыАккаунта.Подразделение;
			
			НовыйДокумент = Документы.ПередачаТоваровХранителю.СоздатьДокумент();               
			//@skip-check bsl-legacy-check-static-feature-access-for-unknown-left-part
			НовыйДокумент.ХозяйственнаяОперация = ОперацияПередачаНаКомиссию; 
			//@skip-check bsl-legacy-check-static-feature-access-for-unknown-left-part
			НовыйДокумент.Склад              	= Объект.рар_мп_Склад;
			//@skip-check bsl-legacy-check-static-feature-access-for-unknown-left-part
			НовыйДокумент.Организация           = Организация;   
			НовыйДокумент.Дата 					= ТекущаяДатаСеанса();
			//@skip-check reading-attribute-from-database
			//@skip-check bsl-legacy-check-static-feature-access-for-unknown-left-part
			НовыйДокумент.Партнер 				= Контрагент.Партнер;
			//@skip-check bsl-legacy-check-static-feature-access-for-unknown-left-part
			НовыйДокумент.Контрагент 			= Контрагент;
			//@skip-check bsl-legacy-check-static-feature-access-for-unknown-left-part
			НовыйДокумент.Соглашение 			= Соглашение;
			//@skip-check bsl-legacy-check-static-feature-access-for-unknown-left-part
			НовыйДокумент.Договор 				= Договор;
			//@skip-check bsl-legacy-check-static-feature-access-for-unknown-left-part
			НовыйДокумент.Валюта 				= Валюта;
			//@skip-check bsl-legacy-check-static-feature-access-for-unknown-left-part
			НовыйДокумент.Менеджер				= Менеджер;
			//@skip-check bsl-legacy-check-static-feature-access-for-unknown-left-part
			НовыйДокумент.Подразделение			= Подразделение;  
			//@skip-check bsl-legacy-check-static-feature-access-for-unknown-left-part
			НовыйДокумент.СпособДоставки        = Перечисления.СпособыДоставки.Самовывоз;   
			
			
			
			Для каждого Товар Из Объект.рар_мп_СписокТоваров Цикл
				
				НоваяСтрока = НовыйДокумент.Товары.Добавить();
				
				//@skip-check bsl-legacy-check-static-feature-access-for-unknown-left-part
				НоваяСтрока.Номенклатура       = Товар.рар_мп_Номенклатура;
				//@skip-check bsl-legacy-check-static-feature-access-for-unknown-left-part
				НоваяСтрока.Характеристика     = Товар.рар_мп_Характеристика;
				//@skip-check bsl-legacy-check-static-feature-access-for-unknown-left-part
				НоваяСтрока.Упаковка           = Товар.рар_мп_Упаковка;
				//@skip-check bsl-legacy-check-static-feature-access-for-unknown-left-part
				НоваяСтрока.КоличествоУпаковок = Товар.рар_мп_Количество; 
				//@skip-check bsl-legacy-check-static-feature-access-for-unknown-left-part
				НоваяСтрока.Склад              = Объект.рар_мп_Склад;
				
			КонецЦикла;
			
			Попытка
				
				НовыйДокумент.Записать(РежимЗаписиДокумента.Проведение);  
				
				Сообщение = Новый СообщениеПользователю;
				Сообщение.Текст = "Создание передачи на комиссию завершено";
				Сообщение.Сообщить();
				
				
			Исключение
				
				НовыйДокумент.Записать(РежимЗаписиДокумента.Запись);
				
				Сообщение = Новый СообщениеПользователю;
				Сообщение.Текст = "Ошибка при проведении документа 'Передача на комиссию'. Описание ошибки в журнале регистрации.";
				Сообщение.Сообщить();
				
				Комментарий = СтрШаблон("Аккаунт: %1, Описание ошибки: %2",
				Объект.рар_мп_АккаунтМаркетплейса, ОписаниеОшибки());
				
				ЗаписьЖурналаРегистрации("Ошибка при проведении документа 'Передача на комиссию'", УровеньЖурналаРегистрации.Ошибка,,Объект.рар_мп_АккаунтМаркетплейса,Комментарий,);
				
			КонецПопытки;      
			
			Объект.рар_мп_Реализация = НовыйДокумент.Ссылка;
			
		КонецЕсли;
	КонецЕсли;	
КонецПроцедуры

//@skip-check module-structure-form-event-regions
&НаКлиенте
Процедура СформироватьДокументРеализации(Команда)   
	
	Если ОпределитьТекМаркетплейс_ЯндексМаркет() Тогда
	
		Сообщение = Новый СообщениеПользователю;
		Сообщение.Текст = "Данный функционал недоступен для Яндекс маркета";
		Сообщение.Сообщить();      
		
	Иначе
		
		СвернутьТЧСписокТоваров();
		СформироватьДокументРеализацииНаСервере();
		
	КонецЕсли;
КонецПроцедуры

#КонецОбласти                      

//@skip-check module-structure-top-region
#Область СвернутьТЧ
&НаСервере
Процедура СвернутьТЧСписокТоваров()
	
	ТЗ_Товаров = Объект.рар_мп_СписокТоваров.Выгрузить();
	ТЗ_Товаров.Свернуть("рар_мп_Артикул, рар_мп_Баркод, рар_мп_Номенклатура, рар_мп_Характеристика, рар_мп_Упаковка", "рар_мп_Количество");
	Объект.рар_мп_СписокТоваров.Загрузить(ТЗ_Товаров);
КонецПроцедуры	
#КонецОбласти