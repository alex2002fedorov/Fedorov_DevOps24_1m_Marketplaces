&НаСервере
Функция ОпределитьТекМаркетплейс_Ozon() 
	
	Маркетплейс = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Объект.рар_мп_АккаунтМаркетплейса, "Маркетплейс");
	
	Если Маркетплейс = Перечисления.рар_мп_Маркетплейсы.OZON Тогда
		
		Возврат Истина
		
	Иначе  
		
		Возврат Ложь
		
	КонецЕсли;
	
КонецФункции  

&НаСервере
Функция ОпределитьТекМаркетплейс_Wildberries() 
	
	Маркетплейс = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Объект.рар_мп_АккаунтМаркетплейса, "Маркетплейс");
	
	Если Маркетплейс = Перечисления.рар_мп_Маркетплейсы.Wildberries Тогда
		
		Возврат Истина
		
	Иначе  
		
		Возврат Ложь
		
	КонецЕсли;
	
КонецФункции

&НаСервере
Функция ОпределитьТекМаркетплейс_ЯндексМаркет() 
	
	Маркетплейс = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Объект.рар_мп_АккаунтМаркетплейса, "Маркетплейс");
	
	Если Маркетплейс = Перечисления.рар_мп_Маркетплейсы.ЯндексМаркет Тогда
		
		Возврат Истина
		
	Иначе  
		
		Возврат Ложь
		
	КонецЕсли;
	
КонецФункции

