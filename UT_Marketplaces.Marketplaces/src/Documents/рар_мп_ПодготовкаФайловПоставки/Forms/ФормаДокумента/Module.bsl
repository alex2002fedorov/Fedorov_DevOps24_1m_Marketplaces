//@skip-check module-structure-top-region
#Область ИзменениеАртикулаВСпискеТоваров

&НаСервере
Функция ПолучитьНоменклатуруПоАртикулу(Артикул)
	
	Если ОпределитьТекМаркетплейс_Ozon() Тогда
		
		Запрос = Новый Запрос;
		
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	рар_мп_Ozon_СопоставленныеТовары.Номенклатура КАК Номенклатура,     
		|	рар_мп_Ozon_СопоставленныеТовары.Характеристика КАК Характеристика,
		|	рар_мп_Ozon_СопоставленныеТовары.Упаковка КАК Упаковка
		|ИЗ
		|	РегистрСведений.рар_мп_Ozon_СопоставленныеТовары КАК рар_мп_Ozon_СопоставленныеТовары
		|ГДЕ
		|	рар_мп_Ozon_СопоставленныеТовары.Аккаунт = &Аккаунт
		|	И рар_мп_Ozon_СопоставленныеТовары.Артикул = &Артикул"; 
		
		Запрос.УстановитьПараметр("Аккаунт", Объект.рар_мп_АккаунтМаркетплейса);  
		Запрос.УстановитьПараметр("Артикул", Артикул);
		
	ИначеЕсли ОпределитьТекМаркетплейс_Wildberries() Тогда
		
		Запрос = Новый Запрос;
		
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	рар_мп_Wildberries_СопоставленныеТовары.Номенклатура КАК Номенклатура,
		|	рар_мп_Wildberries_СопоставленныеТовары.Характеристика КАК Характеристика,
		|	рар_мп_Wildberries_СопоставленныеТовары.Упаковка КАК Упаковка
		|ИЗ
		|	РегистрСведений.рар_мп_Wildberries_СопоставленныеТовары КАК рар_мп_Wildberries_СопоставленныеТовары
		|ГДЕ
		|	рар_мп_Wildberries_СопоставленныеТовары.Аккаунт = &Аккаунт
		|	И рар_мп_Wildberries_СопоставленныеТовары.Баракод = &Баракод"; 
		
		Запрос.УстановитьПараметр("Аккаунт", Объект.рар_мп_АккаунтМаркетплейса);  
		Запрос.УстановитьПараметр("Баракод", Артикул);
		
	КонецЕсли;           
	
	РезультатЗапроса = Запрос.Выполнить();        
	
	Если Не РезультатЗапроса.Пустой() Тогда             
		
		Выборка = РезультатЗапроса.Выбрать(); 
		
		МассивЗначенийВыборки = Новый Массив;
		
		Пока Выборка.Следующий() Цикл
			
			МассивЗначенийВыборки.Добавить(Выборка.Номенклатура);
			МассивЗначенийВыборки.Добавить(Выборка.Характеристика);
			МассивЗначенийВыборки.Добавить(Выборка.Упаковка);
			
		КонецЦикла;                      
		
		Возврат МассивЗначенийВыборки;  
		
		
	КонецЕсли; 
	
КонецФункции

//@skip-check module-structure-form-event-regions
&НаКлиенте
Процедура АртикулПриИзменении(Элемент)
	
	ТекСтрока = Элементы.рар_мп_СписокТоваров.ТекущиеДанные; 
	
	ТекУникЗначение = ТекСтрока.рар_мп_Артикул;   
	
	МассивЗначенийНоменклатуры = ПолучитьНоменклатуруПоАртикулу(ТекУникЗначение);
	
	Если МассивЗначенийНоменклатуры = Неопределено Тогда  
			
		Сообщение = Новый СообщениеПользователю;
		//@skip-check bsl-legacy-check-dynamic-feature-access
		Сообщение.Текст = СтрШаблон("По введенному артикулу подставить номенклатуру, характеристику и упаковку невозможно, " +
		"так как данный артикул не сопоставлен с номенклатурой маркетплейса (Строка: %1)", ТекСтрока.НомерСтроки);
		Сообщение.Сообщить();			                      
		
		ТекСтрока.рар_мп_Номенклатура   = Неопределено; 
		ТекСтрока.рар_мп_Характеристика = Неопределено;
		ТекСтрока.рар_мп_Упаковка       = Неопределено;
		
	ИначеЕсли МассивЗначенийНоменклатуры.Количество() > 3 Тогда
		
		//для вывода баркодов в строку
		СтрокаНоменклатуры = МассивЗначенийНоменклатуры[0];
		
		Для Индекс = 3 По МассивЗначенийНоменклатуры.Количество() - 1 Цикл
			
			СтрокаНоменклатуры = СтрШаблон("%1, %2", СтрокаНоменклатуры, Строка(МассивЗначенийНоменклатуры[Индекс]));  
			
			Индекс = Индекс + 3;
			
		КонецЦикла;
			
		//@skip-check use-non-recommended-method
		Если Найти(СтрокаНоменклатуры, Строка(ТекСтрока.рар_мп_Номенклатура)) И ТекСтрока.рар_мп_Номенклатура <> "" Тогда         
			
			ИндексТекущейНоменклатуры = МассивЗначенийНоменклатуры.Найти(ТекСтрока.рар_мп_Номенклатура); 
			
			ТекСтрока.рар_мп_Характеристика = МассивЗначенийНоменклатуры.Получить(ИндексТекущейНоменклатуры+1);
			ТекСтрока.рар_мп_Упаковка       = МассивЗначенийНоменклатуры.Получить(ИндексТекущейНоменклатуры+2); 
			
		Иначе                                 
			
			Сообщение = Новый СообщениеПользователю;
			Сообщение.Текст = СтрШаблон("По данному артикулу существует несколько значений номенклатуры: %1. " + 
			"Пожалуйста, введите один из них, чтобы выбрать определенную номенклатуру.", СтрокаНоменклатуры);
			Сообщение.Сообщить(); 
			
			ТекСтрока.рар_мп_Номенклатура   = Неопределено; 
			ТекСтрока.рар_мп_Характеристика = Неопределено;
			ТекСтрока.рар_мп_Упаковка       = Неопределено;   
			
		КонецЕсли;   
		
		
	Иначе
		
		ТекСтрока.рар_мп_Номенклатура   = МассивЗначенийНоменклатуры[0]; 
		ТекСтрока.рар_мп_Характеристика = МассивЗначенийНоменклатуры[1];
		ТекСтрока.рар_мп_Упаковка       = МассивЗначенийНоменклатуры[2];
		
	КонецЕсли;
	
КонецПроцедуры  

//@skip-check module-structure-form-event-regions
&НаКлиенте
Процедура БаракодПриИзменении(Элемент)
	
	ТекСтрока = Элементы.рар_мп_СписокТоваров.ТекущиеДанные; 
	
	ТекУникЗначение = ТекСтрока.рар_мп_Баркод;   
	
	МассивЗначенийНоменклатуры = ПолучитьНоменклатуруПоАртикулу(ТекУникЗначение);
	
	Если МассивЗначенийНоменклатуры = Неопределено Тогда  

		Сообщение = Новый СообщениеПользователю;
		//@skip-check bsl-legacy-check-dynamic-feature-access
		Сообщение.Текст = СтрШаблон("По введенному баркоду подставить номенклатуру, характеристику и упаковку невозможно, " +
		"так как данный баркод не сопоставлен с номенклатурой маркетплейса (Строка: %1)", ТекСтрока.НомерСтроки);
		Сообщение.Сообщить();   
		
		ТекСтрока.рар_мп_Номенклатура   = Неопределено; 
		ТекСтрока.рар_мп_Характеристика = Неопределено;
		ТекСтрока.рар_мп_Упаковка       = Неопределено;
		
	ИначеЕсли МассивЗначенийНоменклатуры.Количество() > 3 Тогда
		
		//для вывода баркодов в строку
		СтрокаНоменклатуры = МассивЗначенийНоменклатуры[0];
		
		Для Индекс = 3 По МассивЗначенийНоменклатуры.Количество() - 1 Цикл
			
			СтрокаНоменклатуры = СтрШаблон("%1, %2", СтрокаНоменклатуры, Строка(МассивЗначенийНоменклатуры[Индекс]));  
			
			Индекс = Индекс + 3;
			
		КонецЦикла;
			
		Если СтрНайти(СтрокаНоменклатуры, Строка(ТекСтрока.рар_мп_Номенклатура)) И ЗначениеЗаполнено(ТекСтрока.рар_мп_Номенклатура) Тогда         
			
			ИндексТекущейНоменклатуры = МассивЗначенийНоменклатуры.Найти(ТекСтрока.рар_мп_Номенклатура); 
			
			ТекСтрока.рар_мп_Характеристика = МассивЗначенийНоменклатуры.Получить(ИндексТекущейНоменклатуры+1);
			ТекСтрока.рар_мп_Упаковка       = МассивЗначенийНоменклатуры.Получить(ИндексТекущейНоменклатуры+2); 
			
		Иначе     
			
			Сообщение = Новый СообщениеПользователю;
			Сообщение.Текст = СтрШаблон("По данному баркоду существует несколько значений номенклатуры: %1. " + 
			"Пожалуйста, введите один из них, чтобы выбрать определенную номенклатуру.", СтрокаНоменклатуры);
			Сообщение.Сообщить(); 			
			
			ТекСтрока.рар_мп_Номенклатура   = Неопределено; 
			ТекСтрока.рар_мп_Характеристика = Неопределено;
			ТекСтрока.рар_мп_Упаковка       = Неопределено;   
			
		КонецЕсли;    
			
	Иначе
		
		ТекСтрока.рар_мп_Номенклатура   = МассивЗначенийНоменклатуры[0]; 
		ТекСтрока.рар_мп_Характеристика = МассивЗначенийНоменклатуры[1];
		ТекСтрока.рар_мп_Упаковка       = МассивЗначенийНоменклатуры[2];
		
	КонецЕсли;
	
КонецПроцедуры  

#КонецОбласти     


//@skip-check module-structure-top-region
#Область ИзменениеНоменклатурыВСпискеТоваров

//@skip-check module-structure-form-event-regions
&НаКлиенте
Процедура рар_мп_СписокТовароврар_мп_НоменклатураПриИзменении(Элемент)    
	
	ТекСтрока = Элементы.рар_мп_СписокТоваров.ТекущиеДанные;    
	
	МассивЗначенийНоменклатуры = ПолучитьБаркодПоНоменклатуре(ТекСтрока.рар_мп_Номенклатура);
	
	Если МассивЗначенийНоменклатуры = Неопределено Тогда
		
		Если ОпределитьТекМаркетплейс_Ozon() Тогда
			
			Сообщение = Новый СообщениеПользователю;
			//@skip-check bsl-legacy-check-dynamic-feature-access
			Сообщение.Текст = СтрШаблон("По введенной номенклатуре подставить артикул, характеристику и упаковку невозможно, " +
			"так как данная номенклатура не сопоставлена с номенклатурой маркетплейса (Строка: %1)", ТекСтрока.НомерСтроки);
			Сообщение.Сообщить();  	
			
			ТекСтрока.рар_мп_Артикул        = Неопределено; 
			ТекСтрока.рар_мп_Характеристика = Неопределено;
			ТекСтрока.рар_мп_Упаковка       = Неопределено;
			
		ИначеЕсли ОпределитьТекМаркетплейс_Wildberries() Тогда
			
			Сообщение = Новый СообщениеПользователю;
			//@skip-check bsl-legacy-check-dynamic-feature-access
			Сообщение.Текст = СтрШаблон("По введенной номенклатуре подставить баркод, характеристику и упаковку невозможно, " +
			"так как данная номенклатура не сопоставлена с номенклатурой маркетплейса (Строка: %1)", ТекСтрока.НомерСтроки);
			Сообщение.Сообщить();  
			
			ТекСтрока.рар_мп_Баркод         = Неопределено; 
			ТекСтрока.рар_мп_Характеристика = Неопределено;
			ТекСтрока.рар_мп_Упаковка       = Неопределено;
			
		КонецЕсли;   
		
	ИначеЕсли МассивЗначенийНоменклатуры.Количество() > 3 Тогда
		
		//для вывода баркодов в строку
		СтрокаБаркодов = МассивЗначенийНоменклатуры[0];
		
		Для Индекс = 3 По МассивЗначенийНоменклатуры.Количество() - 1 Цикл
			
			СтрокаБаркодов = СтрокаБаркодов + ", " + МассивЗначенийНоменклатуры[Индекс];  
			
			Индекс = Индекс + 3;
			
		КонецЦикла;
		
		
		Если ОпределитьТекМаркетплейс_Ozon() Тогда
			
			//@skip-check use-non-recommended-method
			Если Найти(СтрокаБаркодов, ТекСтрока.рар_мп_Артикул)  И ТекСтрока.рар_мп_Артикул <> "" Тогда         
				
				ИндексТекущегоАртикула = МассивЗначенийНоменклатуры.Найти(ТекСтрока.рар_мп_Артикул); 
				
				ТекСтрока.рар_мп_Характеристика = МассивЗначенийНоменклатуры.Получить(ИндексТекущегоАртикула+1);
				ТекСтрока.рар_мп_Упаковка       = МассивЗначенийНоменклатуры.Получить(ИндексТекущегоАртикула+2); 
				
			Иначе                                 
				
				Сообщение = Новый СообщениеПользователю;
				Сообщение.Текст = СтрШаблон("По данной номенклатуре существует несколько значений артикула: %1. " + 
				"Пожалуйста, введите один из них, чтобы выбрать определенную номенклатуру.", СтрокаБаркодов);
				Сообщение.Сообщить(); 
				
				ТекСтрока.рар_мп_Артикул        = Неопределено; 
				ТекСтрока.рар_мп_Характеристика = Неопределено;
				ТекСтрока.рар_мп_Упаковка       = Неопределено;   
				
			КонецЕсли;   
			
		ИначеЕсли ОпределитьТекМаркетплейс_Wildberries() Тогда
			
			Если СтрНайти(СтрокаБаркодов, ТекСтрока.рар_мп_Баркод) И ТекСтрока.рар_мп_Баркод <> "" Тогда         
				
				ИндексТекущегоБаркода = МассивЗначенийНоменклатуры.Найти(ТекСтрока.рар_мп_Баркод); 
				
				ТекСтрока.рар_мп_Характеристика = МассивЗначенийНоменклатуры.Получить(ИндексТекущегоБаркода+1);
				ТекСтрока.рар_мп_Упаковка       = МассивЗначенийНоменклатуры.Получить(ИндексТекущегоБаркода+2); 
				
			Иначе     
				
				Сообщение = Новый СообщениеПользователю;
				Сообщение.Текст = СтрШаблон("По данной номенклатуре существует несколько значений баркода: %1. " + 
				"Пожалуйста, введите один из них, чтобы выбрать определенную номенклатуру.", СтрокаБаркодов);
				Сообщение.Сообщить(); 			
				
				ТекСтрока.рар_мп_Баркод         = Неопределено; 
				ТекСтрока.рар_мп_Характеристика = Неопределено;
				ТекСтрока.рар_мп_Упаковка       = Неопределено;   
				
			КонецЕсли;    
			
		КонецЕсли;
		
		
	Иначе
		
		Если ОпределитьТекМаркетплейс_Ozon() Тогда
			
			ТекСтрока.рар_мп_Артикул        = МассивЗначенийНоменклатуры[0]; 
			ТекСтрока.рар_мп_Характеристика = МассивЗначенийНоменклатуры[1];
			ТекСтрока.рар_мп_Упаковка       = МассивЗначенийНоменклатуры[2];
			
		ИначеЕсли ОпределитьТекМаркетплейс_Wildberries() Тогда
			
			ТекСтрока.рар_мп_Баркод         = МассивЗначенийНоменклатуры[0];
			ТекСтрока.рар_мп_Характеристика = МассивЗначенийНоменклатуры[1];
			ТекСтрока.рар_мп_Упаковка       = МассивЗначенийНоменклатуры[2];
			
		КонецЕсли;
		
	КонецЕсли;	
	
КонецПроцедуры

&НаСервере
Функция ПолучитьБаркодПоНоменклатуре(Номенклатура)
	
	Если ОпределитьТекМаркетплейс_Ozon() Тогда 
		
		Запрос = Новый Запрос;
		
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	рар_мп_Ozon_СопоставленныеТовары.Артикул КАК Баракод,
		|	рар_мп_Ozon_СопоставленныеТовары.Характеристика КАК Характеристика,
		|	рар_мп_Ozon_СопоставленныеТовары.Упаковка КАК Упаковка
		|ИЗ
		|	РегистрСведений.рар_мп_Ozon_СопоставленныеТовары КАК рар_мп_Ozon_СопоставленныеТовары
		|ГДЕ
		|	рар_мп_Ozon_СопоставленныеТовары.Аккаунт = &Аккаунт
		|	И рар_мп_Ozon_СопоставленныеТовары.Номенклатура = &Номенклатура"; 
		
		Запрос.УстановитьПараметр("Аккаунт", Объект.рар_мп_АккаунтМаркетплейса);  
		Запрос.УстановитьПараметр("Номенклатура", Номенклатура);	
		
	ИначеЕсли ОпределитьТекМаркетплейс_Wildberries() Тогда
		
		Запрос = Новый Запрос;
		
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	рар_мп_Wildberries_СопоставленныеТовары.Баракод КАК Баракод,
		|	рар_мп_Wildberries_СопоставленныеТовары.Характеристика КАК Характеристика,
		|	рар_мп_Wildberries_СопоставленныеТовары.Упаковка КАК Упаковка
		|ИЗ
		|	РегистрСведений.рар_мп_Wildberries_СопоставленныеТовары КАК рар_мп_Wildberries_СопоставленныеТовары
		|ГДЕ
		|	рар_мп_Wildberries_СопоставленныеТовары.Аккаунт = &Аккаунт
		|	И рар_мп_Wildberries_СопоставленныеТовары.Номенклатура = &Номенклатура";     
		
		Запрос.УстановитьПараметр("Аккаунт", Объект.рар_мп_АккаунтМаркетплейса);  
		Запрос.УстановитьПараметр("Номенклатура", Номенклатура);
		
	КонецЕсли;       
	
	РезультатЗапроса = Запрос.Выполнить();        
	
	Если Не РезультатЗапроса.Пустой() Тогда             
		
		Выборка = РезультатЗапроса.Выбрать();   
		
		МассивЗначенийВыборки = Новый Массив;
		
		Пока Выборка.Следующий() Цикл
			
			МассивЗначенийВыборки.Добавить(Выборка.Баракод);
			МассивЗначенийВыборки.Добавить(Выборка.Характеристика);
			МассивЗначенийВыборки.Добавить(Выборка.Упаковка);
			
		КонецЦикла;   
		
		Возврат МассивЗначенийВыборки;  		
	КонецЕсли;
	
	
КонецФункции

#КонецОбласти


//@skip-check module-structure-top-region
#Область КнопкаПодбораНоменклатуры

//@skip-check module-structure-form-event-regions
&НаКлиенте
Процедура Подбор(Команда)
	
	Если ЗначениеЗаполнено(Объект.рар_мп_АккаунтМаркетплейса) Тогда              
		
		Если ЗначениеЗаполнено(Объект.рар_мп_Склад) Тогда     
			
			Если Не ПроверкаОстатковТоваров() Тогда
				
				СвернутьТЧСписокТоваров();
				
				//Создаем структуру с отбором и добавляем значения
				ПараметрыФормы = Новый Структура;
				ПараметрыФормы.Вставить("Аккаунт", Объект.рар_мп_АккаунтМаркетплейса); 
				ПараметрыФормы.Вставить("Склад", Объект.рар_мп_Склад);
				ПараметрыФормы.Вставить("СписокТоваров", Объект.рар_мп_СписокТоваров);
				
				//@skip-check form-self-reference
				ОткрытьФорму("Обработка.рар_мп_ПодготовкаФайловПоставки_ПодборНоменклатуры.Форма.ФормаПодбора", ПараметрыФормы, ЭтаФорма);
				
			КонецЕсли;			
			
		Иначе
			
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Для того, чтобы открыть подбор номенклатуры, заполните поле ""Склад"".");
			
		КонецЕсли;
		
	Иначе                                                            
		
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Для того, чтобы открыть подбор номенклатуры, заполните поле ""Аккаунт маркетплейса"".");
		
	КонецЕсли;   	
КонецПроцедуры

&НаКлиенте                                                                                                  
Процедура ОбработатьПодбор(АдресВХ) Экспорт
	
	ОбработатьПодборНаСервере(АдресВХ);
	Модифицированность = Истина;
	
КонецПроцедуры  

&НаСервере
Процедура ОбработатьПодборНаСервере(АдресВХ)
	
	НоменклатураИзПодбора = ПолучитьИзВременногоХранилища(АдресВХ); 
	
	ТЧ_СпискаТоваров = Объект.рар_мп_СписокТоваров.Выгрузить(); 
	
	Если ОпределитьТекМаркетплейс_Ozon() Тогда
		
		ТЧ_СпискаТоваров.Свернуть("рар_мп_Артикул, рар_мп_Номенклатура, рар_мп_Характеристика, рар_мп_Упаковка", "рар_мп_Количество");
		
	ИначеЕсли ОпределитьТекМаркетплейс_Wildberries() Тогда
		
		ТЧ_СпискаТоваров.Свернуть("рар_мп_Баркод, рар_мп_Номенклатура, рар_мп_Характеристика, рар_мп_Упаковка", "рар_мп_Количество");
		
	ИначеЕсли ОпределитьТекМаркетплейс_ЯндексМаркет() Тогда
		
		//Код ЯндексМаркета
		
	КонецЕсли;
	
	Если НоменклатураИзПодбора.Количество() > 0 Тогда
		
		Для каждого Элем из НоменклатураИзПодбора Цикл 
			
			СтруктураВыбранныеТовары = Новый Структура();
			СтруктураВыбранныеТовары.Вставить("рар_мп_Номенклатура", Элем.Номенклатура);
			СтруктураВыбранныеТовары.Вставить("рар_мп_Упаковка", Элем.Упаковка);
			СтруктураВыбранныеТовары.Вставить("рар_мп_Характеристика", Элем.Характеристика);
			
			Если ТЧ_СпискаТоваров.НайтиСтроки(СтруктураВыбранныеТовары).Количество() = 0 Тогда
				
				НоваяСтрока = ТЧ_СпискаТоваров.Добавить();
				НоваяСтрока.рар_мп_Номенклатура	  = Элем.Номенклатура; 
				НоваяСтрока.рар_мп_Упаковка		  = Элем.Упаковка;
				НоваяСтрока.рар_мп_Характеристика = Элем.Характеристика;
				НоваяСтрока.рар_мп_Количество	  = Элем.Количество;
				
				Если ОпределитьТекМаркетплейс_Ozon() Тогда
					
					НоваяСтрока.рар_мп_Артикул = Элем.Артикул;   
					
				ИначеЕсли ОпределитьТекМаркетплейс_Wildberries() Тогда
					
					НоваяСтрока.рар_мп_Баркод = Элем.Артикул; 
					
				ИначеЕсли ОпределитьТекМаркетплейс_ЯндексМаркет() Тогда
					
					//Обработка для ЯндексМаркета
					
				КонецЕсли;
				
			ИначеЕсли ТЧ_СпискаТоваров.НайтиСтроки(СтруктураВыбранныеТовары).Количество() <> 0 Тогда
				
				СущНоменклатура = ТЧ_СпискаТоваров.НайтиСтроки(СтруктураВыбранныеТовары); 
				
				Для каждого Строка_СпискаТоваров из СущНоменклатура Цикл
					
					Строка_СпискаТоваров.рар_мп_Количество = Элем.Количество;
					
				КонецЦикла;
				
			КонецЕсли;
			
		КонецЦикла;
		
	КонецЕсли; 
	
	Объект.рар_мп_СписокТоваров.Загрузить(ТЧ_СпискаТоваров);
	
КонецПроцедуры  

#КонецОбласти    


//@skip-check module-structure-top-region
#Область СозданиеExcelФайла

//@skip-check module-structure-form-event-regions
&НаКлиенте
Процедура СоздатьExcelФайл(Команда)
	
	Если ЗначениеЗаполнено(Объект.рар_мп_АккаунтМаркетплейса) Тогда  
		
		Если ОпределитьТекМаркетплейс_ЯндексМаркет() Тогда
			
			Сообщение = Новый СообщениеПользователю;
			Сообщение.Текст = "Данный функционал недоступен для Яндекс маркета";
			Сообщение.Сообщить();  
			
		Иначе
			Если Объект.рар_мп_СписокТоваров.Количество() > 0 Тогда  
				
				НеСоздаватьЭксельФайл = Ложь;
				
				Для каждого Строка Из Объект.рар_мп_СписокТоваров Цикл
					
					Если Строка.рар_мп_Количество = 0 Тогда
						
						Сообщение = Новый СообщениеПользователю;
						//@skip-check bsl-legacy-check-dynamic-feature-access
						Сообщение.Текст = "Ошибка создания Excel файла. Введите количество товара в строке " + Строка.НомерСтроки;
						Сообщение.Сообщить();  
						
						НеСоздаватьЭксельФайл = Истина;
						
					КонецЕсли;  
					
					Если ОпределитьТекМаркетплейс_Ozon() Тогда
						
						Если Строка.рар_мп_Артикул = "" Тогда
							
							Сообщение = Новый СообщениеПользователю;
							//@skip-check bsl-legacy-check-dynamic-feature-access
							Сообщение.Текст = "Ошибка создания Excel файла. Введите артикул в строке " + Строка.НомерСтроки;
							Сообщение.Сообщить();  
							
							НеСоздаватьЭксельФайл = Истина;
							
						КонецЕсли;      
						
					ИначеЕсли ОпределитьТекМаркетплейс_Wildberries() Тогда
						
						Если Строка.рар_мп_Баркод = "" Тогда
							
							Сообщение = Новый СообщениеПользователю;
							//@skip-check bsl-legacy-check-dynamic-feature-access
							Сообщение.Текст = "Ошибка создания Excel файла. Введите баркод в строке " + Строка.НомерСтроки;
							Сообщение.Сообщить();  
							
							НеСоздаватьЭксельФайл = Истина;
							
						КонецЕсли;      
						
					КонецЕсли;
					
				КонецЦикла;  
				
				Если Не НеСоздаватьЭксельФайл И Не ПроверкаОстатковТоваров() Тогда
					
					ДлительнаяОперация = СоздатьExcelФайлНаСервере();
					
					ПараметрыОжидания = ДлительныеОперацииКлиент.ПараметрыОжидания(ЭтотОбъект); 
					ПараметрыОжидания.ВыводитьОкноОжидания = Истина;  
					ПараметрыОжидания.Заголовок = "Создание Excel файла";
					Оповещение = Новый ОписаниеОповещения("ПриЗавершенииСозданияФайлаExcel", ЭтотОбъект);
					ДлительныеОперацииКлиент.ОжидатьЗавершение(ДлительнаяОперация, Оповещение, ПараметрыОжидания);
					
				КонецЕсли;
				
			Иначе
				
				Сообщение = Новый СообщениеПользователю;
				Сообщение.Текст = "Ошибка создания Excel файла. Нет данных в списке товаров";
				Сообщение.Сообщить();
				
			КонецЕсли;
			
		КонецЕсли;
		
		
	Иначе
		
		Сообщение = Новый СообщениеПользователю;
		Сообщение.Текст = "Ошибка создания Excel файла. Не заполнен аккаунт маркетплейса.";
		Сообщение.Сообщить();                      
		
	КонецЕсли;  
	
КонецПроцедуры        

