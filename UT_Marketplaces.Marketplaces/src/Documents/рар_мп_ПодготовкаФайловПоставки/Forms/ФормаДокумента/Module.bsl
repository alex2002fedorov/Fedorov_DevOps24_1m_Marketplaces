&НаКлиенте
Процедура рар_мп_СписокТоваровПередНачаломДобавления(Элемент, Отказ, Копирование, Родитель, Группа, Параметр)
	
	Если Не ЗначениеЗаполнено(Объект.рар_мп_АккаунтМаркетплейса) Тогда
		
		Сообщение = Новый СообщениеПользователю;
		Сообщение.Текст = "Не заполнен аккаунт маркетплейса.";
		Сообщение.Сообщить();                      
		
		Отказ = Истина;
		
	КонецЕсли;  
	
КонецПроцедуры  

