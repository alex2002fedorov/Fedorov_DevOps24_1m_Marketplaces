#Область ПроверкаОстатковТоваров   

&НаСервере
Функция ПроверкаОстатковТоваров() 
	
	СвернутьТЧСписокТоваров();
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	&Склад КАК Склад,
	|	вт_ТЧТовары.рар_мп_Номенклатура КАК рар_мп_Номенклатура,
	|	вт_ТЧТовары.рар_мп_Количество КАК рар_мп_Количество,
	|	вт_ТЧТовары.рар_мп_Характеристика КАК рар_мп_Характеристика
	|ПОМЕСТИТЬ вт_ТЧТовары
	|ИЗ
	|	&вт_ТЧТовары КАК вт_ТЧТовары
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	рар_мп_Номенклатура,
	|	Склад,
	|	рар_мп_Характеристика
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ЕСТЬNULL(ТоварыНаСкладахОстатки.ВНаличииОстаток, 0) КАК ВНаличииОстаток,
	|	вт_ТЧТовары.рар_мп_Номенклатура КАК Номенклатура,
	|	вт_ТЧТовары.рар_мп_Количество КАК Количество,
	|	вт_ТЧТовары.рар_мп_Характеристика КАК Характеристика,
	|	вт_ТЧТовары.Склад КАК Склад
	|ИЗ
	|	вт_ТЧТовары КАК вт_ТЧТовары
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.ТоварыНаСкладах.Остатки(
	|				&Период,
	|				Номенклатура В
	|						(ВЫБРАТЬ
	|							Товары.рар_мп_Номенклатура КАК Номенклатура
	|						ИЗ
	|							вт_ТЧТовары КАК Товары)
	|					И Склад = &Склад) КАК ТоварыНаСкладахОстатки
	|		ПО вт_ТЧТовары.рар_мп_Номенклатура = ТоварыНаСкладахОстатки.Номенклатура
	|			И вт_ТЧТовары.рар_мп_Характеристика = ТоварыНаСкладахОстатки.Характеристика";
	
	Запрос.УстановитьПараметр("Склад", Объект.рар_мп_Склад);
	Запрос.УстановитьПараметр("вт_ТЧТовары", Объект.рар_мп_СписокТоваров.Выгрузить());
	Запрос.УстановитьПараметр("Период", ТекущаяДатаСеанса());
	
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Выборка = РезультатЗапроса.Выбрать();   
	
	НеСоздаватьФайл = Ложь;
	
	Пока Выборка.Следующий() Цикл 
		
		НедостатокТовара = Выборка.Количество - Выборка.ВНаличииОстаток;
		
		Если НедостатокТовара > 0 Тогда
			
			НеСоздаватьФайл = Истина;  
			Сообщение = Новый СообщениеПользователю;
			Сообщение.Текст = СтрШаблон("Контроль остатков товаров. Товара %1 с характеристикой %2 недостаточно в количестве %3 шт. на складе %4", 
			Выборка.Номенклатура, Выборка.Характеристика, НедостатокТовара, Выборка.Склад);
			Сообщение.Сообщить();
			
		КонецЕсли;                   
		
		Если НеСоздаватьФайл Тогда
			
			Продолжить;
			
		КонецЕсли;
		
	КонецЦикла;  
	
	Возврат НеСоздаватьФайл;
	
	
КонецФункции

#КонецОбласти


//@skip-check module-structure-top-region
#Область ОбновлениеТЧДляКоробок

//@skip-check module-structure-form-event-regions
&НаКлиенте
Процедура ОбновитьТЧ(Команда)  
	
	Если Не ПроверкаОстатковТоваров() Тогда    
		
		Оповещение   = Новый ОписаниеОповещения("ОбновитьТЧЗавершение", ЭтотОбъект);		
		ТекстВопроса = НСтр("ru = 'При обновлении будут очищены текущая табличная часть и табличная часть распределенных товаров. 
		|Продолжить?'");							 
		ПоказатьВопрос(Оповещение, ТекстВопроса, РежимДиалогаВопрос.ДаНет, , КодВозвратаДиалога.Нет);   
		
		
	КонецЕсли;
	
КонецПроцедуры     

&НаКлиенте
Процедура ОбновитьТЧЗавершение(Ответ, ДополнительныеПараметры) Экспорт
	
	Если Ответ = КодВозвратаДиалога.Да Тогда
		
		Объект.рар_мп_ТоварыИзЗаказов.Очистить();   
		Объект.рар_мп_РаспределенныеТовары.Очистить();
		СвернутьТЧСписокТоваров();
		
		Для каждого Строка Из Объект.рар_мп_СписокТоваров Цикл
			
			Если (ЗначениеЗаполнено(Строка.рар_мп_Баркод) ИЛИ ЗначениеЗаполнено(Строка.рар_мп_Артикул)) 
				И ЗначениеЗаполнено(Строка.рар_мп_Номенклатура) И ЗначениеЗаполнено(Строка.рар_мп_Характеристика)
				И ЗначениеЗаполнено(Строка.рар_мп_Упаковка) И ЗначениеЗаполнено(Строка.рар_мп_Количество) Тогда
				
				НоваяСтрока = Объект.рар_мп_ТоварыИзЗаказов.Добавить();
				ЗаполнитьЗначенияСвойств(НоваяСтрока, Строка);
				
			Иначе
				
				Сообщение = Новый СообщениеПользователю;
				//@skip-check bsl-legacy-check-dynamic-feature-access
				Сообщение.Текст = СтрШаблон("Строка %1 не заполнена до конца. Пожалуйста, дозаполните строку и обновите табличную часть повторно.", Строка.НомерСтроки);
				Сообщение.Сообщить();
				
			КонецЕсли;		
		КонецЦикла;  
		
	КонецЕсли;
КонецПроцедуры

