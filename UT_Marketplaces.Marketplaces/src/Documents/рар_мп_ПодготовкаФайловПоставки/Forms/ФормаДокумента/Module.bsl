&НаСервере
Процедура АккаунтМаркетплейсаПриИзмененииНаСервере()     
	
	Объект.рар_мп_Реализация = Документы.ПередачаТоваровХранителю.ПустаяСсылка();
	
	Если ОпределитьТекМаркетплейс_Ozon() Тогда
		
		//Обработка Ozon
		
		Элементы.Группарар_мп_ЯндексМаркет_СписокТоваров.Видимость = Ложь; 

		Элементы.Страница_СписокТоваров.Видимость = Истина;
		
		Элементы.СтраницаРаспределениеТоваровПоКоробкам.Видимость = Ложь;
		
		Элементы.рар_мп_СписокТоваров.ПодчиненныеЭлементы.рар_мп_СписокТовароврар_мп_Артикул.Видимость = Истина;
		
		Элементы.рар_мп_СписокТоваров.ПодчиненныеЭлементы.рар_мп_СписокТовароврар_мп_Баркод.Видимость = Ложь;
		
		Элементы.рар_мп_СписокТоваров.ПодчиненныеЭлементы.рар_мп_СписокТовароврар_мп_Номенклатура.Видимость = Истина;   
		
		Элементы.рар_мп_СписокТоваров.ПодчиненныеЭлементы.рар_мп_СписокТовароврар_мп_Упаковка.Видимость = Истина;
		
		Элементы.рар_мп_СписокТоваров.ПодчиненныеЭлементы.рар_мп_СписокТовароврар_мп_Характеристика.Видимость = Истина;
		
		Элементы.СоздатьExcelФайлСРаспределеннымиТоварами.Видимость = Ложь;
		
	ИначеЕсли ОпределитьТекМаркетплейс_ЯндексМаркет() Тогда
		
		Элементы.Группарар_мп_ЯндексМаркет_СписокТоваров.Видимость = Истина;   
		
		Элементы.Страница_СписокТоваров.Видимость = Ложь;
		
		Элементы.СтраницаРаспределениеТоваровПоКоробкам.Видимость = Ложь;   
		
		Элементы.СоздатьExcelФайлСРаспределеннымиТоварами.Видимость = Ложь;
		
		
	ИначеЕсли ОпределитьТекМаркетплейс_Wildberries() Тогда	
		
		//Обработка Wildberries  
		
		Элементы.Группарар_мп_ЯндексМаркет_СписокТоваров.Видимость = Ложь;
		
		Элементы.СтраницаРаспределениеТоваровПоКоробкам.Видимость = Истина;       

		Элементы.Страница_СписокТоваров.Видимость = Истина;
		
		Элементы.рар_мп_СписокТоваров.ПодчиненныеЭлементы.рар_мп_СписокТовароврар_мп_Артикул.Видимость = Ложь;
		
		Элементы.рар_мп_СписокТоваров.ПодчиненныеЭлементы.рар_мп_СписокТовароврар_мп_Баркод.Видимость = Истина;
		
		Элементы.рар_мп_СписокТоваров.ПодчиненныеЭлементы.рар_мп_СписокТовароврар_мп_Номенклатура.Видимость = Истина;
		
		Элементы.рар_мп_СписокТоваров.ПодчиненныеЭлементы.рар_мп_СписокТовароврар_мп_Упаковка.Видимость = Истина;
		
		Элементы.рар_мп_СписокТоваров.ПодчиненныеЭлементы.рар_мп_СписокТовароврар_мп_Характеристика.Видимость = Истина;
		
		Элементы.рар_мп_ТоварыИзЗаказов.ПодчиненныеЭлементы.рар_мп_ТоварыИзЗаказоврар_мп_Артикул.Видимость = Ложь;   
		
		Элементы.рар_мп_РаспределенныеТовары.ПодчиненныеЭлементы.рар_мп_РаспределенныеТоварырар_мп_Артикул.Видимость = Ложь;
		
		Элементы.СоздатьExcelФайлСРаспределеннымиТоварами.Видимость = Истина;
	Иначе
		
		Элементы.Группарар_мп_ЯндексМаркет_СписокТоваров.Видимость = Истина;
		
		Элементы.СтраницаРаспределениеТоваровПоКоробкам.Видимость = Истина; 
		
		Элементы.Страница_СписокТоваров.Видимость = Истина;
		
		Элементы.рар_мп_СписокТоваров.ПодчиненныеЭлементы.рар_мп_СписокТовароврар_мп_Артикул.Видимость = Истина;
		
		Элементы.рар_мп_СписокТоваров.ПодчиненныеЭлементы.рар_мп_СписокТовароврар_мп_Баркод.Видимость = Истина;
		
		Элементы.рар_мп_СписокТоваров.ПодчиненныеЭлементы.рар_мп_СписокТовароврар_мп_Номенклатура.Видимость = Истина; 
		
		Элементы.рар_мп_СписокТоваров.ПодчиненныеЭлементы.рар_мп_СписокТовароврар_мп_Упаковка.Видимость = Истина;
		
		Элементы.рар_мп_СписокТоваров.ПодчиненныеЭлементы.рар_мп_СписокТовароврар_мп_Характеристика.Видимость = Истина;
		
		Элементы.рар_мп_ТоварыИзЗаказов.ПодчиненныеЭлементы.рар_мп_ТоварыИзЗаказоврар_мп_Артикул.Видимость = Истина; 
		
		Элементы.рар_мп_РаспределенныеТовары.ПодчиненныеЭлементы.рар_мп_РаспределенныеТоварырар_мп_Артикул.Видимость = Истина;
		
		Элементы.СоздатьExcelФайлСРаспределеннымиТоварами.Видимость = Истина;
	КонецЕсли;
	
КонецПроцедуры

