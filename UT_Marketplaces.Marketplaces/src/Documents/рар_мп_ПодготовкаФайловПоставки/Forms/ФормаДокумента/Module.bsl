
#Область ОбработчикиСобытийФормы

&НаКлиенте
Процедура ПриОткрытии(Отказ)
    Если ПриПовторномОткрытииНаСервере() = Ложь Тогда
        Сообщение = Новый СообщениеПользователю;
        Сообщение.Текст = НСтр("ru='Вы не приняли лицензионное соглашение 1С-Рарус, функционал механизма не доступен'");
        Сообщение.Сообщить();
        //@skip-check module-self-reference
		ЭтотОбъект.Закрыть();
    КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ПриПовторномОткрытии()
    Если ПриПовторномОткрытииНаСервере() = Ложь Тогда
        Сообщение = Новый СообщениеПользователю;
        Сообщение.Текст = НСтр("ru='Вы не приняли лицензионное соглашение 1С-Рарус, функционал механизма не доступен'");
        Сообщение.Сообщить();
        //@skip-check module-self-reference
		ЭтотОбъект.Закрыть();
    КонецЕсли;
КонецПроцедуры

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Если Не Параметры.Ключ.Пустая() Тогда
		
		АккаунтМаркетплейсаПриИзмененииНаСервере();	
		
	КонецЕсли;
	
КонецПроцедуры 

&НаКлиенте
Процедура ОбработкаОповещения(ИмяСобытия, Параметр, Источник)     
	
	Если ИмяСобытия = "РазделениеТоваров" Тогда      
		
		Для каждого Товар Из Параметр Цикл
			
			НоваяСтрока = Объект.рар_мп_ТоварыИзЗаказов.Добавить();  
			НоваяСтрока.рар_мп_Баркод         = Товар.Баркод;
			НоваяСтрока.рар_мп_Номенклатура   = Товар.Номенклатура;
			НоваяСтрока.рар_мп_Характеристика = Товар.Характеристика;
			НоваяСтрока.рар_мп_Упаковка       = Товар.Упаковка;
			НоваяСтрока.рар_мп_Количество     = Товар.Количество;
			
		КонецЦикла;    
		
	КонецЕсли;
КонецПроцедуры

#КонецОбласти

